---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Blog" description="Architecture decisions, homelab learnings, and the honest retrospective.">

  <div class="page-wrap">

    <div class="page-header fade-up">
      <div>
        <p class="mono" style="color:var(--color-peach);margin-bottom:0.25rem">~/blog</p>
        <h1 style="margin:0">Blog</h1>
      </div>
      <p class="hero-sub">
        Architecture decisions, homelab learnings, and honest retrospectives.
        Rooted in real <a href="https://github.com/Kagiso-me/homelab-infrastructure/tree/main/docs/adr" target="_blank" rel="noopener" class="link-inline">ADRs</a> — what we decided, why, and what actually happened.
      </p>
    </div>

    <div class="post-list fade-up" style="animation-delay:0.05s">
      {posts.map(post => (
        <a href={`/blog/${post.id}`} class="post-card">
          <div class="post-meta">
            <span class="post-date mono">{new Date(post.data.date).toLocaleDateString('en-ZA', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            {post.data.adr && <span class="post-adr mono">{post.data.adr}</span>}
          </div>
          <h2 class="post-title">{post.data.title}</h2>
          <p class="post-summary">{post.data.summary}</p>
          <span class="post-read-more mono">read →</span>
        </a>
      ))}
    </div>

  </div>

</Layout>

<style is:global>
  .page-wrap {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: 0.75rem; }

  .hero-sub {
    color: var(--color-subtle);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 640px;
    margin: 0;
  }

  .link-inline {
    color: var(--color-peach);
    text-decoration: underline;
    text-underline-offset: 3px;
  }


  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--color-surface);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 14px;
    padding: 1.5rem;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }

  .post-card:hover {
    border-color: var(--color-mauve);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
    color: inherit;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--color-subtle);
  }

  .post-adr {
    font-size: 0.72rem;
    color: var(--color-mauve);
    background: color-mix(in srgb, var(--color-mauve) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-mauve) 25%, transparent);
    border-radius: 4px;
    padding: 0.1rem 0.45rem;
  }

  .post-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 0;
    line-height: 1.3;
  }

  .post-summary {
    font-size: 0.9rem;
    color: var(--color-subtle);
    line-height: 1.65;
    margin: 0;
  }

  .post-read-more {
    font-size: 0.75rem;
    color: var(--color-peach);
    margin-top: 0.25rem;
  }
</style>
