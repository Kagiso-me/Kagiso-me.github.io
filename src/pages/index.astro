---
import Layout from '../layouts/Layout.astro';
import ClusterTerminal from '../components/ClusterTerminal.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Layout title="Command Center" description="Living Homelab — built in public by Kagiso." ogImage="https://kagiso-me.github.io/og/home.svg">

  <!-- ── Hero + live cluster map ── -->
  <header class="cc-hero fade-up">
    <div class="cc-hero-text">
      <div class="cc-kicker mono">
        <span class="cc-kicker-dot" aria-hidden="true"></span>
        live · k3s HA · 10.0.10.0/24 · built in public
      </div>
      <h1 class="cc-h1">
        The homelab,<br>running where<br>you can <span class="cc-accent">watch it.</span>
      </h1>
      <p class="cc-lede">
        Not a diagram. Not a demo. A real three-node Kubernetes cluster — every
        metric on this page is read straight off the hardware on my shelf.
      </p>
      <div class="cc-actions">
        <a href="/status" class="cc-btn-primary">Open live status →</a>
        <a href="/blog" class="cc-btn-ghost">Read the blog</a>
      </div>
    </div>

    <!-- LIVE TOPOLOGY (signature visual) -->
    <div class="cc-map">
      <div class="cc-map-head mono">
        <span>cluster.architecture · live</span>
        <span class="cc-map-clock"><span class="cc-map-dot" aria-hidden="true"></span><span id="cc-map-clock">—</span></span>
      </div>
      <div class="cc-map-stage">
        <svg viewBox="0 0 500 470" class="cc-map-svg" aria-hidden="true">
          <defs>
            <marker id="cc-arC" markerWidth="7" markerHeight="7" refX="5" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#4cc9e8"/></marker>
            <marker id="cc-arA" markerWidth="7" markerHeight="7" refX="5" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#f3b34d"/></marker>
            <marker id="cc-arG" markerWidth="7" markerHeight="7" refX="5" refY="3" orient="auto"><path d="M0,0 L6,3 L0,6 Z" fill="#5a6573"/></marker>
            <filter id="cc-glow" x="-70%" y="-70%" width="240%" height="240%"><feGaussianBlur stdDeviation="2.2" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          </defs>
          <rect class="cc-perim" x="8" y="8" width="484" height="454" rx="16" fill="none" stroke="rgba(255,255,255,.06)" stroke-dasharray="2 7"/>
          <path d="M250,52 V90" fill="none" stroke="rgba(76,201,232,.45)" stroke-width="1.4" marker-end="url(#cc-arC)"/>
          <path d="M152,150 H178" fill="none" stroke="rgba(243,179,77,.5)" stroke-width="1.4" marker-end="url(#cc-arA)"/>
          <path d="M265,290 V305" fill="none" stroke="rgba(76,201,232,.45)" stroke-width="1.4" marker-end="url(#cc-arC)" marker-start="url(#cc-arC)"/>
          <path d="M368,152 L352,164" fill="none" stroke="rgba(120,135,155,.55)" stroke-width="1.2" stroke-dasharray="3 4" marker-end="url(#cc-arG)"/>
          <path d="M188,52 C120,130 83,200 83,296" fill="none" stroke="rgba(120,135,155,.4)" stroke-width="1.2" stroke-dasharray="3 4" marker-end="url(#cc-arG)"/>
          <g filter="url(#cc-glow)">
            <circle r="3.3" fill="#9fe8f7"><animateMotion dur="1.7s" repeatCount="indefinite" path="M250,52 V90"/></circle>
            <circle r="2.2" fill="#4cc9e8" opacity=".65"><animateMotion dur="1.7s" begin="-.07s" repeatCount="indefinite" path="M250,52 V90"/></circle>
            <circle r="3.3" fill="#9fe8f7"><animateMotion dur="1.7s" begin="-.85s" repeatCount="indefinite" path="M250,52 V90"/></circle>
            <circle r="3.3" fill="#ffd58a"><animateMotion dur="1.3s" repeatCount="indefinite" path="M152,150 H178"/></circle>
            <circle r="2.2" fill="#f3b34d" opacity=".6"><animateMotion dur="1.3s" begin="-.65s" repeatCount="indefinite" path="M152,150 H178"/></circle>
            <circle r="3.1" fill="#9fe8f7"><animateMotion dur="1.8s" repeatCount="indefinite" path="M265,288 V306"/></circle>
            <circle r="2.6" fill="#aeb8c6"><animateMotion dur="3.6s" repeatCount="indefinite" path="M188,52 C120,130 83,200 83,296"/></circle>
            <circle r="2.2" fill="#aeb8c6" opacity=".7"><animateMotion dur="2.2s" repeatCount="indefinite" path="M368,152 L352,164"/></circle>
          </g>
          <text x="257" y="76" font-size="8" fill="rgba(76,201,232,.75)">serve</text>
          <text x="150" y="142" font-size="8" fill="rgba(243,179,77,.85)">flux ⸱ deploy</text>
          <text x="272" y="301" font-size="8" fill="rgba(76,201,232,.75)">NFS PVCs</text>
          <text x="356" y="158" font-size="7.5" fill="rgba(150,165,185,.8)">watch</text>
          <text x="20" y="24" font-size="8" fill="rgba(255,255,255,.28)">10.0.10.0/24</text>
        </svg>

        <div class="cc-host cc-host-router" style="left:30%;top:1.4%;width:40%;height:8.6%">
          <span class="cc-host-dot ok"></span>
          <div class="cc-host-l"><div class="cc-host-name">mikrotik <span class="cc-host-ip">.1</span></div><div class="cc-host-sub">router · DNS · gateway</div></div>
          <span class="cc-host-tag cc-tag-signal">ROUTES</span>
        </div>

        <div class="cc-host cc-host-varys" style="left:2.6%;top:23%;width:28%;height:16.5%">
          <div class="cc-host-row"><span class="cc-host-dot" data-node="varys"></span><span class="cc-host-name">varys</span><span class="cc-host-ip">.10</span><span class="cc-host-tag cc-tag-accent">DRIVES</span></div>
          <div class="cc-host-sub cc-accent">the brain · GitOps origin</div>
          <div class="cc-host-sub">kubectl · flux · ansible<br><span class="cc-faint">hosts nothing</span></div>
        </div>

        <div class="cc-host cc-host-bran" style="left:73.4%;top:23%;width:24%;height:16.5%">
          <div class="cc-host-row"><span class="cc-host-dot" data-node="bran"></span><span class="cc-host-name">bran</span><span class="cc-host-ip">.9</span></div>
          <div class="cc-host-sub cc-signal">the watcher · Pi</div>
          <div class="cc-host-sub">UPS · CI · paging<br><span class="cc-faint">survives full outage</span></div>
        </div>

        <div class="cc-cluster" style="left:36%;top:17.5%;width:33.6%;height:43%">
          <div class="cc-cluster-head"><span class="cc-accent">k3s · HA cluster</span><span class="cc-tag-accent">SERVES</span></div>
          <div class="cc-cluster-vip cc-signal">vip · api .100 · traefik .110</div>
          <div class="cc-cluster-nodes">
            <div class="cc-cluster-node"><span class="cc-host-dot" data-node="tywin"></span><span>tywin</span><span class="cc-host-ip">.11</span></div>
            <div class="cc-cluster-node"><span class="cc-host-dot" data-node="jaime"></span><span>jaime</span><span class="cc-host-ip">.12</span></div>
            <div class="cc-cluster-node"><span class="cc-host-dot" data-node="tyrion"></span><span>tyrion</span><span class="cc-host-ip">.13</span></div>
          </div>
          <div class="cc-cluster-quorum"><span class="cc-host-dot ok"></span><span id="cc-quorum">etcd quorum · runs all workloads</span></div>
        </div>

        <div class="cc-host cc-host-truenas" style="left:36%;top:65%;width:33.6%;height:12%">
          <div class="cc-host-row"><span class="cc-host-dot ok"></span><span class="cc-host-name">truenas</span><span class="cc-host-ip">.80</span><span class="cc-host-tag cc-tag-signal">PERSISTS</span></div>
          <div class="cc-host-sub">NFS-backed PVCs · MinIO backup target</div>
        </div>

        <div class="cc-host cc-host-bronn cc-island" style="left:2.6%;top:64.5%;width:28%;height:13.6%">
          <div class="cc-host-row"><span class="cc-host-dot ok"></span><span class="cc-host-name cc-muted">bronn</span><span class="cc-host-ip">.20</span><span class="cc-host-tag cc-tag-muted">MEDIA</span></div>
          <div class="cc-host-sub">standalone docker compose</div>
          <div class="cc-host-sub cc-faint">not in cluster · no monitoring</div>
        </div>
      </div>
    </div>
  </header>

  <!-- ── Interactive shell ── -->
  <section class="cc-shell-section fade-up">
    <div class="cc-shell-head">
      <div>
        <div class="cc-shell-kicker mono">~/shell</div>
        <h2 class="cc-shell-title">A real shell into the cluster.</h2>
      </div>
      <span class="cc-shell-note mono">read-only · runs against live state · no, you can't <span class="cc-accent">rm -rf</span> it</span>
    </div>
    <ClusterTerminal />
  </section>

  <!-- ── Stack Dashboard ── -->
  <section class="section fade-up" style="animation-delay: 0.1s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Stack · Live</h2>
        <span class="mono live-badge">
          <span class="status-dot ok"></span>
          Live
          <span class="live-updated-label mono" id="live-updated"></span>
        </span>
      </div>

      <div class="ops-panel" id="ops-panel">
        <!-- Skeleton rows while loading -->
        <div class="ops-skeleton-row"></div>
        <div class="ops-skeleton-row"></div>
        <div class="ops-skeleton-row"></div>
        <div class="ops-skeleton-row"></div>
        <div class="ops-skeleton-row"></div>
        <div class="ops-skeleton-row"></div>
      </div>
    </div>
  </section>

  <!-- ── Cluster Status Strip ── -->
  <section class="section fade-up" style="animation-delay: 0.2s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Cluster Health</h2>
        <a href="/status" class="mono link-subtle">Full dashboard →</a>
      </div>
      <div class="status-strip" id="status-strip">
        <div class="status-strip-item skeleton" style="height: 56px; border-radius: 8px;"></div>
        <div class="status-strip-item skeleton" style="height: 56px; border-radius: 8px;"></div>
        <div class="status-strip-item skeleton" style="height: 56px; border-radius: 8px;"></div>
      </div>
    </div>
  </section>

  <!-- ── Network Teaser ── -->
  <section class="section fade-up topo-teaser-section" style="animation-delay: 0.22s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Live Network</h2>
        <a href="/status#netmap" class="mono link-subtle">Full topology →</a>
      </div>
      <a href="/status" class="topo-teaser" aria-label="View live network topology">
        <div class="topo-teaser-inner" id="topo-teaser-inner">
          <!-- Mirrored mini-map: rendered by JS from live.json node states -->
          <svg class="topo-mini-svg" id="topo-mini-svg" aria-hidden="true">
            <defs>
              <pattern id="tt-grid" width="24" height="24" patternUnits="userSpaceOnUse">
                <path d="M 24 0 L 0 0 0 24" fill="none" stroke="rgba(203,166,247,0.05)" stroke-width="1"/>
              </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#tt-grid)"/>
            <g id="tt-lines"></g>
            <g id="tt-packets"></g>
          </svg>
          <!-- Static node glyphs — JS colours them from live data -->
          <div class="tt-nodes">
            <div class="tt-node tt-internet" id="tt-internet">
              <div class="tt-node-dot" id="tt-dot-internet"></div>
              <span>WAN</span>
            </div>
            <div class="tt-arrow">↓</div>
            <div class="tt-node tt-router" id="tt-router">
              <div class="tt-node-dot" id="tt-dot-mikrotik"></div>
              <span>MikroTik</span>
            </div>
            <div class="tt-arrow">↓</div>
            <div class="tt-cluster">
              <div class="tt-cluster-label">k3s cluster</div>
              <div class="tt-cluster-nodes">
                <div class="tt-node tt-k3s" id="tt-tywin">
                  <div class="tt-node-dot" id="tt-dot-tywin"></div>
                  <span>Tywin</span>
                </div>
                <div class="tt-node tt-k3s" id="tt-jaime">
                  <div class="tt-node-dot" id="tt-dot-jaime"></div>
                  <span>Jaime</span>
                </div>
                <div class="tt-node tt-k3s" id="tt-tyrion">
                  <div class="tt-node-dot" id="tt-dot-tyrion"></div>
                  <span>Tyrion</span>
                </div>
              </div>
            </div>
            <div class="tt-edge-nodes">
              <div class="tt-node tt-edge" id="tt-bronn">
                <div class="tt-node-dot" id="tt-dot-bronn"></div>
                <span>Bronn</span>
              </div>
              <div class="tt-node tt-edge" id="tt-varys">
                <div class="tt-node-dot" id="tt-dot-varys"></div>
                <span>Varys</span>
              </div>
              <div class="tt-node tt-edge" id="tt-ned">
                <div class="tt-node-dot" id="tt-dot-ned"></div>
                <span>Ned</span>
              </div>
            </div>
          </div>
          <div class="topo-teaser-cta">
            <span class="topo-cta-text">Explore the live network</span>
            <span class="topo-cta-arrow">→</span>
          </div>
          <div class="topo-teaser-fade"></div>
        </div>
      </a>
    </div>
  </section>

  <!-- ── Stack ── -->
  <section class="section fade-up" style="animation-delay: 0.25s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Stack</h2>
        <a href="/blog" class="mono link-subtle">ADRs →</a>
      </div>
      <div class="stack-grid">
        {[
          { name: 'k3s',         role: 'Kubernetes distro',     accent: 'peach'    },
          { name: 'Flux',        role: 'GitOps operator',        accent: 'mauve'    },
          { name: 'Traefik',     role: 'Ingress / proxy',        accent: 'sapphire' },
          { name: 'Authentik',   role: 'Identity provider',      accent: 'gold'     },
          { name: 'Prometheus',  role: 'Metrics & alerting',     accent: 'peach'    },
          { name: 'Grafana',     role: 'Observability',          accent: 'gold'     },
          { name: 'Loki',        role: 'Log aggregation',        accent: 'mauve'    },
          { name: 'Velero',      role: 'Cluster backups',        accent: 'sapphire' },
          { name: 'CrowdSec',    role: 'Threat intelligence',    accent: 'crit'     },
          { name: 'SOPS',        role: 'Secret encryption',      accent: 'mauve'    },
          { name: 'MikroTik',    role: 'Router / firewall',      accent: 'peach'    },
          { name: 'TrueNAS',     role: 'NAS / storage',          accent: 'gold'     },
        ].map(t => (
          <div class="stack-item sheen" data-accent={t.accent}>
            <span class="stack-name">{t.name}</span>
            <span class="stack-role">{t.role}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Cinematic break strip ── -->
  <section class="manifesto-strip fade-up" style="animation-delay: 0.26s" aria-hidden="true">
    <div class="manifesto-inner">
      <span class="manifesto-line">No demos.</span>
      <span class="manifesto-sep">·</span>
      <span class="manifesto-line">No staging.</span>
      <span class="manifesto-sep">·</span>
      <span class="manifesto-line manifesto-accent">Built in public.</span>
    </div>
  </section>

  <!-- ── 24h Activity ── -->
  <section class="section fade-up" style="animation-delay: 0.27s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Activity — Last 24h</h2>
        <a href="https://github.com/Kagiso-me" target="_blank" rel="noopener" class="mono live-badge">
          <span class="status-dot ok"></span>
          github.com/Kagiso-me ↗
        </a>
      </div>
      <div class="act-wrap" id="act-wrap">
        <!-- Skeleton -->
        <div class="act-repo-card skeleton" style="height:140px"></div>
        <div class="act-repo-card skeleton" style="height:140px"></div>
      </div>
    </div>
  </section>

  <!-- ── Recent Posts ── -->
  <section class="section fade-up" style="animation-delay: 0.28s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">From the Blog</h2>
        <a href="/blog" class="mono link-subtle">All posts →</a>
      </div>
      <div class="blog-grid">
        {recentPosts.map(post => (
          <a href={`/blog/${post.id}`} class="blog-card">
            <div class="blog-card-meta">
              <span class="mono blog-date">{new Date(post.data.date).toLocaleDateString('en-ZA', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
              {post.data.adr && <span class="mono blog-adr">{post.data.adr}</span>}
            </div>
            <div class="blog-card-title">{post.data.title}</div>
            <div class="blog-card-summary">{post.data.summary}</div>
            <span class="mono blog-read">read →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Recent Digest + Active Project ── -->
  <section class="section fade-up" style="animation-delay: 0.3s">
    <div class="section-inner two-col">

      <div>
        <div class="section-header">
          <h2 class="section-title">Recent Digest</h2>
          <a href="/digest" class="mono link-subtle">All entries →</a>
        </div>
        <div id="digest-list">
          <div class="skeleton" style="height: 80px; border-radius: 8px; margin-bottom: 0.75rem;"></div>
          <div class="skeleton" style="height: 80px; border-radius: 8px; margin-bottom: 0.75rem;"></div>
          <div class="skeleton" style="height: 80px; border-radius: 8px;"></div>
        </div>
      </div>

      <div>
        <div class="section-header">
          <h2 class="section-title">Active Work</h2>
          <a href="/projects" class="mono link-subtle">Roadmap →</a>
        </div>
        <div id="active-project">
          <div class="skeleton" style="height: 200px; border-radius: 12px;"></div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── About ── -->
  <section class="section about-section fade-up" style="animation-delay: 0.35s">
    <div class="section-inner">
      <div class="about-grid">

        <div class="about-text">
          <p class="mono" style="color:var(--color-gold);margin-bottom:0.75rem">~/whoami</p>
          <h2 style="font-size:clamp(1.5rem,3vw,2rem);margin:0 0 1.25rem">Hey, I'm Kagiso.</h2>
          <p style="color:var(--color-subtle);line-height:1.8;margin-bottom:1rem">
            Corporate exec by day, self-taught engineer by night. I built this cluster to close the gap
            between knowing how systems work and actually operating them — storage, media, backups,
            identity, observability, security: all running for real, with production discipline.
          </p>
          <p style="color:var(--color-subtle);line-height:1.8;margin-bottom:1.75rem">
            Everything here is real. The data is live, the ops log is the actual changelog,
            the blog documents decisions I've genuinely wrestled with. No demos, no staging, no hand-waving.
          </p>
          <div class="about-links">
            <a href="https://github.com/Kagiso-me" target="_blank" rel="noopener" class="about-link">
              <span class="about-link-icon">⌥</span> GitHub
            </a>
            <a href="/blog" class="about-link">
              <span class="about-link-icon">⎇</span> Blog
            </a>
            <a href="/digest" class="about-link">
              <span class="about-link-icon">◎</span> Ops Log
            </a>
          </div>

          <!-- GitHub contribution graph -->
          <div class="contrib-wrap">
            <div class="contrib-header">
              <span class="mono contrib-label">GitHub activity</span>
              <span class="mono" id="contrib-total" style="color:var(--color-subtle);font-size:0.7rem"></span>
            </div>
            <div id="contrib-graph" class="contrib-graph">
              <div class="contrib-loading">loading graph…</div>
            </div>
            <div class="contrib-legend">
              <span class="mono" style="color:var(--color-subtle);font-size:0.65rem">less</span>
              <span class="contrib-cell" data-level="0"></span>
              <span class="contrib-cell" data-level="1"></span>
              <span class="contrib-cell" data-level="2"></span>
              <span class="contrib-cell" data-level="3"></span>
              <span class="contrib-cell" data-level="4"></span>
              <span class="mono" style="color:var(--color-subtle);font-size:0.65rem">more</span>
            </div>
          </div>
        </div>

        <div class="about-hardware">
          <div class="hw-label mono">Hardware</div>
          <div class="hw-list">
            {[
              { icon: '▣', name: '3× Lenovo ThinkCentre M93p', sub: 'k3s control-plane — Tywin, Jaime, Tyrion', specs: 'Intel Core i5-4570T @ 3.20GHz · 16GB DDR3 · 256GB SSD (each)' },
              { icon: '▣', name: 'Intel NUC',                   sub: 'Docker host — Bronn',                     specs: 'Intel Core i3-7100U @ 2.40GHz · 32GB DDR4 · 256GB NVMe' },
              { icon: '▣', name: 'Intel NUC',                   sub: 'Control node — Varys',                    specs: 'Intel Core i3-5010U @ 2.10GHz · 16GB DDR4 · 256GB NVMe' },
              { icon: '▣', name: 'HP MicroServer Gen8',         sub: 'TrueNAS storage — Ned',                   specs: 'Xeon E3-1260L · 16GB ECC · LSI 9207-8i HBA · 1×8TB + 2×4TB SAS mirror + 2×480GB SSD mirror' },
              { icon: '◈', name: 'RPi 3B+',                     sub: 'CI runner — Bran',                        specs: 'BCM2837B0 Cortex-A53 @ 1.4GHz · 1GB LPDDR2 · 32GB microSD' },
              { icon: '◉', name: 'APC Back-UPS Pro 650VA',      sub: 'UPS — 390W · ~2h runtime',               specs: 'USB monitoring via NUT · alerts via Prometheus Alertmanager' },
            ].map(h => (
              <div class="hw-item" role="button" tabindex="0" aria-expanded="false">
                <span class="hw-icon mono">{h.icon}</span>
                <div class="hw-main">
                  <div class="hw-name-row">
                    <div class="hw-name">{h.name}</div>
                    {h.specs && <span class="hw-chevron mono" aria-hidden="true">›</span>}
                  </div>
                  <div class="hw-sub mono">{h.sub}</div>
                  {h.specs && <div class="hw-specs mono">{h.specs}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style is:global>
  /* ════ Command-center hero + live cluster map (mockup) ════ */
  .cc-hero {
    display: grid;
    grid-template-columns: 0.92fr 1.08fr;
    gap: 40px;
    align-items: center;
    max-width: 1220px;
    margin: 0 auto;
    padding: 64px 1.5rem 40px;
  }
  .cc-kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--signal);
    margin-bottom: 26px;
  }
  .cc-kicker-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--signal); box-shadow: 0 0 10px var(--signal); }
  .cc-h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.2rem, 5vw, 60px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin: 0 0 22px;
    color: var(--color-heading);
  }
  .cc-accent { color: var(--accent); }
  .cc-signal { color: var(--signal); }
  .cc-muted { color: var(--color-text); }
  .cc-faint { color: var(--color-faint); }
  .cc-lede { max-width: 40ch; font-size: 17px; line-height: 1.62; color: var(--color-text); margin: 0 0 30px; }
  .cc-actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .cc-btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 13px 20px; border-radius: 9px;
    background: var(--accent); color: #1a1206;
    text-decoration: none; font-weight: 600; font-size: 14.5px;
    box-shadow: 0 10px 34px color-mix(in srgb, var(--accent) 14%, transparent);
    transition: filter 0.16s ease;
  }
  .cc-btn-primary:hover { filter: brightness(1.07); }
  .cc-btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 13px 20px; border-radius: 9px;
    background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1);
    color: #dfe4ec; text-decoration: none; font-weight: 500; font-size: 14.5px;
    transition: border-color 0.16s ease, background 0.16s ease;
  }
  .cc-btn-ghost:hover { border-color: rgba(255,255,255,.22); background: rgba(255,255,255,.06); }

  /* ── map shell ── */
  .cc-map {
    position: relative;
    background:
      radial-gradient(120% 120% at 50% 30%, rgba(76,201,232,.06), transparent 60%),
      linear-gradient(#0d111a, #0b0e15);
    border: 1px solid var(--color-muted);
    border-radius: 18px;
    padding: 14px 16px 8px;
    box-shadow: 0 36px 90px -36px rgba(0,0,0,.8), inset 0 1px 0 rgba(255,255,255,.04);
  }
  .cc-map-head {
    display: flex; align-items: center; justify-content: space-between;
    font-size: 11.5px; color: var(--color-subtle); padding: 2px 4px 8px;
  }
  .cc-map-clock { display: inline-flex; align-items: center; gap: 6px; color: var(--color-ok); }
  .cc-map-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-ok); box-shadow: 0 0 6px var(--color-ok); }
  .cc-map-stage { position: relative; width: 100%; aspect-ratio: 500 / 470; font-family: var(--font-mono); margin-top: 2px; }
  .cc-map-svg { position: absolute; inset: 0; width: 100%; height: 100%; overflow: visible; }
  .cc-perim { animation: ccDash 9s linear infinite; }
  @keyframes ccDash { to { stroke-dashoffset: -18; } }

  .cc-host, .cc-cluster {
    position: absolute; box-sizing: border-box; border-radius: 10px;
    transition: transform 0.2s cubic-bezier(.2,.7,.2,1), border-color 0.2s ease;
  }
  .cc-host { display: flex; flex-direction: column; justify-content: center; gap: 3px; padding: 8px 10px;
    background: rgba(255,255,255,.025); border: 1px solid var(--color-muted); }
  .cc-host:hover { transform: translateY(-2px); border-color: rgba(255,255,255,.22); }
  .cc-host-router { flex-direction: row; align-items: center; gap: 8px; border-radius: 9px; padding: 0 11px;
    background: rgba(76,201,232,.06); border-color: rgba(76,201,232,.3); }
  .cc-host-varys { background: linear-gradient(rgba(243,179,77,.07), transparent); border-color: rgba(243,179,77,.32); }
  .cc-host-truenas { gap: 2px; background: rgba(76,201,232,.05); border-color: rgba(76,201,232,.26); }
  .cc-island { border-style: dashed; border-color: rgba(255,255,255,.16); background: rgba(255,255,255,.02); }
  .cc-host-row { display: flex; align-items: center; gap: 6px; }
  .cc-host-name { font-size: 11.5px; color: var(--color-heading); font-weight: 600; }
  .cc-host-router .cc-host-name { font-size: 11px; font-weight: 500; }
  .cc-host-ip { color: var(--color-faint); font-size: 9px; }
  .cc-host-sub { font-size: 8px; color: var(--color-subtle); line-height: 1.4; }
  .cc-host-tag { margin-left: auto; font-size: 7px; letter-spacing: .1em; }
  .cc-tag-signal { color: var(--signal); }
  .cc-tag-accent { color: var(--accent); }
  .cc-tag-muted { color: var(--color-subtle); }
  .cc-host-l { line-height: 1.25; }
  .cc-host-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-unknown); box-shadow: 0 0 6px var(--color-unknown); flex: none; }
  .cc-host-dot.ok { background: var(--color-ok); box-shadow: 0 0 6px var(--color-ok); }
  .cc-host-dot.warn { background: var(--color-warn); box-shadow: 0 0 6px var(--color-warn); }
  .cc-host-dot.crit { background: var(--color-crit); box-shadow: 0 0 6px var(--color-crit); }

  .cc-cluster {
    display: flex; flex-direction: column; gap: 4px; padding: 7px 9px; border-radius: 12px;
    background: linear-gradient(rgba(243,179,77,.06), rgba(243,179,77,.02));
    border: 1px solid rgba(243,179,77,.34);
    animation: ccBoxGlow 3.8s ease-in-out infinite;
  }
  @keyframes ccBoxGlow {
    0%, 100% { box-shadow: 0 0 16px -8px rgba(243,179,77,.3); }
    50%      { box-shadow: 0 0 30px -3px rgba(243,179,77,.5); }
  }
  .cc-cluster-head { display: flex; align-items: center; justify-content: space-between; font-size: 9px; letter-spacing: .07em; text-transform: uppercase; }
  .cc-cluster-vip { font-size: 7.5px; background: rgba(76,201,232,.08); border-radius: 5px; padding: 2px 6px; }
  .cc-cluster-nodes { display: flex; flex-direction: column; gap: 3px; flex: 1; justify-content: center; }
  .cc-cluster-node { display: flex; align-items: center; gap: 6px; background: rgba(255,255,255,.03); border: 1px solid var(--color-muted); border-radius: 6px; padding: 3px 7px; font-size: 10px; color: var(--color-heading); }
  .cc-cluster-quorum { display: flex; align-items: center; gap: 5px; font-size: 8px; color: var(--color-ok); }

  @media (prefers-reduced-motion: reduce) { .cc-perim, .cc-cluster { animation: none; } }
  @media (max-width: 860px) {
    .cc-hero { grid-template-columns: 1fr; }
    .cc-h1 { font-size: 34px; line-height: 1.06; }
  }

  /* ── Shell section ── */
  .cc-shell-section { max-width: 1220px; margin: 0 auto; padding: 30px 1.5rem 8px; }
  .cc-shell-head { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 18px; flex-wrap: wrap; gap: 10px; }
  .cc-shell-kicker { font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--signal); margin-bottom: 8px; }
  .cc-shell-title { font-family: var(--font-display); font-size: clamp(1.5rem, 3.5vw, 34px); font-weight: 600; margin: 0; color: var(--color-heading); letter-spacing: -.01em; }
  .cc-shell-note { font-size: 12px; color: var(--color-subtle); max-width: 36ch; text-align: right; line-height: 1.5; }

  /* ── Hero (legacy, unused) ── */
  .hero {
    padding: 6.5rem 1.5rem 5rem;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-muted);
  }

  /* ── Editorial backdrop ── */
  .aurora {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  /* Dot-grid: a quiet graph-paper texture, faded so type leads */
  .aurora::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, color-mix(in srgb, var(--color-muted) 30%, transparent) 1px, transparent 1px);
    background-size: 34px 34px;
    opacity: 0.3;
    mask-image: radial-gradient(ellipse 70% 90% at 8% 0%, black 35%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 70% 90% at 8% 0%, black 35%, transparent 100%);
  }

  /* One restrained directional bloom — anchors the top-left, no drifting orbs */
  .aurora::after {
    content: '';
    position: absolute;
    top: -30%; left: -15%;
    width: 55vw; height: 55vw;
    background: radial-gradient(ellipse, color-mix(in srgb, var(--color-gold) 11%, transparent), transparent 68%);
    filter: blur(80px);
    mix-blend-mode: screen;
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .aurora::after { opacity: 0.5; }
    .aurora::before { opacity: 0.18; }
  }

  #hero-grid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.32;
    z-index: 1;
  }

  @media (max-width: 768px) {
    #hero-grid { display: none; }
  }

  @media (max-width: 768px) {
    #hero-grid { display: none; }
  }

  /* Typewriter cursor */
  .h1-cursor {
    display: inline-block;
    color: var(--color-gold);
    animation: cur-blink 0.9s step-end infinite;
    font-weight: 300;
    margin-left: 0.05em;
  }
  .h1-cursor.done { animation: none; opacity: 0; }
  @keyframes cur-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.15fr 0.95fr;
    gap: 4.5rem;
    align-items: center;
    position: relative;
  }

  .hero-left {
    min-width: 0;
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .hero-term-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 0.25rem;
  }

  .hero-content {
    min-width: 0;
  }

  /* Editorial kicker — numbered section label, magazine-style */
  .hero-kicker {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-subtle);
    margin: 0 0 1.5rem;
  }

  .hero-kicker-no {
    color: var(--color-gold);
    font-weight: 600;
  }

  .hero-kicker-rule {
    width: 2rem;
    height: 1px;
    background: color-mix(in srgb, var(--color-gold) 55%, var(--color-muted));
    flex-shrink: 0;
  }

  h1 {
    font-size: clamp(4rem, 9.5vw, 7.5rem);
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 0.88;
    margin: 0 0 1.75rem;
    color: var(--color-heading);
  }

  .hero-identity {
    font-size: clamp(1.15rem, 2.2vw, 1.4rem);
    font-weight: 600;
    color: var(--color-heading);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--color-subtle);
    max-width: 480px;
    margin: 0 0 2.5rem;
    line-height: 1.75;
  }

  /* Live stats — open editorial row, hairline-divided, big numerals */
  .hero-stats {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin-bottom: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--color-muted) 70%, transparent);
    width: fit-content;
    max-width: 100%;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0 1.75rem;
  }

  .hero-stat:first-child { padding-left: 0; }

  .hero-stat-div {
    width: 1px;
    align-self: stretch;
    background: color-mix(in srgb, var(--color-muted) 60%, transparent);
  }

  .hero-stat-val {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .hero-stat-label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--color-subtle);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 0.7rem 1.75rem;
    background: linear-gradient(135deg, var(--color-gold), color-mix(in srgb, var(--color-gold) 70%, var(--color-green)));
    color: var(--color-base);
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.9rem;
    transition: transform 0.2s, box-shadow 0.2s, opacity 0.2s;
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-gold) 40%, transparent);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    color: var(--color-base);
    box-shadow: 0 4px 24px color-mix(in srgb, var(--color-gold) 45%, transparent),
                0 0 0 1px color-mix(in srgb, var(--color-gold) 30%, transparent);
  }

  .btn-ghost {
    padding: 0.7rem 1.75rem;
    border: 1px solid var(--color-muted);
    color: var(--color-text);
    border-radius: 8px;
    font-size: 0.9rem;
    transition: border-color 0.2s, color 0.2s, background 0.2s, box-shadow 0.2s;
    backdrop-filter: blur(4px);
    background: color-mix(in srgb, var(--color-overlay) 40%, transparent);
  }

  .btn-ghost:hover {
    border-color: color-mix(in srgb, var(--color-gold) 60%, transparent);
    color: var(--color-gold);
    background: color-mix(in srgb, var(--color-gold) 8%, transparent);
    box-shadow: 0 0 16px color-mix(in srgb, var(--color-gold) 15%, transparent);
  }

  .section {
    padding: 6rem 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--color-muted) 50%, transparent);
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 1.4rem;
    margin: 0;
    position: relative;
    padding-bottom: 0.5rem;
    letter-spacing: -0.025em;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 2.5rem;
    height: 2px;
    background: linear-gradient(90deg, var(--color-gold), var(--color-green));
    border-radius: 2px;
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-gold) 60%, transparent);
  }

  .link-subtle {
    color: var(--color-subtle);
    transition: color 0.2s;
  }

  .link-subtle:hover { color: var(--color-gold); }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-ok);
  }

  .live-updated-label {
    color: var(--color-subtle);
    font-size: 0.68rem;
  }

  /* ── Ops Panel ── */
  .ops-panel {
    background: color-mix(in srgb, var(--color-mantle) 80%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-muted) 50%, transparent);
    border-top: 1px solid color-mix(in srgb, white 7%, transparent);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }

  /* group header row */
  .ops-group-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 1.5rem;
    background: color-mix(in srgb, var(--color-overlay) 60%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-muted) 30%, transparent);
  }

  .ops-group-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-subtle);
  }

  .ops-group-line {
    flex: 1;
    height: 1px;
    background: color-mix(in srgb, var(--color-muted) 30%, transparent);
  }

  /* service row */
  .ops-row {
    display: grid;
    grid-template-columns: 2rem 1fr 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 0.95rem 1.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-muted) 18%, transparent);
    transition: background 0.15s;
    cursor: default;
  }

  .ops-row:last-child { border-bottom: none; }

  .ops-row:hover {
    background: color-mix(in srgb, var(--color-overlay) 50%, transparent);
  }

  /* dot column */
  .ops-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    justify-self: center;
  }
  .ops-dot.ok      { background: var(--color-ok);      box-shadow: 0 0 6px var(--color-ok);      animation: ops-pulse-ok 2.5s ease-in-out infinite; }
  .ops-dot.warn    { background: var(--color-warn);     box-shadow: 0 0 5px var(--color-warn); }
  .ops-dot.crit    { background: var(--color-crit);     box-shadow: 0 0 5px var(--color-crit); }
  .ops-dot.unknown { background: var(--color-muted);    box-shadow: none; opacity: 0.5; }

  @keyframes ops-pulse-ok {
    0%, 100% { box-shadow: 0 0 4px var(--color-ok); }
    50%       { box-shadow: 0 0 10px var(--color-ok); opacity: 0.85; }
  }

  /* name column */
  .ops-name {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* stat column — the live number */
  .ops-stat {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ops-stat .ops-num {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }

  .ops-stat .ops-unit {
    color: var(--color-subtle);
    font-size: 0.72rem;
    margin-left: 0.15rem;
  }

  /* badge column */
  .ops-badge {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ops-badge.ok      { color: var(--color-ok);      background: color-mix(in srgb, var(--color-ok)      12%, transparent); border: 1px solid color-mix(in srgb, var(--color-ok)      28%, transparent); }
  .ops-badge.warn    { color: var(--color-warn);     background: color-mix(in srgb, var(--color-warn)    12%, transparent); border: 1px solid color-mix(in srgb, var(--color-warn)    28%, transparent); }
  .ops-badge.crit    { color: var(--color-crit);     background: color-mix(in srgb, var(--color-crit)    12%, transparent); border: 1px solid color-mix(in srgb, var(--color-crit)    28%, transparent); }
  .ops-badge.unknown { color: var(--color-subtle);   background: color-mix(in srgb, var(--color-muted)   12%, transparent); border: 1px solid color-mix(in srgb, var(--color-muted)   28%, transparent); }
  .ops-badge.active  { color: var(--color-gold);     background: color-mix(in srgb, var(--color-gold)    12%, transparent); border: 1px solid color-mix(in srgb, var(--color-gold)    28%, transparent); }

  /* skeleton rows */
  .ops-skeleton-row {
    height: 56px;
    border-bottom: 1px solid color-mix(in srgb, var(--color-muted) 18%, transparent);
    background: linear-gradient(
      90deg,
      var(--color-surface) 25%,
      var(--color-overlay) 50%,
      var(--color-surface) 75%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }
  .ops-skeleton-row:last-child { border-bottom: none; }

  .status-strip {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  @media (max-width: 640px) {
    .ops-row { grid-template-columns: 1.5rem 1fr auto; gap: 0.6rem; padding: 0.85rem 1rem; }
    .ops-stat { display: none; }
    .ops-group-header { padding: 0.5rem 1rem; }
  }


  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; gap: 2rem; }
    .hero { padding: 3.5rem 1.25rem 3rem; }
    h1 { font-size: clamp(3rem, 14vw, 4.5rem); }
    .hero-stats { width: 100%; }
    .stack-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.5rem; }
    .contrib-grid { gap: 1.5px; }
    .contrib-cell { width: 8px; height: 8px; }
  }

  @media (max-width: 480px) {
    .stack-grid { grid-template-columns: repeat(2, 1fr); }
    .hero-stat { padding: 0 1.1rem; }
    .hero-stat-val { font-size: 1.9rem; }
    /* Reduce terminal height on small phones so it doesn't dominate */
    .hero-right .term-wrap { border-radius: 8px; }
  }

  /* ── Stack grid ── */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(168px, 1fr));
    gap: 0.85rem;
  }

  .stack-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid color-mix(in srgb, var(--color-muted) 60%, transparent);
