---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Status" description="Live cluster health, node metrics, and service uptime.">

  <div class="page-wrap">

    <!-- ── Header ── -->
    <div class="page-header fade-up">
      <div>
        <p class="mono" style="color:var(--color-peach); margin-bottom:0.25rem">~/status</p>
        <h1 style="margin:0">Cluster Status</h1>
      </div>
      <div style="text-align:right">
        <div class="mono live-badge">
          <span class="status-dot ok"></span>
          Live · auto-refresh 30s
        </div>
        <div class="mono" id="last-updated" style="color:var(--color-subtle); margin-top:0.25rem">—</div>
      </div>
    </div>

    <!-- ── Network ── -->
    <section class="section fade-up" style="animation-delay:0.05s">
      <h2 class="section-label">Network</h2>
      <div class="cards-grid" id="network-cards" style="margin-bottom:1.5rem">
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
      </div>
      <div id="offenders-section">
        <div class="skeleton" style="height:180px;border-radius:12px"></div>
      </div>
    </section>

    <!-- ── Infrastructure ── -->
    <section class="section fade-up" style="animation-delay:0.1s">
      <h2 class="section-label">Infrastructure</h2>
      <div id="infra-deploy" style="margin-bottom:1rem">
        <div class="skeleton" style="height:56px;border-radius:10px"></div>
      </div>
      <div class="cards-grid" id="infra-cards">
        <div class="card skeleton" style="height:120px"></div>
        <div class="card skeleton" style="height:120px"></div>
        <div class="card skeleton" style="height:120px"></div>
        <div class="card skeleton" style="height:120px"></div>
      </div>
    </section>

    <!-- ── Storage ── -->
    <section class="section fade-up" style="animation-delay:0.13s">
      <h2 class="section-label">Storage</h2>
      <div id="storage-grid">
        <div class="skeleton" style="height:120px;border-radius:12px"></div>
      </div>
    </section>

    <!-- ── At a Glance ── -->
    <section class="section fade-up" style="animation-delay:0.15s">
      <h2 class="section-label">At a Glance</h2>
      <div class="cards-grid" id="glance-cards">
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
      </div>
    </section>

    <!-- ── Nodes ── -->
    <section class="section fade-up" style="animation-delay:0.18s">
      <h2 class="section-label">Nodes</h2>
      <div class="nodes-grid" id="nodes-grid">
        <div class="skeleton" style="height:160px; border-radius:12px"></div>
        <div class="skeleton" style="height:160px; border-radius:12px"></div>
        <div class="skeleton" style="height:160px; border-radius:12px"></div>
      </div>
    </section>

    <!-- ── GitOps ── -->
    <section class="section fade-up" style="animation-delay:0.20s">
      <h2 class="section-label">GitOps — Flux Kustomizations</h2>
      <div id="flux-section">
        <div class="skeleton" style="height:220px; border-radius:12px"></div>
      </div>
    </section>

    <!-- ── Backups ── -->
    <section class="section fade-up" style="animation-delay:0.23s">
      <h2 class="section-label">Backups</h2>
      <div class="cards-grid" id="backup-cards">
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
      </div>
    </section>

  </div>

</Layout>

<style>
  .page-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-ok);
    justify-content: flex-end;
  }

  .section { margin-bottom: 3rem; }

  .section-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-subtle);
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-weight: 500;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .nodes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }

  .node-card {
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 12px;
    padding: 1.25rem 1.5rem 1.5rem;
    border-left-width: 3px;
    transition: box-shadow 0.2s;
  }

  .node-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.25); }

  .node-card.ok      { border-left-color: var(--color-ok); }
  .node-card.warn    { border-left-color: var(--color-warn); }
  .node-card.crit    { border-left-color: var(--color-crit); }
  .node-card.unknown { border-left-color: var(--color-muted); }

  .node-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .node-identity { display: flex; flex-direction: column; gap: 0.35rem; }
  .node-identity-row { display: flex; align-items: baseline; gap: 0.5rem; }

  .node-field-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    flex-shrink: 0;
    min-width: 2.4rem;
  }

  .node-field-value {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.2;
  }

  .node-field-value.role {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-subtle);
  }

  .node-status-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    flex-shrink: 0;
  }

  .node-status-ring { width: 52px; height: 52px; }

  .node-ring-label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--color-subtle);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .node-metrics-4 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 0.4rem;
  }

  @media (max-width: 440px) {
    .node-metrics-4 { grid-template-columns: 1fr 1fr; }
  }

  .metric {
    background: var(--color-overlay);
    border-radius: 8px;
    padding: 0.625rem 0.5rem 0.5rem;
    overflow: hidden;
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-peach);
    display: block;
    text-align: center;
  }

  .metric-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-subtle);
    display: block;
    text-align: center;
    margin-top: 0.2rem;
    margin-bottom: 0.5rem;
  }

  .metric-bar-track {
    height: 3px;
    background: color-mix(in srgb, var(--color-muted) 60%, transparent);
    border-radius: 2px;
    overflow: hidden;
    margin-top: 0.4rem;
  }

  .metric-bar-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--color-peach);
    transition: width 0.4s ease;
  }

  .metric-bar-fill.warn { background: var(--color-warn); }
  .metric-bar-fill.crit { background: var(--color-crit); }

  .flux-table {
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 12px;
    overflow: hidden;
  }

  .flux-row {
    display: grid;
    grid-template-columns: 1.5fr 120px 120px 100px;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--color-muted);
    align-items: center;
    gap: 1rem;
    transition: background 0.15s;
  }

  .flux-row:last-child { border-bottom: none; }
  .flux-row:not(.header):hover { background: var(--color-overlay); }

  .flux-row.header {
    background: var(--color-overlay);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-subtle);
  }

  .flux-row.crit-row {
    background: color-mix(in srgb, var(--color-crit) 7%, transparent);
    border-left: 3px solid var(--color-crit);
    padding-left: calc(1.25rem - 3px);
  }
  .flux-row.crit-row:hover {
    background: color-mix(in srgb, var(--color-crit) 12%, transparent);
  }

  .flux-summary {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .flux-ratio-bar {
    flex: 1;
    min-width: 140px;
    max-width: 300px;
    height: 6px;
    background: var(--color-overlay);
    border-radius: 3px;
    overflow: hidden;
    display: flex;
  }
  .flux-ratio-bar-ok   { height: 100%; background: var(--color-ok);   transition: width 0.6s ease; }
  .flux-ratio-bar-crit { height: 100%; background: var(--color-crit); transition: width 0.6s ease; }

  .flux-ratio-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-subtle);
    white-space: nowrap;
  }

  .flux-name-cell { display: flex; align-items: center; min-width: 0; overflow: hidden; }
  .flux-name-icon {
    display: inline-block;
    width: 1rem;
    text-align: center;
    margin-right: 0.4rem;
    flex-shrink: 0;
    font-size: 0.85rem;
  }
  .flux-name-icon.ok   { color: var(--color-ok); }
  .flux-name-icon.crit { color: var(--color-crit); }
  .flux-name-text {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-heading);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .badge.ok      { background: color-mix(in srgb, var(--color-ok)     18%, transparent); color: var(--color-ok); }
  .badge.warn    { background: color-mix(in srgb, var(--color-warn)   18%, transparent); color: var(--color-warn); }
  .badge.crit    { background: color-mix(in srgb, var(--color-crit)   18%, transparent); color: var(--color-crit); }
  .badge.unknown { background: color-mix(in srgb, var(--color-subtle) 18%, transparent); color: var(--color-subtle); }

  .skeleton {
    background: linear-gradient(
      90deg,
      var(--color-surface) 25%,
      var(--color-overlay) 50%,
      var(--color-surface) 75%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Deploy banner ── */
  .deploy-banner {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 10px;
    padding: 0.875rem 1.25rem;
    font-family: var(--font-mono);
  }

  .deploy-sha {
    font-size: 0.72rem;
    color: var(--color-peach);
    background: color-mix(in srgb, var(--color-peach) 12%, transparent);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .deploy-msg {
    font-size: 0.85rem;
    color: var(--color-heading);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
  }

  .deploy-age {
    font-size: 0.75rem;
    color: var(--color-subtle);
    flex-shrink: 0;
  }

  /* ── Storage pools ── */
  .storage-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 860px) {
    .storage-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .storage-grid { grid-template-columns: 1fr; }
  }

  .storage-card {
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 14px;
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .storage-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--color-ok);
    border-radius: 14px 14px 0 0;
  }
  .storage-card.warn::before { background: var(--color-warn); }
  .storage-card.crit::before { background: var(--color-crit); }

  .storage-pool-name {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .storage-health {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    margin-bottom: 1.25rem;
  }

  .storage-donut-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .storage-donut {
    flex-shrink: 0;
  }

  .storage-legend {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .storage-legend-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .storage-legend-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    margin-right: 0.4rem;
    flex-shrink: 0;
  }

  .storage-bar-track {
    height: 6px;
    background: var(--color-overlay);
    border-radius: 3px;
    overflow: hidden;
  }

  .storage-bar-fill {
    height: 100%;
    border-radius: 3px;
    background: var(--color-ok);
    transition: width 0.7s ease;
  }
  .storage-bar-fill.warn { background: var(--color-warn); }
  .storage-bar-fill.crit { background: var(--color-crit); }

  @media (max-width: 640px) {
    .flux-row { grid-template-columns: 1fr 90px; }
    .flux-row > *:nth-child(2),
    .flux-row > *:nth-child(3) { display: none; }
  }
</style>

<script>
  async function loadStatus() {
    try {
      const res = await fetch('/data/live.json?t=' + Date.now());
      if (!res.ok) throw new Error('no data');
      const data = await res.json();

      // Last updated timestamp
      if (data.updated) {
        const el = document.getElementById('last-updated');
        if (el) {
          const d = new Date(data.updated);
          el.textContent = 'Data as of ' + d.toLocaleTimeString('en-ZA', {
            timeZone: 'Africa/Johannesburg',
            hour: '2-digit', minute: '2-digit'
          }) + ' SAST';
        }
      }

      // Glance cards — only Workloads + Flux (backups live in their own section)
      const glance = document.getElementById('glance-cards');
      if (glance && data.cards) {
        const glanceLabels = ['workloads', 'flux'];
        glance.innerHTML = data.cards.filter((c: any) => glanceLabels.includes(c.label.toLowerCase())).map((c: any) => `
          <div class="card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
              <span class="mono" style="color:var(--color-subtle);font-size:0.72rem;text-transform:uppercase;letter-spacing:0.06em">${c.label}</span>
              <span class="status-dot ${c.status}"></span>
            </div>
            <div style="font-size:1.4rem;font-weight:700;color:var(--color-heading);font-family:var(--font-mono);margin-bottom:0.25rem">${c.value}</div>
            <div class="mono" style="font-size:0.85rem">${c.sub ?? ''}</div>
          </div>
        `).join('');
      }

      // Nodes
      const nodesGrid = document.getElementById('nodes-grid');
      if (nodesGrid && data.nodes) {
        const parsePct = (s: string) => { const m = s?.match(/(\d+)/); return m ? parseInt(m[1]) : null; };
        const barClass = (pct: number | null) => pct == null ? '' : pct >= 85 ? 'crit' : pct >= 70 ? 'warn' : '';
        const metricBar = (val: string, label: string) => {
          const pct = parsePct(val);
          const fill = pct != null ? `<div class="metric-bar-track"><div class="metric-bar-fill ${barClass(pct)}" style="width:${Math.min(pct,100)}%"></div></div>` : '';
          return `<div class="metric">
            <span class="metric-value">${val}</span>
            <span class="metric-label">${label}</span>
            ${fill}
          </div>`;
        };

        const uptimeRing = (status: string) => {
          const r = 20, cx = 26, cy = 26, stroke = 4;
          const circ = 2 * Math.PI * r;
          const fillPct = status === 'ok' ? 100 : status === 'warn' ? 75 : 25;
          const used = (fillPct / 100) * circ;
          const color = status === 'ok' ? 'var(--color-ok)' : status === 'warn' ? 'var(--color-warn)' : 'var(--color-crit)';
          const glyph = status === 'ok' ? '✓' : status === 'warn' ? '!' : '✗';
          const label = status === 'ok' ? 'Ready' : status === 'warn' ? 'Degraded' : 'Not Ready';
          return `<div class="node-status-badge">
            <svg class="node-status-ring" viewBox="0 0 52 52" fill="none">
              <circle cx="${cx}" cy="${cy}" r="${r}" stroke="var(--color-overlay)" stroke-width="${stroke}"/>
              <circle cx="${cx}" cy="${cy}" r="${r}" stroke="${color}" stroke-width="${stroke}"
                stroke-dasharray="${used.toFixed(1)} ${(circ - used).toFixed(1)}"
                stroke-dashoffset="${(circ * 0.25).toFixed(1)}"
                stroke-linecap="round" style="transition:stroke-dasharray 0.6s ease"/>
              <text x="${cx}" y="${cy}" text-anchor="middle" dominant-baseline="middle"
                font-family="var(--font-mono)" font-size="11" font-weight="700"
                fill="${color}">${glyph}</text>
            </svg>
            <div class="node-ring-label">${label}</div>
          </div>`;
        };

        const fourthMetric = (n: any) => {
          const pressures = (n.pressure ?? []).filter((p: string) => !/false/i.test(p));
          const podCap = (n.pods ?? '—/—').split('/')[1] ?? '—';
          if (pressures.length > 0) {
            return `<div class="metric" style="border:1px solid color-mix(in srgb,var(--color-crit) 40%,transparent)">
              <span class="metric-value" style="color:var(--color-crit)">${pressures.length}</span>
              <span class="metric-label" style="color:var(--color-crit)">Pressure</span>
            </div>`;
          }
          return `<div class="metric">
            <span class="metric-value" style="font-size:0.8rem">${podCap}</span>
            <span class="metric-label">Pod Cap</span>
          </div>`;
        };

        nodesGrid.innerHTML = data.nodes.map((n: any) => {
          const alertBanner = n.status === 'crit'
            ? `<div style="margin-top:0.875rem;padding:0.4rem 0.75rem;background:color-mix(in srgb,var(--color-crit) 15%,transparent);border-radius:6px;font-family:var(--font-mono);font-size:0.72rem;color:var(--color-crit)">⚠ Node not ready — check kubelet</div>`
            : '';
          return `
          <div class="node-card ${n.status}">
            <div class="node-header">
              <div class="node-identity">
                <div class="node-identity-row">
                  <span class="node-field-label">Node</span>
                  <span class="node-field-value">${n.name}</span>
                </div>
                <div class="node-identity-row">
                  <span class="node-field-label">Role</span>
                  <span class="node-field-value role">${n.role}</span>
                </div>
              </div>
              ${uptimeRing(n.status)}
            </div>
            <div class="node-metrics-4">
              ${metricBar(n.cpu,    'CPU')}
              ${metricBar(n.memory, 'Memory')}
              <div class="metric">
                <span class="metric-value">${n.pods}</span>
                <span class="metric-label">Pods</span>
              </div>
              ${fourthMetric(n)}
            </div>
            ${alertBanner}
          </div>`;
        }).join('');
      }

      // Infrastructure — Last Deployment
      const deployEl = document.getElementById('infra-deploy');
      if (deployEl && data.last_deploy) {
        const d = data.last_deploy;
        deployEl.innerHTML = `
          <div class="deploy-banner">
            <span class="mono" style="font-size:0.72rem;color:var(--color-subtle);text-transform:uppercase;letter-spacing:0.06em;flex-shrink:0">Last commit</span>
            <span class="deploy-sha">${d.sha}</span>
            <span class="deploy-msg">${d.message}</span>
            <span class="deploy-age">${d.age}</span>
          </div>`;
      }

      // Infrastructure — bran + UPS + Power placeholders
      const infraCards = document.getElementById('infra-cards');
      if (infraCards) {
        const b = data.bran ?? {};
        const tempStatus = b.temp_status ?? 'unknown';
        const tempVal    = b.temp_c != null ? b.temp_c + '°C' : '—';
        const loadVal    = b.load   != null ? b.load.toFixed(2) : '—';
        const memVal     = b.mem_pct != null ? b.mem_pct + '%' : '—';

        infraCards.innerHTML = `
          <div class="card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem">
              <div>
                <span class="mono" style="color:var(--color-subtle);font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em">bran</span>
                <div style="font-size:0.78rem;color:var(--color-subtle);font-family:var(--font-mono);margin-top:0.1rem">RPi 4 · automation runner, DNS &amp; Pi-hole</div>
              </div>
              <span class="status-dot ${tempStatus}"></span>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.4rem;margin-top:0.75rem">
              <div class="metric">
                <span class="metric-value" style="font-size:0.85rem">${tempVal}</span>
                <span class="metric-label">Temp</span>
              </div>
              <div class="metric">
                <span class="metric-value" style="font-size:0.85rem">${memVal}</span>
                <span class="metric-label">Mem</span>
              </div>
              <div class="metric">
                <span class="metric-value" style="font-size:0.85rem">${loadVal}</span>
                <span class="metric-label">Load</span>
              </div>
            </div>
          </div>
          <div class="card" style="opacity:0.6;border-style:dashed">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
              <span class="mono" style="color:var(--color-subtle);font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em">Homelab Power</span>
              <span class="status-dot unknown"></span>
            </div>
            <div style="font-size:1.25rem;font-weight:700;color:var(--color-subtle);font-family:var(--font-mono);margin-bottom:0.25rem">— W</div>
            <div class="mono" style="color:var(--color-subtle);font-size:0.85rem">Sonoff POW on PDU · not yet connected</div>
          </div>
          ${(() => {
            const u = data.ups ?? {};
            const dot = u.dot ?? 'unknown';
            const hasData = u.charge != null;
            if (!hasData) return `
          <div class="card" style="opacity:0.6;border-style:dashed">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
              <span class="mono" style="color:var(--color-subtle);font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em">UPS</span>
              <span class="status-dot unknown"></span>
            </div>
            <div style="font-size:1.25rem;font-weight:700;color:var(--color-subtle);font-family:var(--font-mono);margin-bottom:0.25rem">—</div>
            <div class="mono" style="color:var(--color-subtle);font-size:0.85rem">NUT unavailable</div>
          </div>`;
            const onBattery = u.on_battery ? ' · ON BATTERY' : '';
            return `
          <div class="card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem">
              <div>
                <span class="mono" style="color:var(--color-subtle);font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em">UPS</span>
                <div style="font-size:0.78rem;color:var(--color-subtle);font-family:var(--font-mono);margin-top:0.1rem">APC · ${u.nominal_w ?? '—'}W nominal${onBattery}</div>
              </div>
              <span class="status-dot ${dot}"></span>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.4rem;margin-top:0.75rem">
              <div class="metric">
                <span class="metric-value" style="font-size:0.85rem">${u.charge ?? '—'}%</span>
                <span class="metric-label">Charge</span>
              </div>
              <div class="metric">
                <span class="metric-value" style="font-size:0.85rem">${u.runtime_str ?? '—'}</span>
                <span class="metric-label">Runtime</span>
              </div>
              <div class="metric">
                <span class="metric-value" style="font-size:0.85rem">${u.load_pct ?? '—'}%</span>
                <span class="metric-label">Load</span>
              </div>
            </div>
          </div>`;
          })()}`;
      }

      // Storage pools
      const storageGrid = document.getElementById('storage-grid');
      if (storageGrid) {
        const pools = data.storage ?? [];
        if (pools.length > 0) {
          const colorVar = (status: string) =>
            status === 'crit' ? 'var(--color-crit)' : status === 'warn' ? 'var(--color-warn)' : 'var(--color-ok)';

          const donut = (pct: number, status: string) => {
            const r = 36, cx = 44, cy = 44, stroke = 10;
            const circ = 2 * Math.PI * r;
            const used = (pct / 100) * circ;
            const free = circ - used;
            const color = colorVar(status);
            return `<svg class="storage-donut" width="88" height="88" viewBox="0 0 88 88">
              <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="var(--color-overlay)" stroke-width="${stroke}"/>
              <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${color}" stroke-width="${stroke}"
                stroke-dasharray="${used} ${free}" stroke-dashoffset="${circ * 0.25}"
                stroke-linecap="round" style="transition:stroke-dasharray 0.7s ease"/>
              <text x="${cx}" y="${cy}" text-anchor="middle" dominant-baseline="middle"
                font-family="var(--font-mono)" font-size="13" font-weight="700" fill="${color}">${pct}%</text>
            </svg>`;
          };

          storageGrid.className = 'storage-grid';
          storageGrid.innerHTML = pools.map((p: any) => `
            <div class="storage-card ${p.status}">
              <div class="storage-pool-name">${p.name}</div>
              <div class="storage-health" style="color:var(--color-${p.healthy ? 'ok' : 'crit'})">
                ● ${p.pool_status ?? 'UNKNOWN'}
              </div>
              <div class="storage-donut-row">
                ${donut(p.pct, p.status)}
                <div class="storage-legend">
                  <div class="storage-legend-item">
                    <div style="display:flex;align-items:center">
                      <div class="storage-legend-dot" style="background:${colorVar(p.status)}"></div>
                      <span style="color:var(--color-subtle)">Used</span>
                    </div>
                    <span style="color:var(--color-heading);font-weight:600">${p.used}</span>
                  </div>
                  <div class="storage-legend-item">
                    <div style="display:flex;align-items:center">
                      <div class="storage-legend-dot" style="background:var(--color-overlay)"></div>
                      <span style="color:var(--color-subtle)">Total</span>
                    </div>
                    <span style="color:var(--color-heading);font-weight:600">${p.total}</span>
                  </div>
                  <div class="storage-bar-track" style="margin-top:0.5rem">
                    <div class="storage-bar-fill ${p.status}" style="width:${Math.min(p.pct,100)}%"></div>
                  </div>
                </div>
              </div>
            </div>
          `).join('');
        } else {
          storageGrid.innerHTML = '<div class="mono" style="color:var(--color-subtle);padding:0.5rem 0">Storage data unavailable</div>';
        }
      }

      // Flux
      const fluxSection = document.getElementById('flux-section');
      if (fluxSection && data.flux) {
        const f = data.flux;
        const ks = f.kustomizations ?? [];

        // Sort: failed first, then ready
        const sorted = [...ks].sort((a: any, b: any) => {
          if (!a.ready && b.ready) return -1;
          if (a.ready && !b.ready) return 1;
          return 0;
        });

        const total = f.total || 1;
        const readyPct  = Math.round((f.ready / total) * 100);
        const failedPct = 100 - readyPct;
        const failedCount = total - f.ready;

        const summary = `
          <div class="flux-summary">
            <span class="badge ${f.status}">${f.ready}/${f.total} synced</span>
            <div class="flux-ratio-bar" title="${f.ready} ready · ${failedCount} failed">
              <div class="flux-ratio-bar-ok"   style="width:${readyPct}%"></div>
              <div class="flux-ratio-bar-crit" style="width:${failedPct}%"></div>
            </div>
            <span class="flux-ratio-label">${f.ready} ready · ${failedCount} failed</span>
            <span class="mono" style="margin-left:auto;color:var(--color-subtle)">last sync ${f.last_sync}</span>
          </div>`;

        const tableRows = sorted.map((k: any) => `
          <div class="flux-row${k.ready ? '' : ' crit-row'}">
            <div class="flux-name-cell">
              <span class="flux-name-icon ${k.ready ? 'ok' : 'crit'}">${k.ready ? '✓' : '✗'}</span>
              <span class="flux-name-text">${k.name}</span>
            </div>
            <span style="font-family:var(--font-mono);font-size:0.75rem;color:var(--color-subtle)">${k.namespace}</span>
            <span style="font-family:var(--font-mono);font-size:0.75rem;color:var(--color-subtle)">${k.age}</span>
            <span class="badge ${k.ready ? 'ok' : 'crit'}">${k.ready ? '✓ Ready' : '✗ Failed'}</span>
          </div>`).join('');

        fluxSection.innerHTML = summary + (ks.length ? `
          <div class="flux-table">
            <div class="flux-row header">
              <span>Kustomization</span>
              <span>Namespace</span>
              <span>Last Applied</span>
              <span>Status</span>
            </div>
            ${tableRows}
          </div>` : `<div class="mono" style="color:var(--color-subtle);padding:1rem 0">No kustomization data yet — pipeline pending</div>`);
      }

      // Backups
      const backupCards = document.getElementById('backup-cards');
      if (backupCards && data.cards) {
        const find = (label: string) => data.cards.find((c: any) => c.label === label);
        const da = find('Docker Appdata');
        const et = find('etcd Snapshot');
        const vc = find('Velero');
        const vy = find('varys Keys');
        const items = [
          { label: 'Docker Appdata', value: da?.value ?? '—', sub: 'bronn · daily 02:00',  status: da?.status ?? 'unknown' },
          { label: 'etcd Snapshot',  value: et?.value ?? '—', sub: 'k3s · daily',           status: et?.status ?? 'unknown' },
          { label: 'Velero (k8s)',   value: vc?.value ?? '—', sub: 'last cluster backup',    status: vc?.status ?? 'unknown' },
          { label: 'varys Keys',     value: vy?.value ?? '—', sub: 'age keys · varys',       status: vy?.status ?? 'unknown' },
        ];
        backupCards.innerHTML = items.map(c => `
          <div class="card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
              <span class="mono" style="color:var(--color-subtle);font-size:0.72rem;text-transform:uppercase;letter-spacing:0.06em">${c.label}</span>
              <span class="status-dot ${c.status}"></span>
            </div>
            <div style="font-size:1.25rem;font-weight:700;color:var(--color-heading);font-family:var(--font-mono);margin-bottom:0.25rem">${c.value}</div>
            <div class="mono" style="font-size:0.85rem">${c.sub}</div>
          </div>
        `).join('');
      }

      // Network
      const net = data.network;
      if (net) {
        const latencyStatus = net.latency_ms == null ? 'unknown'
          : net.latency_ms < 30 ? 'ok'
          : net.latency_ms < 80 ? 'warn' : 'crit';

        const ph = net.pihole;
        const piholeCard = ph ? `
          <div class="card" style="border-left:3px solid var(--color-ok)">
            <div style="margin-bottom:0.5rem">
              <span class="mono" style="color:var(--color-subtle);font-size:0.72rem;text-transform:uppercase;letter-spacing:0.06em">Privacy Shield</span>
            </div>
            <div style="font-size:1.25rem;font-weight:700;color:var(--color-ok);font-family:var(--font-mono);margin-bottom:0.25rem">${ph.percent}%</div>
            <div class="mono" style="font-size:0.85rem">of your internet, blocked</div>
            <div class="mono" style="color:var(--color-subtle);font-size:0.82rem;margin-top:0.25rem">${ph.blocked.toLocaleString()} trackers silenced today</div>
          </div>` : '';

        const netCards = document.getElementById('network-cards');
        if (netCards) {
          netCards.innerHTML = piholeCard + [
            { label: 'Firewall Blocks', value: net.fw_hits != null ? net.fw_hits.toLocaleString() : '—', sub: 'packets dropped at router', status: 'ok' },
            { label: 'WAN Latency',     value: net.latency_ms != null ? net.latency_ms + ' ms' : '—',    sub: 'avg RTT to 8.8.8.8',       status: latencyStatus },
          ].map(c => `
            <div class="card">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
                <span class="mono" style="color:var(--color-subtle);font-size:0.72rem;text-transform:uppercase;letter-spacing:0.06em">${c.label}</span>
                <span class="status-dot ${c.status}"></span>
              </div>
              <div style="font-size:1.25rem;font-weight:700;color:var(--color-heading);font-family:var(--font-mono);margin-bottom:0.25rem">${c.value}</div>
              <div class="mono" style="font-size:0.85rem">${c.sub}</div>
            </div>
          `).join('');
        }

        // Persistent offenders table
        const offEl = document.getElementById('offenders-section');
        if (offEl) {
          const offs = net.offenders ?? [];
          if (offs.length > 0) {
            offEl.innerHTML = `
              <div class="flux-table">
                <div class="flux-row header" style="grid-template-columns:1.5fr 80px 140px">
                  <span>IP Address</span><span>Hits</span><span>Rule</span>
                </div>
                ${offs.map((o: any) => `
                  <div class="flux-row" style="grid-template-columns:1.5fr 80px 140px">
                    <span style="font-family:var(--font-mono);font-size:0.875rem;color:var(--color-peach)">${o.ip}</span>
                    <span class="badge crit">${o.hits}</span>
                    <span style="font-family:var(--font-mono);font-size:0.75rem;color:var(--color-subtle)">${o.type}</span>
                  </div>
                `).join('')}
              </div>`;
          } else {
            offEl.innerHTML = '<div class="mono" style="color:var(--color-subtle);padding:0.5rem 0">No persistent offenders detected</div>';
          }
        }
      }

    } catch { /* skeletons remain */ }
  }

  loadStatus();
  setInterval(loadStatus, 30000);
</script>
