---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Real "decisions recorded" — blog posts carrying an ADR reference
const posts = await getCollection('blog');
const DECISIONS = posts.filter(p => (p.data as any).adr).length;
---

<Layout
  title="About"
  description="Corporate exec by day. Self-taught engineer by night. Chief of Staff at a telco, running a k3s homelab in Johannesburg."
>

<!-- ════════════════════════════
     PHASE 1 — TERMINAL
════════════════════════════ -->
<div id="terminal-phase">
  <div class="term-window">
    <div class="term-bar">
      <div class="term-dot r"></div>
      <div class="term-dot y"></div>
      <div class="term-dot g"></div>
      <div class="term-title">kagiso@homelab — zsh — 80×30</div>
    </div>
    <div class="term-body" id="term-body"></div>
  </div>
</div>

<button id="skip-btn">skip intro ↓</button>

<!-- ════════════════════════════
     PHASE 2 — MANIFESTO
════════════════════════════ -->
<div id="manifesto-phase">

  <!-- HERO -->
  <header class="ab-hero">
    <div class="ab-hero-text">
      <div class="ab-kicker mono">$ whoami</div>
      <h1 class="ab-h1">Kagiso — exec by day, operator by night.</h1>
    </div>
    <div class="ab-photo">
      <img src="/images/kagiso.jpg" alt="Kagiso" />
    </div>
  </header>

  <!-- MANIFESTO -->
  <section class="ab-manifesto">
    <p class="ab-quote">I run strategy in a boardroom and a Kubernetes cluster in my study. This site is the seam between the two — proof that I don't just talk about how systems should work, I operate one.</p>
    <p class="ab-body">I didn't learn to code to change careers. I learned because I refused to stay illiterate in the language that runs the industry I help lead. So I built something real to close the gap: three mini-PCs, a proper HA Kubernetes cluster, GitOps, identity, storage, backups, observability — run with production discipline, for an audience of one (plus whoever's reading this).</p>
    <p class="ab-body">Everything here is genuinely live. The metrics come off the hardware, the ops log is the actual changelog, and the decision records document choices I really wrestled with — including the ones I got wrong first.</p>
  </section>

  <!-- DUALITY -->
  <section class="ab-section">
    <div class="ab-label mono">~/identity</div>
    <h2 class="ab-h2">One person. Two worlds.</h2>
    <p class="ab-sub">
      Most executives in a telco don't run Kubernetes clusters at home.
      Most people running Kubernetes clusters aren't in the C-suite by morning.
      I decided I wasn't going to pick a side.
    </p>
    <div class="ab-dual">
      <div class="ab-dual-card">
        <span class="ab-dual-icon mono">◈</span>
        <div class="ab-dual-title">The Executive</div>
        <div class="ab-dual-when mono">telco · monday → friday · 08:00–18:00</div>
        <div class="ab-trait">Force multiplier to executive leadership</div>
        <div class="ab-trait">Owns the agenda — strategy, cadence, decisions</div>
        <div class="ab-trait">Bridges commercial and technical in an industry being rebuilt by software</div>
        <div class="ab-trait">Makes other people's best thinking possible</div>
        <div class="ab-trait">Manages complexity so others can move faster</div>
      </div>
      <div class="ab-dual-card">
        <span class="ab-dual-icon mono">⬡</span>
        <div class="ab-dual-title">The Engineer</div>
        <div class="ab-dual-when mono">evenings · weekends · 22:00–02:00</div>
        <div class="ab-trait">Runs a real k3s cluster on owned hardware</div>
        <div class="ab-trait">GitOps with Flux CD and Helm</div>
        <div class="ab-trait">Full observability: Prometheus + Loki</div>
        <div class="ab-trait">Writes Ansible, YAML, the odd bash crime</div>
        <div class="ab-trait">Learning in public — incidents and all</div>
      </div>
    </div>

    <div class="ab-personal-wrap">
      <div class="ab-label mono">~/away-from-the-terminal</div>
      <div class="ab-personal">
        <div class="ab-personal-card">
          <span class="ab-personal-icon">♡</span>
          <div class="ab-personal-title">Husband & Father</div>
          <div class="ab-personal-sub mono">the most important role</div>
          <p class="ab-personal-body">Everything I build — the cluster, the self-hosting, the data sovereignty — is ultimately for the people at home. Their photos are on my Immich. Their privacy matters more than my convenience.</p>
        </div>
        <div class="ab-personal-card">
          <span class="ab-personal-icon">📷</span>
          <div class="ab-personal-title">Photographer</div>
          <div class="ab-personal-sub mono">stills · canon ecosystem</div>
          <p class="ab-personal-body">I shoot our family's story — moments that deserve better than a compressed thumbnail on someone else's server. Immich stores every frame. I own the archive.</p>
        </div>
        <div class="ab-personal-card">
          <span class="ab-personal-icon">🎬</span>
          <div class="ab-personal-title">Videographer</div>
          <div class="ab-personal-sub mono">video · blackmagic · colour</div>
          <p class="ab-personal-body">Video is photography with a timeline. The same eye for composition, the same obsession with getting the detail right — just with more storage requirements and a reason to upgrade the NAS.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BELIEFS -->
  <section class="ab-section">
    <div class="ab-label mono">~/philosophy</div>
    <h2 class="ab-h2">What I believe about running systems</h2>
    <div class="ab-beliefs">
      <div class="ab-belief">
        <div class="ab-belief-title mono">If it isn't in git, it doesn't exist</div>
        <p class="ab-belief-body">Every change is a reviewed commit. The cluster is reproducible from a repo, or it's a pet I'm one bad night away from losing.</p>
      </div>
      <div class="ab-belief">
        <div class="ab-belief-title mono">Build it to fail safely</div>
        <p class="ab-belief-body">HA, quorum, floating VIPs, tested restores. The goal isn't to avoid failure — it's to make failure boring.</p>
      </div>
      <div class="ab-belief">
        <div class="ab-belief-title mono">Document the why, not just the what</div>
        <p class="ab-belief-body">Anyone can read a config. The decision records capture the trade-offs I made and would otherwise forget by next quarter.</p>
      </div>
      <div class="ab-belief">
        <div class="ab-belief-title mono">Operate in the open</div>
        <p class="ab-belief-body">Showing the scars — incidents, wrong turns, the slow SSD — is more useful than another polished architecture diagram.</p>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="ab-stats">
    <div class="ab-stat"><div class="ab-stat-val mono" id="ab-uptime">—</div><div class="ab-stat-label mono">longest uptime</div></div>
    <div class="ab-stat"><div class="ab-stat-val mono">{DECISIONS}</div><div class="ab-stat-label mono">decisions recorded</div></div>
    <div class="ab-stat"><div class="ab-stat-val mono">8</div><div class="ab-stat-label mono">hosts on one /24</div></div>
    <div class="ab-stat"><div class="ab-stat-val mono" style="color:var(--ab-ok)">∞</div><div class="ab-stat-label mono">things still to break</div></div>
  </section>

  <!-- POKE AROUND + CONTRIB -->
  <section class="ab-section">
    <div class="ab-poke">
      <h2 class="ab-h2" style="margin:0 0 8px">Poke around. It's all open.</h2>
      <p class="ab-sub" style="margin:0 0 20px">The repo, the decisions, the live status — nothing here is staged. If you run a lab too, I'd genuinely like to compare notes.</p>
      <div class="ab-chips">
        <a href="https://github.com/Kagiso-me" target="_blank" rel="noopener" class="ab-chip mono">GitHub</a>
        <a href="/blog" class="ab-chip mono">Journal</a>
        <a href="/status" class="ab-chip mono">Live status</a>
        <a href="/digest" class="ab-chip mono">Ops log</a>
      </div>

      <!-- GitHub activity (real, from live.json contribs) -->
      <div class="ab-contrib-wrap">
        <div class="ab-contrib-head">
          <span class="mono ab-contrib-label">github activity</span>
          <span class="mono ab-contrib-total" id="ab-contrib-total"></span>
        </div>
        <div id="ab-contrib-graph" class="ab-contrib-graph"><div class="ab-contrib-loading mono">loading graph…</div></div>
        <div class="ab-contrib-legend mono">
          <span>less</span>
          <span class="ab-cc" data-level="0"></span>
          <span class="ab-cc" data-level="1"></span>
          <span class="ab-cc" data-level="2"></span>
          <span class="ab-cc" data-level="3"></span>
          <span class="ab-cc" data-level="4"></span>
          <span>more</span>
        </div>
      </div>
    </div>
  </section>

</div>

</Layout>

<style is:global>
/* ── TERMINAL PHASE ── */
#terminal-phase {
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 5rem 1rem 2rem;
}

.term-window {
  width: 100%; max-width: 780px;
  background: #0a0c12;
  border: 1px solid var(--color-muted);
  border-radius: 14px; overflow: hidden;
  box-shadow: 0 0 0 1px rgba(255,255,255,.04), 0 32px 80px rgba(0,0,0,.7);
  position: relative;
}
.term-window::before {
  content: ''; position: absolute; inset: 0; z-index: 10; pointer-events: none;
  background: repeating-linear-gradient(0deg, rgba(0,0,0,.06) 0px, rgba(0,0,0,.06) 1px, transparent 1px, transparent 3px);
  border-radius: inherit;
}
.term-window::after {
  content: ''; position: absolute; inset: 0; z-index: 9; pointer-events: none;
  background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(230,180,80,.025) 0%, transparent 70%);
  border-radius: inherit;
}

.term-bar {
  display: flex; align-items: center; gap: .6rem;
  padding: .8rem 1.1rem; background: #0d0f17;
  border-bottom: 1px solid var(--color-muted);
}
.term-dot { width: 12px; height: 12px; border-radius: 50%; }
.term-dot.r { background: #ff5f57; }
.term-dot.y { background: #ffbd2e; }
.term-dot.g { background: #28c840; }
.term-title { flex: 1; text-align: center; font-size: .7rem; color: var(--color-subtle); letter-spacing: .06em; font-family: var(--font-mono); }

.term-body {
  padding: 1.5rem 1.75rem 2rem; min-height: 520px;
  position: relative; z-index: 1;
  font-size: clamp(.72rem, 1.5vw, .82rem);
  line-height: 1.7; font-family: var(--font-mono);
}

.prompt { display: flex; align-items: baseline; }
.p-user { color: var(--color-green); font-weight: 700; }
.p-at, .p-sep { color: var(--color-subtle); }
.p-host { color: var(--color-sapphire); }
.p-path { color: var(--color-gold); }
.p-sym  { color: var(--color-subtle); margin-right: .45em; }
.p-cmd  { color: var(--color-heading); }

.cursor {
  display: inline-block; width: .55em; height: 1.1em;
  background: var(--color-gold); vertical-align: text-bottom;
  animation: blink .9s step-end infinite; margin-left: 1px; opacity: .9;
}
@keyframes blink { 0%,100%{opacity:.9} 50%{opacity:0} }

.out      { color: var(--color-text); }
.out-dim  { color: var(--color-subtle); }
.out-gold { color: var(--color-gold); font-weight: 500; }
.out-green{ color: var(--color-green); }
.blank    { height: .6rem; }
.lvl-info { color: var(--color-sapphire); }
.lvl-ok   { color: var(--color-green); }
.lvl-event{ color: var(--color-gold); }
.log-ts   { color: var(--color-subtle); }

#skip-btn {
  position: fixed; bottom: 2rem; right: 2rem; z-index: 200;
  background: rgba(14,16,23,.85); border: 1px solid var(--color-muted);
  border-radius: 99px; color: var(--color-subtle);
  font-family: var(--font-mono); font-size: .68rem;
  padding: .45rem 1.1rem; cursor: pointer;
  transition: border-color .2s, color .2s;
  backdrop-filter: blur(8px); letter-spacing: .06em;
}
#skip-btn:hover { border-color: var(--color-gold); color: var(--color-gold); }

/* ── MANIFESTO PHASE ── */
#manifesto-phase { display: none; opacity: 0; }
#manifesto-phase.show { display: block; }
#manifesto-phase.fade-in { animation: mfade 1.2s cubic-bezier(.16,1,.3,1) forwards; }
@keyframes mfade { from{opacity:0} to{opacity:1} }

/* ── Editorial About (Command Center mockup) ── */
#manifesto-phase {
  --ab-tx:#eaeaed; --ab-mut:#9a9aa3; --ab-fnt:#63636b;
  --ab-hair:rgba(255,255,255,.09); --ab-box:rgba(255,255,255,.16);
  --ab-ok:#2fa06b;
  --ab-serif:var(--font-display); --ab-mono:var(--font-mono);
}
.ab-hero, .ab-manifesto, .ab-section, .ab-stats {
  max-width: 1080px; margin-left: auto; margin-right: auto;
  padding-left: 1.5rem; padding-right: 1.5rem;
}

/* Hero */
.ab-hero { display: grid; grid-template-columns: 1fr auto; gap: 26px; align-items: center; padding-top: 48px; padding-bottom: 6px; }
.ab-kicker { font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--ab-mut); margin-bottom: 10px; }
.ab-h1 { font-family: var(--ab-serif); font-weight: 500; font-size: clamp(1.9rem,4vw,44px); letter-spacing: -.02em; line-height: 1.06; margin: 0; color: var(--ab-tx); }
.ab-photo { width: 72px; height: 72px; flex: none; }
.ab-photo img { width: 100%; height: 100%; object-fit: cover; border-radius: 16px; border: 1px solid var(--ab-hair); }

/* Manifesto */
.ab-manifesto { padding: 32px 1.5rem 8px; max-width: calc(72ch + 3rem); }
.ab-quote { font-family: var(--ab-serif); font-style: italic; font-size: 22px; line-height: 1.55; color: var(--ab-tx); margin: 0 0 24px; font-weight: 400; }
.ab-body { font-size: 15.5px; line-height: 1.72; color: var(--ab-mut); margin: 0 0 18px; }

/* Sections */
.ab-section { padding-top: 44px; padding-bottom: 8px; }
.ab-label { font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--ab-mut); margin-bottom: 9px; }
.ab-h2 { font-family: var(--ab-serif); font-weight: 500; font-size: 25px; margin: 0 0 12px; color: var(--ab-tx); }
.ab-sub { font-size: 14.5px; line-height: 1.65; color: var(--ab-mut); margin: 0 0 22px; max-width: 70ch; }

/* Duality */
.ab-dual { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.ab-dual-card { border: 1px solid var(--ab-hair); border-radius: 12px; padding: 22px 24px; }
.ab-dual-icon { font-size: 16px; color: var(--ab-mut); }
.ab-dual-title { font-family: var(--ab-serif); font-size: 20px; font-weight: 500; color: var(--ab-tx); margin: 8px 0 3px; }
.ab-dual-when { font-size: 11px; color: var(--ab-fnt); margin-bottom: 14px; }
.ab-trait { font-size: 13.5px; line-height: 1.5; color: var(--ab-mut); padding: 7px 0; border-top: 1px solid var(--ab-hair); }

.ab-personal-wrap { margin-top: 36px; }
.ab-personal { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
.ab-personal-card { border: 1px solid var(--ab-hair); border-radius: 12px; padding: 20px 22px; }
.ab-personal-icon { font-size: 18px; }
.ab-personal-title { font-family: var(--ab-serif); font-size: 17px; font-weight: 500; color: var(--ab-tx); margin: 10px 0 2px; }
.ab-personal-sub { font-size: 11px; color: var(--ab-fnt); margin-bottom: 12px; }
.ab-personal-body { font-size: 13px; line-height: 1.62; color: var(--ab-mut); margin: 0; }

/* Beliefs 2x2 */
.ab-beliefs { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-top: 1px solid var(--ab-hair); border-left: 1px solid var(--ab-hair); }
.ab-belief { padding: 20px 22px; border-right: 1px solid var(--ab-hair); border-bottom: 1px solid var(--ab-hair); }
.ab-belief-title { font-size: 14px; font-weight: 500; color: var(--ab-tx); margin-bottom: 8px; }
.ab-belief-body { font-size: 13.5px; line-height: 1.65; color: var(--ab-mut); margin: 0; }

/* Stats strip */
.ab-stats { display: grid; grid-template-columns: repeat(4,1fr); margin-top: 44px; border-top: 1px solid var(--ab-hair); }
.ab-stat { padding: 20px 22px 20px 0; border-left: 1px solid var(--ab-hair); padding-left: 22px; margin-left: -1px; }
.ab-stat:first-child { border-left: none; padding-left: 0; margin-left: 0; }
.ab-stat-val { font-size: 28px; font-weight: 500; color: var(--ab-tx); font-variant-numeric: tabular-nums; }
.ab-stat-label { font-size: 11px; color: var(--ab-mut); margin-top: 5px; }

/* Poke around */
.ab-poke { border: 1px solid var(--ab-hair); border-radius: 12px; padding: 30px 32px; }
.ab-chips { display: flex; gap: 10px; flex-wrap: wrap; }
.ab-chip { padding: 9px 15px; border-radius: 8px; border: 1px solid var(--ab-hair); color: var(--ab-tx); text-decoration: none; font-size: 12.5px; transition: border-color .18s ease; }
.ab-chip:hover { border-color: var(--ab-box); color: var(--ab-tx); }

.ab-contrib-wrap { display: inline-flex; flex-direction: column; gap: 9px; margin-top: 26px; padding-top: 20px; border-top: 1px solid var(--ab-hair); }
.ab-contrib-head { display: flex; align-items: baseline; gap: 12px; }
.ab-contrib-label { font-size: 9.5px; letter-spacing: .12em; text-transform: uppercase; color: var(--ab-fnt); }
.ab-contrib-total { font-size: 10px; color: var(--ab-fnt); }
.ab-contrib-graph { overflow-x: auto; }
.ab-contrib-grid { display: grid; grid-auto-flow: column; grid-template-rows: repeat(7, 10px); gap: 3px; width: max-content; }
.ab-cc, .ab-contrib-grid span { width: 10px; height: 10px; border-radius: 2px; }
.ab-cc[data-level="0"], .ab-contrib-grid span[data-level="0"] { background: rgba(255,255,255,.06); }
.ab-cc[data-level="1"], .ab-contrib-grid span[data-level="1"] { background: rgba(111,143,176,.35); }
.ab-cc[data-level="2"], .ab-contrib-grid span[data-level="2"] { background: rgba(47,160,107,.5); }
.ab-cc[data-level="3"], .ab-contrib-grid span[data-level="3"] { background: color-mix(in srgb, #2fa06b 78%, transparent); }
.ab-cc[data-level="4"], .ab-contrib-grid span[data-level="4"] { background: #2fa06b; }
.ab-contrib-legend { display: flex; align-items: center; gap: 5px; justify-content: flex-end; font-size: 10px; color: var(--ab-fnt); }
.ab-contrib-loading { font-size: 11px; color: var(--ab-mut); padding: 8px 0; }

@media (max-width: 860px) {
  .ab-dual, .ab-beliefs, .ab-personal, .ab-stats { grid-template-columns: 1fr; }
  .ab-personal { grid-template-columns: 1fr; }
  .ab-stats { grid-template-columns: repeat(2,1fr); }
  .ab-h1 { font-size: 30px; }
}

</style>

<script is:inline>
const termBody = document.getElementById('term-body');
const PROMPT = `<span class="p-user">kagiso</span><span class="p-at">@</span><span class="p-host">homelab</span><span class="p-sep">:</span><span class="p-path">~</span><span class="p-sym"> $</span> `;
let aborted = false;

const sleep = ms => new Promise(r => setTimeout(r, ms));

function el(tag, cls, html) {
  const e = document.createElement(tag);
  if (cls) e.className = cls;
  if (html) e.innerHTML = html;
  return e;
}

function append(node) {
  termBody.appendChild(node);
  termBody.scrollTop = termBody.scrollHeight;
}

async function typeCmd(text, speed = 48) {
  const row = el('div', 'prompt');
  row.innerHTML = PROMPT;
  const span = el('span', 'p-cmd');
  const cur = el('span', 'cursor');
  row.appendChild(span); row.appendChild(cur); append(row);
  for (const ch of text) {
    if (aborted) return;
    span.textContent += ch;
    termBody.scrollTop = termBody.scrollHeight;
    await sleep(speed + Math.random() * 30);
  }
  cur.remove();
}

async function printLines(lines, delay = 28) {
  for (const line of lines) {
    if (aborted) return;
    const d = el('div'); d.innerHTML = line; append(d);
    await sleep(delay);
  }
}

async function blank() { append(el('div', 'blank')); }

async function run() {
  await sleep(600);

  await typeCmd('whoami');
  await sleep(120);
  await printLines([`<span class="out-gold">kagiso</span>`], 0);
  await blank();

  await typeCmd('cat identity.txt');
  await sleep(120);
  await printLines([
    `<span class="out-dim">╭──────────────────────────────────────────────────╮</span>`,
    `<span class="out-dim">│</span>  <span class="out-gold">Name   </span>  Kagiso                                  <span class="out-dim">│</span>`,
    `<span class="out-dim">│</span>  <span class="out-gold">Role   </span>  Chief of Staff, Telco + Self-taught Eng <span class="out-dim">│</span>`,
    `<span class="out-dim">│</span>  <span class="out-gold">Base   </span>  Johannesburg, South Africa              <span class="out-dim">│</span>`,
    `<span class="out-dim">│</span>  <span class="out-gold">Shell  </span>  zsh — but also the boardroom            <span class="out-dim">│</span>`,
    `<span class="out-dim">│</span>  <span class="out-gold">Status </span>  <span class="out-green">learning in public · cluster is live</span>    <span class="out-dim">│</span>`,
    `<span class="out-dim">╰──────────────────────────────────────────────────╯</span>`,
  ], 40);
  await blank();

  await typeCmd('cat life.log | tail -n 20');
  await sleep(120);
  await printLines([
    `<span class="log-ts">[early career]</span>   <span class="lvl-info">INFO</span>   <span class="out">entered corporate — smart spreadsheets, polished decks</span>`,
    `<span class="log-ts">[early career]</span>   <span class="lvl-info">INFO</span>   <span class="out">started leading teams, managing strategy</span>`,
    `<span class="log-ts">[the question]</span>   <span class="lvl-event">WARN</span>   <span class="out">why do I nod along without actually understanding the tech?</span>`,
    `<span class="log-ts">[turning point]</span>  <span class="lvl-event">EVNT</span>   <span class="out-gold">decided to learn — not for a new job. pure stubbornness.</span>`,
    `<span class="log-ts">[2023]         </span>   <span class="lvl-info">INFO</span>   <span class="out">python. broke a lot of things. kept going.</span>`,
    `<span class="log-ts">[2024-Q1]      </span>   <span class="lvl-info">INFO</span>   <span class="out">bought 3x Lenovo ThinkCentres. second-hand. R4200.</span>`,
    `<span class="log-ts">[2024-Q2]      </span>   <span class="lvl-info">INFO</span>   <span class="out">installed Proxmox. broke it. installed it again.</span>`,
    `<span class="log-ts">[2024-Q3]      </span>   <span class="lvl-event">EVNT</span>   <span class="out-gold">k3s cluster goes live. 3 nodes. real GitOps. real workloads.</span>`,
