---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Projects" description="Active builds, upcoming work, and planned projects — tracked by milestones.">

  <div class="page-wrap">

    <!-- ── Header ── -->
    <div class="page-header fade-up">
      <div>
        <p class="mono" style="color:var(--color-mauve);margin-bottom:0.25rem">~/projects</p>
        <h1 style="margin:0">Projects</h1>
      </div>
      <p class="hero-sub">
        What's being built and how far along it is.
        Each card tracks milestones — not just intentions.
      </p>
    </div>

    <!-- ── Active ── -->
    <section class="lane fade-up" style="animation-delay:0.05s" id="lane-active">
      <div class="lane-header">
        <span class="lane-dot active"></span>
        <h2 class="lane-title">Active</h2>
        <span class="lane-sub">In flight now</span>
      </div>
      <div class="projects-grid" id="grid-active">
        <div class="proj-card skeleton" style="height:260px"></div>
        <div class="proj-card skeleton" style="height:260px"></div>
      </div>
    </section>

    <!-- ── Upcoming ── -->
    <section class="lane fade-up" style="animation-delay:0.1s" id="lane-upcoming">
      <div class="lane-header">
        <span class="lane-dot upcoming"></span>
        <h2 class="lane-title">Upcoming</h2>
        <span class="lane-sub">Starts soon</span>
      </div>
      <div class="projects-grid" id="grid-upcoming">
        <div class="proj-card skeleton" style="height:260px"></div>
      </div>
    </section>

    <!-- ── Planned ── -->
    <section class="lane fade-up" style="animation-delay:0.15s" id="lane-planned">
      <div class="lane-header">
        <span class="lane-dot planned"></span>
        <h2 class="lane-title">Planned</h2>
        <span class="lane-sub">Decided, not yet scheduled</span>
      </div>
      <div class="projects-grid" id="grid-planned">
        <div class="proj-card skeleton" style="height:260px"></div>
      </div>
    </section>

  </div>

</Layout>

<style is:global>
  .page-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .page-header { margin-bottom: 3.5rem; }

  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); }

  .hero-sub {
    color: var(--color-subtle);
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: 520px;
    margin: 0.75rem 0 0;
  }

  /* ── Lane ── */
  .lane { margin-bottom: 3.5rem; }

  .lane-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-muted);
  }

  .lane-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .lane-dot.active   { background: var(--color-ok); box-shadow: 0 0 8px var(--color-ok); }
  .lane-dot.upcoming { background: var(--color-peach); }
  .lane-dot.planned  { background: var(--color-subtle); }

  h2.lane-title {
    font-size: 1rem;
    margin: 0;
    color: var(--color-heading);
  }

  .lane-sub {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-subtle);
  }

  /* ── Grid ── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1rem;
  }

  /* ── Project card ── */
  .proj-card {
    background: rgba(30, 37, 52, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 14px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: border-color 0.2s, transform 0.2s;
  }

  .proj-card:hover { transform: translateY(-2px); }
  .proj-card.active   { border-top: 3px solid var(--color-ok);     border-color: color-mix(in srgb, var(--color-ok) 30%, var(--color-muted)); }
  .proj-card.upcoming { border-top: 3px solid var(--color-peach);   border-color: color-mix(in srgb, var(--color-peach) 30%, var(--color-muted)); }
  .proj-card.planned  { border-top: 3px solid var(--color-subtle);  }

  .proj-card.active:hover   { border-color: var(--color-ok); }
  .proj-card.upcoming:hover { border-color: var(--color-peach); }
  .proj-card.planned:hover  { border-color: var(--color-subtle); }

  /* Card top row */
  .proj-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .proj-status-badge {
    font-family: var(--font-mono);
    font-size: 0.63rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }
  .proj-status-badge.active   { background: color-mix(in srgb, var(--color-ok) 15%, transparent);    color: var(--color-ok); }
  .proj-status-badge.upcoming { background: color-mix(in srgb, var(--color-peach) 15%, transparent); color: var(--color-peach); }
  .proj-status-badge.planned  { background: color-mix(in srgb, var(--color-subtle) 15%, transparent);color: var(--color-subtle); }

  .proj-timeline {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-subtle);
    white-space: nowrap;
  }

  .proj-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 0 0 0.35rem;
    line-height: 1.25;
  }

  .proj-description {
    font-size: 0.875rem;
    color: var(--color-text);
    line-height: 1.65;
    margin-bottom: 1.25rem;
    flex: 1;
  }

  /* ── Progress bar ── */
  .proj-progress {
    margin-bottom: 1.1rem;
  }

  .proj-progress-label {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.67rem;
    color: var(--color-subtle);
    margin-bottom: 0.35rem;
  }

  .proj-progress-bar {
    height: 4px;
    background: var(--color-overlay);
    border-radius: 2px;
    overflow: hidden;
  }

  .proj-progress-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .active   .proj-progress-fill { background: var(--color-ok); }
  .upcoming .proj-progress-fill { background: var(--color-peach); }
  .planned  .proj-progress-fill { background: var(--color-subtle); }

  /* ── Milestones ── */
  .milestones {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid var(--color-muted);
    padding-top: 1rem;
  }

  .milestone {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .milestone.done .milestone-label { color: var(--color-subtle); text-decoration: line-through; text-decoration-color: var(--color-muted); }
  .milestone:not(.done) .milestone-label { color: var(--color-text); }

  .milestone-check {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    font-weight: 700;
  }

  .milestone.done .milestone-check {
    background: color-mix(in srgb, var(--color-ok) 20%, transparent);
    border: 1px solid var(--color-ok);
    color: var(--color-ok);
  }

  .milestone:not(.done) .milestone-check {
    background: transparent;
    border: 1px solid var(--color-muted);
    color: transparent;
  }

  /* Skeleton */
  .skeleton {
    background: linear-gradient(90deg, var(--color-surface) 25%, var(--color-overlay) 50%, var(--color-surface) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: 14px;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  @media (max-width: 640px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  function buildCard(item: any): string {
    const done   = (item.milestones ?? []).filter((m: any) => m.done).length;
    const total  = (item.milestones ?? []).length;
    const pct    = total > 0 ? Math.round((done / total) * 100) : 0;

    const progressHtml = total > 0 ? `
      <div class="proj-progress">
        <div class="proj-progress-label">
          <span>milestones</span>
          <span>${done} / ${total}</span>
        </div>
        <div class="proj-progress-bar">
          <div class="proj-progress-fill" style="width:${pct}%"></div>
        </div>
      </div>` : '';

    const milestonesHtml = total > 0 ? `
      <ul class="milestones">
        ${(item.milestones as any[]).map(m => `
          <li class="milestone${m.done ? ' done' : ''}">
            <span class="milestone-check">${m.done ? '✓' : ''}</span>
            <span class="milestone-label">${m.label}</span>
          </li>`).join('')}
      </ul>` : '';

    const timelineHtml = item.timeline
      ? `<span class="proj-timeline">⏱ ${item.timeline}</span>`
      : '';

    return `
    <div class="proj-card ${item.status}">
      <div class="proj-top">
        <span class="proj-status-badge ${item.status}">${item.status}</span>
        ${timelineHtml}
      </div>
      <div class="proj-title">${item.title}</div>
      <div class="proj-description">${item.description}</div>
      ${progressHtml}
      ${milestonesHtml}
    </div>`;
  }

  async function load() {
    try {
      const res = await fetch('/data/projects.json');
      if (!res.ok) throw new Error();
      const items: any[] = await res.json();

      const groups: Record<string, any[]> = { active: [], upcoming: [], planned: [] };
      for (const item of items) {
        if (groups[item.status]) groups[item.status].push(item);
      }

      for (const [status, list] of Object.entries(groups)) {
        const el = document.getElementById(`grid-${status}`);
        if (!el) continue;
        if (!list.length) {
          el.closest('.lane')?.remove();
        } else {
          el.innerHTML = list.map(buildCard).join('');
        }
      }
    } catch { /* skeletons remain */ }
  }

  load();
</script>
