  // ── Number counters ───────────────────────────────────────────────────────
  function countUp(el: Element, target: number, suffix: string, duration = 900) {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = target + suffix;
      return;
    }
    const start = performance.now();
    const step = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(eased * target) + suffix;
      if (progress < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  function initCounters() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseFloat(el.dataset.countTo ?? '0');
        const suffix = el.dataset.countSuffix ?? '';
        countUp(el, target, suffix);
        observer.unobserve(el);
      });
    }, { threshold: 0.3 });

    document.querySelectorAll('[data-count-to]').forEach(el => observer.observe(el));
  }

  // ── CVE banner (fetched once, not on 30s poll) ───────────────────────────
  async function loadCVEBanner() {
    const banner = document.getElementById('cve-banner');
    if (!banner) return;
    try {
      const res = await fetch('/data/cve.json?t=' + Date.now());
      if (!res.ok) throw new Error('no data');
      const d = await res.json();

      const statusDotClass = d.status === 'clean' || d.status === 'ok' ? 'ok'
                           : d.status === 'crit'                        ? 'crit'
                           : 'warn';

      let label = '';
      if (d.status === 'clean') {
        label = `No known CVEs &middot; ${d.tracked ?? '?'} components tracked`;
      } else {
        const parts: string[] = [];
        if (d.counts?.CRITICAL) parts.push(`${d.counts.CRITICAL} CRITICAL`);
        if (d.counts?.HIGH)     parts.push(`${d.counts.HIGH} HIGH`);
        if (d.counts?.MEDIUM)   parts.push(`${d.counts.MEDIUM} MEDIUM`);
        if (d.counts?.LOW)      parts.push(`${d.counts.LOW} LOW`);
        label = parts.join(', ') || `${d.total} CVEs`;
      }

      banner.innerHTML = `
        <a href="/security" class="deploy-banner" style="text-decoration:none; display:flex; align-items:center; gap:1rem">
          <span class="status-dot ${statusDotClass}"></span>
          <span class="deploy-msg">${label}</span>
          <span class="deploy-age">view details →</span>
        </a>`;
    } catch {
      banner.innerHTML = '';
    }
  }

  // ── Polling lifecycle ─────────────────────────────────────────────────────
  let pollInterval: ReturnType<typeof setInterval> | null = null;

  function startPolling() {
    if (pollInterval) clearInterval(pollInterval);
    loadStatus().then(() => setTimeout(initCounters, 80));
    pollInterval = setInterval(() => loadStatus().then(() => setTimeout(initCounters, 80)), 30000);
  }

  function stopPolling() {
    if (pollInterval) { clearInterval(pollInterval); pollInterval = null; }
  }

  // ── Ring scroll-reveal ───────────────────────────────────────────────────
  // Watches for node cards injected by loadStatus(), then animates each
  // ring arc from 0 to its target dasharray when it enters the viewport.
  function initRingObserver() {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const arc = entry.target as SVGCircleElement;
        const target = arc.dataset.dash;
        if (!target) return;
        // Tiny delay so the CSS transition has a frame to start from zero
        requestAnimationFrame(() => {
          arc.style.strokeDasharray = target;
          arc.classList.add('ring-revealed');
        });
        io.unobserve(arc);
      });
    }, { threshold: 0.3 });

    document.querySelectorAll('.node-status-ring circle.arc[data-dash]').forEach(arc => {
      io.observe(arc);
    });
  }

  // Re-run after each data load (nodes grid is replaced each poll)
  (window as any).__ringObserverPatched = true;

  // Hook into the nodes grid being populated via MutationObserver
  const nodesGridEl = document.getElementById('nodes-grid');
  if (nodesGridEl) {
    const mo = new MutationObserver(() => {
      // Small delay for innerHTML to fully settle before querying arcs
      setTimeout(initRingObserver, 60);
    });
    mo.observe(nodesGridEl, { childList: true, subtree: false });
  }

  // ── Cluster uptime counter ───────────────────────────────────────────────
  let _clusterEpoch: number | null = null;
  let _uptimeTimer: ReturnType<typeof setInterval> | null = null;

  function startUptimeCounter(epochMs: number) {
    if (_uptimeTimer) clearInterval(_uptimeTimer);
    _clusterEpoch = epochMs;
    function tick() {
      const el = document.getElementById('uptime-value');
      if (!el || _clusterEpoch === null) return;
      const ms = Date.now() - _clusterEpoch;
      const s  = Math.floor(ms / 1000);
      const m  = Math.floor(s  / 60);
      const h  = Math.floor(m  / 60);
      const d  = Math.floor(h  / 24);
      const hh = String(h % 24).padStart(2, '0');
      const mm = String(m % 60).padStart(2, '0');
      const ss = String(s % 60).padStart(2, '0');
      el.textContent = `${d}d ${hh}h ${mm}m ${ss}s`;
    }
    tick();
    _uptimeTimer = setInterval(tick, 1000);
  }

  // Seed with live data; falls back to hardcoded epoch if cluster_start unavailable
  (async () => {
    try {
      const r = await fetch('/data/live.json?t=' + Date.now());
      const d = r.ok ? await r.json() : null;
      const epoch = d?.cluster_start
        ? new Date(d.cluster_start).getTime()
        : new Date('2024-11-01T00:00:00Z').getTime();
      startUptimeCounter(epoch);
    } catch {
      startUptimeCounter(new Date('2024-11-01T00:00:00Z').getTime());
    }
  })();

  document.addEventListener('astro:before-swap', () => { if (_uptimeTimer) clearInterval(_uptimeTimer); });

  document.addEventListener('astro:page-load', () => { startPolling(); loadCVEBanner(); initNetMap(); });
  document.addEventListener('astro:before-swap', stopPolling);

  // ── Network Diagram ─────────────────────────────────────────────────────────
  type Pt = { x: number; y: number };

  // [fromId, toId, colour, dashed]
  const NET_LINKS: [string, string, string, boolean][] = [
    ['nm-internet', 'nm-mikrotik', '#fab387', false],
    ['nm-mikrotik', 'nm-tywin',   '#cba6f7', false],
    ['nm-mikrotik', 'nm-jaime',   '#cba6f7', false],
    ['nm-mikrotik', 'nm-tyrion',  '#cba6f7', false],
    ['nm-mikrotik', 'nm-bronn',   '#74c7ec', false],
    ['nm-mikrotik', 'nm-varys',   '#a6e3a1', false],
    ['nm-mikrotik', 'nm-ned',     '#e6b450', false],
    ['nm-mikrotik', 'nm-bran',    '#f38ba8', false],
    ['nm-tywin',    'nm-jaime',   '#cba6f7', true],
    ['nm-tywin',    'nm-tyrion',  '#cba6f7', true],
    ['nm-jaime',    'nm-tyrion',  '#cba6f7', true],
    ['nm-bronn',    'nm-ned',     '#74c7ec', true],
  ];

  // Packet animations: one packet per active primary link, looping
  interface Packet { el: SVGCircleElement; fromId: string; toId: string; color: string; t: number; speed: number; }
  const _packets: Packet[] = [];
  let   _rafId = 0;
  let   _hoverId: string | null = null;

  async function initNetMap() {
    const svg     = document.getElementById('netmap-svg') as SVGSVGElement | null;
    const linesG  = document.getElementById('nm-lines')   as SVGGElement   | null;
    const packsG  = document.getElementById('nm-packets') as SVGGElement   | null;
    const tooltip = document.getElementById('nm-tooltip') as HTMLElement   | null;
    if (!svg || !linesG || !packsG) return;

    const wrap = () => document.getElementById('netmap-wrap') as HTMLElement;

    function centre(id: string): Pt | null {
      const el = document.getElementById(id);
      if (!el) return null;
      const wr = wrap().getBoundingClientRect();
      const r  = el.getBoundingClientRect();
      return { x: r.left + r.width  / 2 - wr.left,
               y: r.top  + r.height / 2 - wr.top  };
    }

    // Bezier helper — gentle curve for hierarchy lines
    function bezier(a: Pt, b: Pt): string {
      const dy = b.y - a.y;
      const cy = dy * 0.45;
      return `M ${a.x} ${a.y} C ${a.x} ${a.y + cy}, ${b.x} ${b.y - cy}, ${b.x} ${b.y}`;
    }
    function lerp(a: Pt, b: Pt, t: number): Pt {
      // cubic bezier point
      const cy = (b.y - a.y) * 0.45;
      const p0 = a, p1 = { x: a.x, y: a.y + cy }, p2 = { x: b.x, y: b.y - cy }, p3 = b;
      const mt = 1 - t;
      return {
        x: mt*mt*mt*p0.x + 3*mt*mt*t*p1.x + 3*mt*t*t*p2.x + t*t*t*p3.x,
        y: mt*mt*mt*p0.y + 3*mt*mt*t*p1.y + 3*mt*t*t*p2.y + t*t*t*p3.y,
      };
    }

    function drawLines(hoverId: string | null) {
      _hoverId = hoverId;
      linesG.innerHTML = '';

      for (const [a, b, color, dashed] of NET_LINKS) {
        const ca = centre(a), cb = centre(b);
        if (!ca || !cb) continue;

        const aId = a.replace('nm-', '');
        const bId = b.replace('nm-', '');
        const active = hoverId && (a.includes(hoverId) || b.includes(hoverId) || aId === hoverId || bId === hoverId);

        const d = bezier(ca, cb);

        // Shadow / glow path (behind)
        if (active) {
          const glow = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          glow.setAttribute('d', d);
          glow.setAttribute('stroke', color);
          glow.setAttribute('stroke-width', '6');
          glow.setAttribute('fill', 'none');
          glow.setAttribute('stroke-opacity', '0.15');
          glow.setAttribute('stroke-linecap', 'round');
          linesG.appendChild(glow);
        }

        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('d', d);
        path.setAttribute('stroke', color + (active ? 'dd' : '30'));
        path.setAttribute('stroke-width', active ? '2' : '1');
        path.setAttribute('fill', 'none');
        path.setAttribute('stroke-linecap', 'round');
        if (dashed) path.setAttribute('stroke-dasharray', active ? '5 6' : '3 8');
        linesG.appendChild(path);
      }
    }

    // ── Packet animation ──────────────────────────────────────────────────
    function spawnPackets() {
      packsG.innerHTML = '';
      _packets.length = 0;

      // Only primary (non-dashed) links get flowing packets
      for (const [a, b, color, dashed] of NET_LINKS) {
        if (dashed) continue;
        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('r', '3.5');
        circle.setAttribute('fill', color);
        circle.setAttribute('filter', `drop-shadow(0 0 4px ${color})`);
        circle.setAttribute('opacity', '0');
        packsG.appendChild(circle);
        _packets.push({
          el: circle,
          fromId: a, toId: b,
          color,
          t: Math.random(),
          speed: 0.0008 + Math.random() * 0.0006,
        });
      }
    }

    function tickPackets() {
      for (const p of _packets) {
        p.t += p.speed;
        if (p.t > 1) p.t -= 1;

        const ca = centre(p.fromId), cb = centre(p.toId);
        if (!ca || !cb) { p.el.setAttribute('opacity', '0'); continue; }

        const pt = lerp(ca, cb, p.t);
        p.el.setAttribute('cx', String(pt.x));
        p.el.setAttribute('cy', String(pt.y));

        // Fade in/out at ends
        const fade = p.t < 0.12 ? p.t / 0.12 : p.t > 0.88 ? (1 - p.t) / 0.12 : 1;
        p.el.setAttribute('opacity', String(fade * 0.85));
      }
      _rafId = requestAnimationFrame(tickPackets);
    }

    // ── Tooltip ───────────────────────────────────────────────────────────
    document.querySelectorAll<HTMLElement>('.nm-node').forEach(node => {
      node.addEventListener('mouseenter', () => {
        const id = node.dataset.id ?? node.id.replace('nm-', '');
        drawLines(id);

        if (tooltip) {
          const ttName = document.getElementById('nm-tt-name');
          const ttIp   = document.getElementById('nm-tt-ip');
          const ttRole = document.getElementById('nm-tt-role');
          const ttSvc  = document.getElementById('nm-tt-services');

          if (ttName) ttName.textContent = node.querySelector('.nm-label')?.textContent ?? '';
          if (ttIp)   ttIp.textContent   = node.dataset.ip ?? '';
          if (ttRole) ttRole.textContent  = node.dataset.role ?? '';
          if (ttSvc)  ttSvc.innerHTML = (node.dataset.services ?? '')
            .split(' · ')
            .map(s => `<span class="nm-tt-svc-row">${s}</span>`)
            .join('');

          const wr = wrap().getBoundingClientRect();
          const nr = node.getBoundingClientRect();
          let tx = nr.left - wr.left + nr.width + 12;
          let ty = nr.top  - wr.top  - 8;
          if (tx + 245 > wr.width) tx = nr.left - wr.left - 250;
          if (ty + 160 > wr.height) ty = wr.height - 170;
          if (ty < 4) ty = 4;
          tooltip.style.left = tx + 'px';
          tooltip.style.top  = ty + 'px';
          tooltip.classList.add('visible');
        }
      });

      node.addEventListener('mouseleave', () => {
        drawLines(null);
        tooltip?.classList.remove('visible');
      });
    });

    // ── Live status dots ──────────────────────────────────────────────────
    try {
      const r = await fetch('/data/live.json');
      if (r.ok) {
        const data = await r.json();
        for (const n of (data.nodes ?? [])) {
          const dot = document.getElementById('dot-' + n.name?.toLowerCase());
          if (dot) dot.className = 'nm-dot ' + (n.status === 'ok' ? 'ok' : n.status === 'warn' ? 'warn' : 'crit');
        }
      }
    } catch {}

    // ── Init ──────────────────────────────────────────────────────────────
    drawLines(null);
    spawnPackets();
    tickPackets();

    let _resizeTimer = 0;
    window.addEventListener('resize', () => {
      clearTimeout(_resizeTimer);
      _resizeTimer = window.setTimeout(() => {
        drawLines(_hoverId);
        spawnPackets(); // recreate packet elements (positions may have shifted)
      }, 120);
    }, { passive: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNetMap);
  } else {
    initNetMap();
  }

  document.addEventListener('astro:before-swap', () => {
    if (_rafId) { cancelAnimationFrame(_rafId); _rafId = 0; }
  });
</script>
