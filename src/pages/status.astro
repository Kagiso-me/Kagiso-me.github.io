---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Status" description="Live cluster health, node metrics, and service uptime.">

  <div class="page-wrap">

    <!-- ── Header ── -->
    <div class="page-header fade-up">
      <div>
        <p class="mono" style="color:var(--color-peach); margin-bottom:0.25rem">~/status</p>
        <h1 style="margin:0">Cluster Status</h1>
        <!-- Live cluster uptime counter -->
        <div class="uptime-counter" id="uptime-counter">
          <span class="uptime-label mono">cluster uptime</span>
          <span class="uptime-value mono" id="uptime-value">—</span>
        </div>
      </div>
      <div style="text-align:right">
        <div class="mono live-badge">
          <span class="status-dot ok"></span>
          Live · auto-refresh 30s
        </div>
        <div class="mono" id="last-updated" style="color:var(--color-subtle); margin-top:0.25rem">—</div>
      </div>
    </div>

    <!-- ── Security ── -->
    <section class="section fade-up" style="animation-delay:0.02s">
      <h2 class="section-label">Security</h2>
      <div id="cve-banner">
        <div class="skeleton" style="height:56px; border-radius:10px"></div>
      </div>
    </section>

    <!-- ── Network ── -->
    <section class="section fade-up" style="animation-delay:0.05s">
      <h2 class="section-label">Network</h2>
      <div class="cards-grid" id="network-cards" style="margin-bottom:1.5rem">
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
      </div>
      <div id="offenders-section">
        <div class="skeleton" style="height:180px;border-radius:12px"></div>
      </div>
    </section>

    <!-- ── Infrastructure ── -->
    <section class="section fade-up" style="animation-delay:0.1s">
      <h2 class="section-label">Infrastructure</h2>
      <div id="infra-deploy" style="margin-bottom:1rem">
        <div class="skeleton" style="height:56px;border-radius:10px"></div>
      </div>
      <div class="cards-grid" id="infra-cards">
        <div class="card skeleton" style="height:120px"></div>
        <div class="card skeleton" style="height:120px"></div>
        <div class="card skeleton" style="height:120px"></div>
        <div class="card skeleton" style="height:120px"></div>
      </div>
    </section>

    <!-- ── Storage ── -->
    <section class="section fade-up" style="animation-delay:0.13s">
      <h2 class="section-label">Storage</h2>
      <div id="storage-grid">
        <div class="skeleton" style="height:120px;border-radius:12px"></div>
      </div>
    </section>

    <!-- ── At a Glance ── -->
    <section class="section fade-up" style="animation-delay:0.15s">
      <h2 class="section-label">At a Glance</h2>
      <div class="cards-grid" id="glance-cards">
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
      </div>
    </section>

    <!-- ── Nodes ── -->
    <section class="section fade-up" style="animation-delay:0.18s">
      <h2 class="section-label">Nodes</h2>
      <div class="nodes-grid" id="nodes-grid">
        <div class="skeleton" style="height:160px; border-radius:12px"></div>
        <div class="skeleton" style="height:160px; border-radius:12px"></div>
        <div class="skeleton" style="height:160px; border-radius:12px"></div>
      </div>
    </section>

    <!-- ── Network Topology Map ── -->
    <section class="section fade-up" style="animation-delay:0.18s">
      <h2 class="section-label">Network Topology</h2>

      <div class="netmap-wrap" id="netmap-wrap">
        <!-- Full-canvas SVG: grid + connection beams + packet animations -->
        <svg class="netmap-svg" id="netmap-svg" aria-hidden="true">
          <defs>
            <!-- Grid pattern -->
            <pattern id="nm-grid" width="32" height="32" patternUnits="userSpaceOnUse">
              <path d="M 32 0 L 0 0 0 32" fill="none" stroke="rgba(203,166,247,0.04)" stroke-width="1"/>
            </pattern>
            <!-- Glow filters per colour -->
            <filter id="glow-wan"    x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            <filter id="glow-mauve"  x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="4" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            <filter id="glow-sap"    x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            <filter id="glow-green"  x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            <filter id="glow-gold"   x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            <filter id="glow-red"    x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="3" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            <!-- Soft node halo -->
            <filter id="node-halo" x="-60%" y="-60%" width="220%" height="220%">
              <feGaussianBlur stdDeviation="8" result="b"/>
              <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <!-- Grid background rect -->
          <rect width="100%" height="100%" fill="url(#nm-grid)"/>
          <!-- Lines group (redrawn by JS) -->
          <g id="nm-lines"></g>
          <!-- Packets group (animated by JS) -->
          <g id="nm-packets"></g>
        </svg>

        <!-- ── Tier 1 : Internet ── -->
        <div class="nm-node nm-tier1 nm-internet" id="nm-internet"
             data-id="internet" data-ip="WAN" data-role="Internet / WAN"
             data-services="Cloudflare · ISP uplink · DDoS protection">
          <div class="nm-node-glow"></div>
          <svg class="nm-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          <div class="nm-label">The Internet</div>
          <div class="nm-ip">WAN</div>
          <span class="nm-badge" style="--nm-c:#74c7ec">WAN</span>
          <span class="nm-dot" id="dot-internet"></span>
        </div>

        <!-- ── Tier 2 : Router ── -->
        <div class="nm-node nm-tier2 nm-router" id="nm-mikrotik"
             data-id="mikrotik" data-ip="10.0.10.1" data-role="Router · Firewall"
             data-services="RouterOS · DHCP · DNS · VLANs · Firewall · CrowdSec">
          <div class="nm-node-glow"></div>
          <svg class="nm-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="8" width="20" height="8" rx="2"/><path d="M6 12h.01M10 12h.01M14 12h4"/><path d="M18 8V6a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v2"/><path d="M6 16v2a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-2"/>
          </svg>
          <div class="nm-label">MikroTik</div>
          <div class="nm-ip">10.0.10.1</div>
          <span class="nm-badge" style="--nm-c:#fab387">ROUTER</span>
          <span class="nm-dot" id="dot-mikrotik"></span>
        </div>

        <!-- ── Tier 3 : k3s cluster group ── -->
        <div class="nm-group nm-group-k3s" id="nm-group-k3s">
          <div class="nm-group-label">
            <svg viewBox="0 0 16 16" fill="none" width="10" height="10" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="4" r="2"/><circle cx="3" cy="12" r="2"/><circle cx="13" cy="12" r="2"/><path d="M8 6v2M8 8L3 10M8 8l5 2"/></svg>
            k3s Cluster · 10.0.10.0/24
          </div>
          <div class="nm-group-inner">
            <div class="nm-node nm-k3s nm-master" id="nm-tywin"
                 data-id="tywin" data-ip="10.0.10.11" data-role="k3s Control-plane"
                 data-services="Traefik · Authentik · Flux · cert-manager · MetalLB">
              <div class="nm-node-glow"></div>
              <svg class="nm-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><circle cx="12" cy="10" r="2"/>
              </svg>
              <div class="nm-label">Tywin</div>
              <div class="nm-ip">10.0.10.11</div>
              <span class="nm-badge" style="--nm-c:#cba6f7">MASTER</span>
              <span class="nm-dot" id="dot-tywin"></span>
            </div>
            <div class="nm-node nm-k3s nm-worker" id="nm-jaime"
                 data-id="jaime" data-ip="10.0.10.12" data-role="k3s Worker"
                 data-services="Prometheus · Grafana · Loki · Alertmanager">
              <div class="nm-node-glow"></div>
              <svg class="nm-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
              </svg>
              <div class="nm-label">Jaime</div>
              <div class="nm-ip">10.0.10.12</div>
              <span class="nm-badge" style="--nm-c:#cba6f7">WORKER</span>
              <span class="nm-dot" id="dot-jaime"></span>
            </div>
            <div class="nm-node nm-k3s nm-worker" id="nm-tyrion"
                 data-id="tyrion" data-ip="10.0.10.13" data-role="k3s Worker"
                 data-services="CrowdSec · SOPS · Velero · Longhorn">
              <div class="nm-node-glow"></div>
              <svg class="nm-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
              </svg>
              <div class="nm-label">Tyrion</div>
              <div class="nm-ip">10.0.10.13</div>
              <span class="nm-badge" style="--nm-c:#cba6f7">WORKER</span>
              <span class="nm-dot" id="dot-tyrion"></span>
            </div>
          </div>
        </div>

        <!-- ── Tier 4 : Edge nodes ── -->
        <div class="nm-node nm-edge nm-docker" id="nm-bronn"
             data-id="bronn" data-ip="10.0.10.20" data-role="Docker Host"
             data-services="Ollama (LLM) · Open WebUI · Docker Compose">
          <div class="nm-node-glow"></div>
          <svg class="nm-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 12.5a9.5 9.5 0 1 1-19 0 9.5 9.5 0 0 1 19 0z"/><path d="M2.5 12.5h19M12 2.5c-2.5 3-4 5.5-4 10s1.5 7 4 10M12 2.5c2.5 3 4 5.5 4 10s-1.5 7-4 10"/>
          </svg>
          <div class="nm-label">Bronn</div>
          <div class="nm-ip">10.0.10.20</div>
          <span class="nm-badge" style="--nm-c:#74c7ec">DOCKER</span>
          <span class="nm-dot" id="dot-bronn"></span>
        </div>

        <div class="nm-node nm-edge nm-control" id="nm-varys"
             data-id="varys" data-ip="10.0.10.9" data-role="Control Node · CI"
             data-services="GitHub Actions runner · SSH bastion · age keys">
          <div class="nm-node-glow"></div>
          <svg class="nm-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
          </svg>
          <div class="nm-label">Varys</div>
          <div class="nm-ip">10.0.10.9</div>
          <span class="nm-badge" style="--nm-c:#a6e3a1">CI / OPS</span>
          <span class="nm-dot" id="dot-varys"></span>
        </div>

        <div class="nm-node nm-edge nm-storage" id="nm-ned"
             data-id="ned" data-ip="10.0.10.80" data-role="NAS · Storage"
             data-services="TrueNAS SCALE · ZFS · NFS · 8TB + 4TB SAS">
          <div class="nm-node-glow"></div>
          <svg class="nm-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/>
          </svg>
          <div class="nm-label">Ned</div>
          <div class="nm-ip">10.0.10.80</div>
          <span class="nm-badge" style="--nm-c:#e6b450">STORAGE</span>
          <span class="nm-dot" id="dot-ned"></span>
        </div>

        <div class="nm-node nm-edge nm-pi" id="nm-bran"
             data-id="bran" data-ip="10.0.10.9" data-role="RPi 3B+ · DNS"
             data-services="Pi-hole · Unbound · recursive DNS · ad-blocking">
          <div class="nm-node-glow"></div>
          <svg class="nm-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path d="M12 6v6l4 2"/>
          </svg>
          <div class="nm-label">Bran</div>
          <div class="nm-ip">10.0.10.9</div>
          <span class="nm-badge" style="--nm-c:#f38ba8">RPi DNS</span>
          <span class="nm-dot" id="dot-bran"></span>
        </div>

        <!-- VLAN legend -->
        <div class="nm-legend">
          <div class="nm-legend-item" style="--lc:#cba6f7"><span class="nm-legend-pip"></span>LAN · 10.0.10.0/24</div>
          <div class="nm-legend-item" style="--lc:#74c7ec"><span class="nm-legend-pip"></span>MGMT · 10.0.20.0/24</div>
          <div class="nm-legend-item" style="--lc:#fab387"><span class="nm-legend-pip"></span>WAN uplink</div>
        </div>

        <!-- Tooltip panel -->
        <div class="nm-tooltip" id="nm-tooltip" role="tooltip" aria-live="polite">
          <div class="nm-tt-header">
            <span class="nm-tt-name" id="nm-tt-name"></span>
            <span class="nm-tt-ip"   id="nm-tt-ip"></span>
          </div>
          <div class="nm-tt-role" id="nm-tt-role"></div>
          <div class="nm-tt-divider"></div>
          <div class="nm-tt-services" id="nm-tt-services"></div>
        </div>
      </div>
    </section>

    <!-- ── GitOps ── -->
    <section class="section fade-up" style="animation-delay:0.20s">
      <h2 class="section-label">GitOps — Flux Kustomizations</h2>
      <div id="flux-section">
        <div class="skeleton" style="height:220px; border-radius:12px"></div>
      </div>
    </section>

    <!-- ── Backups ── -->
    <section class="section fade-up" style="animation-delay:0.23s">
      <h2 class="section-label">Backups</h2>
      <div class="cards-grid" id="backup-cards">
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
      </div>
    </section>

  </div>

</Layout>

<style is:global>
  .page-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
    position: relative;
    z-index: 1;
  }

  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-ok);
    justify-content: flex-end;
  }

  .uptime-counter {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.75rem;
    background: color-mix(in srgb, var(--color-ok) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-ok) 25%, transparent);
    border-radius: 8px;
    padding: 0.4rem 0.9rem;
  }

  .uptime-label {
    font-size: 0.68rem;
    color: var(--color-ok);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .uptime-value {
    font-size: 0.82rem;
    color: var(--color-heading);
    font-weight: 600;
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }

  .section { margin-bottom: 5.5rem; }

  .section-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-subtle);
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-label::before {
    content: '';
    display: block;
    width: 3px;
    height: 0.85rem;
    background: linear-gradient(to bottom, #fab387, #cba6f7);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .nodes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }

  .node-card {
    background: var(--color-surface);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 1.25rem 1.5rem 1.5rem;
    border-left-width: 3px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.06);
    transition: box-shadow 0.25s, transform 0.25s;
    position: relative;
    overflow: hidden;
  }

  .node-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 60px;
    border-radius: 16px 16px 0 0;
    pointer-events: none;
    opacity: 0.08;
  }
  .node-card.ok::after   { background: radial-gradient(ellipse at 50% 0%, var(--color-ok), transparent 70%); }
  .node-card.warn::after { background: radial-gradient(ellipse at 50% 0%, var(--color-warn), transparent 70%); }
  .node-card.crit::after { background: radial-gradient(ellipse at 50% 0%, var(--color-crit), transparent 70%); }

  .node-card:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.09);
    transform: translateY(-2px);
  }

  .node-card.ok      { border-left-color: var(--color-ok); }
  .node-card.warn    { border-left-color: var(--color-warn); }
  .node-card.crit    { border-left-color: var(--color-crit); }
  .node-card.unknown { border-left-color: var(--color-muted); }

  /* Ring scroll-in animation */
  .node-status-ring circle.arc {
    stroke-dasharray: 0 125.7;
    transition: stroke-dasharray 0.9s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .node-status-ring circle.arc.ring-revealed {
    /* dasharray set inline by JS once revealed */
  }

  @keyframes ring-pulse {
    0%, 100% { opacity: 1; filter: drop-shadow(0 0 3px var(--color-ok)); }
    50%       { opacity: 0.7; filter: drop-shadow(0 0 8px var(--color-ok)); }
  }
  .node-card.ok .node-status-ring circle.arc.ring-revealed {
    animation: ring-pulse 2.4s ease-in-out infinite;
  }

  .node-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .node-identity { display: flex; flex-direction: column; gap: 0.35rem; }
  .node-identity-row { display: flex; align-items: baseline; gap: 0.5rem; }

  .node-field-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    flex-shrink: 0;
    min-width: 2.4rem;
  }

  .node-field-value {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.2;
  }

  .node-field-value.role {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-subtle);
  }

  .node-status-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    flex-shrink: 0;
  }

  .node-status-ring { width: 52px; height: 52px; }

  .node-ring-label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--color-subtle);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .node-metrics-4 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 0.4rem;
  }

  @media (max-width: 440px) {
    .node-metrics-4 { grid-template-columns: 1fr 1fr; }
  }

  .metric {
    background: var(--color-overlay);
    border: 1px solid var(--color-muted);
    border-radius: 8px;
    padding: 0.6rem 0.5rem 0.5rem;
    overflow: hidden;
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-peach);
    display: block;
    text-align: center;
  }

  .metric-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-subtle);
    display: block;
    text-align: center;
    margin-top: 0.2rem;
    margin-bottom: 0.4rem;
  }

  .metric-bar-track {
    height: 3px;
    background: rgba(255,255,255,0.07);
    border-radius: 2px;
    overflow: hidden;
    margin-top: 0.35rem;
  }

  .metric-bar-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--color-peach);
    transition: width 0.4s ease;
  }

  .metric-bar-fill.warn { background: var(--color-warn); }
  .metric-bar-fill.crit { background: var(--color-crit); }

  .flux-table {
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.05);
  }

  .flux-row {
    display: grid;
    grid-template-columns: 1.8fr 120px 110px 100px;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    align-items: center;
    gap: 1rem;
    transition: background 0.15s;
  }

  .flux-row:last-child { border-bottom: none; }
  .flux-row:not(.header):hover { background: rgba(255,255,255,0.03); }

  .flux-row.header {
    background: rgba(255,255,255,0.04);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-subtle);
  }

  .flux-row.crit-row {
    background: color-mix(in srgb, var(--color-crit) 7%, transparent);
    border-left: 3px solid var(--color-crit);
    padding-left: calc(1.25rem - 3px);
  }
  .flux-row.crit-row:hover {
    background: color-mix(in srgb, var(--color-crit) 12%, transparent);
  }

  .flux-summary {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .flux-ratio-bar {
    flex: 1;
    min-width: 140px;
    max-width: 300px;
    height: 6px;
    background: var(--color-overlay);
    border-radius: 3px;
    overflow: hidden;
    display: flex;
  }
  .flux-ratio-bar-ok   { height: 100%; background: var(--color-ok);   transition: width 0.6s ease; }
  .flux-ratio-bar-crit { height: 100%; background: var(--color-crit); transition: width 0.6s ease; }

  .flux-ratio-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-subtle);
    white-space: nowrap;
  }

  .flux-name-cell { display: flex; align-items: center; min-width: 0; overflow: hidden; }
  .flux-name-icon {
    display: inline-block;
    width: 1rem;
    text-align: center;
    margin-right: 0.4rem;
    flex-shrink: 0;
    font-size: 0.85rem;
  }
  .flux-name-icon.ok   { color: var(--color-ok); }
  .flux-name-icon.crit { color: var(--color-crit); }
  .flux-name-text {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-heading);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .badge.ok      { background: color-mix(in srgb, var(--color-ok)     18%, transparent); color: var(--color-ok); }
  .badge.warn    { background: color-mix(in srgb, var(--color-warn)   18%, transparent); color: var(--color-warn); }
  .badge.crit    { background: color-mix(in srgb, var(--color-crit)   18%, transparent); color: var(--color-crit); }
  .badge.unknown { background: color-mix(in srgb, var(--color-subtle) 18%, transparent); color: var(--color-subtle); }

  .skeleton {
    background: linear-gradient(
      90deg,
      var(--color-surface) 25%,
      var(--color-overlay) 50%,
      var(--color-surface) 75%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
