---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Status" description="Live cluster health, node metrics, and service uptime.">

  <div class="page-wrap">

    <!-- ── Header ── -->
    <div class="page-header fade-up">
      <div>
        <p class="mono" style="color:var(--color-peach); margin-bottom:0.25rem">~/status</p>
        <h1 style="margin:0">Cluster Status</h1>
        <!-- Live cluster uptime counter -->
        <div class="uptime-counter" id="uptime-counter">
          <span class="uptime-label mono">cluster uptime</span>
          <span class="uptime-value mono" id="uptime-value">—</span>
        </div>
      </div>
      <div style="text-align:right">
        <div class="mono live-badge">
          <span class="status-dot ok"></span>
          Live · auto-refresh 30s
        </div>
        <div class="mono" id="last-updated" style="color:var(--color-subtle); margin-top:0.25rem">—</div>
      </div>
    </div>

    <!-- ── Security ── -->
    <section class="section fade-up" style="animation-delay:0.02s">
      <h2 class="section-label">Security</h2>
      <div id="cve-banner">
        <div class="skeleton" style="height:56px; border-radius:10px"></div>
      </div>
    </section>

    <!-- ── Network ── -->
    <section class="section fade-up" style="animation-delay:0.05s">
      <h2 class="section-label">Network</h2>
      <div class="cards-grid" id="network-cards" style="margin-bottom:1.5rem">
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
      </div>
      <div id="offenders-section">
        <div class="skeleton" style="height:180px;border-radius:12px"></div>
      </div>
    </section>

    <!-- ── Infrastructure ── -->
    <section class="section fade-up" style="animation-delay:0.1s">
      <h2 class="section-label">Infrastructure</h2>
      <div id="infra-deploy" style="margin-bottom:1rem">
        <div class="skeleton" style="height:56px;border-radius:10px"></div>
      </div>
      <div class="cards-grid" id="infra-cards">
        <div class="card skeleton" style="height:120px"></div>
        <div class="card skeleton" style="height:120px"></div>
        <div class="card skeleton" style="height:120px"></div>
        <div class="card skeleton" style="height:120px"></div>
      </div>
    </section>

    <!-- ── Storage ── -->
    <section class="section fade-up" style="animation-delay:0.13s">
      <h2 class="section-label">Storage</h2>
      <div id="storage-grid">
        <div class="skeleton" style="height:120px;border-radius:12px"></div>
      </div>
    </section>

    <!-- ── At a Glance ── -->
    <section class="section fade-up" style="animation-delay:0.15s">
      <h2 class="section-label">At a Glance</h2>
      <div class="cards-grid" id="glance-cards">
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
      </div>
    </section>

    <!-- ── Nodes ── -->
    <section class="section fade-up" style="animation-delay:0.18s">
      <h2 class="section-label">Nodes</h2>
      <div class="nodes-grid" id="nodes-grid">
        <div class="skeleton" style="height:160px; border-radius:12px"></div>
        <div class="skeleton" style="height:160px; border-radius:12px"></div>
        <div class="skeleton" style="height:160px; border-radius:12px"></div>
      </div>
    </section>

    <!-- ── Network Topology Map ── -->
    <section class="section fade-up" style="animation-delay:0.18s">
      <h2 class="section-label">Network Topology</h2>

      <div class="netmap-wrap">
        <!-- SVG lines layer -->
        <svg class="netmap-svg" id="netmap-svg" aria-hidden="true"></svg>

        <!-- Internet / WAN -->
        <div class="nm-node nm-internet" id="nm-internet" data-id="internet" data-ip="WAN" data-role="Internet" data-services="Cloudflare · ISP uplink">
          <div class="nm-icon">🌐</div>
          <div class="nm-label">The Internet</div>
          <div class="nm-ip">WAN</div>
          <span class="nm-dot" id="dot-internet"></span>
        </div>

        <!-- MikroTik router -->
        <div class="nm-node nm-router" id="nm-mikrotik" data-id="mikrotik" data-ip="10.0.10.1" data-role="Router · Firewall" data-services="RouterOS · DHCP · DNS · VLANs · Firewall · CrowdSec">
          <div class="nm-icon">🔀</div>
          <div class="nm-label">MikroTik</div>
          <div class="nm-ip">10.0.10.1</div>
          <span class="nm-badge" style="--nm-c:#fab387">ROUTER</span>
          <span class="nm-dot" id="dot-mikrotik"></span>
        </div>

        <!-- k3s cluster group -->
        <div class="nm-group nm-group-k3s">
          <div class="nm-group-label">k3s Cluster · 10.0.10.0/24</div>
          <div class="nm-group-nodes">
            <div class="nm-node nm-k3s nm-master" id="nm-tywin" data-id="tywin" data-ip="10.0.10.11" data-role="k3s Control-plane" data-services="Traefik · Authentik · Flux · cert-manager · MetalLB">
              <div class="nm-icon">🖥</div>
              <div class="nm-label">Tywin</div>
              <div class="nm-ip">10.0.10.11</div>
              <span class="nm-badge" style="--nm-c:#cba6f7">MASTER</span>
              <span class="nm-dot" id="dot-tywin"></span>
            </div>
            <div class="nm-node nm-k3s nm-worker" id="nm-jaime" data-id="jaime" data-ip="10.0.10.12" data-role="k3s Worker" data-services="Prometheus · Grafana · Loki · Alertmanager">
              <div class="nm-icon">🖥</div>
              <div class="nm-label">Jaime</div>
              <div class="nm-ip">10.0.10.12</div>
              <span class="nm-badge" style="--nm-c:#cba6f7">WORKER</span>
              <span class="nm-dot" id="dot-jaime"></span>
            </div>
            <div class="nm-node nm-k3s nm-worker" id="nm-tyrion" data-id="tyrion" data-ip="10.0.10.13" data-role="k3s Worker" data-services="CrowdSec · SOPS · Velero · Longhorn">
              <div class="nm-icon">🖥</div>
              <div class="nm-label">Tyrion</div>
              <div class="nm-ip">10.0.10.13</div>
              <span class="nm-badge" style="--nm-c:#cba6f7">WORKER</span>
              <span class="nm-dot" id="dot-tyrion"></span>
            </div>
          </div>
        </div>

        <!-- Supporting nodes row -->
        <div class="nm-node nm-docker" id="nm-bronn" data-id="bronn" data-ip="10.0.10.20" data-role="Docker Host" data-services="Ollama (LLM) · Open WebUI · Docker Compose">
          <div class="nm-icon">🐳</div>
          <div class="nm-label">Bronn</div>
          <div class="nm-ip">10.0.10.20</div>
          <span class="nm-badge" style="--nm-c:#74c7ec">DOCKER</span>
          <span class="nm-dot" id="dot-bronn"></span>
        </div>

        <div class="nm-node nm-control" id="nm-varys" data-id="varys" data-ip="10.0.10.9" data-role="Control Node · CI" data-services="GitHub Actions runner · SSH bastion · age keys">
          <div class="nm-icon">⚙️</div>
          <div class="nm-label">Varys</div>
          <div class="nm-ip">10.0.10.9</div>
          <span class="nm-badge" style="--nm-c:#a6e3a1">CI / OPS</span>
          <span class="nm-dot" id="dot-varys"></span>
        </div>

        <div class="nm-node nm-storage" id="nm-ned" data-id="ned" data-ip="10.0.10.80" data-role="NAS · Storage" data-services="TrueNAS SCALE · ZFS · NFS · 8TB + 4TB SAS">
          <div class="nm-icon">🗄</div>
          <div class="nm-label">Ned</div>
          <div class="nm-ip">10.0.10.80</div>
          <span class="nm-badge" style="--nm-c:#e6b450">STORAGE</span>
          <span class="nm-dot" id="dot-ned"></span>
        </div>

        <div class="nm-node nm-pi" id="nm-bran" data-id="bran" data-ip="10.0.10.9" data-role="RPi 3B+ · DNS" data-services="Pi-hole · Unbound · recursive DNS · ad-blocking">
          <div class="nm-icon">🍓</div>
          <div class="nm-label">Bran</div>
          <div class="nm-ip">10.0.10.9</div>
          <span class="nm-badge" style="--nm-c:#f38ba8">RPi DNS</span>
          <span class="nm-dot" id="dot-bran"></span>
        </div>

        <!-- VLAN legend -->
        <div class="nm-vlan-legend">
          <div class="nm-vlan-item" style="--vl-c:#cba6f7">
            <span class="nm-vlan-dot"></span>
            <span>LAN · 10.0.10.0/24</span>
          </div>
          <div class="nm-vlan-item" style="--vl-c:#74c7ec">
            <span class="nm-vlan-dot"></span>
            <span>MGMT · 10.0.20.0/24</span>
          </div>
          <div class="nm-vlan-item" style="--vl-c:#fab387">
            <span class="nm-vlan-dot"></span>
            <span>WAN uplink</span>
          </div>
        </div>

        <!-- Hover tooltip -->
        <div class="nm-tooltip" id="nm-tooltip">
          <div class="nm-tooltip-name" id="nm-tt-name"></div>
          <div class="nm-tooltip-ip" id="nm-tt-ip"></div>
          <div class="nm-tooltip-role" id="nm-tt-role"></div>
          <div class="nm-tooltip-services" id="nm-tt-services"></div>
        </div>
      </div>
    </section>

    <!-- ── GitOps ── -->
    <section class="section fade-up" style="animation-delay:0.20s">
      <h2 class="section-label">GitOps — Flux Kustomizations</h2>
      <div id="flux-section">
        <div class="skeleton" style="height:220px; border-radius:12px"></div>
      </div>
    </section>

    <!-- ── Backups ── -->
    <section class="section fade-up" style="animation-delay:0.23s">
      <h2 class="section-label">Backups</h2>
      <div class="cards-grid" id="backup-cards">
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
        <div class="card skeleton" style="height:100px"></div>
      </div>
    </section>

  </div>

</Layout>

<style is:global>
  .page-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
    position: relative;
    z-index: 1;
  }

  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-ok);
    justify-content: flex-end;
  }

  .uptime-counter {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 0.75rem;
    background: color-mix(in srgb, var(--color-ok) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-ok) 25%, transparent);
    border-radius: 8px;
    padding: 0.4rem 0.9rem;
  }

  .uptime-label {
    font-size: 0.68rem;
    color: var(--color-ok);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .uptime-value {
    font-size: 0.82rem;
    color: var(--color-heading);
    font-weight: 600;
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }

  .section { margin-bottom: 5.5rem; }

  .section-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-subtle);
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-label::before {
    content: '';
    display: block;
    width: 3px;
    height: 0.85rem;
    background: linear-gradient(to bottom, #fab387, #cba6f7);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .nodes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }

  .node-card {
    background: var(--color-surface);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 1.25rem 1.5rem 1.5rem;
    border-left-width: 3px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.06);
    transition: box-shadow 0.25s, transform 0.25s;
    position: relative;
    overflow: hidden;
  }

  .node-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 60px;
    border-radius: 16px 16px 0 0;
    pointer-events: none;
    opacity: 0.08;
  }
  .node-card.ok::after   { background: radial-gradient(ellipse at 50% 0%, var(--color-ok), transparent 70%); }
  .node-card.warn::after { background: radial-gradient(ellipse at 50% 0%, var(--color-warn), transparent 70%); }
  .node-card.crit::after { background: radial-gradient(ellipse at 50% 0%, var(--color-crit), transparent 70%); }

  .node-card:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.09);
    transform: translateY(-2px);
  }

  .node-card.ok      { border-left-color: var(--color-ok); }
  .node-card.warn    { border-left-color: var(--color-warn); }
  .node-card.crit    { border-left-color: var(--color-crit); }
  .node-card.unknown { border-left-color: var(--color-muted); }

  /* Ring scroll-in animation */
  .node-status-ring circle.arc {
    stroke-dasharray: 0 125.7;
    transition: stroke-dasharray 0.9s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .node-status-ring circle.arc.ring-revealed {
    /* dasharray set inline by JS once revealed */
  }

  @keyframes ring-pulse {
    0%, 100% { opacity: 1; filter: drop-shadow(0 0 3px var(--color-ok)); }
    50%       { opacity: 0.7; filter: drop-shadow(0 0 8px var(--color-ok)); }
  }
  .node-card.ok .node-status-ring circle.arc.ring-revealed {
    animation: ring-pulse 2.4s ease-in-out infinite;
  }

  .node-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .node-identity { display: flex; flex-direction: column; gap: 0.35rem; }
  .node-identity-row { display: flex; align-items: baseline; gap: 0.5rem; }

  .node-field-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    flex-shrink: 0;
    min-width: 2.4rem;
  }

  .node-field-value {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.2;
  }

  .node-field-value.role {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-subtle);
  }

  .node-status-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    flex-shrink: 0;
  }

  .node-status-ring { width: 52px; height: 52px; }

  .node-ring-label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--color-subtle);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .node-metrics-4 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 0.4rem;
  }

  @media (max-width: 440px) {
    .node-metrics-4 { grid-template-columns: 1fr 1fr; }
  }

  .metric {
    background: var(--color-overlay);
    border: 1px solid var(--color-muted);
    border-radius: 8px;
    padding: 0.6rem 0.5rem 0.5rem;
    overflow: hidden;
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-peach);
    display: block;
    text-align: center;
  }

  .metric-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-subtle);
    display: block;
    text-align: center;
    margin-top: 0.2rem;
    margin-bottom: 0.4rem;
  }

  .metric-bar-track {
    height: 3px;
    background: rgba(255,255,255,0.07);
    border-radius: 2px;
    overflow: hidden;
    margin-top: 0.35rem;
  }

  .metric-bar-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--color-peach);
    transition: width 0.4s ease;
  }

  .metric-bar-fill.warn { background: var(--color-warn); }
  .metric-bar-fill.crit { background: var(--color-crit); }

  .flux-table {
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.05);
  }

  .flux-row {
    display: grid;
    grid-template-columns: 1.8fr 120px 110px 100px;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    align-items: center;
    gap: 1rem;
    transition: background 0.15s;
  }

  .flux-row:last-child { border-bottom: none; }
  .flux-row:not(.header):hover { background: rgba(255,255,255,0.03); }

  .flux-row.header {
    background: rgba(255,255,255,0.04);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-subtle);
  }

  .flux-row.crit-row {
    background: color-mix(in srgb, var(--color-crit) 7%, transparent);
    border-left: 3px solid var(--color-crit);
    padding-left: calc(1.25rem - 3px);
  }
  .flux-row.crit-row:hover {
    background: color-mix(in srgb, var(--color-crit) 12%, transparent);
  }

  .flux-summary {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .flux-ratio-bar {
    flex: 1;
    min-width: 140px;
    max-width: 300px;
    height: 6px;
    background: var(--color-overlay);
    border-radius: 3px;
    overflow: hidden;
    display: flex;
  }
  .flux-ratio-bar-ok   { height: 100%; background: var(--color-ok);   transition: width 0.6s ease; }
  .flux-ratio-bar-crit { height: 100%; background: var(--color-crit); transition: width 0.6s ease; }

  .flux-ratio-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-subtle);
    white-space: nowrap;
  }

  .flux-name-cell { display: flex; align-items: center; min-width: 0; overflow: hidden; }
  .flux-name-icon {
    display: inline-block;
    width: 1rem;
    text-align: center;
    margin-right: 0.4rem;
    flex-shrink: 0;
    font-size: 0.85rem;
  }
  .flux-name-icon.ok   { color: var(--color-ok); }
  .flux-name-icon.crit { color: var(--color-crit); }
  .flux-name-text {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-heading);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .badge.ok      { background: color-mix(in srgb, var(--color-ok)     18%, transparent); color: var(--color-ok); }
  .badge.warn    { background: color-mix(in srgb, var(--color-warn)   18%, transparent); color: var(--color-warn); }
  .badge.crit    { background: color-mix(in srgb, var(--color-crit)   18%, transparent); color: var(--color-crit); }
  .badge.unknown { background: color-mix(in srgb, var(--color-subtle) 18%, transparent); color: var(--color-subtle); }

  .skeleton {
    background: linear-gradient(
      90deg,
      var(--color-surface) 25%,
      var(--color-overlay) 50%,
      var(--color-surface) 75%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Deploy banner ── */
  .deploy-banner {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 10px;
    padding: 0.875rem 1.25rem;
    font-family: var(--font-mono);
  }

  .deploy-sha {
    font-size: 0.72rem;
    color: var(--color-peach);
    background: color-mix(in srgb, var(--color-peach) 12%, transparent);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .deploy-msg {
    font-size: 0.85rem;
    color: var(--color-heading);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
  }

  .deploy-age {
    font-size: 0.75rem;
    color: var(--color-subtle);
    flex-shrink: 0;
  }

  /* ── Storage pools ── */
  .storage-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 860px) {
    .storage-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .storage-grid { grid-template-columns: 1fr; }
  }

  .storage-card {
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 14px;
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .storage-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--color-ok);
    border-radius: 14px 14px 0 0;
  }
  .storage-card.warn::before { background: var(--color-warn); }
  .storage-card.crit::before { background: var(--color-crit); }

  .storage-pool-name {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .storage-health {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    margin-bottom: 1.25rem;
  }

  .storage-donut-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .storage-donut {
    flex-shrink: 0;
  }

  .storage-legend {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .storage-legend-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .storage-legend-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    margin-right: 0.4rem;
    flex-shrink: 0;
  }

  .storage-bar-track {
    height: 6px;
    background: var(--color-overlay);
    border-radius: 3px;
    overflow: hidden;
  }

  .storage-bar-fill {
    height: 100%;
    border-radius: 3px;
    background: var(--color-ok);
    transition: width 0.7s ease;
  }
  .storage-bar-fill.warn { background: var(--color-warn); }
  .storage-bar-fill.crit { background: var(--color-crit); }

  @media (max-width: 640px) {
    .flux-row { grid-template-columns: 1fr 90px; }
    .flux-row > *:nth-child(2),
    .flux-row > *:nth-child(3) { display: none; }
  }

  /* ── Network Diagram ── */
  .netmap-wrap {
    position: relative;
    background: color-mix(in srgb, var(--color-mantle) 90%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-muted) 50%, transparent);
    border-top: 1px solid color-mix(in srgb, white 7%, transparent);
    border-radius: 20px;
    padding: 2rem;
    min-height: 520px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    overflow: hidden;
  }

  .netmap-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: visible;
    z-index: 0;
  }

  /* Node base */
  .nm-node {
    position: absolute;
    background: color-mix(in srgb, var(--color-surface) 85%, transparent);
    backdrop-filter: blur(8px);
    border: 1px solid color-mix(in srgb, var(--color-muted) 70%, transparent);
    border-top: 1px solid color-mix(in srgb, white 10%, transparent);
    border-radius: 12px;
    padding: 0.7rem 0.9rem 0.6rem;
    cursor: pointer;
    z-index: 2;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    text-align: center;
    min-width: 110px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .nm-node:hover {
    border-color: color-mix(in srgb, var(--nm-c, var(--color-peach)) 60%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--nm-c, var(--color-peach)) 25%, transparent),
                0 8px 32px rgba(0,0,0,0.4),
                0 0 20px color-mix(in srgb, var(--nm-c, var(--color-peach)) 12%, transparent);
    transform: translateY(-3px);
    z-index: 5;
  }

  .nm-icon {
    font-size: 1.4rem;
    line-height: 1;
    margin-bottom: 0.1rem;
  }

  .nm-label {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: 0.01em;
  }

  .nm-ip {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--color-subtle);
    letter-spacing: 0.04em;
  }

  .nm-badge {
    display: inline-block;
    margin-top: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.12rem 0.45rem;
    border-radius: 3px;
    color: var(--nm-c, var(--color-peach));
    background: color-mix(in srgb, var(--nm-c, var(--color-peach)) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--nm-c, var(--color-peach)) 30%, transparent);
  }

  .nm-dot {
    position: absolute;
    top: 0.45rem; right: 0.5rem;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--color-ok);
    box-shadow: 0 0 5px var(--color-ok);
    animation: pulse-ok 2.5s ease-in-out infinite;
  }
  .nm-dot.warn { background: var(--color-warn); box-shadow: 0 0 5px var(--color-warn); animation: none; }
  .nm-dot.crit { background: var(--color-crit); box-shadow: 0 0 5px var(--color-crit); animation: none; }

  /* Node positioning — absolute layout matching a real network diagram */
  .nm-internet { left: 50%; top: 1.5rem; transform: translateX(-50%); --nm-c: #74c7ec; }
  .nm-router   { left: 50%; top: 9rem;   transform: translateX(-50%); --nm-c: #fab387; min-width: 130px; }

  /* k3s group box */
  .nm-group-k3s {
    position: absolute;
    left: 50%;
    top: 18rem;
    transform: translateX(-50%);
    border: 1px dashed color-mix(in srgb, var(--color-mauve) 35%, transparent);
    border-radius: 16px;
    padding: 2.2rem 1.25rem 1.25rem;
    z-index: 1;
    min-width: 380px;
    background: color-mix(in srgb, var(--color-mauve) 4%, transparent);
  }

  .nm-group-label {
    position: absolute;
    top: 0.55rem; left: 1rem;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-mauve) 70%, var(--color-subtle));
  }

  .nm-group-nodes {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  /* k3s nodes are relative inside the group */
  .nm-k3s {
    position: relative !important;
    transform: none !important;
    left: auto !important;
    top: auto !important;
    min-width: 105px;
    --nm-c: #cba6f7;
  }

  .nm-k3s:hover {
    transform: translateY(-3px) !important;
  }

  /* Supporting nodes row */
  .nm-docker  { --nm-c: #74c7ec; left: 6%;   bottom: 2.5rem; }
  .nm-control { --nm-c: #a6e3a1; left: 27%;  bottom: 2.5rem; }
  .nm-storage { --nm-c: #e6b450; right: 22%; bottom: 2.5rem; }
  .nm-pi      { --nm-c: #f38ba8; right: 4%;  bottom: 2.5rem; }

  /* VLAN legend */
  .nm-vlan-legend {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 1.5rem;
    z-index: 3;
  }

  .nm-vlan-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-subtle);
  }

  .nm-vlan-dot {
    width: 8px; height: 8px;
    border-radius: 2px;
    background: var(--vl-c, var(--color-muted));
    flex-shrink: 0;
  }

  /* Tooltip */
  .nm-tooltip {
    position: absolute;
    background: var(--color-crust);
    border: 1px solid var(--color-muted);
    border-radius: 10px;
    padding: 0.8rem 1rem;
    min-width: 190px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
    z-index: 20;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
  }
  .nm-tooltip.visible { opacity: 1; }
  .nm-tooltip-name {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: 0.1rem;
  }
  .nm-tooltip-ip {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-peach);
    margin-bottom: 0.4rem;
  }
  .nm-tooltip-role {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-subtle);
    margin-bottom: 0.5rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-muted);
  }
  .nm-tooltip-services {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .netmap-wrap { min-height: 700px; }
    .nm-group-k3s { min-width: 300px; }
    .nm-docker  { left: 2%;   bottom: 1.5rem; }
    .nm-control { left: 28%;  bottom: 1.5rem; }
    .nm-storage { right: 18%; bottom: 1.5rem; }
    .nm-pi      { right: 2%;  bottom: 1.5rem; }
    .nm-vlan-legend { flex-wrap: wrap; justify-content: center; gap: 0.75rem; }
  }
</style>

<script>
  async function loadStatus() {
    try {
      const res = await fetch('/data/live.json?t=' + Date.now());
      if (!res.ok) throw new Error('no data');
      const data = await res.json();

      // Last updated timestamp
      if (data.updated) {
        const el = document.getElementById('last-updated');
        if (el) {
          const d = new Date(data.updated);
          el.textContent = 'Data as of ' + d.toLocaleTimeString('en-ZA', {
            timeZone: 'Africa/Johannesburg',
            hour: '2-digit', minute: '2-digit'
          }) + ' SAST';
        }
      }

      // Glance cards — only Workloads + Flux (backups live in their own section)
      const glance = document.getElementById('glance-cards');
      if (glance && data.cards) {
        const glanceLabels = ['workloads', 'flux'];
        glance.innerHTML = data.cards.filter((c: any) => glanceLabels.includes(c.label.toLowerCase())).map((c: any) => {
          // Extract leading number for count-up (e.g. "61/64" → 61, "19/19 synced" → 19)
          const numMatch = (c.value ?? '').match(/^(\d+)/);
          const countAttr = numMatch ? `data-count-to="${numMatch[1]}" data-count-suffix="${c.value.slice(numMatch[1].length)}"` : '';
          return `
          <div class="card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
              <span class="mono" style="color:var(--color-subtle);font-size:0.72rem;text-transform:uppercase;letter-spacing:0.06em">${c.label}</span>
              <span class="status-dot ${c.status}"></span>
            </div>
            <div style="font-size:1.4rem;font-weight:700;color:var(--color-heading);font-family:var(--font-mono);margin-bottom:0.25rem"
                 ${countAttr}>0</div>
            <div class="mono" style="font-size:0.85rem">${c.sub ?? ''}</div>
          </div>`;
        }).join('');
      }

      // Nodes
      const nodesGrid = document.getElementById('nodes-grid');
      if (nodesGrid && data.nodes) {
        const parsePct = (s: string) => { const m = s?.match(/(\d+)/); return m ? parseInt(m[1]) : null; };
        const barClass = (pct: number | null) => pct == null ? '' : pct >= 85 ? 'crit' : pct >= 70 ? 'warn' : '';
        const metricBar = (val: string, label: string) => {
          const pct = parsePct(val);
          const fill = pct != null ? `<div class="metric-bar-track"><div class="metric-bar-fill ${barClass(pct)}" style="width:${Math.min(pct,100)}%"></div></div>` : '';
          return `<div class="metric">
            <span class="metric-value">${val}</span>
            <span class="metric-label">${label}</span>
            ${fill}
          </div>`;
        };

        const uptimeRing = (status: string) => {
          const color = status === 'ok' ? 'var(--color-ok)' : status === 'warn' ? 'var(--color-warn)' : 'var(--color-crit)';
          const glyph = status === 'ok' ? '✓' : status === 'warn' ? '!' : '✗';
          const label = status === 'ok' ? 'Ready' : status === 'warn' ? 'Degraded' : 'Not Ready';
          // Exact values from mockup: r=20, circ=125.66
          // ok: full ring (125.7 0), warn: ~75% (94.3 31.4), crit: ~25% (31.4 94.3)
          const dash = status === 'ok' ? '125.7 0' : status === 'warn' ? '94.3 31.4' : '31.4 94.3';
          return `<div class="node-status-badge">
            <svg class="node-status-ring" viewBox="0 0 52 52" fill="none">
              <circle cx="26" cy="26" r="20" stroke="rgba(255,255,255,0.06)" stroke-width="4"/>
              <circle class="arc" cx="26" cy="26" r="20" stroke="${color}" stroke-width="4"
                stroke-dasharray="0 125.7" data-dash="${dash}" stroke-dashoffset="31.4"
                stroke-linecap="round"/>
              <text x="26" y="26" text-anchor="middle" dominant-baseline="middle"
                font-family="JetBrains Mono,monospace" font-size="11" font-weight="700"
                fill="${color}">${glyph}</text>
            </svg>
            <div class="node-ring-label">${label}</div>
          </div>`;
        };

        const fourthMetric = (n: any) => {
          const pressures = (n.pressure ?? []).filter((p: string) => !/false/i.test(p));
          const podCap = (n.pods ?? '—/—').split('/')[1] ?? '—';
          if (pressures.length > 0) {
            return `<div class="metric" style="border:1px solid color-mix(in srgb,var(--color-crit) 40%,transparent)">
              <span class="metric-value" style="color:var(--color-crit)">${pressures.length}</span>
              <span class="metric-label" style="color:var(--color-crit)">Pressure</span>
            </div>`;
          }
          return `<div class="metric">
            <span class="metric-value" style="font-size:0.8rem">${podCap}</span>
            <span class="metric-label">Pod Cap</span>
          </div>`;
        };

        nodesGrid.innerHTML = data.nodes.map((n: any) => {
          const alertBanner = n.status === 'crit'
            ? `<div style="margin-top:0.875rem;padding:0.4rem 0.75rem;background:color-mix(in srgb,var(--color-crit) 15%,transparent);border-radius:6px;font-family:var(--font-mono);font-size:0.72rem;color:var(--color-crit)">⚠ Node not ready — check kubelet</div>`
            : '';
          return `
          <div class="node-card ${n.status}">
            <div class="node-header">
              <div class="node-identity">
                <div class="node-identity-row">
                  <span class="node-field-label">Node</span>
                  <span class="node-field-value">${n.name}</span>
                </div>
                <div class="node-identity-row">
                  <span class="node-field-label">Role</span>
                  <span class="node-field-value role">${n.role}</span>
                </div>
              </div>
              ${uptimeRing(n.status)}
            </div>
            <div class="node-metrics-4">
              ${metricBar(n.cpu,    'CPU')}
              ${metricBar(n.memory, 'Memory')}
              <div class="metric">
                <span class="metric-value">${n.pods}</span>
                <span class="metric-label">Pods</span>
              </div>
              ${fourthMetric(n)}
            </div>
            ${alertBanner}
          </div>`;
        }).join('');
      }

      // Infrastructure — Last Deployment
      const deployEl = document.getElementById('infra-deploy');
      if (deployEl && data.last_deploy) {
        const d = data.last_deploy;
        deployEl.innerHTML = `
          <div class="deploy-banner">
            <span class="mono" style="font-size:0.72rem;color:var(--color-subtle);text-transform:uppercase;letter-spacing:0.06em;flex-shrink:0">Last commit</span>
            <span class="deploy-sha">${d.sha}</span>
            <span class="deploy-msg">${d.message}</span>
            <span class="deploy-age">${d.age}</span>
          </div>`;
      }

      // Infrastructure — bran + UPS + Power placeholders
      const infraCards = document.getElementById('infra-cards');
      if (infraCards) {
        const b = data.bran ?? {};
        const tempStatus = b.temp_status ?? 'unknown';
        const tempVal    = b.temp_c != null ? b.temp_c + '°C' : '—';
        const loadVal    = b.load   != null ? b.load.toFixed(2) : '—';
        const memVal     = b.mem_pct != null ? b.mem_pct + '%' : '—';

        infraCards.innerHTML = `
          <div class="card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem">
              <div>
                <span class="mono" style="color:var(--color-subtle);font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em">bran</span>
                <div style="font-size:0.78rem;color:var(--color-subtle);font-family:var(--font-mono);margin-top:0.1rem">RPi 4 · automation runner &amp; site CI</div>
              </div>
              <span class="status-dot ${tempStatus}"></span>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.4rem;margin-top:0.75rem">
              <div class="metric">
                <span class="metric-value" style="font-size:0.85rem">${tempVal}</span>
                <span class="metric-label">Temp</span>
              </div>
              <div class="metric">
                <span class="metric-value" style="font-size:0.85rem">${memVal}</span>
                <span class="metric-label">Mem</span>
              </div>
              <div class="metric">
                <span class="metric-value" style="font-size:0.85rem">${loadVal}</span>
                <span class="metric-label">Load</span>
              </div>
            </div>
          </div>
          <div class="card" style="opacity:0.6;border-style:dashed">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
              <span class="mono" style="color:var(--color-subtle);font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em">Homelab Power</span>
              <span class="status-dot unknown"></span>
            </div>
            <div style="font-size:1.25rem;font-weight:700;color:var(--color-subtle);font-family:var(--font-mono);margin-bottom:0.25rem">— W</div>
            <div class="mono" style="color:var(--color-subtle);font-size:0.85rem">Sonoff POW on PDU · not yet connected</div>
          </div>
          ${(() => {
            const u = data.ups ?? {};
            const dot = u.dot ?? 'unknown';
            const hasData = u.charge != null;
            if (!hasData) return `
          <div class="card" style="opacity:0.6;border-style:dashed">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
              <span class="mono" style="color:var(--color-subtle);font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em">UPS</span>
              <span class="status-dot unknown"></span>
            </div>
            <div style="font-size:1.25rem;font-weight:700;color:var(--color-subtle);font-family:var(--font-mono);margin-bottom:0.25rem">—</div>
            <div class="mono" style="color:var(--color-subtle);font-size:0.85rem">NUT unavailable</div>
          </div>`;
            const onBattery = u.on_battery ? ' · ON BATTERY' : '';
            return `
          <div class="card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem">
              <div>
                <span class="mono" style="color:var(--color-subtle);font-size:0.78rem;text-transform:uppercase;letter-spacing:0.06em">UPS</span>
                <div style="font-size:0.78rem;color:var(--color-subtle);font-family:var(--font-mono);margin-top:0.1rem">APC · ${u.nominal_w ?? '—'}W nominal${onBattery}</div>
              </div>
              <span class="status-dot ${dot}"></span>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.4rem;margin-top:0.75rem">
              <div class="metric">
                <span class="metric-value" style="font-size:0.85rem"
                      data-count-to="${u.charge ?? 0}" data-count-suffix="%">0%</span>
                <span class="metric-label">Charge</span>
              </div>
              <div class="metric">
                <span class="metric-value" style="font-size:0.85rem">${u.runtime_str ?? '—'}</span>
                <span class="metric-label">Runtime</span>
              </div>
              <div class="metric">
                <span class="metric-value" style="font-size:0.85rem">${u.load_pct ?? '—'}%</span>
                <span class="metric-label">Load</span>
              </div>
            </div>
          </div>`;
          })()}`;
      }

      // Storage pools
      const storageGrid = document.getElementById('storage-grid');
      if (storageGrid) {
        const pools = data.storage ?? [];
        if (pools.length > 0) {
          const colorVar = (status: string) =>
            status === 'crit' ? 'var(--color-crit)' : status === 'warn' ? 'var(--color-warn)' : 'var(--color-ok)';

          const donut = (pct: number, status: string) => {
            const r = 36, cx = 44, cy = 44, stroke = 10;
            const circ = 2 * Math.PI * r;
            const used = (pct / 100) * circ;
            const free = circ - used;
            const color = colorVar(status);
            return `<svg class="storage-donut" width="88" height="88" viewBox="0 0 88 88">
              <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="var(--color-overlay)" stroke-width="${stroke}"/>
              <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${color}" stroke-width="${stroke}"
                stroke-dasharray="${used} ${free}" stroke-dashoffset="${circ * 0.25}"
                stroke-linecap="round" style="transition:stroke-dasharray 0.7s ease"/>
              <text x="${cx}" y="${cy}" text-anchor="middle" dominant-baseline="middle"
                font-family="var(--font-mono)" font-size="13" font-weight="700" fill="${color}"
                data-count-to="${pct}" data-count-suffix="%">0%</text>
            </svg>`;
          };

          storageGrid.className = 'storage-grid';
          storageGrid.innerHTML = pools.map((p: any) => `
            <div class="storage-card ${p.status}">
              <div class="storage-pool-name">${p.name}</div>
              <div class="storage-health" style="color:var(--color-${p.healthy ? 'ok' : 'crit'})">
                ● ${p.pool_status ?? 'UNKNOWN'}
              </div>
              <div class="storage-donut-row">
                ${donut(p.pct, p.status)}
                <div class="storage-legend">
                  <div class="storage-legend-item">
                    <div style="display:flex;align-items:center">
                      <div class="storage-legend-dot" style="background:${colorVar(p.status)}"></div>
                      <span style="color:var(--color-subtle)">Used</span>
                    </div>
                    <span style="color:var(--color-heading);font-weight:600">${p.used}</span>
                  </div>
                  <div class="storage-legend-item">
                    <div style="display:flex;align-items:center">
                      <div class="storage-legend-dot" style="background:var(--color-overlay)"></div>
                      <span style="color:var(--color-subtle)">Total</span>
                    </div>
                    <span style="color:var(--color-heading);font-weight:600">${p.total}</span>
                  </div>
                  <div class="storage-bar-track" style="margin-top:0.5rem">
                    <div class="storage-bar-fill ${p.status}" style="width:${Math.min(p.pct,100)}%"></div>
                  </div>
                </div>
              </div>
            </div>
          `).join('');
        } else {
          storageGrid.innerHTML = '<div class="mono" style="color:var(--color-subtle);padding:0.5rem 0">Storage data unavailable</div>';
        }
      }

      // Flux
      const fluxSection = document.getElementById('flux-section');
      if (fluxSection && data.flux) {
        const f = data.flux;
        const ks = f.kustomizations ?? [];

        // Sort: failed first, then ready
        const sorted = [...ks].sort((a: any, b: any) => {
          if (!a.ready && b.ready) return -1;
          if (a.ready && !b.ready) return 1;
          return 0;
        });

        const total = f.total || 1;
        const readyPct  = Math.round((f.ready / total) * 100);
        const failedPct = 100 - readyPct;
        const failedCount = total - f.ready;

        const summary = `
          <div class="flux-summary">
            <span class="badge ${f.status}">${f.ready}/${f.total} synced</span>
            <div class="flux-ratio-bar" title="${f.ready} ready · ${failedCount} failed">
              <div class="flux-ratio-bar-ok"   style="width:${readyPct}%"></div>
              <div class="flux-ratio-bar-crit" style="width:${failedPct}%"></div>
            </div>
            <span class="flux-ratio-label">${f.ready} ready · ${failedCount} failed</span>
            <span class="mono" style="margin-left:auto;color:var(--color-subtle)">last sync ${f.last_sync}</span>
          </div>`;

        const tableRows = sorted.map((k: any) => `
          <div class="flux-row${k.ready ? '' : ' crit-row'}">
            <div class="flux-name-cell">
              <span class="flux-name-icon ${k.ready ? 'ok' : 'crit'}">${k.ready ? '✓' : '✗'}</span>
              <span class="flux-name-text">${k.name}</span>
            </div>
            <span style="font-family:var(--font-mono);font-size:0.75rem;color:var(--color-subtle)">${k.namespace}</span>
            <span style="font-family:var(--font-mono);font-size:0.75rem;color:var(--color-subtle)">${k.age}</span>
            <span class="badge ${k.ready ? 'ok' : 'crit'}">${k.ready ? '✓ Ready' : '✗ Failed'}</span>
          </div>`).join('');

        fluxSection.innerHTML = summary + (ks.length ? `
          <div class="flux-table">
            <div class="flux-row header">
              <span>Kustomization</span>
              <span>Namespace</span>
              <span>Last Applied</span>
              <span>Status</span>
            </div>
            ${tableRows}
          </div>` : `<div class="mono" style="color:var(--color-subtle);padding:1rem 0">No kustomization data yet — pipeline pending</div>`);
      }

      // Backups
      const backupCards = document.getElementById('backup-cards');
      if (backupCards && data.cards) {
        const find = (label: string) => data.cards.find((c: any) => c.label === label);
        const da = find('Docker Appdata');
        const et = find('etcd Snapshot');
        const vc = find('Velero');
        const vy = find('varys Keys');
        const items = [
          { label: 'Docker Appdata', value: da?.value ?? '—', sub: 'bronn · daily 02:00',  status: da?.status ?? 'unknown' },
          { label: 'etcd Snapshot',  value: et?.value ?? '—', sub: 'k3s · daily',           status: et?.status ?? 'unknown' },
          { label: 'Velero (k8s)',   value: vc?.value ?? '—', sub: 'last cluster backup',    status: vc?.status ?? 'unknown' },
          { label: 'varys Keys',     value: vy?.value ?? '—', sub: 'age keys · varys',       status: vy?.status ?? 'unknown' },
        ];
        backupCards.innerHTML = items.map(c => `
          <div class="card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
              <span class="mono" style="color:var(--color-subtle);font-size:0.72rem;text-transform:uppercase;letter-spacing:0.06em">${c.label}</span>
              <span class="status-dot ${c.status}"></span>
            </div>
            <div style="font-size:1.25rem;font-weight:700;color:var(--color-heading);font-family:var(--font-mono);margin-bottom:0.25rem">${c.value}</div>
            <div class="mono" style="font-size:0.85rem">${c.sub}</div>
          </div>
        `).join('');
      }

      // Network
      const net = data.network;
      if (net) {
        const latencyStatus = net.latency_ms == null ? 'unknown'
          : net.latency_ms < 30 ? 'ok'
          : net.latency_ms < 80 ? 'warn' : 'crit';

        const bans = net.crowdsec_bans;
        const crowdsecCard = bans != null ? `
          <div class="card" style="border-left:3px solid var(--color-crit)">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
              <span class="mono" style="color:var(--color-subtle);font-size:0.72rem;text-transform:uppercase;letter-spacing:0.06em">CrowdSec Bans</span>
              <span class="status-dot ok"></span>
            </div>
            <div style="font-size:1.25rem;font-weight:700;color:var(--color-crit);font-family:var(--font-mono);margin-bottom:0.25rem"
                 data-count-to="${bans}" data-count-suffix="">0</div>
            <div class="mono" style="font-size:0.85rem">active IP bans · threat intelligence</div>
          </div>` : '';

        const netCards = document.getElementById('network-cards');
        if (netCards) {
          netCards.innerHTML = crowdsecCard + [
            { label: 'Firewall Blocks', raw: net.fw_hits,    suffix: '',    display: net.fw_hits != null ? net.fw_hits.toLocaleString() : '—', sub: 'packets dropped at router', status: 'ok' },
            { label: 'WAN Latency',     raw: net.latency_ms, suffix: ' ms', display: net.latency_ms != null ? net.latency_ms + ' ms' : '—',    sub: 'avg RTT to 8.8.8.8',       status: latencyStatus },
          ].map(c => `
            <div class="card">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
                <span class="mono" style="color:var(--color-subtle);font-size:0.72rem;text-transform:uppercase;letter-spacing:0.06em">${c.label}</span>
                <span class="status-dot ${c.status}"></span>
              </div>
              <div style="font-size:1.25rem;font-weight:700;color:var(--color-heading);font-family:var(--font-mono);margin-bottom:0.25rem"
                   ${c.raw != null ? `data-count-to="${c.raw}" data-count-suffix="${c.suffix}"` : ''}>0</div>
              <div class="mono" style="font-size:0.85rem">${c.sub}</div>
            </div>
          `).join('');
        }

        // Persistent offenders table
        const offEl = document.getElementById('offenders-section');
        if (offEl) {
          const offs = net.offenders ?? [];
          if (offs.length > 0) {
            offEl.innerHTML = `
              <div class="flux-table">
                <div class="flux-row header" style="grid-template-columns:1.5fr 80px 140px">
                  <span>IP Address</span><span>Hits</span><span>Rule</span>
                </div>
                ${offs.map((o: any) => `
                  <div class="flux-row" style="grid-template-columns:1.5fr 80px 140px">
                    <span style="font-family:var(--font-mono);font-size:0.875rem;color:var(--color-peach)">${o.ip}</span>
                    <span class="badge crit">${o.hits}</span>
                    <span style="font-family:var(--font-mono);font-size:0.75rem;color:var(--color-subtle)">${o.type}</span>
                  </div>
                `).join('')}
              </div>`;
          } else {
            offEl.innerHTML = '<div class="mono" style="color:var(--color-subtle);padding:0.5rem 0">No persistent offenders detected</div>';
          }
        }
      }

    } catch { /* skeletons remain */ }
  }

  // ── Number counters ───────────────────────────────────────────────────────
  function countUp(el: Element, target: number, suffix: string, duration = 900) {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = target + suffix;
      return;
    }
    const start = performance.now();
    const step = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(eased * target) + suffix;
      if (progress < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  function initCounters() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseFloat(el.dataset.countTo ?? '0');
        const suffix = el.dataset.countSuffix ?? '';
        countUp(el, target, suffix);
        observer.unobserve(el);
      });
    }, { threshold: 0.3 });

    document.querySelectorAll('[data-count-to]').forEach(el => observer.observe(el));
  }

  // ── CVE banner (fetched once, not on 30s poll) ───────────────────────────
  async function loadCVEBanner() {
    const banner = document.getElementById('cve-banner');
    if (!banner) return;
    try {
      const res = await fetch('/data/cve.json?t=' + Date.now());
      if (!res.ok) throw new Error('no data');
      const d = await res.json();

      const statusDotClass = d.status === 'clean' || d.status === 'ok' ? 'ok'
                           : d.status === 'crit'                        ? 'crit'
                           : 'warn';

      let label = '';
      if (d.status === 'clean') {
        label = `No known CVEs &middot; ${d.tracked ?? '?'} components tracked`;
      } else {
        const parts: string[] = [];
        if (d.counts?.CRITICAL) parts.push(`${d.counts.CRITICAL} CRITICAL`);
        if (d.counts?.HIGH)     parts.push(`${d.counts.HIGH} HIGH`);
        if (d.counts?.MEDIUM)   parts.push(`${d.counts.MEDIUM} MEDIUM`);
        if (d.counts?.LOW)      parts.push(`${d.counts.LOW} LOW`);
        label = parts.join(', ') || `${d.total} CVEs`;
      }

      banner.innerHTML = `
        <a href="/security" class="deploy-banner" style="text-decoration:none; display:flex; align-items:center; gap:1rem">
          <span class="status-dot ${statusDotClass}"></span>
          <span class="deploy-msg">${label}</span>
          <span class="deploy-age">view details →</span>
        </a>`;
    } catch {
      banner.innerHTML = '';
    }
  }

  // ── Polling lifecycle ─────────────────────────────────────────────────────
  let pollInterval: ReturnType<typeof setInterval> | null = null;

  function startPolling() {
    if (pollInterval) clearInterval(pollInterval);
    loadStatus().then(() => setTimeout(initCounters, 80));
    pollInterval = setInterval(() => loadStatus().then(() => setTimeout(initCounters, 80)), 30000);
  }

  function stopPolling() {
    if (pollInterval) { clearInterval(pollInterval); pollInterval = null; }
  }

  // ── Ring scroll-reveal ───────────────────────────────────────────────────
  // Watches for node cards injected by loadStatus(), then animates each
  // ring arc from 0 to its target dasharray when it enters the viewport.
  function initRingObserver() {
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const arc = entry.target as SVGCircleElement;
        const target = arc.dataset.dash;
        if (!target) return;
        // Tiny delay so the CSS transition has a frame to start from zero
        requestAnimationFrame(() => {
          arc.style.strokeDasharray = target;
          arc.classList.add('ring-revealed');
        });
        io.unobserve(arc);
      });
    }, { threshold: 0.3 });

    document.querySelectorAll('.node-status-ring circle.arc[data-dash]').forEach(arc => {
      io.observe(arc);
    });
  }

  // Re-run after each data load (nodes grid is replaced each poll)
  (window as any).__ringObserverPatched = true;

  // Hook into the nodes grid being populated via MutationObserver
  const nodesGridEl = document.getElementById('nodes-grid');
  if (nodesGridEl) {
    const mo = new MutationObserver(() => {
      // Small delay for innerHTML to fully settle before querying arcs
      setTimeout(initRingObserver, 60);
    });
    mo.observe(nodesGridEl, { childList: true, subtree: false });
  }

  // ── Cluster uptime counter ───────────────────────────────────────────────
  // k3s cluster first deployed 2024-11-01 (approximate — adjust if known)
  const CLUSTER_EPOCH = new Date('2024-11-01T00:00:00Z').getTime();

  function updateUptime() {
    const el = document.getElementById('uptime-value');
    if (!el) return;
    const ms = Date.now() - CLUSTER_EPOCH;
    const s  = Math.floor(ms / 1000);
    const m  = Math.floor(s  / 60);
    const h  = Math.floor(m  / 60);
    const d  = Math.floor(h  / 24);
    const hh = String(h % 24).padStart(2, '0');
    const mm = String(m % 60).padStart(2, '0');
    const ss = String(s % 60).padStart(2, '0');
    el.textContent = `${d}d ${hh}h ${mm}m ${ss}s`;
  }

  updateUptime();
  const _uptimeTimer = setInterval(updateUptime, 1000);
  document.addEventListener('astro:before-swap', () => clearInterval(_uptimeTimer));

  document.addEventListener('astro:page-load', () => { startPolling(); loadCVEBanner(); initNetMap(); });
  document.addEventListener('astro:before-swap', stopPolling);

  // ── Network Diagram ───────────────────────────────────────────────────────
  const NET_LINKS: [string, string, string][] = [
    // [fromId, toId, lineColor]
    ['internet',  'mikrotik', '#fab387'],
    ['mikrotik',  'nm-tywin',  '#cba6f7'],
    ['mikrotik',  'nm-jaime',  '#cba6f7'],
    ['mikrotik',  'nm-tyrion', '#cba6f7'],
    ['mikrotik',  'nm-bronn',  '#74c7ec'],
    ['mikrotik',  'nm-varys',  '#a6e3a1'],
    ['mikrotik',  'nm-ned',    '#e6b450'],
    ['mikrotik',  'nm-bran',   '#f38ba8'],
    ['nm-tywin',  'nm-jaime',  '#cba6f7'],
    ['nm-tywin',  'nm-tyrion', '#cba6f7'],
    ['nm-jaime',  'nm-tyrion', '#cba6f7'],
    ['nm-bronn',  'nm-ned',    '#74c7ec'],
  ];

  async function initNetMap() {
    const svg = document.getElementById('netmap-svg') as SVGSVGElement | null;
    const tooltip = document.getElementById('nm-tooltip');
    if (!svg) return;

    function centre(id: string): { x: number; y: number } | null {
      const el = document.getElementById(id) ?? document.querySelector<HTMLElement>(`.nm-node[data-id="${id}"]`);
      if (!el) return null;
      const wrap = document.querySelector<HTMLElement>('.netmap-wrap')!;
      const wr = wrap.getBoundingClientRect();
      const r = el.getBoundingClientRect();
      return { x: r.left + r.width / 2 - wr.left, y: r.top + r.height / 2 - wr.top };
    }

    function drawLines(hoverId: string | null = null) {
      svg.querySelectorAll('.nm-line').forEach(l => l.remove());
      for (const [a, b, color] of NET_LINKS) {
        const ca = centre(a === 'internet' ? 'nm-internet' : a === 'mikrotik' ? 'nm-mikrotik' : a);
        const cb = centre(b === 'internet' ? 'nm-internet' : b === 'mikrotik' ? 'nm-mikrotik' : b);
        if (!ca || !cb) continue;
        const isActive = hoverId && (a.includes(hoverId) || b.includes(hoverId));
        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.classList.add('nm-line');
        line.setAttribute('x1', String(ca.x));
        line.setAttribute('y1', String(ca.y));
        line.setAttribute('x2', String(cb.x));
        line.setAttribute('y2', String(cb.y));
        line.setAttribute('stroke', isActive ? color : color + '28');
        line.setAttribute('stroke-width', isActive ? '2' : '1');
        line.setAttribute('stroke-dasharray', isActive ? '' : '4 6');
        if (isActive) {
          line.setAttribute('filter', `drop-shadow(0 0 3px ${color})`);
        }
        svg.appendChild(line);
      }
    }

    // Tooltip on hover
    document.querySelectorAll<HTMLElement>('.nm-node').forEach(node => {
      node.addEventListener('mouseenter', (e) => {
        const id = node.dataset.id ?? node.id;
        drawLines(id);

        if (tooltip) {
          const ttName = document.getElementById('nm-tt-name');
          const ttIp   = document.getElementById('nm-tt-ip');
          const ttRole = document.getElementById('nm-tt-role');
          const ttSvc  = document.getElementById('nm-tt-services');
          if (ttName) ttName.textContent = node.querySelector('.nm-label')?.textContent ?? '';
          if (ttIp)   ttIp.textContent   = node.dataset.ip ?? '';
          if (ttRole) ttRole.textContent  = node.dataset.role ?? '';
          if (ttSvc)  ttSvc.innerHTML     = (node.dataset.services ?? '').split(' · ').map(s => `<span>· ${s}</span>`).join('');

          const wrap = document.querySelector<HTMLElement>('.netmap-wrap')!;
          const wr = wrap.getBoundingClientRect();
          const nr = node.getBoundingClientRect();
          let tx = nr.left - wr.left + nr.width + 10;
          let ty = nr.top  - wr.top;
          if (tx + 200 > wr.width) tx = nr.left - wr.left - 210;
          tooltip.style.left = tx + 'px';
          tooltip.style.top  = ty + 'px';
          tooltip.classList.add('visible');
        }
      });

      node.addEventListener('mouseleave', () => {
        drawLines(null);
        tooltip?.classList.remove('visible');
      });
    });

    // Apply live statuses from live.json
    try {
      const r = await fetch('/data/live.json');
      if (r.ok) {
        const data = await r.json();
        for (const n of (data.nodes ?? [])) {
          const dot = document.getElementById('dot-' + n.name?.toLowerCase());
          if (dot) dot.className = 'nm-dot ' + (n.status === 'ok' ? 'ok' : n.status === 'warn' ? 'warn' : 'crit');
        }
      }
    } catch {}

    drawLines(null);
    window.addEventListener('resize', () => drawLines(null), { passive: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNetMap);
  } else {
    initNetMap();
  }
</script>
