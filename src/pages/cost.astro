---
import Layout from '../layouts/Layout.astro';
import { ONGOING, ELECTRICITY_KWH, ELECTRICITY_RATE, ELECTRICITY_COST, MONTHLY_TOTAL } from '../lib/cost';

// Ongoing + electricity sourced from src/lib/cost.ts (shared with the live spine).
const MY_MONTHLY_TOTAL = MONTHLY_TOTAL;

// ── Subscriptions actually cancelled ─────────────────────────────────────
// These are real invoices that no longer arrive. Exact prices as billed.
const CANCELLED = [
  {
    name:     'iCloud 200GB',
    replaces: 'Immich + Nextcloud',
    vendor:   'Apple',
    cost:     59.99,
    note:     'Photos → Immich · Files → Nextcloud · Calendar/Contacts → Nextcloud',
    logo:     '/logos/apple.svg',
    invert:   true,
  },
  {
    name:     'Microsoft 365 Basic',
    replaces: 'Nextcloud',
    vendor:   'Microsoft',
    cost:     39.00,
    note:     'OneDrive 1TB + Office web → Nextcloud handles files and docs',
    logo:     '/logos/microsoft.svg',
    invert:   false,
  },
  {
    name:     'Apple TV+',
    replaces: 'Plex',
    vendor:   'Apple',
    cost:     124.99,
    note:     'Streaming → self-hosted Plex library. Own the content, own the server.',
    logo:     '/logos/apple.svg',
    invert:   true,
  },
  {
    name:     'Showmax',
    replaces: 'Plex',
    vendor:   'Showmax',
    cost:     99,
    note:     'Streaming → self-hosted Plex library.',
    logo:     '/logos/showmax.svg',
    invert:   false,
  },
  {
    name:     'Apple Music',
    replaces: 'Navidrome',
    vendor:   'Apple',
    cost:     69.99,
    note:     'Music streaming → Navidrome self-hosted music server.',
    logo:     '/logos/apple.svg',
    invert:   true,
  },
  {
    name:     'YouTube Premium',
    replaces: 'Invidious + SponsorBlock',
    vendor:   'Google',
    cost:     189,
    note:     'Ad-free YouTube → self-hosted frontend, no tracking. Saves via yt-dlp to Plex.',
    logo:     '/logos/youtube.svg',
    invert:   false,
  },
  {
    name:     'ChatGPT',
    replaces: 'Ollama (local LLM)',
    vendor:   'OpenAI',
    cost:     149,
    note:     'Local LLM on Bronn. Upgrade to a 32B model after the RAM expansion.',
    logo:     '/logos/openai.svg',
    invert:   true,
  },
];

const CANCELLED_TOTAL = CANCELLED.reduce((s, c) => s + c.cost, 0);

// ── Running-cost stat tiles + breakdown (mockup) — all from real cost.ts ──
// Always-on draw behind the 91 kWh/month figure (127W continuous — see cost.ts note)
const RACK_WATTS = Math.round((ELECTRICITY_KWH * 1000) / (30 * 24));
const BREAKDOWN = [
  { name: 'Electricity (~' + RACK_WATTS + 'W avg)', cost: ELECTRICITY_COST, color: 'var(--ed-info)', note: 'Three mini-PCs, TrueNAS, Pi, switch, UPS overhead' },
  ...ONGOING.filter(o => o.cost > 0).map(o => ({
    name: o.item, cost: o.cost, color: 'var(--ed-mauve)', note: 'monthly · leaves the account',
  })),
];
const BREAKDOWN_TOTAL = BREAKDOWN.reduce((s, b) => s + b.cost, 0);

// "What I stopped paying for" — real cancelled subscriptions, condensed to was→now
const REPLACED = CANCELLED.map(c => ({ was: c.name, now: c.replaces, cost: c.cost }));
---

<Layout
  title="Cost"
  description="What this homelab actually costs — and what you'd pay the cloud for the same."
>

<div class="page-wrap">

  <!-- ── Editorial hero ── -->
  <header class="cost-hero fade-up">
    <div class="cost-kicker mono">~/cost</div>
    <h1 class="cost-h1">What it actually costs</h1>
    <p class="cost-lede">
      No cloud bill, no hand-waving. The real monthly cost of running a
      production-grade homelab on hardware I already own — electricity, a
      domain, off-site backup, and the few things I still pay for.
    </p>
  </header>

  <!-- ── 4-stat strip (real, from cost.ts) ── -->
  <section class="cost-stats fade-up">
    <div class="cost-stat">
      <div class="cost-stat-val mono">R{MY_MONTHLY_TOTAL}<span class="cost-stat-unit">/mo</span></div>
      <div class="cost-stat-label mono">all-in, current</div>
    </div>
    <div class="cost-stat">
      <div class="cost-stat-val mono">R{ELECTRICITY_COST}</div>
      <div class="cost-stat-label mono">electricity / mo</div>
    </div>
    <div class="cost-stat">
      <div class="cost-stat-val mono">~{RACK_WATTS}<span class="cost-stat-unit">W</span></div>
      <div class="cost-stat-label mono">whole-rack draw</div>
    </div>
    <div class="cost-stat">
      <div class="cost-stat-val mono" style="color:var(--ed-ok)">R{Math.round(CANCELLED_TOTAL)}<span class="cost-stat-unit">/mo</span></div>
      <div class="cost-stat-label mono">subscriptions replaced</div>
    </div>
  </section>

  <!-- ── Two-up: where it goes + what I stopped paying for ── -->
  <section class="cost-twocol fade-up">
    <div class="cost-panel">
      <div class="cost-panel-head">Where the R{MY_MONTHLY_TOTAL} goes</div>
      <div class="cost-panel-body">
        {BREAKDOWN.map(b => (
          <div class="cost-bd-row">
            <div class="cost-bd-top">
              <span class="cost-bd-name">{b.name}</span>
              <span class="cost-bd-cost mono">R{b.cost}</span>
            </div>
            <div class="cost-bd-track"><div class="cost-bd-fill" style={`width:${Math.round((b.cost / BREAKDOWN_TOTAL) * 100)}%;background:${b.color}`}></div></div>
            <div class="cost-bd-note">{b.note}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="cost-rightcol">
      <div class="cost-compare">
        <div class="cost-compare-title">The honest comparison</div>
        <p class="cost-compare-text">
          The same workloads on managed cloud — object storage, a couple of
          always-on VMs, streaming and AI subscriptions — is what I used to pay
          for. Cancelling them stopped <span class="cost-hl">R{CANCELLED_TOTAL.toFixed(0)}/mo</span> of
          real invoices; the lab replaces them for R{MY_MONTHLY_TOTAL}/mo, and I own the hardware.
        </p>
        <p class="cost-compare-sub">
          Cancelled prices are exact. Electricity at R{ELECTRICITY_RATE}/kWh (Johannesburg
          municipal), draw from UPS load readings. Hardware already owned — no monthly payments.
        </p>
      </div>
      <div class="cost-panel">
        <div class="cost-panel-head">What I stopped paying for</div>
        <div class="cost-panel-body">
          {REPLACED.map(r => (
            <div class="cost-repl-row">
              <span class="cost-repl-txt">{r.was} <span class="cost-repl-arrow">→</span> {r.now}</span>
              <span class="cost-repl-cost mono">R{r.cost.toFixed(2).replace('.', ',')}/mo</span>
            </div>
          ))}
          <div class="cost-repl-total">
            <span class="mono">Total cancelled</span>
            <span class="cost-repl-total-amt mono">R{CANCELLED_TOTAL.toFixed(2).replace('.', ',')}/mo</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── The bill you're not paying (manifesto) ── -->
  <section class="cost-manifesto fade-up">
    <h2 class="cost-manifesto-title">The bill you're not paying</h2>
    <p class="cost-manifesto-lead">
      The money saved is real. But that's not why I did it. I did it because I
      was tired of paying companies to store my data on their terms, train their
      models on it, and change the rules whenever they felt like it.
    </p>
    <p class="cost-manifesto-punch">The savings are a bonus. <span class="cost-hl">The control is the point.</span></p>
  </section>


</div>

</Layout>

<style is:global>
  .page-wrap {
    --ed-tx:#eaeaed; --ed-mut:#9a9aa3; --ed-fnt:#63636b;
    --ed-hair:rgba(255,255,255,.09); --ed-box:rgba(255,255,255,.16);
    --ed-ok:#2fa06b; --ed-warn:#c98a1e; --ed-crit:#cf5349;
    --ed-info:#6f8fb0; --ed-mauve:#9a86ad;
    --ed-serif:var(--font-display); --ed-mono:var(--font-mono);
    max-width: 1080px; margin: 0 auto; padding: 3rem 1.5rem 4rem;
  }

  /* ── Hero ── */
  .cost-hero { margin-bottom: 8px; }
  .cost-kicker { font-size:11.5px; letter-spacing:.16em; text-transform:uppercase; color:var(--ed-mut); }
  .cost-h1 { font-family:var(--ed-serif); font-weight:500; font-size:clamp(2rem,5vw,56px); letter-spacing:-.02em; line-height:1.03; margin:16px 0 0; color:var(--ed-tx); }
  .cost-lede { color:var(--ed-mut); font-size:16px; line-height:1.62; max-width:62ch; margin:18px 0 0; }

  /* ── 4-stat strip (hairline rules) ── */
  .cost-stats { display:grid; grid-template-columns:repeat(4,1fr); margin:38px 0 0; border-top:1px solid var(--ed-hair); }
  .cost-stat { padding:20px 22px 20px 0; border-left:1px solid var(--ed-hair); padding-left:22px; margin-left:-1px; }
  .cost-stat:first-child { border-left:none; padding-left:0; margin-left:0; }
  .cost-stat-val { font-size:32px; font-weight:500; color:var(--ed-tx); line-height:1; font-variant-numeric:tabular-nums; }
  .cost-stat-unit { font-size:15px; color:var(--ed-fnt); }
  .cost-stat-label { font-size:11px; color:var(--ed-mut); margin-top:6px; }

  /* ── Two-up ── */
  .cost-twocol { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin:36px 0 0; align-items:start; }
  .cost-rightcol { display:flex; flex-direction:column; gap:14px; }
  .cost-panel { border:1px solid var(--ed-hair); border-radius:12px; overflow:hidden; }
  .cost-panel-head { padding:16px 20px; border-bottom:1px solid var(--ed-hair); font-family:var(--ed-serif); font-size:19px; font-weight:500; color:var(--ed-tx); }
  .cost-panel-body { padding:6px 20px 16px; }

  .cost-bd-row { padding:14px 0; border-top:1px solid var(--ed-hair); }
  .cost-bd-row:first-child { border-top:none; }
  .cost-bd-top { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:8px; }
  .cost-bd-name { font-size:14px; color:var(--ed-tx); }
  .cost-bd-cost { font-size:13px; color:var(--ed-tx); }
  .cost-bd-track { height:4px; border-radius:2px; background:rgba(255,255,255,.08); overflow:hidden; }
  .cost-bd-fill { height:100%; border-radius:2px; }
  .cost-bd-note { font-size:11.5px; color:var(--ed-mut); margin-top:7px; }

  .cost-repl-row { display:flex; align-items:baseline; justify-content:space-between; gap:12px; padding:9px 0; border-top:1px solid var(--ed-hair); }
  .cost-repl-row:first-child { border-top:none; }
  .cost-repl-txt { font-size:13.5px; color:var(--ed-tx); }
  .cost-repl-arrow { color:var(--ed-fnt); }
  .cost-repl-cost { font-size:12.5px; color:var(--ed-mut); white-space:nowrap; }
  .cost-repl-total { display:flex; align-items:baseline; justify-content:space-between; padding:12px 0 2px; margin-top:4px; border-top:1px solid var(--ed-box); font-size:12.5px; color:var(--ed-mut); }
  .cost-repl-total-amt { color:var(--ed-ok); }

  .cost-compare { border:1px solid var(--ed-hair); border-radius:12px; padding:20px 22px; }
  .cost-compare-title { font-family:var(--ed-serif); font-size:19px; font-weight:500; color:var(--ed-tx); margin-bottom:13px; }
  .cost-compare-text { font-size:14px; line-height:1.68; color:var(--ed-mut); margin:0 0 13px; }
  .cost-compare-sub { font-size:12.5px; line-height:1.6; color:var(--ed-fnt); margin:0; }
  .cost-hl { color:var(--ed-ok); font-family:var(--ed-mono); }

  /* ── Manifesto ── */
  .cost-manifesto { border-top:1px solid var(--ed-hair); padding-top:34px; margin-top:44px; max-width:74ch; }
  .cost-manifesto-title { font-family:var(--ed-serif); font-style:italic; font-weight:500; font-size:clamp(1.6rem,4vw,32px); margin:0 0 18px; color:var(--ed-tx); }
  .cost-manifesto-lead { font-size:16px; line-height:1.72; color:var(--ed-mut); margin:0 0 16px; }
  .cost-manifesto-punch { font-size:16px; line-height:1.72; color:var(--ed-tx); margin:0; }

  @media (max-width:860px) {
    .cost-stats { grid-template-columns:repeat(2,1fr); }
    .cost-twocol { grid-template-columns:1fr; }
    .cost-h1 { font-size:34px; }
  }
</style>
