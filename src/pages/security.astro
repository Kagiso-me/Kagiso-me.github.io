---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Security" description="Live security posture — CVE feed scoped to exact running versions (OSV.dev), real CrowdSec + firewall telemetry, and the honest known gaps.">

  <div class="page-wrap">

    <!-- ── Header ── -->
    <div class="page-header fade-up">
      <div>
        <p class="mono" style="color:var(--accent); margin-bottom:0.25rem">~/security</p>
        <h1 style="margin:0">Security posture</h1>
        <p class="hero-sub">
          A single home network, treated like it matters. Defence in depth,
          encrypted secrets, one identity provider, and a CVE feed scoped to the
          exact versions running — sourced from
          <a href="https://osv.dev" target="_blank" rel="noopener" style="color:var(--accent)">OSV.dev</a>,
          not a generic advisory list. Shown honestly, gaps included.
        </p>
      </div>
      <div style="text-align:right; flex-shrink:0">
        <div class="mono" id="last-checked" style="color:var(--color-subtle)">—</div>
        <div class="mono" style="color:var(--color-subtle); font-size:0.78rem; margin-top:0.25rem">
          refreshed daily · OSV.dev + cluster telemetry
        </div>
      </div>
    </div>

    <!-- ── Posture cards ── -->
    <section class="posture-grid fade-up" style="animation-delay:0.03s">
      <div class="posture-card">
        <div class="posture-top"><span class="posture-label mono">OPEN CVEs</span><span class="posture-dot" id="posture-cve-dot"></span></div>
        <div class="posture-value mono" id="posture-cve-value">—</div>
        <div class="posture-note" id="posture-cve-note">High/Critical · scoped to running versions</div>
      </div>
      <div class="posture-card">
        <div class="posture-top"><span class="posture-label mono">SECRETS</span><span class="posture-dot ok"></span></div>
        <div class="posture-value mono">SOPS</div>
        <div class="posture-note">age-encrypted in git · decrypted in-cluster</div>
      </div>
      <div class="posture-card">
        <div class="posture-top"><span class="posture-label mono">IDENTITY</span><span class="posture-dot ok"></span></div>
        <div class="posture-value mono">Authentik</div>
        <div class="posture-note">SSO + MFA · forward-auth on every app</div>
      </div>
      <div class="posture-card">
        <div class="posture-top"><span class="posture-label mono">EDGE</span><span class="posture-dot" id="posture-edge-dot"></span></div>
        <div class="posture-value mono" id="posture-edge-value">—</div>
        <div class="posture-note" id="posture-edge-note">firewall hits · CrowdSec bans</div>
      </div>
    </section>

    <!-- ── CVE list + defence-in-depth ── -->
    <section class="sec-split fade-up" style="animation-delay:0.06s">
      <div class="sec-col">
        <div class="sec-panel-head">
          <h2 class="section-label" style="margin:0">Vulnerabilities</h2>
          <div class="summary-chips" id="summary-section" style="display:none">
            <span class="summary-chip crit"><span class="chip-count" id="count-critical">0</span>C</span>
            <span class="summary-chip high"><span class="chip-count" id="count-high">0</span>H</span>
            <span class="summary-chip medium"><span class="chip-count" id="count-medium">0</span>M</span>
            <span class="summary-chip low"><span class="chip-count" id="count-low">0</span>L</span>
          </div>
        </div>
        <div id="cve-list">
          <div class="skeleton" style="height:64px; border-radius:10px; margin-bottom:0.5rem"></div>
          <div class="skeleton" style="height:64px; border-radius:10px; margin-bottom:0.5rem"></div>
          <div class="skeleton" style="height:64px; border-radius:10px; margin-bottom:0.5rem"></div>
        </div>
        <div id="cve-footer" style="display:none" class="mono"></div>
      </div>

      <div class="sec-col">
        <div class="layers-panel">
          <div class="layers-head">Defence in depth</div>
          <div class="layers-body">
            <div class="layer-row"><span class="layer-check">✓</span><div><div class="layer-name">Perimeter firewall</div><div class="layer-detail">MikroTik · default-deny inbound, VLAN segmentation</div></div></div>
            <div class="layer-row"><span class="layer-check">✓</span><div><div class="layer-name">CrowdSec</div><div class="layer-detail">Behavioural blocking + community threat intel</div></div></div>
            <div class="layer-row"><span class="layer-check">✓</span><div><div class="layer-name">No exposed node IPs</div><div class="layer-detail">Ingress only via Traefik VIP (.110)</div></div></div>
            <div class="layer-row"><span class="layer-check">✓</span><div><div class="layer-name">SSO + MFA everywhere</div><div class="layer-detail">Authentik forward-auth, no per-app logins</div></div></div>
            <div class="layer-row"><span class="layer-check">✓</span><div><div class="layer-name">Encrypted secrets</div><div class="layer-detail">SOPS + age · nothing in plaintext, ever</div></div></div>
            <div class="layer-row"><span class="layer-check">✓</span><div><div class="layer-name">Image scanning in CI</div><div class="layer-detail">Trivy gate · block on HIGH</div></div></div>
            <div class="layer-row"><span class="layer-check">✓</span><div><div class="layer-name">Off-site encrypted backups</div><div class="layer-detail">Velero → MinIO → Backblaze B2 · tested restores</div></div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Honest gaps ── -->
    <section class="gaps-panel fade-up" style="animation-delay:0.09s">
      <div class="mono gaps-kicker">KNOWN GAPS · honest</div>
      <div class="gaps-grid">
        <p>bronn (media) sits <span style="color:var(--accent)">outside</span> the monitoring and identity stack by design — convenient, but a deliberate soft spot, isolated on its own path.</p>
        <p>The SOPS age key is the crown jewel. It lives only on varys and bran; losing both would mean re-keying every secret. Custody, not encryption, is the real risk.</p>
      </div>
    </section>

  </div>

</Layout>

<style is:global>
  .page-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); }

  .hero-sub {
    color: var(--color-subtle);
    font-size: 0.95rem;
    line-height: 1.75;
    max-width: 620px;
    margin: 0.75rem 0 0;
  }

  .section { margin-bottom: 3rem; }

  .section-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-subtle);
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-label::before {
    content: '';
    display: block;
    width: 3px;
    height: 0.85rem;
    background: linear-gradient(to bottom, #fab387, #cba6f7);
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* ── Summary chips ── */
  .summary-chips {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .summary-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    border: 1px solid transparent;
    font-family: var(--font-mono);
  }

  .summary-chip.crit   { background: color-mix(in srgb, var(--color-crit) 12%, transparent); border-color: color-mix(in srgb, var(--color-crit) 30%, transparent); }
  .summary-chip.high   { background: color-mix(in srgb, var(--color-crit) 8%, transparent);  border-color: color-mix(in srgb, var(--color-crit) 20%, transparent); }
  .summary-chip.medium { background: color-mix(in srgb, var(--color-warn) 10%, transparent); border-color: color-mix(in srgb, var(--color-warn) 25%, transparent); }
  .summary-chip.low    { background: color-mix(in srgb, var(--color-ok)   10%, transparent); border-color: color-mix(in srgb, var(--color-ok)   25%, transparent); }

  .chip-count {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1;
  }

  .summary-chip.crit   .chip-count { color: var(--color-crit); }
  .summary-chip.high   .chip-count { color: var(--color-crit); }
  .summary-chip.medium .chip-count { color: var(--color-warn); }
  .summary-chip.low    .chip-count { color: var(--color-ok); }

  .chip-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-subtle);
  }

  /* ── Posture cards ── */
  .posture-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.875rem;
    margin-bottom: 1.75rem;
  }
  .posture-card {
    background: rgba(255, 255, 255, 0.022);
    border: 1px solid var(--color-muted);
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
    transition: border-color 0.2s ease;
  }
  .posture-card:hover { border-color: color-mix(in srgb, var(--color-text) 16%, transparent); }
  .posture-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .posture-label { font-size: 0.7rem; letter-spacing: 0.05em; color: var(--color-subtle); }
  .posture-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--color-unknown); box-shadow: 0 0 8px var(--color-unknown);
  }
  .posture-dot.ok   { background: var(--color-ok);   box-shadow: 0 0 8px var(--color-ok); }
  .posture-dot.warn { background: var(--color-warn); box-shadow: 0 0 8px var(--color-warn); }
  .posture-dot.crit { background: var(--color-crit); box-shadow: 0 0 8px var(--color-crit); }
  .posture-value { font-size: 1.55rem; font-weight: 600; color: var(--color-heading); line-height: 1; }
  .posture-note { font-size: 0.74rem; color: var(--color-subtle); margin-top: 0.5rem; line-height: 1.5; }

  /* ── Split: CVE list + layers ── */
  .sec-split {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 1.25rem;
    margin-bottom: 1.75rem;
    align-items: start;
  }
  .sec-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .sec-panel-head .summary-chip { padding: 0.25rem 0.6rem; gap: 0.3rem; font-size: 0.72rem; }
  .sec-panel-head .chip-count { font-size: 0.9rem; }

  .layers-panel {
    background: rgba(255, 255, 255, 0.012);
    border: 1px solid var(--color-muted);
    border-radius: 16px;
    overflow: hidden;
  }
  .layers-head {
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--color-muted);
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-heading);
  }
  .layers-body { padding: 0.4rem 0.75rem; }
  .layer-row {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    padding: 0.7rem 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }
  .layer-row:last-child { border-bottom: none; }
  .layer-check { color: var(--color-ok); font-family: var(--font-mono); font-size: 0.85rem; flex-shrink: 0; line-height: 1.4; }
  .layer-name { font-size: 0.9rem; color: var(--color-text); font-weight: 500; }
  .layer-detail { font-size: 0.74rem; color: var(--color-subtle); margin-top: 0.1rem; }

  /* ── Honest gaps ── */
  .gaps-panel {
    border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
    border-radius: 16px;
    padding: 1.5rem 1.75rem;
    background: linear-gradient(120deg, color-mix(in srgb, var(--accent) 7%, transparent), transparent);
    margin-bottom: 2.5rem;
  }
  .gaps-kicker { font-size: 0.72rem; color: var(--accent); letter-spacing: 0.1em; margin-bottom: 0.9rem; }
  .gaps-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .gaps-grid p { margin: 0; font-size: 0.9rem; line-height: 1.7; color: var(--color-text); }

  @media (max-width: 820px) {
    .sec-split { grid-template-columns: 1fr; }
    .gaps-grid { grid-template-columns: 1fr; }
  }

  /* ── CVE table ── */
  .cve-table {
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.05);
  }

  .cve-group-header {
    padding: 0.5rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .cve-group-header.crit   { background: color-mix(in srgb, var(--color-crit) 10%, transparent); color: var(--color-crit); }
  .cve-group-header.high   { background: color-mix(in srgb, var(--color-crit) 6%, transparent);  color: var(--color-crit); }
  .cve-group-header.medium { background: color-mix(in srgb, var(--color-warn) 8%, transparent);  color: var(--color-warn); }
  .cve-group-header.low    { background: color-mix(in srgb, var(--color-ok)   8%, transparent);  color: var(--color-ok); }
  .cve-group-header.unknown { background: rgba(255,255,255,0.03); color: var(--color-subtle); }

  .cve-row {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    align-items: start;
    gap: 1rem;
    transition: background 0.15s;
  }

  .cve-row:last-child { border-bottom: none; }
  .cve-row:hover { background: rgba(255,255,255,0.025); }

  .cve-id-cell {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .cve-id {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-peach);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cve-component {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-subtle);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cve-summary {
    font-size: 0.875rem;
    color: var(--color-text);
    line-height: 1.45;
  }

  .cve-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.35rem;
    flex-shrink: 0;
  }

  .cvss-score {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
  }

  .cvss-score.crit   { background: color-mix(in srgb, var(--color-crit) 18%, transparent); color: var(--color-crit); }
  .cvss-score.high   { background: color-mix(in srgb, var(--color-crit) 18%, transparent); color: var(--color-crit); }
  .cvss-score.medium { background: color-mix(in srgb, var(--color-warn) 18%, transparent); color: var(--color-warn); }
  .cvss-score.low    { background: color-mix(in srgb, var(--color-ok)   18%, transparent); color: var(--color-ok); }

  .cve-link {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-subtle);
    text-decoration: none;
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
    border: 1px solid rgba(255,255,255,0.08);
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .cve-link:hover { color: var(--color-heading); border-color: rgba(255,255,255,0.2); }

  /* ── Empty state ── */
  .cve-empty {
    text-align: center;
    padding: 3rem 2rem;
    background: rgba(30, 37, 52, 0.4);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px;
  }

  .cve-empty-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-ok);
  }

  .cve-empty-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: 0.5rem;
  }

  .cve-empty-sub {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-subtle);
  }

  /* ── Skeletons ── */
  .skeleton {
    background: linear-gradient(
      90deg,
      var(--color-surface) 25%,
      var(--color-overlay) 50%,
      var(--color-surface) 75%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  @media (max-width: 640px) {
    .cve-row { grid-template-columns: 1fr; }
    .cve-meta { flex-direction: row; align-items: center; }
  }
</style>

<script>
  async function loadCVEs() {
    const listEl    = document.getElementById('cve-list');
    const summaryEl = document.getElementById('summary-section');
    const footerEl  = document.getElementById('cve-footer');
    const checkedEl = document.getElementById('last-checked');

    try {
      const res = await fetch('/data/cve.json?t=' + Date.now());
      if (!res.ok) throw new Error('no data');
      const data = await res.json();

      if (checkedEl && data.fetched_at) {
        const d = new Date(data.fetched_at);
        checkedEl.textContent = 'Checked ' + d.toLocaleDateString('en-ZA', {
          timeZone: 'Africa/Johannesburg',
          day: '2-digit', month: 'short', year: 'numeric',
          hour: '2-digit', minute: '2-digit',
        });
      }

      const counts = data.counts ?? {};
      if (summaryEl) {
        document.getElementById('count-critical')!.textContent = String(counts.CRITICAL ?? 0);
        document.getElementById('count-high')!.textContent     = String(counts.HIGH ?? 0);
        document.getElementById('count-medium')!.textContent   = String(counts.MEDIUM ?? 0);
        document.getElementById('count-low')!.textContent      = String(counts.LOW ?? 0);
        if (data.total > 0) summaryEl.style.display = '';
      }

      // CVE posture card — headline is High+Critical, the figures that page you
      const hi = (counts.CRITICAL ?? 0) + (counts.HIGH ?? 0);
      const cveVal = document.getElementById('posture-cve-value');
      const cveDot = document.getElementById('posture-cve-dot');
      const cveNote = document.getElementById('posture-cve-note');
      if (cveVal) cveVal.textContent = String(hi);
      if (cveDot) cveDot.className = 'posture-dot ' + (hi > 0 ? 'crit' : 'ok');
      if (cveNote) cveNote.textContent = `High/Critical · ${data.tracked ?? '?'} components tracked`;

      if (footerEl) {
        footerEl.style.display = '';
        footerEl.textContent = `Sourced from OSV.dev · ${data.tracked ?? '?'} components tracked`;
      }

      if (!listEl) return;

      const vulns: any[] = data.vulnerabilities ?? [];

      if (vulns.length === 0) {
        listEl.innerHTML = `
          <div class="cve-empty">
            <div class="cve-empty-icon">✓</div>
            <div class="cve-empty-title">No known CVEs</div>
            <div class="cve-empty-sub">${data.tracked ?? '?'} components tracked · all clear</div>
          </div>`;
        return;
      }

      const sevClass = (sev: string) => {
        if (sev === 'CRITICAL' || sev === 'HIGH') return 'crit';
        if (sev === 'MEDIUM') return 'medium';
        if (sev === 'LOW') return 'low';
        return 'unknown';
      };

      const groups: Record<string, any[]> = {};
      for (const v of vulns) {
        (groups[v.severity] ??= []).push(v);
      }

      const ORDER = ['CRITICAL', 'HIGH', 'MEDIUM', 'LOW', 'UNKNOWN'];
      let html = '<div class="cve-table">';

      for (const sev of ORDER) {
        const items = groups[sev];
        if (!items?.length) continue;

        const cls = sevClass(sev);
        html += `<div class="cve-group-header ${cls}">${sev} · ${items.length}</div>`;

        for (const v of items) {
          const id     = v.cve_id || v.id || '—';
          const score  = v.cvss != null ? `<span class="cvss-score ${cls}">${v.cvss}</span>` : '';
          const refUrl = v.refs?.[0] ?? `https://osv.dev/vulnerability/${v.id}`;
          const date   = v.published ? new Date(v.published).toLocaleDateString('en-ZA', { day: '2-digit', month: 'short', year: 'numeric' }) : '—';

          html += `
            <div class="cve-row">
              <div class="cve-id-cell">
                <span class="cve-id">${id}</span>
                <span class="cve-component">${v.component} ${v.component_version}</span>
              </div>
              <div class="cve-summary">${v.summary}</div>
              <div class="cve-meta">
                ${score}
                <a class="cve-link" href="${refUrl}" target="_blank" rel="noopener">↗ advisory</a>
                <span class="mono" style="font-size:0.68rem; color:var(--color-subtle)">${date}</span>
              </div>
            </div>`;
        }
      }

      html += '</div>';
      listEl.innerHTML = html;

    } catch (err) {
      if (listEl) {
        listEl.innerHTML = `<div style="color:var(--color-subtle); font-family:var(--font-mono); font-size:0.85rem; padding:1.5rem; text-align:center">Failed to load CVE data</div>`;
      }
      const cveVal = document.getElementById('posture-cve-value');
      const cveDot = document.getElementById('posture-cve-dot');
      if (cveVal) cveVal.textContent = 'unknown';
      if (cveDot) cveDot.className = 'posture-dot';
    }
  }

  async function loadEdge() {
    const valEl  = document.getElementById('posture-edge-value');
    const dotEl  = document.getElementById('posture-edge-dot');
    const noteEl = document.getElementById('posture-edge-note');
    try {
      const res = await fetch('/data/live.json', { cache: 'no-store' });
      if (!res.ok) throw new Error('no data');
      const d = await res.json();
      const net = d.network ?? {};
      const bans = net.crowdsec_bans ?? 0;
      const hits = net.fw_hits;
      if (valEl) valEl.textContent = bans > 0 ? `${bans} banned` : (typeof hits === 'number' ? `${hits.toLocaleString()} hits` : 'unknown');
      if (dotEl) dotEl.className = 'posture-dot ' + (typeof hits === 'number' ? 'ok' : '');
      if (noteEl) noteEl.textContent = typeof hits === 'number'
        ? `firewall blocks · ${bans} active CrowdSec bans`
        : 'firewall hits · CrowdSec bans';
    } catch {
      if (valEl) valEl.textContent = 'unknown';
      if (dotEl) dotEl.className = 'posture-dot';
    }
  }

  function initSecurity() { loadCVEs(); loadEdge(); }
  document.addEventListener('astro:page-load', initSecurity);
</script>
