---
import Layout from '../layouts/Layout.astro';
import ClusterTerminal from '../components/ClusterTerminal.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Layout title="Command Center" description="Living Homelab — built in public by Kagiso." ogImage="https://kagiso-me.github.io/og/home.svg">

  <!-- ── Hero ── -->
  <section class="hero fade-up">
    <!-- Aurora background layers -->
    <div class="aurora" aria-hidden="true">
      <div class="aurora-orb aurora-orb-1"></div>
      <div class="aurora-orb aurora-orb-2"></div>
      <div class="aurora-orb aurora-orb-3"></div>
    </div>
    <!-- Particle network canvas -->
    <canvas id="hero-grid" aria-hidden="true"></canvas>
    <div class="hero-inner">

      <!-- Left: identity + stats -->
      <div class="hero-left">
        <div class="hero-accent" aria-hidden="true"></div>
        <div class="hero-content">
          <h1><span id="h1-line1"></span><br><span id="h1-line2"></span><span class="h1-cursor" aria-hidden="true">▌</span></h1>
          <p class="hero-identity">Corporate exec by day. Self-taught engineer by night.</p>
          <p class="hero-sub">
            A real k3s cluster built and operated in public — live metrics, honest decisions,
            and an ops log that documents what actually happened.
          </p>
          <div class="hero-stats" id="hero-stats">
            <div class="hero-stat">
              <span class="hero-stat-val mono" id="stat-nodes">—</span>
              <span class="hero-stat-label">nodes ready</span>
            </div>
            <div class="hero-stat-div" aria-hidden="true"></div>
            <div class="hero-stat">
              <span class="hero-stat-val mono" id="stat-pods">—</span>
              <span class="hero-stat-label">pods running</span>
            </div>
            <div class="hero-stat-div" aria-hidden="true"></div>
            <div class="hero-stat">
              <span class="hero-stat-val mono" id="stat-flux">—</span>
              <span class="hero-stat-label">Flux releases</span>
            </div>
          </div>
          <div class="hero-actions">
            <a href="/status" class="btn-primary">Live Status</a>
            <a href="/decisions" class="btn-ghost">Architecture Decisions</a>
            <a href="/blog" class="btn-ghost">Blog</a>
          </div>
        </div>
      </div>

      <!-- Right: terminal -->
      <div class="hero-right">
        <div class="hero-term-label">
          <span class="mono">cluster · read-only · live</span>
          <span class="status-dot ok"></span>
        </div>
        <ClusterTerminal />
      </div>

    </div>
  </section>

  <!-- ── What's Running Right Now ── -->
  <section class="section fade-up" style="animation-delay: 0.1s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">What's Running Right Now</h2>
        <span class="mono live-badge">
          <span class="status-dot ok"></span>
          Live
          <span class="live-updated-label mono" id="live-updated"></span>
        </span>
      </div>

      <!-- Summary cards -->
      <div class="live-grid" id="live-grid">
        <div class="live-card skeleton"></div>
        <div class="live-card skeleton"></div>
        <div class="live-card skeleton"></div>
        <div class="live-card skeleton"></div>
      </div>

      <!-- Service grid — populated immediately by JS with static data, then enriched from live.json -->
      <div class="svc-grid" id="svc-grid"></div>

    </div>
  </section>

  <!-- ── Cluster Status Strip ── -->
  <section class="section fade-up" style="animation-delay: 0.2s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Cluster Health</h2>
        <a href="/status" class="mono link-subtle">Full dashboard →</a>
      </div>
      <div class="status-strip" id="status-strip">
        <div class="status-strip-item skeleton" style="height: 56px; border-radius: 8px;"></div>
        <div class="status-strip-item skeleton" style="height: 56px; border-radius: 8px;"></div>
        <div class="status-strip-item skeleton" style="height: 56px; border-radius: 8px;"></div>
      </div>
    </div>
  </section>

  <!-- ── Stack ── -->
  <section class="section fade-up" style="animation-delay: 0.25s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Stack</h2>
        <a href="/decisions" class="mono link-subtle">ADRs →</a>
      </div>
      <div class="stack-grid">
        {[
          { name: 'k3s',         role: 'Kubernetes distro',     accent: 'peach'    },
          { name: 'Flux',        role: 'GitOps operator',        accent: 'mauve'    },
          { name: 'Traefik',     role: 'Ingress / proxy',        accent: 'sapphire' },
          { name: 'Authentik',   role: 'Identity provider',      accent: 'gold'     },
          { name: 'Prometheus',  role: 'Metrics & alerting',     accent: 'peach'    },
          { name: 'Grafana',     role: 'Observability',          accent: 'gold'     },
          { name: 'Loki',        role: 'Log aggregation',        accent: 'mauve'    },
          { name: 'Velero',      role: 'Cluster backups',        accent: 'sapphire' },
          { name: 'CrowdSec',    role: 'Threat intelligence',    accent: 'crit'     },
          { name: 'SOPS',        role: 'Secret encryption',      accent: 'mauve'    },
          { name: 'MikroTik',    role: 'Router / firewall',      accent: 'peach'    },
          { name: 'TrueNAS',     role: 'NAS / storage',          accent: 'gold'     },
        ].map(t => (
          <div class="stack-item sheen" data-accent={t.accent}>
            <span class="stack-name">{t.name}</span>
            <span class="stack-role">{t.role}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Cinematic break strip ── -->
  <section class="manifesto-strip fade-up" style="animation-delay: 0.26s" aria-hidden="true">
    <div class="manifesto-inner">
      <span class="manifesto-line">No demos.</span>
      <span class="manifesto-sep">·</span>
      <span class="manifesto-line">No staging.</span>
      <span class="manifesto-sep">·</span>
      <span class="manifesto-line manifesto-accent">Built in public.</span>
    </div>
  </section>

  <!-- ── 24h Activity ── -->
  <section class="section fade-up" style="animation-delay: 0.27s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Activity — Last 24h</h2>
        <a href="https://github.com/Kagiso-me" target="_blank" rel="noopener" class="mono live-badge">
          <span class="status-dot ok"></span>
          github.com/Kagiso-me ↗
        </a>
      </div>
      <div class="act-wrap" id="act-wrap">
        <!-- Skeleton -->
        <div class="act-repo-card skeleton" style="height:140px"></div>
        <div class="act-repo-card skeleton" style="height:140px"></div>
      </div>
    </div>
  </section>

  <!-- ── Recent Posts ── -->
  <section class="section fade-up" style="animation-delay: 0.28s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">From the Blog</h2>
        <a href="/blog" class="mono link-subtle">All posts →</a>
      </div>
      <div class="blog-grid">
        {recentPosts.map(post => (
          <a href={`/blog/${post.id}`} class="blog-card">
            <div class="blog-card-meta">
              <span class="mono blog-date">{new Date(post.data.date).toLocaleDateString('en-ZA', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
              {post.data.adr && <span class="mono blog-adr">{post.data.adr}</span>}
            </div>
            <div class="blog-card-title">{post.data.title}</div>
            <div class="blog-card-summary">{post.data.summary}</div>
            <span class="mono blog-read">read →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Recent Digest + Active Project ── -->
  <section class="section fade-up" style="animation-delay: 0.3s">
    <div class="section-inner two-col">

      <div>
        <div class="section-header">
          <h2 class="section-title">Recent Digest</h2>
          <a href="/digest" class="mono link-subtle">All entries →</a>
        </div>
        <div id="digest-list">
          <div class="skeleton" style="height: 80px; border-radius: 8px; margin-bottom: 0.75rem;"></div>
          <div class="skeleton" style="height: 80px; border-radius: 8px; margin-bottom: 0.75rem;"></div>
          <div class="skeleton" style="height: 80px; border-radius: 8px;"></div>
        </div>
      </div>

      <div>
        <div class="section-header">
          <h2 class="section-title">Active Work</h2>
          <a href="/projects" class="mono link-subtle">Roadmap →</a>
        </div>
        <div id="active-project">
          <div class="skeleton" style="height: 200px; border-radius: 12px;"></div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── About ── -->
  <section class="section about-section fade-up" style="animation-delay: 0.35s">
    <div class="section-inner">
      <div class="about-grid">

        <div class="about-text">
          <p class="mono" style="color:var(--color-peach);margin-bottom:0.75rem">~/whoami</p>
          <h2 style="font-size:clamp(1.5rem,3vw,2rem);margin:0 0 1.25rem">Hey, I'm Kagiso.</h2>
          <p style="color:var(--color-subtle);line-height:1.8;margin-bottom:1rem">
            Corporate exec by day, self-taught engineer by night. I built this cluster to close the gap
            between knowing how systems work and actually operating them — storage, media, backups,
            identity, observability, security: all running for real, with production discipline.
          </p>
          <p style="color:var(--color-subtle);line-height:1.8;margin-bottom:1.75rem">
            Everything here is real. The data is live, the ops log is the actual changelog,
            the ADRs document decisions I've genuinely wrestled with. No demos, no staging, no hand-waving.
          </p>
          <div class="about-links">
            <a href="https://github.com/Kagiso-me" target="_blank" rel="noopener" class="about-link">
              <span class="about-link-icon">⌥</span> GitHub
            </a>
            <a href="/decisions" class="about-link">
              <span class="about-link-icon">⎇</span> ADRs
            </a>
            <a href="/digest" class="about-link">
              <span class="about-link-icon">◎</span> Ops Log
            </a>
          </div>

          <!-- GitHub contribution graph -->
          <div class="contrib-wrap">
            <div class="contrib-header">
              <span class="mono contrib-label">GitHub activity</span>
              <span class="mono" id="contrib-total" style="color:var(--color-subtle);font-size:0.7rem"></span>
            </div>
            <div id="contrib-graph" class="contrib-graph">
              <div class="contrib-loading">loading graph…</div>
            </div>
            <div class="contrib-legend">
              <span class="mono" style="color:var(--color-subtle);font-size:0.65rem">less</span>
              <span class="contrib-cell" data-level="0"></span>
              <span class="contrib-cell" data-level="1"></span>
              <span class="contrib-cell" data-level="2"></span>
              <span class="contrib-cell" data-level="3"></span>
              <span class="contrib-cell" data-level="4"></span>
              <span class="mono" style="color:var(--color-subtle);font-size:0.65rem">more</span>
            </div>
          </div>
        </div>

        <div class="about-hardware">
          <div class="hw-label mono">Hardware</div>
          <div class="hw-list">
            {[
              { icon: '▣', name: '3× Lenovo ThinkCentre M93p', sub: 'k3s control-plane — Tywin, Jaime, Tyrion', specs: 'Intel Core i5-4570T @ 3.20GHz · 16GB DDR3 · 256GB SSD (each)' },
              { icon: '▣', name: 'Intel NUC',                   sub: 'Docker host — Bronn',                     specs: 'Intel Core i3-7100U @ 2.40GHz · 32GB DDR4 · 256GB NVMe' },
              { icon: '▣', name: 'Intel NUC',                   sub: 'Control node — Varys',                    specs: 'Intel Core i3-5010U @ 2.10GHz · 16GB DDR4 · 256GB NVMe' },
              { icon: '▣', name: 'HP MicroServer Gen8',         sub: 'TrueNAS storage — Ned',                   specs: 'Xeon E3-1260L · 16GB ECC · LSI 9207-8i HBA · 1×8TB + 2×4TB SAS mirror + 2×480GB SSD mirror' },
              { icon: '◈', name: 'RPi 3B+',                     sub: 'CI runner — Bran',                        specs: 'BCM2837B0 Cortex-A53 @ 1.4GHz · 1GB LPDDR2 · 32GB microSD' },
              { icon: '◉', name: 'APC Back-UPS Pro 650VA',      sub: 'UPS — 390W · ~2h runtime',               specs: 'USB monitoring via NUT · alerts via Prometheus Alertmanager' },
            ].map(h => (
              <div class="hw-item" role="button" tabindex="0" aria-expanded="false">
                <span class="hw-icon mono">{h.icon}</span>
                <div class="hw-main">
                  <div class="hw-name-row">
                    <div class="hw-name">{h.name}</div>
                    {h.specs && <span class="hw-chevron mono" aria-hidden="true">›</span>}
                  </div>
                  <div class="hw-sub mono">{h.sub}</div>
                  {h.specs && <div class="hw-specs mono">{h.specs}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    padding: 4rem 1.5rem 3rem;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--color-muted);
  }

  /* Aurora orbs */
  .aurora {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .aurora-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    mix-blend-mode: screen;
    will-change: transform;
  }

  .aurora-orb-1 {
    width: 55vw; height: 55vw;
    top: -20%; left: -10%;
    background: radial-gradient(ellipse, color-mix(in srgb, var(--color-peach) 22%, transparent), transparent 70%);
    animation: aurora-drift-1 18s ease-in-out infinite alternate;
  }

  .aurora-orb-2 {
    width: 45vw; height: 45vw;
    top: -15%; right: -5%;
    background: radial-gradient(ellipse, color-mix(in srgb, var(--color-mauve) 18%, transparent), transparent 70%);
    animation: aurora-drift-2 22s ease-in-out infinite alternate;
  }

  .aurora-orb-3 {
    width: 35vw; height: 35vw;
    bottom: -10%; left: 35%;
    background: radial-gradient(ellipse, color-mix(in srgb, var(--color-sapphire) 12%, transparent), transparent 70%);
    animation: aurora-drift-3 26s ease-in-out infinite alternate;
  }

  @keyframes aurora-drift-1 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(8%, 12%) scale(1.15); }
  }
  @keyframes aurora-drift-2 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-10%, 8%) scale(1.2); }
  }
  @keyframes aurora-drift-3 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-6%, -14%) scale(1.1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .aurora-orb { animation: none; }
  }

  #hero-grid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.7;
    z-index: 1;
  }

  /* Typewriter cursor */
  .h1-cursor {
    display: inline-block;
    color: var(--color-peach);
    animation: cur-blink 0.9s step-end infinite;
    font-weight: 300;
    margin-left: 0.05em;
  }
  .h1-cursor.done { animation: none; opacity: 0; }
  @keyframes cur-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    position: relative;
  }

  .hero-left {
    display: flex;
    align-items: flex-start;
    gap: 0;
    padding-bottom: 3rem;
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-top: 0.5rem;
  }

  .hero-term-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 0.25rem;
  }

  /* The vertical accent line — the visual signature */
  .hero-accent {
    width: 3px;
    align-self: stretch;
    background: linear-gradient(to bottom, var(--color-peach), var(--color-mauve) 60%, transparent);
    border-radius: 3px;
    flex-shrink: 0;
    margin-right: 2.5rem;
    min-height: 200px;
  }

  .hero-content {
    flex: 1;
    min-width: 0;
  }

  h1 {
    font-size: clamp(3.75rem, 8vw, 6.5rem);
    letter-spacing: -0.045em;
    line-height: 0.92;
    margin: 0 0 1.5rem;
    color: var(--color-heading);
  }

  .hero-identity {
    font-size: clamp(1rem, 2vw, 1.1rem);
    font-weight: 600;
    color: var(--color-peach);
    margin: 0 0 0.75rem;
    letter-spacing: -0.01em;
  }

  .hero-sub {
    font-size: 1rem;
    color: var(--color-subtle);
    max-width: 540px;
    margin: 0 0 2rem;
    line-height: 1.7;
  }

  /* Live stat strip — three numbers rendered immediately from skeleton, filled by JS */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0;
    margin-bottom: 2.25rem;
    border: 1px solid var(--color-muted);
    border-radius: 10px;
    overflow: hidden;
    width: fit-content;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-surface);
  }

  .hero-stat-div {
    width: 1px;
    align-self: stretch;
    background: var(--color-muted);
  }

  .hero-stat-val {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .hero-stat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 0.7rem 1.75rem;
    background: linear-gradient(135deg, var(--color-peach), color-mix(in srgb, var(--color-peach) 70%, var(--color-mauve)));
    color: var(--color-base);
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.9rem;
    transition: transform 0.2s, box-shadow 0.2s, opacity 0.2s;
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-peach) 40%, transparent);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    color: var(--color-base);
    box-shadow: 0 4px 24px color-mix(in srgb, var(--color-peach) 45%, transparent),
                0 0 0 1px color-mix(in srgb, var(--color-peach) 30%, transparent);
  }

  .btn-ghost {
    padding: 0.7rem 1.75rem;
    border: 1px solid var(--color-muted);
    color: var(--color-text);
    border-radius: 8px;
    font-size: 0.9rem;
    transition: border-color 0.2s, color 0.2s, background 0.2s, box-shadow 0.2s;
    backdrop-filter: blur(4px);
    background: color-mix(in srgb, var(--color-overlay) 40%, transparent);
  }

  .btn-ghost:hover {
    border-color: color-mix(in srgb, var(--color-mauve) 60%, transparent);
    color: var(--color-mauve);
    background: color-mix(in srgb, var(--color-mauve) 8%, transparent);
    box-shadow: 0 0 16px color-mix(in srgb, var(--color-mauve) 15%, transparent);
  }

  .section {
    padding: 6rem 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--color-muted) 50%, transparent);
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 1.4rem;
    margin: 0;
    position: relative;
    padding-bottom: 0.5rem;
    letter-spacing: -0.025em;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 2.5rem;
    height: 2px;
    background: linear-gradient(90deg, var(--color-peach), var(--color-mauve));
    border-radius: 2px;
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-peach) 60%, transparent);
  }

  .link-subtle {
    color: var(--color-subtle);
    transition: color 0.2s;
  }

  .link-subtle:hover { color: var(--color-peach); }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-ok);
  }

  .live-updated-label {
    color: var(--color-subtle);
    font-size: 0.68rem;
  }

  .live-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .live-card {
    background: color-mix(in srgb, var(--color-surface) 65%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);
    border-top: 1px solid color-mix(in srgb, white 9%, transparent);
    border-radius: 14px;
    padding: 1.35rem;
    min-height: 100px;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
  }

  .live-card:hover {
    border-color: color-mix(in srgb, var(--color-peach) 35%, var(--color-muted));
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.45), 0 0 0 1px color-mix(in srgb, var(--color-peach) 15%, transparent);
    transform: translateY(-2px);
  }

  .live-card::after {
    content: '';
    pointer-events: none;
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s;
    background: radial-gradient(
      500px circle at calc(var(--mx, 50%) * 1%) calc(var(--my, 50%) * 1%),
      rgba(255,255,255,0.07) 0%,
      rgba(255,255,255,0.025) 40%,
      transparent 65%
    );
    z-index: 10;
  }
  .live-card:hover::after { opacity: 1; }

  .status-strip {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  /* ── Service card grid ── */
  .svc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .svc-card {
    position: relative;
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    backdrop-filter: blur(8px);
    border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);
    border-top: 1px solid color-mix(in srgb, white 7%, transparent);
    border-radius: 14px;
    padding: 1.25rem 1.25rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    overflow: hidden;
    cursor: default;
  }

  .svc-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--svc-color, var(--color-ok));
    opacity: 0.7;
    border-radius: 14px 14px 0 0;
    transition: opacity 0.2s;
  }

  .svc-card::after {
    content: '';
    pointer-events: none;
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s;
    background: radial-gradient(
      400px circle at calc(var(--mx, 50%) * 1%) calc(var(--my, 50%) * 1%),
      rgba(255,255,255,0.06) 0%,
      transparent 65%
    );
    z-index: 1;
  }

  .svc-card:hover {
    border-color: color-mix(in srgb, var(--svc-color, var(--color-ok)) 40%, var(--color-muted));
    box-shadow: 0 8px 32px rgba(0,0,0,0.35), 0 0 0 1px color-mix(in srgb, var(--svc-color, var(--color-ok)) 12%, transparent);
    transform: translateY(-2px);
  }

  .svc-card:hover::before { opacity: 1; }
  .svc-card:hover::after { opacity: 1; }

  .svc-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .svc-card-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--svc-color, var(--color-ok));
    box-shadow: 0 0 6px var(--svc-color, var(--color-ok));
    flex-shrink: 0;
    animation: svc-pulse 2.5s ease-in-out infinite;
  }

  @keyframes svc-pulse {
    0%, 100% { box-shadow: 0 0 3px var(--svc-color, var(--color-ok)); }
    50%       { box-shadow: 0 0 10px var(--svc-color, var(--color-ok)); }
  }

  .svc-card-badge {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--svc-color, var(--color-ok));
    background: color-mix(in srgb, var(--svc-color, var(--color-ok)) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--svc-color, var(--color-ok)) 30%, transparent);
    border-radius: 4px;
    padding: 0.12rem 0.45rem;
  }

  .svc-card-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .svc-card-meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-subtle);
    line-height: 1.5;
    min-height: 1.05rem;
  }

  .svc-card.skeleton {
    height: 110px;
    animation: skeleton-shimmer 1.5s ease-in-out infinite;
  }

  @keyframes skeleton-shimmer {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 0.7; }
  }

  @media (max-width: 600px) {
    .svc-grid { grid-template-columns: repeat(2, 1fr); }
  }


  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2rem; }
    .hero-left { padding-bottom: 0; }
  }

  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; gap: 2rem; }
    .hero { padding: 3rem 1.25rem 2.5rem; }
    .hero-accent { margin-right: 1.5rem; min-height: 160px; }
    .hero-stats { flex-wrap: wrap; width: 100%; }
    .hero-stat { flex: 1; min-width: 80px; }
    .stack-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.5rem; }
    .contrib-grid { gap: 1.5px; }
    .contrib-cell { width: 8px; height: 8px; }
  }

  @media (max-width: 480px) {
    .stack-grid { grid-template-columns: repeat(2, 1fr); }
    .hero-accent { display: none; }
    .hero-stat-val { font-size: 1.4rem; }
  }

  /* ── Stack grid ── */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(168px, 1fr));
    gap: 0.85rem;
  }

  .stack-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid color-mix(in srgb, var(--color-muted) 60%, transparent);
    border-top: 1px solid color-mix(in srgb, white 8%, transparent);
    border-radius: 12px;
    padding: 1.1rem 1.1rem 1rem;
    transition: border-color 0.25s, box-shadow 0.25s;
    position: relative;
    overflow: hidden;
    cursor: default;
    will-change: transform;
  }

  /* Ambient glow behind each card */
  .stack-item::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 12px;
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
    z-index: 0;
  }

  .stack-item[data-accent="peach"]::after    { box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-peach)    45%, transparent); }
  .stack-item[data-accent="mauve"]::after    { box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-mauve)    45%, transparent); }
  .stack-item[data-accent="gold"]::after     { box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-gold)     45%, transparent); }
  .stack-item[data-accent="sapphire"]::after { box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-sapphire) 45%, transparent); }
  .stack-item[data-accent="crit"]::after     { box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-crit)     45%, transparent); }

  /* Coloured top bar */
  .stack-item::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    border-radius: 12px 12px 0 0;
    opacity: 0.6;
    transition: opacity 0.25s, box-shadow 0.25s;
    z-index: 1;
  }

  .stack-item[data-accent="peach"]::before    { background: var(--color-peach); }
  .stack-item[data-accent="mauve"]::before    { background: var(--color-mauve); }
  .stack-item[data-accent="gold"]::before     { background: var(--color-gold); }
  .stack-item[data-accent="sapphire"]::before { background: var(--color-sapphire); }
  .stack-item[data-accent="crit"]::before     { background: var(--color-crit); }

  .stack-item:hover::before { opacity: 1; }
  .stack-item:hover::after  { opacity: 1; }

  .stack-item[data-accent="peach"]:hover    { box-shadow: 0 12px 32px rgba(0,0,0,0.4), 0 0 20px color-mix(in srgb, var(--color-peach)    18%, transparent); }
  .stack-item[data-accent="mauve"]:hover    { box-shadow: 0 12px 32px rgba(0,0,0,0.4), 0 0 20px color-mix(in srgb, var(--color-mauve)    18%, transparent); }
  .stack-item[data-accent="gold"]:hover     { box-shadow: 0 12px 32px rgba(0,0,0,0.4), 0 0 20px color-mix(in srgb, var(--color-gold)     18%, transparent); }
  .stack-item[data-accent="sapphire"]:hover { box-shadow: 0 12px 32px rgba(0,0,0,0.4), 0 0 20px color-mix(in srgb, var(--color-sapphire) 18%, transparent); }
  .stack-item[data-accent="crit"]:hover     { box-shadow: 0 12px 32px rgba(0,0,0,0.4), 0 0 20px color-mix(in srgb, var(--color-crit)     18%, transparent); }

  .stack-item > * { position: relative; z-index: 2; }

  .stack-name {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-heading);
    letter-spacing: 0.01em;
  }

  .stack-role {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-subtle);
    line-height: 1.4;
  }

  /* ── Activity cards ── */
  .act-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 640px) { .act-wrap { grid-template-columns: 1fr; } }

  .act-repo-card {
    position: relative;
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    backdrop-filter: blur(10px);
    border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);
    border-top: 1px solid color-mix(in srgb, white 8%, transparent);
    border-radius: 16px;
    padding: 1.5rem 1.5rem 1.25rem;
    overflow: hidden;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s ease, border-color 0.2s, box-shadow 0.2s;
  }

  .act-repo-card.reveal { opacity: 1; transform: translateY(0); }

  .act-repo-card:hover {
    border-color: color-mix(in srgb, var(--color-peach) 35%, var(--color-muted));
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }

  .act-repo-card::before {
    content: \'\';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-peach), var(--color-mauve));
    border-radius: 16px 16px 0 0;
  }

  .act-repo-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .act-repo-name {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-peach);
    letter-spacing: 0.04em;
  }

  .act-repo-link {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-subtle);
    text-decoration: none;
    transition: color 0.15s;
  }
  .act-repo-link:hover { color: var(--color-peach); }

  .act-stat-row {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }

  .act-stat-num {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-heading);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .act-stat-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-subtle);
    letter-spacing: 0.03em;
  }

  .act-heatmap {
    display: flex;
    gap: 3px;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .act-pip {
    width: 10px; height: 10px;
    border-radius: 2px;
    background: var(--color-ok);
    opacity: 0.15;
  }
  .act-pip.active {
    opacity: 1;
    box-shadow: 0 0 4px var(--color-ok);
  }

  .act-last-commit {
    font-family: var(--font-mono);
    font-size: 0.73rem;
    color: var(--color-text);
    line-height: 1.5;
    padding-top: 0.9rem;
    border-top: 1px solid color-mix(in srgb, var(--color-muted) 35%, transparent);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .act-commit-label {
    display: block;
    font-size: 0.6rem;
    color: var(--color-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.3rem;
  }

  .act-time-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.6rem;
  }

  .act-time {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--color-subtle);
  }

  .act-type-pills { display: flex; gap: 0.35rem; }

  .act-pill {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.12rem 0.45rem;
    border-radius: 4px;
  }
  .act-pill.push   { color: var(--color-ok);    background: color-mix(in srgb, var(--color-ok)    10%, transparent); border: 1px solid color-mix(in srgb, var(--color-ok)    28%, transparent); }
  .act-pill.pr     { color: var(--color-mauve);  background: color-mix(in srgb, var(--color-mauve) 10%, transparent); border: 1px solid color-mix(in srgb, var(--color-mauve) 28%, transparent); }
  .act-pill.deploy { color: var(--color-peach);  background: color-mix(in srgb, var(--color-peach) 10%, transparent); border: 1px solid color-mix(in srgb, var(--color-peach) 28%, transparent); }

  .act-empty {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-subtle);
    grid-column: 1 / -1;
    text-align: center;
    padding: 2rem;
  }


  /* ── Cinematic manifesto strip ── */
  .manifesto-strip {
    padding: 4rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    background: linear-gradient(
      to bottom,
      transparent,
      color-mix(in srgb, var(--color-mauve) 4%, transparent) 50%,
      transparent
    );
  }

  .manifesto-strip::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 60%;
    height: 1px;
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--color-muted) 50%, transparent), transparent);
  }

  .manifesto-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .manifesto-line {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3.5vw, 2.2rem);
    font-weight: 700;
    color: var(--color-subtle);
    letter-spacing: -0.03em;
  }

  .manifesto-accent {
    background: linear-gradient(135deg, var(--color-peach), var(--color-mauve));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 20px color-mix(in srgb, var(--color-peach) 40%, transparent));
  }

  .manifesto-sep {
    color: var(--color-muted);
    font-size: 1.5rem;
    font-weight: 300;
  }

  .skeleton {
    background: linear-gradient(
      90deg,
      var(--color-surface) 25%,
      var(--color-overlay) 50%,
      var(--color-surface) 75%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }


  /* ── About section ── */
  .about-section {
    border-top: 1px solid var(--color-muted);
    background: linear-gradient(to bottom, transparent, color-mix(in srgb, var(--color-mantle) 60%, transparent));
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  .about-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .about-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-subtle);
    border: 1px solid var(--color-muted);
    border-radius: 6px;
    padding: 0.35rem 0.8rem;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .about-link:hover {
    color: var(--color-peach);
    border-color: var(--color-peach);
    background: color-mix(in srgb, var(--color-peach) 8%, transparent);
  }

  .about-link-icon {
    font-size: 0.75rem;
    opacity: 0.7;
  }

  .hw-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-subtle);
    margin-bottom: 1rem;
  }

  .hw-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .hw-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    cursor: pointer;
    transition: border-color 0.2s;
    user-select: none;
  }

  .hw-item:hover { border-color: var(--color-mauve); }
  .hw-item.open  { border-color: var(--color-mauve); }

  .hw-main { flex: 1; min-width: 0; }

  .hw-name-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .hw-chevron {
    font-size: 1rem;
    color: var(--color-subtle);
    transition: transform 0.2s, color 0.2s;
    flex-shrink: 0;
  }

  .hw-item.open .hw-chevron {
    transform: rotate(90deg);
    color: var(--color-mauve);
  }

  .hw-specs {
    display: none;
    font-size: 0.72rem;
    color: var(--color-subtle);
    line-height: 1.6;
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-muted);
  }

  .hw-item.open .hw-specs { display: block; }

  .hw-icon {
    color: var(--color-mauve);
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .hw-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-heading);
    line-height: 1.3;
  }

  .hw-sub {
    font-size: 0.72rem;
    color: var(--color-subtle);
    margin-top: 0.15rem;
  }

  /* ── GitHub contribution graph ── */
  .contrib-wrap {
    margin-top: 2rem;
    border-top: 1px solid var(--color-muted);
    padding-top: 1.25rem;
  }

  .contrib-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .contrib-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-subtle);
  }

  .contrib-graph {
    overflow-x: auto;
    padding-bottom: 0.25rem;
  }

  .contrib-grid {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(7, 10px);
    gap: 2px;
    width: max-content;
  }

  .contrib-cell {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    background: var(--color-overlay);
    transition: transform 0.15s;
    cursor: default;
    flex-shrink: 0;
  }

  .contrib-cell:hover { transform: scale(1.4); }

  .contrib-cell[data-level="0"] { background: var(--color-overlay); }
  .contrib-cell[data-level="1"] { background: color-mix(in srgb, var(--color-peach) 25%, var(--color-overlay)); }
  .contrib-cell[data-level="2"] { background: color-mix(in srgb, var(--color-peach) 50%, var(--color-overlay)); }
  .contrib-cell[data-level="3"] { background: color-mix(in srgb, var(--color-peach) 75%, var(--color-overlay)); }
  .contrib-cell[data-level="4"] { background: var(--color-peach); }

  .contrib-loading {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-subtle);
    padding: 1rem 0;
  }

  .contrib-legend {
    display: flex;
    align-items: center;
    gap: 3px;
    margin-top: 0.5rem;
    justify-content: flex-end;
  }

  .contrib-legend .contrib-cell {
    width: 10px;
    height: 10px;
    cursor: default;
  }
  .contrib-legend .contrib-cell:hover { transform: none; }

  /* ── Blog grid ── */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    backdrop-filter: blur(8px);
    border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);
    border-top: 1px solid color-mix(in srgb, white 7%, transparent);
    border-radius: 12px;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
  }

  .blog-card:hover {
    border-color: color-mix(in srgb, var(--color-mauve) 45%, var(--color-muted));
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.4), 0 0 0 1px color-mix(in srgb, var(--color-mauve) 12%, transparent);
    color: inherit;
  }

  .blog-card::after {
    content: '';
    pointer-events: none;
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s;
    background: radial-gradient(
      500px circle at calc(var(--mx, 50%) * 1%) calc(var(--my, 50%) * 1%),
      rgba(255,255,255,0.07) 0%,
      rgba(255,255,255,0.025) 40%,
      transparent 65%
    );
    z-index: 10;
  }
  .blog-card:hover::after { opacity: 1; }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .blog-date {
    font-size: 0.72rem;
    color: var(--color-subtle);
  }

  .blog-adr {
    font-size: 0.68rem;
    color: var(--color-mauve);
    background: color-mix(in srgb, var(--color-mauve) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-mauve) 25%, transparent);
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
  }

  .blog-card-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.35;
  }

  .blog-card-summary {
    font-size: 0.82rem;
    color: var(--color-subtle);
    line-height: 1.6;
    flex: 1;
  }

  .blog-read {
    font-size: 0.72rem;
    color: var(--color-peach);
    margin-top: 0.25rem;
  }
</style>

<script>
  // ── Fallback static list — shown immediately before live.json loads
  const STATIC_SERVICES = [
    { name: 'Immich',    tag: 'photo library',   status: 'ok' },
    { name: 'Nextcloud', tag: 'file storage',     status: 'ok' },
    { name: 'SABnzbd',   tag: 'download client',  status: 'ok' },
    { name: 'Sonarr',    tag: 'tv automation',    status: 'ok' },
    { name: 'Radarr',    tag: 'movie automation', status: 'ok' },
    { name: 'Lidarr',    tag: 'music automation', status: 'ok' },
  ];

  const SVC_COLORS: Record<string, string> = {
    Immich:    'var(--color-sapphire)',
    Nextcloud: 'var(--color-mauve)',
    SABnzbd:   'var(--color-gold)',
    Sonarr:    'var(--color-peach)',
    Radarr:    'var(--color-peach)',
    Lidarr:    'var(--color-ok)',
  };

  // ── Service card grid builder ──
  function buildSvcGrid(services: any[]) {
    const grid = document.getElementById('svc-grid');
    if (!grid) return;

    grid.innerHTML = services.map(s => {
      const colonIdx = s.tag?.indexOf(':') ?? -1;
      const meta = colonIdx > -1 ? s.tag.slice(colonIdx + 1).trim() : (s.tag && s.tag !== '—' ? s.tag : '');
      const color = SVC_COLORS[s.name] ?? 'var(--color-peach)';
      const badge = s.status === 'ok' ? 'online' : s.status === 'warn' ? 'degraded' : s.status === 'unknown' ? 'checking' : 'offline';
      return `
        <div class="svc-card" style="--svc-color:${color}">
          <div class="svc-card-header">
            <span class="svc-card-dot"></span>
            <span class="svc-card-badge">${badge}</span>
          </div>
          <div class="svc-card-name">${s.name}</div>
          <div class="svc-card-meta">${meta || '—'}</div>
        </div>`;
    }).join('');
  }

  async function loadLiveData() {
    buildSvcGrid(STATIC_SERVICES);

    try {
      const res = await fetch('/data/live.json');
      if (!res.ok) throw new Error('no data');
      const data = await res.json();
      // Push data to ClusterTerminal component
      if (typeof (window as any).__termSetData === 'function') {
        (window as any).__termSetData(data);
      }

      // Populate hero stat strip with counting animation
      function countUp(el: HTMLElement, target: string, duration = 650) {
        const num = parseInt(target);
        if (isNaN(num)) { el.textContent = target; return; }
        const start = performance.now();
        const tick = (now: number) => {
          const pct = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - pct, 3);
          el.textContent = String(Math.round(ease * num));
          if (pct < 1) requestAnimationFrame(tick);
          else el.textContent = target;
        };
        requestAnimationFrame(tick);
      }

      if (data.nodes) {
        const ready = data.nodes.filter((n: any) => n.status === 'ok').length;
        const total = data.nodes.length;
        const pods = data.nodes.reduce((sum: number, n: any) => sum + (parseInt(n.pods) || 0), 0);
        const statNodes = document.getElementById('stat-nodes');
        const statPods  = document.getElementById('stat-pods');
        if (statNodes) countUp(statNodes, `${ready}/${total}`);
        if (statPods)  countUp(statPods,  String(pods));
      }
      if (data.flux) {
        const statFlux = document.getElementById('stat-flux');
        const fluxVal = String(data.flux.ready ?? data.flux.total ?? '—');
        if (statFlux) countUp(statFlux, fluxVal);
      }

      // "Updated X min ago" label
      if (data.updated) {
        const mins = Math.round((Date.now() - new Date(data.updated).getTime()) / 60000);
        const badge = document.getElementById('live-updated');
        if (badge) badge.textContent = `updated ${mins}m ago`;
      }

      const grid = document.getElementById('live-grid');
      if (grid && data.cards) {
        grid.innerHTML = data.cards.map((card: any) => `
          <div class="live-card fade-up">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem">
              <span class="mono" style="color:var(--color-subtle)">${card.label}</span>
              <span class="status-dot ${card.status}"></span>
            </div>
            <div style="font-size:1.5rem;font-weight:700;color:var(--color-heading);font-family:var(--font-mono)">${card.value}</div>
            <div class="mono" style="margin-top:0.25rem">${card.sub ?? ''}</div>
          </div>
        `).join('');
      }

      if (data.services?.length) buildSvcGrid(data.services);

      const strip = document.getElementById('status-strip');
      if (strip && data.nodes) {
        strip.innerHTML = data.nodes.map((node: any) => {
          const pressureWarning = node.pressure?.length
            ? `<span style="color:var(--color-warn);font-size:0.7rem;margin-left:0.5rem">${node.pressure.join(', ')}</span>`
            : '';
          return `
          <div style="background:var(--color-surface);border:1px solid var(--color-muted);border-radius:8px;padding:0.875rem 1rem;display:flex;align-items:center;gap:0.75rem">
            <span class="status-dot ${node.status}"></span>
            <div>
              <div style="font-size:0.875rem;color:var(--color-heading);font-weight:600">${node.name}${pressureWarning}</div>
              <div class="mono">${node.role}</div>
            </div>
            <div style="margin-left:auto;text-align:right">
              <div class="mono" style="color:var(--color-peach)">${node.pods} pods</div>
              <div class="mono">${node.cpu} CPU · ${node.memory} mem</div>
            </div>
          </div>`;
        }).join('');
      }
    } catch {
      // stat strip stays at em-dash placeholders on failure
    }
  }

  async function loadDigest() {
    try {
      const res = await fetch('/data/digest.json');
      if (!res.ok) throw new Error('no data');
      const entries = await res.json();
      const list = document.getElementById('digest-list');
      if (list) {
        const TYPE_COLOR: Record<string, string> = {
          DEPLOY: 'var(--color-ok)', FIX: 'var(--color-peach)', INCIDENT: 'var(--color-crit)',
          HARDWARE: 'var(--color-gold)', NETWORK: 'var(--color-mauve)', SECURITY: 'var(--color-warn)',
        };
        list.innerHTML = entries.slice(0, 3).map((e: any) => {
          const color = TYPE_COLOR[e.type] ?? 'var(--color-subtle)';
          const tag = e.hasDetail ? 'a' : 'div';
          const href = e.hasDetail ? `href="/digest/entry?slug=${e.slug}"` : '';
          return `
          <${tag} ${href} style="display:block;text-decoration:none;margin-bottom:0.75rem">
            <div class="card" style="padding:1rem;transition:border-color 0.15s${e.hasDetail ? ';cursor:pointer' : ''}">
              <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.4rem">
                <span style="font-family:var(--font-mono);font-size:0.65rem;font-weight:600;padding:0.15rem 0.45rem;border-radius:4px;background:color-mix(in srgb,${color} 12%,transparent);color:${color};text-transform:uppercase;letter-spacing:0.05em">${e.type}</span>
                <span class="mono" style="color:var(--color-subtle);font-size:0.72rem">${e.date}</span>
                ${e.hasDetail ? `<span class="mono" style="color:var(--color-peach);font-size:0.7rem;margin-left:auto">read more →</span>` : ''}
              </div>
              <div style="color:var(--color-heading);font-weight:600;font-size:0.875rem;line-height:1.4">${e.title}</div>
            </div>
          </${tag}>`;
        }).join('');
      }
    } catch { /* no data yet */ }
  }

  async function loadProject() {
    try {
      const res = await fetch('/data/roadmap.json');
      if (!res.ok) throw new Error('no data');
      const data = await res.json();
      const active = data.active?.[0];
      if (!active) return;
      const el = document.getElementById('active-project');
      if (el) {
        const progressHtml = active.progress != null ? `
          <div style="margin:1rem 0">
            <div style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:0.68rem;color:var(--color-subtle);margin-bottom:0.35rem">
              <span>progress</span><span>${active.progress}%</span>
            </div>
            <div style="height:4px;background:var(--color-overlay);border-radius:2px;overflow:hidden">
              <div style="height:100%;width:${active.progress}%;background:var(--color-ok);border-radius:2px"></div>
            </div>
          </div>` : '';
        const stackHtml = active.stack?.length
          ? `<div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:1rem">${active.stack.map((s: string) => `<span style="font-family:var(--font-mono);font-size:0.68rem;padding:0.2rem 0.55rem;border-radius:4px;background:var(--color-overlay);color:var(--color-subtle);border:1px solid var(--color-muted)">${s}</span>`).join('')}</div>`
          : '';
        el.innerHTML = `
          <a href="/projects" style="display:block;text-decoration:none">
            <div class="card" style="transition:border-color 0.15s">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
                <span class="mono" style="color:var(--color-ok);font-size:0.75rem;display:flex;align-items:center;gap:0.35rem">● active</span>
                <span class="mono" style="color:var(--color-subtle);font-size:0.72rem">→ roadmap</span>
              </div>
              <h3 style="margin:0 0 0.2rem;font-size:1.1rem">${active.title}</h3>
              <div class="mono" style="color:var(--color-subtle);font-size:0.75rem;margin-bottom:0.75rem">${active.subtitle}</div>
              <p style="color:var(--color-subtle);font-size:0.875rem;margin:0;line-height:1.6">${active.description}</p>
              ${progressHtml}
              ${stackHtml}
            </div>
          </a>
        `;
      }
    } catch { /* no data yet */ }
  }

  // Fire on both first load and Astro view-transition navigations
  let _pageInited = false;
  function initPage() {
    if (_pageInited) return;
    _pageInited = true;
    loadLiveData();
    loadDigest();
    loadProject();
    // Reset for next navigation
    setTimeout(() => { _pageInited = false; }, 500);
  }

  document.addEventListener('astro:page-load', initPage);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPage);
  } else {
    initPage();
  }

  // ── Dot-grid background ──────────────────────────────────────────────────
  // ── Particle network (cursor-reactive) ──────────────────────────────────
  (function initParticleNet() {
    const canvas = document.getElementById('hero-grid') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const PARTICLE_COUNT = 70;
    const MAX_DIST       = 140;   // max px before a line fades out
    const CURSOR_ATTRACT = 180;   // px radius around cursor that attracts
    const CURSOR_FORCE   = 0.012; // strength of cursor pull
    const BASE_SPEED     = 0.28;
    const PEACH  = [250, 179, 135] as const;
    const MAUVE  = [203, 166, 247] as const;
    const SAPHIR = [116, 199, 236] as const;
    const COLS   = [PEACH, MAUVE, SAPHIR];

    let W = 0, H = 0, raf = 0;
    let mouse = { x: -9999, y: -9999 };

    type Particle = {
      x: number; y: number;
      vx: number; vy: number;
      r: number;
      col: readonly [number,number,number];
      alpha: number;
    };

    let particles: Particle[] = [];

    function resize() {
      const rect = canvas.parentElement!.getBoundingClientRect();
      W = canvas.width  = rect.width;
      H = canvas.height = rect.height;
    }

    function spawn(): Particle {
      const col = COLS[Math.floor(Math.random() * COLS.length)];
      const angle = Math.random() * Math.PI * 2;
      return {
        x: Math.random() * W,
        y: Math.random() * H,
        vx: Math.cos(angle) * BASE_SPEED * (0.5 + Math.random()),
        vy: Math.sin(angle) * BASE_SPEED * (0.5 + Math.random()),
        r: 1.5 + Math.random() * 1.5,
        col,
        alpha: 0.4 + Math.random() * 0.5,
      };
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);

      // Update positions + cursor attraction
      for (const p of particles) {
        const dx = mouse.x - p.x;
        const dy = mouse.y - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CURSOR_ATTRACT && dist > 1) {
          p.vx += (dx / dist) * CURSOR_FORCE;
          p.vy += (dy / dist) * CURSOR_FORCE;
        }
        // Speed limit
        const spd = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
        if (spd > 1.2) { p.vx *= 0.97; p.vy *= 0.97; }

        p.x += p.vx;
        p.y += p.vy;

        // Wrap around edges
        if (p.x < 0)  p.x = W;
        if (p.x > W)  p.x = 0;
        if (p.y < 0)  p.y = H;
        if (p.y > H)  p.y = 0;
      }

      // Draw connecting lines between nearby particles
      for (let i = 0; i < particles.length; i++) {
        const a = particles[i];
        for (let j = i + 1; j < particles.length; j++) {
          const b = particles[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const d  = Math.sqrt(dx * dx + dy * dy);
          if (d > MAX_DIST) continue;

          const t = 1 - d / MAX_DIST;
          const [r, g, bv] = a.col;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.strokeStyle = `rgba(${r},${g},${bv},${t * 0.22})`;
          ctx.lineWidth = t * 1.2;
          ctx.stroke();
        }

        // Lines from particle to cursor
        const cdx = a.x - mouse.x;
        const cdy = a.y - mouse.y;
        const cd  = Math.sqrt(cdx * cdx + cdy * cdy);
        if (cd < CURSOR_ATTRACT) {
          const t = 1 - cd / CURSOR_ATTRACT;
          const [r, g, bv] = a.col;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(mouse.x, mouse.y);
          ctx.strokeStyle = `rgba(${r},${g},${bv},${t * 0.45})`;
          ctx.lineWidth = t * 1.5;
          ctx.stroke();
        }
      }

      // Draw dots
      for (const p of particles) {
        const [r, g, bv] = p.col;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r},${g},${bv},${p.alpha})`;
        ctx.fill();
      }

      raf = requestAnimationFrame(draw);
    }

    const obs = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) { raf = requestAnimationFrame(draw); }
      else { cancelAnimationFrame(raf); }
    }, { threshold: 0 });

    resize();
    particles = Array.from({ length: PARTICLE_COUNT }, spawn);
    obs.observe(canvas);
    window.addEventListener('resize', () => { resize(); }, { passive: true });

    // Track cursor relative to canvas
    canvas.parentElement!.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    }, { passive: true });
    canvas.parentElement!.addEventListener('mouseleave', () => {
      mouse.x = -9999; mouse.y = -9999;
    }, { passive: true });

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      cancelAnimationFrame(raf);
      requestAnimationFrame(draw);
    }
  })();

  // ── H1 Typewriter ────────────────────────────────────────────────────────
  (function initTypewriter() {
    const line1El  = document.getElementById('h1-line1');
    const line2El  = document.getElementById('h1-line2');
    const cursorEl = document.querySelector('.h1-cursor') as HTMLElement;
    if (!line1El || !line2El || !cursorEl) return;

    const LINE1 = 'Living';
    const LINE2 = 'Homelab';

    function typeInto(el: HTMLElement, text: string, charDelay: number, onDone: () => void) {
      let i = 0;
      function tick() {
        if (i <= text.length) {
          el.textContent = text.slice(0, i);
          i++;
          setTimeout(tick, charDelay + Math.random() * 30);
        } else {
          onDone();
        }
      }
      tick();
    }

    // Type line 1, pause (as if reconsidering), then type line 2, then hide cursor
    typeInto(line1El, LINE1, 90, () => {
      setTimeout(() => {
        typeInto(line2El, LINE2, 80, () => {
          setTimeout(() => cursorEl.classList.add('done'), 900);
        });
      }, 420);
    });
  })();


  // ── GitHub contribution graph ────────────────────────────────────────────
  function renderContribGraph(dayCounts: Record<string, number>, graphEl: HTMLElement, totalEl: HTMLElement | null) {
    const maxCount = Math.max(1, ...Object.values(dayCounts));
    const toLevel = (n: number) => n === 0 ? 0 : Math.min(4, Math.ceil((n / maxCount) * 4));

    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const gridEnd = new Date(today);
    gridEnd.setDate(gridEnd.getDate() + (6 - today.getDay()));

    const cells: { date: string; level: number; count: number }[] = [];
    for (let w = 51; w >= 0; w--) {
      for (let d = 0; d < 7; d++) {
        const dt = new Date(gridEnd);
        dt.setDate(dt.getDate() - w * 7 - (6 - d));
        const iso = dt.toISOString().slice(0, 10);
        const count = dayCounts[iso] ?? 0;
        cells.push({ date: iso, level: toLevel(count), count });
      }
    }

    const grid = document.createElement('div');
    grid.className = 'contrib-grid';
    grid.innerHTML = cells.map(c => {
      const tip = c.count > 0
        ? `${c.date} · ${c.count} contribution${c.count > 1 ? 's' : ''}`
        : `${c.date} · no contributions`;
      return `<span class="contrib-cell" data-level="${c.level}" title="${tip}"></span>`;
    }).join('');

    graphEl.innerHTML = '';
    graphEl.appendChild(grid);

    if (totalEl) {
      const activeDays = cells.filter(c => c.level > 0).length;
      const totalContribs = Object.values(dayCounts).reduce((a, b) => a + b, 0);
      totalEl.textContent = `${totalContribs} contributions · ${activeDays} active days (last 90 days)`;
    }
  }

  async function loadContribGraph() {
    const graphEl = document.getElementById('contrib-graph');
    const totalEl = document.getElementById('contrib-total');
    if (!graphEl) return;

    try {
      // Prefer pre-fetched data from live.json (updated every 30 min, no rate-limit risk)
      const liveRes = await fetch('/data/live.json').then(r => r.ok ? r.json() : null).catch(() => null);
      if (liveRes?.contribs?.days && Object.keys(liveRes.contribs.days).length > 0) {
        renderContribGraph(liveRes.contribs.days, graphEl, totalEl);
        return;
      }

      // Fallback: fetch directly from GitHub API
      const user = 'Kagiso-me';
      const results = await Promise.all(
        [1, 2, 3].map(p =>
          fetch(`https://api.github.com/users/${user}/events/public?per_page=100&page=${p}`, {
            headers: { Accept: 'application/vnd.github+json' }
          }).then(r => r.ok ? r.json() : []).catch(() => [])
        )
      );
      const events: any[] = results.flat();

      const dayCounts: Record<string, number> = {};
      for (const ev of events) {
        const iso = ev.created_at?.slice(0, 10);
        if (!iso) continue;
        const commits = ev.type === 'PushEvent' ? (ev.payload?.commits?.length ?? 1) : 1;
        dayCounts[iso] = (dayCounts[iso] ?? 0) + commits;
      }

      renderContribGraph(dayCounts, graphEl, totalEl);
    } catch {
      if (graphEl) graphEl.innerHTML = '<div class="contrib-loading">graph unavailable</div>';
    }
  }

  loadContribGraph();

  // ── Hardware expand ──────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.hw-item').forEach(item => {
    const toggle = () => {
      const open = item.classList.toggle('open');
      item.setAttribute('aria-expanded', String(open));
    };
    item.addEventListener('click', toggle);
    item.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
    });
  });

  // ── Stack item 3D tilt ───────────────────────────────────────────────────────
  if (window.matchMedia('(pointer: fine)').matches) {
    document.querySelectorAll<HTMLElement>('.stack-item').forEach(card => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top  + rect.height / 2;
        const rx = ((e.clientY - cy) / (rect.height / 2)) * -6;
        const ry = ((e.clientX - cx) / (rect.width  / 2)) *  6;
        card.style.transform = `perspective(600px) rotateX(${rx}deg) rotateY(${ry}deg) translateZ(4px)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
      });
    });
  }

  // ── Activity cards — grouped by repo ────────────────────────────────────────
  (async function loadActivity() {
    const wrap = document.getElementById('act-wrap');
    if (!wrap) return;

    function relTime(iso: string) {
      const diff = Date.now() - new Date(iso).getTime();
      const m = Math.floor(diff / 60000);
      if (m < 1)  return 'just now';
      if (m < 60) return `${m}m ago`;
      const h = Math.floor(m / 60);
      if (h < 24) return `${h}h ago`;
      return `${Math.floor(h / 24)}d ago`;
    }

    const REPOS = [
      { id: 'homelab-infrastructure', label: 'homelab-infrastructure', url: 'https://github.com/Kagiso-me/homelab-infrastructure' },
      { id: 'kagiso-me.github.io',    label: 'kagiso-me.github.io',    url: 'https://github.com/Kagiso-me/kagiso-me.github.io' },
    ];

    const cutoff = Date.now() - 24 * 60 * 60 * 1000;

    try {
      const repoData = await Promise.all(REPOS.map(async repo => {
        try {
          const r = await fetch(`https://api.github.com/repos/Kagiso-me/${repo.id}/events?per_page=30`);
          if (!r.ok) return { ...repo, events: [] };
          const data: any[] = await r.json();
          const events = data.filter(ev => new Date(ev.created_at).getTime() > cutoff);
          return { ...repo, events };
        } catch {
          return { ...repo, events: [] };
        }
      }));

      const totalEvents = repoData.reduce((s, r) => s + r.events.length, 0);
      if (totalEvents === 0) {
        wrap.innerHTML = '<div class="act-empty mono">No activity in the last 24 hours.</div>';
        return;
      }

      wrap.innerHTML = '';

      repoData.forEach((repo, idx) => {
        const evs = repo.events;
        if (!evs.length) return;

        // Counts by type
        const pushCount   = evs.filter((e: any) => e.type === 'PushEvent').length;
        const prCount     = evs.filter((e: any) => e.type === 'PullRequestEvent').length;
        const deployCount = evs.filter((e: any) => e.type === 'CreateEvent' || e.type === 'ReleaseEvent').length;

        // Total commits across all push events
        const commitCount = evs
          .filter((e: any) => e.type === 'PushEvent')
          .reduce((s: number, e: any) => s + (e.payload?.commits?.length ?? 1), 0);

        // Most recent push commit message
        const lastPush = evs.find((e: any) => e.type === 'PushEvent');
        const lastMsg  = lastPush?.payload?.commits?.[0]?.message?.split('\n')[0]?.slice(0, 72) ?? '';
        const lastTime = evs[0]?.created_at ?? '';

        // 24-slot heatmap — one pip per event slot
        const SLOTS = 16;
        const oldest = new Date(evs[evs.length - 1]?.created_at ?? Date.now()).getTime();
        const range  = Date.now() - oldest || 1;
        const activePips = new Set(evs.map((e: any) =>
          Math.floor(((Date.now() - new Date(e.created_at).getTime()) / range) * (SLOTS - 1))
        ));
        const pips = Array.from({ length: SLOTS }, (_, i) =>
          `<div class="act-pip${activePips.has(i) ? ' active' : ''}"></div>`
        ).join('');

        // Type pills
        const pills = [
          pushCount   ? `<span class="act-pill push">${pushCount} push</span>` : '',
          prCount     ? `<span class="act-pill pr">${prCount} PR</span>` : '',
          deployCount ? `<span class="act-pill deploy">${deployCount} release</span>` : '',
        ].filter(Boolean).join('');

        const card = document.createElement('div');
        card.className = 'act-repo-card';
        card.innerHTML = `
          <div class="act-repo-header">
            <span class="act-repo-name">${repo.label}</span>
            <a class="act-repo-link" href="${repo.url}" target="_blank" rel="noopener">view →</a>
          </div>
          <div class="act-stat-row">
            <span class="act-stat-num">${commitCount}</span>
            <span class="act-stat-label">commit${commitCount !== 1 ? 's' : ''}<br>last 24h</span>
          </div>
          <div class="act-heatmap">${pips}</div>
          ${lastMsg ? `
          <div class="act-last-commit">
            <span class="act-commit-label">last commit</span>
            ${lastMsg}
          </div>` : ''}
          <div class="act-time-row">
            <span class="act-time">${lastTime ? relTime(lastTime) : ''}</span>
            <div class="act-type-pills">${pills}</div>
          </div>
        `;
        wrap.appendChild(card);
        setTimeout(() => card.classList.add('reveal'), idx * 120);
      });

    } catch {
      wrap.innerHTML = '<div class="act-empty mono">Activity unavailable.</div>';
    }
  })();

</script>
