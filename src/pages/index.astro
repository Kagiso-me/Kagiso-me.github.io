  .stack-item[data-accent="peach"]::before    { background: var(--color-peach); }
  .stack-item[data-accent="mauve"]::before    { background: var(--color-mauve); }
  .stack-item[data-accent="gold"]::before     { background: var(--color-gold); }
  .stack-item[data-accent="sapphire"]::before { background: var(--color-sapphire); }
