---
import Layout from '../layouts/Layout.astro';
// Editorial Status page. Every live region is wired to /data/live.json (built
// every ~30 min on bran). Service uptime is real Gatus data (app_uptime[]).
// Static-per-load config (network rows, topology) is described inline.
---

<Layout title="Status" description="Live cluster health, per-service uptime, storage, backups and GitOps — read straight off the hardware.">
  <div class="ed">

    <!-- ── HERO ── -->
    <header class="ed-hero">
      <div class="ed-eyebrow mono">~/status</div>
      <h1 class="ed-h1" id="ed-verdict">All systems operational.</h1>
      <p class="ed-lede">A real k3s cluster, built and run in public. Every figure below is read live off the hardware — no staging, no theatre.</p>
      <div class="ed-metrics">
        <div class="ed-metric"><div class="ed-metric-n mono" id="m-nodes">—</div><div class="ed-metric-l mono">nodes ready</div></div>
        <div class="ed-metric"><div class="ed-metric-n mono" id="m-pods">—</div><div class="ed-metric-l mono">pods running</div></div>
        <div class="ed-metric"><div class="ed-metric-n mono ok" id="m-uptime">—</div><div class="ed-metric-l mono">services healthy</div></div>
        <div class="ed-metric"><div class="ed-metric-n mono" id="m-incidents">—</div><div class="ed-metric-l mono">open incidents</div></div>
      </div>
    </header>

    <!-- ── KNOWN ISSUES ── -->
    <section class="ed-sec">
      <div class="ed-sec-head">
        <div><div class="ed-eyebrow mono">~/known-issues</div><h2 class="ed-h2">Known issues</h2></div>
        <span class="mono ed-note ok" id="ed-issues-note">—</span>
      </div>
      <div id="ed-issues"></div>
    </section>

    <!-- ── NODES ── -->
    <section class="ed-sec">
      <div class="ed-eyebrow mono">~/nodes</div>
      <h2 class="ed-h2">Nodes, live</h2>
      <div class="ed-nhead ed-ngrid mono">
        <span>Host</span><span>Role</span><span>Address</span><span>CPU</span><span>Mem</span>
      </div>
      <div id="ed-nodes"></div>
    </section>

    <!-- ── SERVICES (real Gatus uptime) ── -->
    <section class="ed-sec">
      <div class="ed-sec-head">
        <div><div class="ed-eyebrow mono">~/services</div><h2 class="ed-h2">Services, by uptime</h2></div>
        <span class="mono ed-note" id="ed-svc-note">measured by Gatus · per app</span>
      </div>
      <div class="ed-svhead ed-svgrid mono">
        <span>Service</span><span>Group</span><span style="text-align:right">Uptime</span><span style="text-align:right">Latency</span>
      </div>
      <div id="ed-services"></div>
    </section>

    <!-- ── CLUSTER INCIDENTS (real outages) ── -->
    <section class="ed-sec">
      <div class="ed-sec-head">
        <div><div class="ed-eyebrow mono">~/incidents</div><h2 class="ed-h2">Cluster incidents</h2></div>
        <span class="mono ed-note" id="ed-inc-stat">—</span>
      </div>
      <div class="ed-band" id="ed-band"></div>
      <div class="ed-band-axis mono"><span id="ed-band-start">60 days ago</span><span>today</span></div>
      <div class="ed-inc-log" id="ed-inc-log"></div>
    </section>

    <!-- ── TOPOLOGY ── -->
    <section class="ed-sec">
      <div class="ed-eyebrow mono">~/topology</div>
      <h2 class="ed-h2">Cluster topology</h2>
      <div class="ed-topo">
        <div class="ed-topo-row">
          <div class="ed-box"><span class="ed-box-t">Internet</span><span class="ed-box-s">WAN · fibre</span></div>
          <span class="ed-arrow">→</span>
          <div class="ed-box"><span class="ed-box-t">MikroTik <span class="ed-faint">.1</span></span><span class="ed-box-s">router · DNS · gateway</span></div>
          <span class="ed-arrow">→</span>
          <div class="ed-box"><span class="ed-box-t">MetalLB <span class="ed-faint">.100–120</span></span><span class="ed-box-s">L2 · Traefik ingress</span></div>
        </div>
        <div class="ed-box ed-cluster">
          <div class="ed-cluster-head"><span class="mono">k3s cluster · 10.0.10.0/24</span><span class="mono ok">etcd quorum · runs all workloads</span></div>
          <div class="ed-cluster-nodes">
            <div class="ed-chip"><span class="ed-dot" data-node="tywin"></span><span class="mono">tywin</span><span class="mono ed-faint">.11 · master</span></div>
            <div class="ed-chip"><span class="ed-dot" data-node="jaime"></span><span class="mono">jaime</span><span class="mono ed-faint">.12 · worker</span></div>
            <div class="ed-chip"><span class="ed-dot" data-node="tyrion"></span><span class="mono">tyrion</span><span class="mono ed-faint">.13 · worker</span></div>
          </div>
        </div>
        <div class="ed-topo-support">
          <div class="ed-box ed-support"><span class="ed-support-t"><span class="ed-dot ok"></span><span class="mono">varys <span class="ed-faint">.10</span></span></span><span class="ed-box-s">ci · gitops origin</span></div>
          <div class="ed-box ed-support"><span class="ed-support-t"><span class="ed-dot ok"></span><span class="mono">ned <span class="ed-faint">.80</span></span></span><span class="ed-box-s">truenas · nfs + minio</span></div>
          <div class="ed-box ed-support"><span class="ed-support-t"><span class="ed-dot ok"></span><span class="mono">bran <span class="ed-faint">.9</span></span></span><span class="ed-box-s">rpi · dns · ups watcher</span></div>
          <div class="ed-box ed-support ed-dashed"><span class="ed-support-t"><span class="ed-dot muted"></span><span class="mono ed-mut">bronn <span class="ed-faint">.20</span></span></span><span class="ed-box-s">standalone docker</span></div>
        </div>
      </div>
    </section>

    <!-- ── NETWORK ── -->
    <section class="ed-sec">
      <div class="ed-eyebrow mono">~/network</div>
      <h2 class="ed-h2">Network</h2>
      <div class="ed-net" id="ed-net"></div>
    </section>

    <!-- ── STORAGE ── -->
    <section class="ed-sec">
      <div class="ed-eyebrow mono">~/storage</div>
      <h2 class="ed-h2">Storage</h2>
      <div id="ed-storage"></div>
    </section>

    <!-- ── BACKUPS ── -->
    <section class="ed-sec">
      <div class="ed-eyebrow mono">~/backups</div>
      <h2 class="ed-h2">Backups</h2>
      <div id="ed-backups"></div>
      <div class="mono ed-foot-note">3-2-1 · 2 media · 1 offsite (Backblaze B2)</div>
    </section>

    <!-- ── INFRA ── -->
    <section class="ed-sec">
      <div class="ed-eyebrow mono">~/infra</div>
      <h2 class="ed-h2">Infrastructure &amp; GitOps</h2>
      <div class="ed-infra" id="ed-infra"></div>
    </section>

  </div>
</Layout>

<style is:global>
  .ed {
    --ed-bg: #0e0e11; --ed-tx: #eaeaed; --ed-mut: #9a9aa3; --ed-fnt: #63636b;
    --ed-hair: rgba(255,255,255,.09); --ed-hair2: rgba(255,255,255,.14);
    --ed-ok: #2fa06b; --ed-warn: #c98a1e; --ed-crit: #cf5349; --ed-muted: #6b6f77;
    --ed-serif: 'Newsreader', Georgia, serif;
    max-width: 1080px; margin: 0 auto; padding: 0 32px;
    color: var(--ed-tx); font-family: var(--font-sans);
  }
  .ed .mono { font-family: var(--font-mono); }
  .ed .ok { color: var(--ed-ok); }
  .ed .ed-mut { color: var(--ed-mut); }
  .ed .ed-faint { color: var(--ed-fnt); font-weight: 400; }
  .ed .ed-eyebrow { font-size: 11px; letter-spacing: .16em; text-transform: uppercase; color: var(--ed-mut); }
  .ed .ed-h2 { font-family: var(--ed-serif); font-weight: 500; font-size: 29px; margin: 9px 0 0; color: var(--ed-tx); letter-spacing: -.01em; }

  /* HERO */
  .ed-hero { padding: 60px 0 6px; }
  .ed-h1 { font-family: var(--ed-serif); font-weight: 500; font-size: clamp(40px, 6vw, 64px); line-height: 1.02; letter-spacing: -.02em; margin: 16px 0 0; color: var(--ed-tx); }
  .ed-lede { margin: 18px 0 0; max-width: 60ch; font-size: 16px; line-height: 1.65; color: var(--ed-mut); }
  .ed-metrics { display: grid; grid-template-columns: repeat(4, 1fr); margin-top: 44px; border-top: 1px solid var(--ed-hair); }
  .ed-metric { padding: 22px 22px 22px 0; }
  .ed-metric + .ed-metric { border-left: 1px solid var(--ed-hair); padding-left: 22px; }
  .ed-metric-n { font-size: 36px; font-weight: 500; font-variant-numeric: tabular-nums; color: var(--ed-tx); }
  .ed-metric-l { font-size: 11px; letter-spacing: .04em; color: var(--ed-mut); margin-top: 6px; }

  /* SECTIONS */
  .ed-sec { padding: 46px 0; border-top: 1px solid var(--ed-hair); }
  .ed-sec-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 20px; flex-wrap: wrap; gap: 8px; }
  .ed-note { font-size: 12px; color: var(--ed-fnt); }

  /* KNOWN ISSUES */
  .ed-issue { display: flex; gap: 16px; padding: 16px 0; border-top: 1px solid var(--ed-hair); }
  .ed-issue:first-child { border-top: none; }
  .ed-issue-tag { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: .1em; border: 1px solid; border-radius: 4px; padding: 3px 7px; height: fit-content; flex: none; }
  .ed-issue-title { font-size: 14.5px; color: var(--ed-tx); font-weight: 500; }
  .ed-issue-detail { font-size: 13px; color: var(--ed-mut); margin-top: 4px; line-height: 1.55; }

  /* NODES */
  .ed-ngrid { display: grid; grid-template-columns: 1.15fr 1.7fr 1fr 1.15fr 1.15fr; gap: 16px; align-items: center; }
  .ed-nhead { font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--ed-fnt); padding-bottom: 2px; }
  .ed-nrow { padding: 13px 0; border-top: 1px solid var(--ed-hair); font-family: var(--font-mono); font-size: 13px; transition: background .15s; }
  .ed-nrow:hover { background: rgba(255,255,255,.02); }
  .ed-nname { display: flex; align-items: center; gap: 9px; color: var(--ed-tx); font-weight: 500; }
  .ed-nrole { font-size: 12.5px; color: var(--ed-mut); font-family: var(--font-sans); }
  .ed-nip { font-size: 11.5px; color: var(--ed-fnt); }
  .ed-bar { display: flex; align-items: center; gap: 9px; }
  .ed-bar-track { flex: 1; height: 4px; border-radius: 2px; background: rgba(255,255,255,.08); overflow: hidden; }
  .ed-bar-fill { display: block; height: 100%; transition: width .8s ease; }
  .ed-bar-val { font-size: 11.5px; color: var(--ed-mut); width: 34px; text-align: right; font-variant-numeric: tabular-nums; }

  /* SERVICES */
  .ed-svgrid { display: grid; grid-template-columns: 1.6fr 1fr .9fr .9fr; gap: 16px; align-items: center; }
  .ed-svhead { font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--ed-fnt); padding-bottom: 2px; }
  .ed-svrow { padding: 13px 0; border-top: 1px solid var(--ed-hair); font-family: var(--font-mono); font-size: 13px; transition: background .15s; }
  .ed-svrow:hover { background: rgba(255,255,255,.02); }
  .ed-svname { display: flex; align-items: center; gap: 9px; color: var(--ed-tx); font-weight: 500; font-family: var(--font-sans); font-size: 13.5px; }
  .ed-svgroup { font-size: 11.5px; color: var(--ed-fnt); }
  .ed-svpct { text-align: right; font-size: 12.5px; font-variant-numeric: tabular-nums; }
  .ed-svlat { text-align: right; font-size: 11.5px; color: var(--ed-mut); font-variant-numeric: tabular-nums; }

  /* INCIDENT BAND */
  .ed-band { display: flex; gap: 2px; align-items: flex-end; height: 48px; }
  .ed-band > span { flex: 1; border-radius: 1.5px; }
  .ed-band-axis { display: flex; justify-content: space-between; font-size: 10.5px; color: var(--ed-fnt); margin-top: 8px; }
  .ed-inc-log { margin-top: 30px; }
  .ed-inc-row { display: grid; grid-template-columns: 110px 1fr auto; gap: 16px; align-items: center; padding: 12px 0; border-top: 1px solid var(--ed-hair); }
  .ed-inc-date { font-family: var(--font-mono); font-size: 12px; color: var(--ed-fnt); }
  .ed-inc-title { font-size: 13.5px; color: var(--ed-tx); }
  .ed-inc-sev { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: .08em; border: 1px solid; border-radius: 4px; padding: 2px 7px; }

  /* TOPOLOGY */
  .ed-topo { display: flex; flex-direction: column; gap: 18px; }
  .ed-topo-row { display: flex; align-items: stretch; gap: 12px; flex-wrap: wrap; }
  .ed-box { flex: 1; min-width: 170px; padding: 12px 16px; border: 1px solid var(--ed-hair); border-radius: 8px; display: flex; flex-direction: column; gap: 3px; }
  .ed-box-t { font-family: var(--font-mono); font-size: 12px; color: var(--ed-tx); }
  .ed-box-s { font-family: var(--font-mono); font-size: 10.5px; color: var(--ed-fnt); }
  .ed-arrow { align-self: center; color: var(--ed-fnt); }
  .ed-cluster { border-color: var(--ed-hair2); gap: 12px; }
  .ed-cluster-head { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 6px; font-size: 11px; letter-spacing: .06em; }
  .ed-cluster-nodes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .ed-chip { display: flex; align-items: center; gap: 8px; padding: 9px 12px; background: rgba(255,255,255,.03); border-radius: 7px; font-size: 12px; }
  .ed-chip .ed-faint { margin-left: auto; font-size: 10px; }
  .ed-topo-support { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  .ed-support { min-width: 0; }
  .ed-support-t { display: flex; align-items: center; gap: 7px; font-size: 12px; }
  .ed-dashed { border-style: dashed; }
  .ed-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--ed-muted); flex: none; }
  .ed-dot.ok { background: var(--ed-ok); } .ed-dot.warn { background: var(--ed-warn); }
  .ed-dot.crit { background: var(--ed-crit); } .ed-dot.muted { background: var(--ed-muted); }

  /* NETWORK */
  .ed-net { display: grid; grid-template-columns: 1fr 1fr; gap: 0 40px; }
  .ed-net-row { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; padding: 13px 0; border-top: 1px solid var(--ed-hair); }
  .ed-net-label { font-size: 13px; color: var(--ed-mut); }
  .ed-net-val { font-family: var(--font-mono); font-size: 12.5px; color: var(--ed-tx); text-align: right; }
  .ed-net-note { font-family: var(--font-mono); font-size: 11px; color: var(--ed-fnt); display: block; margin-top: 2px; }

  /* STORAGE */
  .ed-strow { padding: 15px 0; border-top: 1px solid var(--ed-hair); }
  .ed-strow-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 9px; flex-wrap: wrap; gap: 6px; }
  .ed-stname { font-family: var(--font-mono); font-size: 13.5px; color: var(--ed-tx); }
  .ed-stkind { font-size: 12px; color: var(--ed-mut); margin-left: 12px; }
  .ed-stused { font-family: var(--font-mono); font-size: 12px; color: var(--ed-mut); font-variant-numeric: tabular-nums; }
  .ed-sttrack { height: 5px; border-radius: 3px; background: rgba(255,255,255,.08); overflow: hidden; }
  .ed-stfill { display: block; height: 100%; }

  /* BACKUPS */
  .ed-bkrow { display: grid; grid-template-columns: 1.3fr 1.6fr 1fr auto; gap: 16px; align-items: center; padding: 13px 0; border-top: 1px solid var(--ed-hair); font-family: var(--font-mono); font-size: 12.5px; }
  .ed-bkname { color: var(--ed-tx); }
  .ed-bktarget { color: var(--ed-mut); font-family: var(--font-sans); }
  .ed-bkwhen { color: var(--ed-fnt); font-size: 11.5px; }
  .ed-bkstatus { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; }
  .ed-foot-note { font-size: 11.5px; color: var(--ed-fnt); margin-top: 16px; }

  /* INFRA */
  .ed-infra { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .ed-inf { display: flex; align-items: center; gap: 12px; padding: 14px 16px; border: 1px solid var(--ed-hair); border-radius: 9px; }
  .ed-inf-body { flex: 1; }
  .ed-inf-name { font-family: var(--font-mono); font-size: 13px; color: var(--ed-tx); }
  .ed-inf-detail { font-size: 12px; color: var(--ed-mut); margin-top: 2px; }
  .ed-inf-label { font-family: var(--font-mono); font-size: 10.5px; }

  @media (max-width: 820px) {
    .ed-metrics { grid-template-columns: repeat(2, 1fr); }
    .ed-net, .ed-infra { grid-template-columns: 1fr; }
    .ed-cluster-nodes, .ed-topo-support { grid-template-columns: 1fr 1fr; }
    .ed-ngrid { grid-template-columns: 1.2fr 1fr 1fr; }
    .ed-nhead span:nth-child(2), .ed-nrow .ed-nrole, .ed-nhead span:nth-child(3), .ed-nrow .ed-nip { display: none; }
    .ed-svgrid { grid-template-columns: 1.4fr .9fr .9fr; }
    .ed-svhead span:nth-child(2), .ed-svrow .ed-svgroup { display: none; }
  }
</style>

<script>
  const OK = '#2fa06b', WARN = '#c98a1e', CRIT = '#cf5349', MUTED = '#6b6f77', FNT = '#63636b';

  function pct(v: any): string { const m = /(\d+)/.exec(String(v ?? '')); return m ? m[1] : '0'; }
  function el(id: string) { return document.getElementById(id); }
  function set(id: string, t: string) { const e = el(id); if (e) e.textContent = t; }

  async function loadStatus() {
    let d: any;
    try { const r = await fetch('/data/live.json', { cache: 'no-store' }); if (!r.ok) throw 0; d = await r.json(); }
    catch { return; }

    const nodes: any[] = Array.isArray(d.nodes) ? d.nodes : [];
    const hm: Record<string, any> = d.host_metrics ?? {};
    const byName: Record<string, any> = {};
    for (const n of nodes) byName[String(n.name).toLowerCase()] = n;

    // ── Hero verdict + metrics ──
    const ready = nodes.filter(n => n.status === 'ok').length;
    const pods = nodes.reduce((s, n) => s + (parseInt(n.pods) || 0), 0);
    const outages: any[] = Array.isArray(d.outages) ? d.outages : [];
    const openInc = outages.filter(o => (o.minutes ?? 0) === 0 && o.date === new Date().toISOString().slice(0,10)).length;
    const apps: any[] = Array.isArray(d.app_uptime) ? d.app_uptime : [];
    const measured = apps.filter(a => a.has_data);
    const healthy = measured.filter(a => (a.uptime_pct ?? 0) >= 99.5).length;

    set('m-nodes', nodes.length ? `${ready}/${nodes.length}` : '—');
    set('m-pods', pods ? String(pods) : '—');
    set('m-uptime', measured.length ? `${healthy}/${measured.length}` : '—');
    set('m-incidents', String(openInc));

    const verdict = el('ed-verdict');
    if (verdict) {
      if (ready < nodes.length || openInc > 0) { verdict.textContent = 'Operating with known issues.'; }
      else verdict.textContent = 'All systems operational.';
    }

    // ── Known issues ──
    const issues: { tag: string; tone: string; title: string; detail: string }[] = [];
    for (const s of (d.storage ?? [])) {
      if (s.pct > 80) issues.push({ tag: 'WATCH', tone: WARN, title: `${s.name} pool at ${Math.round(s.pct)}% capacity`, detail: `${s.used} of ${s.total} used — plan expansion before it tightens.` });
    }
    issues.push({ tag: 'KNOWN', tone: MUTED, title: 'bronn (.20) outside cluster monitoring', detail: 'standalone docker host, no Prometheus scrape and no Gatus probe — known, by design.' });
    const issuesEl = el('ed-issues');
    if (issuesEl) issuesEl.innerHTML = issues.map(i => `
      <div class="ed-issue">
        <span class="ed-issue-tag" style="color:${i.tone};border-color:${i.tone}">${i.tag}</span>
        <div><div class="ed-issue-title">${i.title}</div><div class="ed-issue-detail">${i.detail}</div></div>
      </div>`).join('');
    set('ed-issues-note', openInc === 0 ? 'no active incidents' : `${openInc} active`);

    // ── Nodes (CPU/Mem real; disk not collected → omitted) ──
    const nEl = el('ed-nodes');
    if (nEl) nEl.innerHTML = nodes.map(n => {
      const key = String(n.name).toLowerCase();
      const cpu = pct(hm[key]?.cpu ?? n.cpu), mem = pct(hm[key]?.mem ?? n.memory);
      const bar = (v: string, c: string) => `<span class="ed-bar"><span class="ed-bar-track"><span class="ed-bar-fill" style="width:${v}%;background:${c}"></span></span><span class="ed-bar-val">${v}%</span></span>`;
      return `<div class="ed-nrow ed-ngrid">
        <span class="ed-nname"><span class="ed-dot ${n.status}"></span>${n.name}</span>
        <span class="ed-nrole">${n.role ?? ''}</span>
        <span class="ed-nip">${n.ip ?? ''}</span>
        ${bar(cpu, '#6f8fb0')}${bar(mem, '#9a86ad')}
      </div>`;
    }).join('');

    // ── Topology dots ──
    document.querySelectorAll<HTMLElement>('.ed-dot[data-node]').forEach(dot => {
      const n = byName[dot.dataset.node ?? ''];
      dot.className = 'ed-dot ' + (n?.status ?? 'ok');
    });

    // ── Services, by uptime (real Gatus) ──
    const svcEl = el('ed-services');
    if (svcEl) {
      if (!apps.length) { svcEl.innerHTML = `<div class="ed-svrow"><span class="ed-svgroup">no service data yet</span></div>`; }
      else {
        const sorted = [...apps].sort((a, b) => (b.uptime_pct ?? -1) - (a.uptime_pct ?? -1));
        svcEl.innerHTML = sorted.map(a => {
          const name = a.app.charAt(0).toUpperCase() + a.app.slice(1);
          const upC = !a.has_data ? FNT : (a.uptime_pct < 99) ? CRIT : (a.uptime_pct < 99.9) ? WARN : OK;
          const upT = a.has_data ? `${a.uptime_pct}%` : 'measuring…';
          const lat = a.avg_ms != null ? `${a.avg_ms}ms` : '—';
          const dot = !a.has_data ? MUTED : (a.uptime_pct < 99 ? CRIT : OK);
          return `<div class="ed-svrow ed-svgrid">
            <span class="ed-svname"><span class="ed-dot" style="background:${dot}"></span>${name}</span>
            <span class="ed-svgroup">${a.group ?? ''}</span>
            <span class="ed-svpct" style="color:${upC}">${upT}</span>
            <span class="ed-svlat">${lat}</span>
          </div>`;
        }).join('');
      }
      const m = apps.filter(a => a.has_data).length;
      set('ed-svc-note', m ? `measured by Gatus · ${m} apps` : 'Gatus · warming up');
    }

    // ── Cluster incident band (rolling 60d, real outages) ──
    buildBand(outages);

    // ── Network ──
    const net = d.network ?? {};
    const netRows = [
      { label: 'WAN latency', value: net.latency_ms != null ? `${net.latency_ms}ms` : '—', note: 'probe round-trip' },
      { label: 'LAN', value: '10.0.10.0/24', note: 'k3s + services' },
      { label: 'Firewall', value: typeof net.fw_hits === 'number' ? `${net.fw_hits.toLocaleString()} hits` : '—', note: `${net.crowdsec_bans ?? 0} CrowdSec bans` },
      { label: 'Ingress', value: 'Traefik · *.kagiso.me', note: 'MetalLB .110' },
      { label: 'Gateway', value: 'MikroTik · .1', note: 'router · DNS' },
      { label: 'MetalLB pool', value: '10.0.10.100–120', note: 'L2 advertise' },
    ];
    const netEl = el('ed-net');
    if (netEl) netEl.innerHTML = netRows.map(x => `
      <div class="ed-net-row"><span class="ed-net-label">${x.label}</span>
      <span><span class="ed-net-val">${x.value}</span><span class="ed-net-note">${x.note}</span></span></div>`).join('');

    // ── Storage (real pools) ──
    const stEl = el('ed-storage');
    if (stEl) stEl.innerHTML = (d.storage ?? []).map((s: any) => {
      const p = Math.round(s.pct ?? 0);
      const c = p > 80 ? WARN : OK;
      return `<div class="ed-strow">
        <div class="ed-strow-head"><span><span class="ed-stname">${s.name}</span><span class="ed-stkind">${s.pool_status ?? ''}</span></span>
        <span class="ed-stused">${s.used} / ${s.total}</span></div>
        <div class="ed-sttrack"><span class="ed-stfill" style="width:${p}%;background:${c}"></span></div>
      </div>`;
    }).join('');

    // ── Backups (from cards) ──
    const cards: any[] = Array.isArray(d.cards) ? d.cards : [];
    const bkMap = [
      { label: 'Velero · cluster', card: 'Velero', target: 'MinIO @ ned (.80)' },
      { label: 'etcd snapshot', card: 'etcd Snapshot', target: 'local · k3s server' },
      { label: 'Docker appdata', card: 'Docker Appdata', target: 'bronn → ned' },
      { label: 'Offsite', card: 'Backblaze B2', target: 'Backblaze B2 · offsite' },
    ];
    const bkEl = el('ed-backups');
    if (bkEl) bkEl.innerHTML = bkMap.map(b => {
      const c = cards.find(x => x.label === b.card);
      const when = c?.value ?? '—';
      const st = c?.status ?? 'unknown';
      const col = st === 'ok' ? OK : st === 'warn' ? WARN : st === 'unknown' ? FNT : CRIT;
      return `<div class="ed-bkrow">
        <span class="ed-bkname">${b.label}</span>
        <span class="ed-bktarget">${b.target}</span>
        <span class="ed-bkwhen">${when}</span>
        <span class="ed-bkstatus" style="color:${col}"><span class="ed-dot" style="background:${col}"></span>${st === 'ok' ? 'current' : st}</span>
      </div>`;
    }).join('');

    // ── Infra / GitOps (real flux) ──
    const flux = d.flux ?? {};
    const infra = [
      { name: 'k3s', detail: '3 nodes · control-plane + etcd', dot: OK },
      { name: 'Flux', detail: flux.ready != null ? `${flux.ready}/${flux.total} kustomizations synced` : 'gitops', dot: flux.status === 'ok' ? OK : WARN },
      { name: 'Authentik', detail: 'SSO · OIDC for all apps', dot: OK },
      { name: 'Observability', detail: 'Prometheus · Grafana · Loki', dot: OK },
      { name: 'Gatus', detail: `active uptime probing · ${apps.length || '—'} apps`, dot: OK },
      { name: 'cert-manager', detail: 'Let’s Encrypt · auto-renew', dot: OK },
    ];
    const infEl = el('ed-infra');
    if (infEl) infEl.innerHTML = infra.map(f => `
      <div class="ed-inf"><span class="ed-dot" style="background:${f.dot}"></span>
      <div class="ed-inf-body"><div class="ed-inf-name">${f.name}</div><div class="ed-inf-detail">${f.detail}</div></div>
      <span class="ed-inf-label" style="color:${f.dot === OK ? OK : WARN}">${f.dot === OK ? 'ready' : 'degraded'}</span></div>`).join('');
  }

  function buildBand(outages: any[]) {
    const bandEl = el('ed-band'); if (!bandEl) return;
    const WINDOW = 60;
    const today = new Date(); today.setHours(0, 0, 0, 0);
    const dayKey = (iso: string) => { const d = new Date(iso.length === 7 ? iso + '-01' : iso); d.setHours(0,0,0,0); return Math.round((today.getTime() - d.getTime()) / 86400000); };
    const worst = new Map<number, 'crit' | 'warn'>();
    let n = 0;
    for (const o of outages) {
      const a = dayKey(o.date ?? ''); if (isNaN(a) || a < 0 || a >= WINDOW) continue;
      const sev = o.severity === 'critical' ? 'crit' : 'warn';
      if (worst.get(a) !== 'crit') worst.set(a, sev); n++;
    }
    set('ed-inc-stat', n === 0 ? `no incidents · ${WINDOW}d` : `${n} incident${n === 1 ? '' : 's'} · ${WINDOW}d`);
    let html = '';
    for (let i = 0; i < WINDOW; i++) {
      const ago = WINDOW - 1 - i;
      const s = worst.get(ago);
      const [h, c, title] = s === 'crit' ? ['46%', 'linear-gradient(180deg,#e07b73,#cf5349)', 'major incident']
        : s === 'warn' ? ['68%', 'linear-gradient(180deg,#dcae6a,#c98a1e)', 'degraded']
        : ['100%', 'linear-gradient(180deg,#3ab77e,#2fa06b)', 'operational'];
      html += `<span title="${ago === 0 ? 'today' : ago + 'd ago'} · ${title}" style="height:${h};background:${c}"></span>`;
    }
    bandEl.innerHTML = html;

    // Incident log — real outages, newest first
    const logEl = el('ed-inc-log'); if (!logEl) return;
    if (!outages.length) { logEl.innerHTML = `<div class="ed-inc-row"><span class="ed-inc-title" style="color:var(--ed-mut)">No incidents recorded in this window.</span></div>`; return; }
    logEl.innerHTML = `<div class="mono ed-eyebrow" style="margin-bottom:6px">Incident record</div>` + outages.slice(0, 6).map(o => {
      const d = new Date((o.date ?? '').length === 7 ? o.date + '-01' : o.date);
      const date = isNaN(+d) ? o.date : d.toLocaleDateString('en-ZA', { day: '2-digit', month: 'short', year: 'numeric' });
      const sev = o.severity === 'critical' ? 'CRIT' : 'WARN';
      const col = o.severity === 'critical' ? CRIT : WARN;
      const dur = (o.minutes ?? 0) > 0 ? `${o.minutes}m` : 'ongoing / recovered';
      return `<div class="ed-inc-row">
        <span class="ed-inc-date">${date}</span>
        <span class="ed-inc-title">cluster incident · ${dur}</span>
        <span class="ed-inc-sev" style="color:${col};border-color:${col}">${sev}</span>
      </div>`;
    }).join('');
  }

  document.addEventListener('astro:page-load', loadStatus);
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', loadStatus);
  else loadStatus();
</script>
