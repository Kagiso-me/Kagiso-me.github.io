---
const links = [
  { href: '/',          label: 'Home' },
  { href: '/status',    label: 'Status' },
  { href: '/security',  label: 'Security' },
  { href: '/digest',    label: 'Digest' },
  { href: '/blog',      label: 'Blog' },
  { href: '/decisions', label: 'Decisions' },
  { href: '/projects',  label: 'Projects' },
];

const current = Astro.url.pathname;
---

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <span class="mono" style="color: var(--color-gold)">~/</span>
      <span style="color: var(--color-heading); font-weight: 700;">kagiso.me</span>
      <span class="nav-heartbeat" id="nav-heartbeat" title="Live cluster data"></span>
    </a>

    <ul class="nav-links">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { active: current === link.href || (link.href !== '/' && current.startsWith(link.href)) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <button class="nav-mobile-toggle" id="nav-toggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <ul class="nav-mobile" id="nav-mobile">
    {links.map(link => (
      <li>
        <a href={link.href} class="nav-link">{link.label}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--color-mantle) 90%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-muted);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .nav-brand {
    font-size: 1rem;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
  }

  .nav-brand:hover { opacity: 0.8; }

  .nav-heartbeat {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-ok);
    box-shadow: 0 0 5px var(--color-ok);
    animation: hb-pulse 2.2s ease-in-out infinite;
    margin-left: 0.2rem;
    flex-shrink: 0;
    transition: background 0.4s, box-shadow 0.4s;
  }

  .nav-heartbeat.stale {
    background: var(--color-warn);
    box-shadow: 0 0 5px var(--color-warn);
    animation: none;
  }

  .nav-heartbeat.offline {
    background: var(--color-crit);
    box-shadow: 0 0 5px var(--color-crit);
    animation: none;
  }

  @keyframes hb-pulse {
    0%, 100% { transform: scale(1);   opacity: 0.9; }
    50%       { transform: scale(1.4); opacity: 1; box-shadow: 0 0 10px var(--color-ok); }
  }

  .nav-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }

  .nav-link {
    display: block;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    font-size: 0.875rem;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
  }

  .nav-link:hover, .nav-link.active {
    color: var(--color-heading);
    background: var(--color-overlay);
  }

  .nav-link.active {
    color: var(--color-gold);
  }

  .nav-mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-mobile-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: 0.2s;
  }

  .nav-mobile {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0.5rem 1.5rem 1rem;
    flex-direction: column;
    gap: 0.25rem;
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-mobile-toggle { display: flex; }
    .nav-mobile.open { display: flex; }
  }

  /* ── Event ticker ── */
  .nav-ticker {
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--color-mantle) 80%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-muted) 50%, transparent);
    overflow: hidden;
    position: relative;
  }

  .nav-ticker:empty { display: none; }

  .ticker-item {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .ticker-item.visible { opacity: 1; }

  .ticker-type {
    font-weight: 700;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
  }

  .ticker-type.DEPLOY   { color: var(--color-ok);      background: color-mix(in srgb, var(--color-ok)      12%, transparent); }
  .ticker-type.FIX      { color: var(--color-peach);   background: color-mix(in srgb, var(--color-peach)   12%, transparent); }
  .ticker-type.SECURITY { color: var(--color-warn);    background: color-mix(in srgb, var(--color-warn)    12%, transparent); }
  .ticker-type.INCIDENT { color: var(--color-crit);    background: color-mix(in srgb, var(--color-crit)    12%, transparent); }
  .ticker-type.CONFIG   { color: var(--color-sapphire);background: color-mix(in srgb, var(--color-sapphire)12%, transparent); }
  .ticker-type.NETWORK  { color: var(--color-gold);    background: color-mix(in srgb, var(--color-gold)    12%, transparent); }
  .ticker-type.DECISION { color: var(--color-mauve);   background: color-mix(in srgb, var(--color-mauve)   12%, transparent); }
  .ticker-type.OPS      { color: var(--color-mauve);   background: color-mix(in srgb, var(--color-mauve)   12%, transparent); }

  .ticker-sep  { color: var(--color-muted); }
  .ticker-title { color: var(--color-subtle); max-width: 420px; overflow: hidden; text-overflow: ellipsis; }
  .ticker-date  { color: var(--color-muted); flex-shrink: 0; }

  .ticker-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .ticker-link:hover .ticker-title { color: var(--color-text); }

  @media (max-width: 640px) {
    .nav-ticker { display: none; }
  }
</style>

<script>
  function initNav() {
    const toggle = document.getElementById('nav-toggle');
    const mobile = document.getElementById('nav-mobile');
    if (!toggle || !mobile) return;

    // Remove any stale listeners by cloning
    const freshToggle = toggle.cloneNode(true) as HTMLElement;
    toggle.parentNode!.replaceChild(freshToggle, toggle);

    freshToggle.addEventListener('click', () => mobile.classList.toggle('open'));

    mobile.querySelectorAll('a').forEach(a =>
      a.addEventListener('click', () => mobile.classList.remove('open'))
    );
  }

  // Run on first load and every Astro view-transition navigation
  document.addEventListener('astro:page-load', initNav);
  // Also run immediately for non-view-transition environments
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNav);
  } else {
    initNav();
  }

  document.addEventListener('astro:before-preparation', () => {
    document.getElementById('nav-mobile')?.classList.remove('open');
  });

  // ── Heartbeat indicator — checks live.json freshness ─────────────────────
  async function checkHeartbeat() {
    const dot = document.getElementById('nav-heartbeat');
    if (!dot) return;
    try {
      const r = await fetch('/data/live.json', { cache: 'no-store' });
      if (!r.ok) { dot.className = 'nav-heartbeat offline'; dot.title = 'Cluster data unavailable'; return; }
      const data = await r.json();
      const age = Date.now() - new Date(data.updated ?? 0).getTime();
      const ageMin = Math.round(age / 60000);
      if (age > 90 * 60 * 1000) {        // > 90 min — stale
        dot.className = 'nav-heartbeat stale';
        dot.title = `Data is ${ageMin}m old — may be stale`;
      } else {
        dot.className = 'nav-heartbeat';
        dot.title = `Live · updated ${ageMin}m ago`;
      }
    } catch {
      dot.className = 'nav-heartbeat offline';
      dot.title = 'Cluster data offline';
    }
  }

  checkHeartbeat();
  document.addEventListener('astro:page-load', checkHeartbeat);

  // ── Event ticker ─────────────────────────────────────────────────────────
  (async function initTicker() {
    const ticker = document.getElementById('nav-ticker');
    if (!ticker) return;

    let entries: any[] = [];
    try {
      const res = await fetch('/data/digest.json');
      if (!res.ok) return;
      const all = await res.json();
      // Take the 3 most recent — already sorted newest-first
      entries = all.slice(0, 3);
    } catch { return; }

    if (!entries.length) return;

    function relativeDate(dateStr: string) {
      // dateStr is "YYYY-MM" or "YYYY-MM-DD"
      const d = new Date(dateStr.length === 7 ? dateStr + '-01' : dateStr);
      const diffMs = Date.now() - d.getTime();
      const diffDays = Math.floor(diffMs / 86400000);
      if (diffDays === 0) return 'today';
      if (diffDays === 1) return '1d ago';
      if (diffDays < 30) return `${diffDays}d ago`;
      const months = Math.floor(diffDays / 30);
      return `${months}mo ago`;
    }

    // Build one DOM element per entry, stacked in the ticker
    const items = entries.map(e => {
      const el = document.createElement('div');
      el.className = 'ticker-item';

      const inner = e.hasDetail
        ? `<a href="/digest/entry?slug=${e.slug}" class="ticker-link">`
        : `<span class="ticker-link" style="cursor:default">`;
      const close = e.hasDetail ? `</a>` : `</span>`;

      el.innerHTML = `${inner}
        <span class="ticker-type ${e.type}">${e.type}</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-title">${e.title}</span>
        <span class="ticker-sep">·</span>
        <span class="ticker-date">${relativeDate(e.date)}</span>
      ${close}`;

      ticker.appendChild(el);
      return el;
    });

    let current = 0;
    items[0].classList.add('visible');

    // Cycle every 4 seconds with crossfade
    setInterval(() => {
      items[current].classList.remove('visible');
      current = (current + 1) % items.length;
      items[current].classList.add('visible');
    }, 4000);
  })();
</script>
