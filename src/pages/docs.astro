---
import Layout from '../layouts/Layout.astro';

const adrs = [
  { id: '001', title: 'k3s over kubeadm',                         slug: 'ADR-001-k3s-over-kubeadm' },
  { id: '002', title: 'FluxCD over ArgoCD',                       slug: 'ADR-002-flux-over-argocd' },
  { id: '003', title: 'Traefik over nginx-ingress',               slug: 'ADR-003-traefik-over-nginx-ingress' },
  { id: '004', title: 'Staging cluster decommissioned',           slug: 'ADR-004-staging-to-pr-validation' },
  { id: '005', title: 'Self-hosted GitHub Actions runners',       slug: 'ADR-005-self-hosted-runners' },
  { id: '006', title: 'Prometheus TSDB on local storage',         slug: 'ADR-006-prometheus-local-storage' },
  { id: '007', title: 'Discord over Slack for alerts',            slug: 'ADR-007-discord-over-slack' },
  { id: '008', title: 'Central PostgreSQL and Redis',             slug: 'ADR-008-central-databases' },
  { id: '009', title: 'PR-based validation pipeline',            slug: 'ADR-009-pr-validation-pipeline' },
  { id: '010', title: 'Public site live data pipeline',           slug: 'ADR-010-site-data-pipeline' },
  { id: '011', title: 'Pi-hole + Unbound DNS stack',              slug: 'ADR-011-pihole-unbound-dns' },
  { id: '012', title: 'Automated upgrade strategy',               slug: 'ADR-012-upgrade-strategy' },
  { id: '013', title: 'SOPS + age encryption',                     slug: 'ADR-013-sops-age-encryption' },
  { id: '014', title: 'MetalLB in L2 mode',                       slug: 'ADR-014-metallb-l2' },
  { id: '015', title: 'Velero backup strategy',                   slug: 'ADR-015-velero-backup-strategy' },
  { id: '016', title: 'TrueNAS SCALE as NFS storage backend',    slug: 'ADR-016-truenas-nfs-storage' },
  { id: '017', title: 'CrowdSec for threat detection',           slug: 'ADR-017-crowdsec' },
];

const REPO = 'https://github.com/Kagiso-me/homelab-infrastructure/blob/main/docs/adr';
---

<Layout title="Docs" description="Architecture Decision Records — the decisions that have shaped this homelab.">

  <div class="page-wrap">

    <!-- ── Header ── -->
    <div class="page-header fade-up">
      <div>
        <p class="mono" style="color:var(--color-peach);margin-bottom:0.25rem">~/docs</p>
        <h1 style="margin:0">Architecture Decisions</h1>
      </div>
      <p class="hero-sub">
        Every meaningful choice in this homelab has a reason behind it.
        These are the Architecture Decision Records — a running log of what was built,
        what was rejected, and why. Not aspirational. Not theoretical.
        Every entry reflects something that actually happened.
      </p>
    </div>

    <!-- ── ADR list ── -->
    <section class="adr-list fade-up" style="animation-delay:0.05s">
      {adrs.map(adr => (
        <a
          class="adr-row"
          href={`${REPO}/${adr.slug}.md`}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="adr-id mono">ADR-{adr.id}</span>
          <span class="adr-title">{adr.title}</span>
          <span class="adr-arrow">↗</span>
        </a>
      ))}
    </section>

  </div>

</Layout>

<style>
  .page-wrap {
    max-width: 860px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); }

  .hero-sub {
    color: var(--color-subtle);
    font-size: 0.95rem;
    line-height: 1.75;
    max-width: 620px;
    margin: 0.75rem 0 0;
  }

  /* ── ADR list ── */
  .adr-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-muted);
    border-radius: 14px;
    overflow: hidden;
  }

  .adr-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    border-bottom: 1px solid var(--color-muted);
    transition: background 0.15s;
  }

  .adr-row:last-child {
    border-bottom: none;
  }

  .adr-row:hover {
    background: var(--color-overlay);
  }

  .adr-row:hover .adr-arrow {
    color: var(--color-peach);
    transform: translate(2px, -2px);
  }

  .adr-id {
    font-size: 0.72rem;
    color: var(--color-peach);
    min-width: 4.5rem;
    flex-shrink: 0;
    letter-spacing: 0.04em;
  }

  .adr-title {
    font-size: 0.925rem;
    color: var(--color-heading);
    flex: 1;
    line-height: 1.4;
  }

  .adr-arrow {
    font-size: 0.85rem;
    color: var(--color-muted);
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }

  @media (max-width: 480px) {
    .adr-id { min-width: 3.5rem; }
    .adr-row { gap: 0.75rem; padding: 0.875rem 1rem; }
  }
</style>
