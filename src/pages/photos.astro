---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Archive — Kagiso">

<!-- ════════════════════════════
     HERO
════════════════════════════ -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-leak"></div>

  <div class="hero-content">
    <div class="hero-eyebrow">The Archive</div>
    <h1 class="hero-title">
      <strong>Kagiso</strong>
      I shoot what I<br>don't want<br>to forget.
    </h1>
    <p class="hero-sub">
      Family moments. Street. The in-between.
      Every frame is intentional — collected in series,
      stored on my own hardware, owned completely.
    </p>
    <div class="hero-meta">
      <div class="hero-stat">
        <div class="hero-stat-num">4</div>
        <div class="hero-stat-label">series</div>
      </div>
      <div class="hero-stat-div"></div>
      <div class="hero-stat">
        <div class="hero-stat-num">1</div>
        <div class="hero-stat-label">film in progress</div>
      </div>
      <div class="hero-stat-div"></div>
      <div class="hero-stat">
        <div class="hero-stat-num">∞</div>
        <div class="hero-stat-label">moments left to shoot</div>
      </div>
    </div>
  </div>

  <div class="scroll-cue">
    <div class="scroll-line"></div>
    scroll
  </div>
</section>

<!-- ════════════════════════════
     CURRENTLY IN THE FRAME
════════════════════════════ -->
<div class="now-wrap">
  <div class="now-card fu">
    <!-- Left: film poster visual -->
    <div class="now-visual">
      <div class="film-strip">
        <div class="film-hole"></div>
        <div class="film-hole"></div>
        <div class="film-hole"></div>
        <div class="film-hole"></div>
        <div class="film-hole"></div>
        <div class="film-hole"></div>
        <div class="film-hole"></div>
        <div class="film-hole"></div>
      </div>
      <div class="now-visual-placeholder">
        <!--
          DROP A STILL FROM YOUR DOCUMENTARY HERE:
          <img src="/img/before-he-arrived-still.jpg" style="width:100%;height:100%;object-fit:cover;opacity:.6" alt="Before He Arrived" />
        -->
      </div>
      <div class="now-visual-year">2025</div>
    </div>

    <!-- Right: film details -->
    <div class="now-body">
      <div class="now-label">
        <div class="now-label-dot"></div>
        Currently in the frame
      </div>
      <div class="now-type">Mini Documentary · Work in Progress</div>
      <div class="now-title">Before He Arrived</div>
      <div class="now-logline">
        The months leading up to — and the moment of — my son's birth.
        Captured as it happened. No recreations. No script.
      </div>
      <div class="now-details">
        <div class="now-detail">
          <div class="now-detail-val">2024–2025</div>
          <div class="now-detail-key">period</div>
        </div>
        <div class="now-detail">
          <div class="now-detail-val">Documentary</div>
          <div class="now-detail-key">format</div>
        </div>
        <div class="now-detail">
          <div class="now-detail-val">In edit</div>
          <div class="now-detail-key">status</div>
        </div>
      </div>
      <div class="now-status">In production</div>
    </div>
  </div>
</div>

<!-- ════════════════════════════
     SERIES
════════════════════════════ -->
<div class="divider" style="margin-top: 6rem"></div>

<section class="section fu">
  <div class="section-eyebrow">The Work</div>
  <h2 class="section-title">Series</h2>
  <p class="section-sub">
    Each body of work is a series — a themed collection with its own
    mood, its own story, its own reason to exist.
  </p>

  <div class="series-grid">

    <!-- Series 1 — large -->
    <div class="series-card sc-large fu">
      <div class="sc-img tone-warm"></div>
      <div class="sc-num">01</div>
      <div class="sc-body">
        <div class="sc-label">Family · Ongoing</div>
        <div class="sc-title">First Light</div>
        <div class="sc-desc">
          The quiet moments no one else sees. Morning routines, small hands,
          the light before anyone is fully awake.
        </div>
        <div class="sc-footer">
          <div class="sc-count">— frames</div>
          <div class="sc-arrow">→</div>
        </div>
      </div>
    </div>

    <!-- Series 2 — medium -->
    <div class="series-card sc-medium fu">
      <div class="sc-img tone-cool"></div>
      <div class="sc-num">02</div>
      <div class="sc-body">
        <div class="sc-label">Street · Johannesburg</div>
        <div class="sc-title">Joburg, Unposed</div>
        <div class="sc-desc">
          The city as it is. Not as it's marketed.
          People moving through space with no idea they're being watched.
        </div>
        <div class="sc-footer">
          <div class="sc-count">— frames</div>
          <div class="sc-arrow">→</div>
        </div>
      </div>
    </div>

    <!-- Series 3 — wide -->
    <div class="series-card sc-wide fu">
      <div class="sc-img tone-deep"></div>
      <div class="sc-num">03</div>
      <div class="sc-body">
        <div class="sc-label">Documentary · 2024–2025</div>
        <div class="sc-title">Before He Arrived — Stills</div>
        <div class="sc-desc">
          The photographs from the documentary. The waiting. The anticipation.
          The moment. Stills pulled from the project as it unfolded.
        </div>
        <div class="sc-footer">
          <div class="sc-count">— frames</div>
          <div class="sc-arrow">→</div>
        </div>
      </div>
    </div>

    <!-- Series 4, 5, 6 — thirds -->
    <div class="series-card sc-third fu">
      <div class="sc-img tone-neut"></div>
      <div class="sc-num">04</div>
      <div class="sc-body">
        <div class="sc-label">Portraits</div>
        <div class="sc-title">People</div>
        <div class="sc-desc">Faces. Expressions. The moment before the mask goes back on.</div>
        <div class="sc-footer">
          <div class="sc-count">— frames</div>
          <div class="sc-arrow">→</div>
        </div>
      </div>
    </div>

    <div class="series-card sc-third fu">
      <div class="sc-img tone-warm"></div>
      <div class="sc-num">05</div>
      <div class="sc-body">
        <div class="sc-label">Ongoing</div>
        <div class="sc-title">New Series</div>
        <div class="sc-desc">The next body of work. TBD. The best one is always the one you haven't shot yet.</div>
        <div class="sc-footer">
          <div class="sc-count">coming</div>
          <div class="sc-arrow">→</div>
        </div>
      </div>
    </div>

    <div class="series-card sc-third fu">
      <div class="sc-img tone-cool"></div>
      <div class="sc-num">06</div>
      <div class="sc-body">
        <div class="sc-label">Archive</div>
        <div class="sc-title">Everything Else</div>
        <div class="sc-desc">The frames that don't fit anywhere. They always end up being the most honest.</div>
        <div class="sc-footer">
          <div class="sc-count">— frames</div>
          <div class="sc-arrow">→</div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ════════════════════════════
     RECENT FRAMES
════════════════════════════ -->
<div class="divider"></div>

<section class="section fu">
  <div class="section-eyebrow">Recent Frames</div>
  <h2 class="section-title">Latest from the archive</h2>
  <p class="section-sub">No captions. Just the work.</p>

  <div class="frames-grid">
    <div class="frame-item fu">
      <div class="frame-ph"><div class="frame-ph-inner" style="aspect-ratio:3/4">your frame</div></div>
      <div class="frame-overlay"><div class="frame-series-tag">First Light</div></div>
    </div>
    <div class="frame-item fu">
      <div class="frame-ph"><div class="frame-ph-inner" style="aspect-ratio:4/3">your frame</div></div>
      <div class="frame-overlay"><div class="frame-series-tag">Joburg, Unposed</div></div>
    </div>
    <div class="frame-item fu">
      <div class="frame-ph"><div class="frame-ph-inner" style="aspect-ratio:1/1">your frame</div></div>
      <div class="frame-overlay"><div class="frame-series-tag">Before He Arrived</div></div>
    </div>
    <div class="frame-item fu">
      <div class="frame-ph"><div class="frame-ph-inner" style="aspect-ratio:4/3">your frame</div></div>
      <div class="frame-overlay"><div class="frame-series-tag">First Light</div></div>
    </div>
    <div class="frame-item fu">
      <div class="frame-ph"><div class="frame-ph-inner" style="aspect-ratio:3/4">your frame</div></div>
      <div class="frame-overlay"><div class="frame-series-tag">People</div></div>
    </div>
    <div class="frame-item fu">
      <div class="frame-ph"><div class="frame-ph-inner" style="aspect-ratio:1/1">your frame</div></div>
      <div class="frame-overlay"><div class="frame-series-tag">Joburg, Unposed</div></div>
    </div>
    <div class="frame-item fu">
      <div class="frame-ph"><div class="frame-ph-inner" style="aspect-ratio:1/1">your frame</div></div>
      <div class="frame-overlay"><div class="frame-series-tag">First Light</div></div>
    </div>
    <div class="frame-item fu">
      <div class="frame-ph"><div class="frame-ph-inner" style="aspect-ratio:4/3">your frame</div></div>
      <div class="frame-overlay"><div class="frame-series-tag">Before He Arrived</div></div>
    </div>
    <div class="frame-item fu">
      <div class="frame-ph"><div class="frame-ph-inner" style="aspect-ratio:3/4">your frame</div></div>
      <div class="frame-overlay"><div class="frame-series-tag">Everything Else</div></div>
    </div>
  </div>
</section>

<!-- ════════════════════════════
     CLOSING
════════════════════════════ -->
<div class="divider"></div>

<section class="closing fu">
  <div class="closing-inner">
    <h2 class="closing-title">
      The archive is never finished.
    </h2>
    <p class="closing-sub">
      Every series starts with a single frame.
      <strong>Every frame is stored on hardware I own</strong> —
      not a subscription, not someone else's cloud,
      not a platform that can change its terms.
      <br><br>
      The work is mine. The memories are mine.
      That's the whole point.
    </p>
    <a href="/about" class="btn-p">About the photographer →</a>
  </div>
</section>

</Layout>

<style>
/* ── Film grain overlay ── */
body::after {
  content: ''; position: fixed; inset: 0; z-index: 9999; pointer-events: none;
  opacity: .04;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 128px;
}

/* ── HERO ── */
.hero {
  position: relative;
  height: 100vh; min-height: 600px;
  display: flex; align-items: flex-end;
  overflow: hidden;
}

.hero-bg {
  position: absolute; inset: 0;
  background: linear-gradient(160deg, #0d0b14 0%, var(--color-base) 40%, #0a0c0a 100%);
  /* TO ADD HERO IMAGE: background-image: url('/img/hero-photo.jpg'); background-size: cover; background-position: center; */
}

.hero-bg::after {
  content: ''; position: absolute; inset: 0;
  background:
    linear-gradient(to top, var(--color-base) 0%, rgba(7,7,11,.7) 40%, rgba(7,7,11,.2) 100%),
    linear-gradient(to right, rgba(7,7,11,.6) 0%, transparent 60%);
}

.hero-bg::before {
  content: ''; position: absolute; inset: 0; z-index: 1; pointer-events: none;
  opacity: .06;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 256px;
}

.hero-leak {
  position: absolute; top: -100px; left: -100px;
  width: 500px; height: 500px; border-radius: 50%;
  background: radial-gradient(ellipse, rgba(201,168,76,.06) 0%, transparent 70%);
  pointer-events: none; z-index: 2;
}

.hero-content {
  position: relative; z-index: 3;
  padding: 0 4rem 5rem;
  max-width: 900px;
}

@media (max-width: 680px) { .hero-content { padding: 0 1.5rem 4rem; } }

.hero-eyebrow {
  font-family: var(--font-mono); font-size: .62rem;
  color: var(--color-gold); letter-spacing: .22em; text-transform: uppercase;
  margin-bottom: 1.5rem;
  display: flex; align-items: center; gap: .75rem;
  opacity: .6;
}
.hero-eyebrow::before {
  content: ''; width: 2rem; height: 1px; background: currentColor;
}

.hero-title {
  font-family: var(--font-serif, 'Playfair Display', Georgia, serif);
  font-size: clamp(3rem, 9vw, 7.5rem);
  font-weight: 400; font-style: italic;
  color: var(--color-heading);
  line-height: 1;
  letter-spacing: -.02em;
  margin-bottom: 1.5rem;
}

.hero-title strong {
  font-style: normal; font-weight: 700;
  display: block; font-size: .55em;
  color: var(--color-gold); letter-spacing: .04em;
  font-family: var(--font-display);
  text-transform: uppercase;
  margin-bottom: .3rem;
}

.hero-sub {
  font-size: clamp(.9rem, 2vw, 1.05rem);
  color: var(--color-subtle); line-height: 1.75;
  max-width: 480px; font-weight: 300;
  margin-bottom: 2.5rem;
}

.hero-meta {
  display: flex; align-items: center; gap: 2rem; flex-wrap: wrap;
}

.hero-stat { display: flex; flex-direction: column; gap: .2rem; }
.hero-stat-num {
  font-family: var(--font-mono); font-size: 1.4rem; font-weight: 700;
  color: var(--color-heading); letter-spacing: -.02em; line-height: 1;
}
.hero-stat-label {
  font-family: var(--font-mono); font-size: .58rem;
  color: var(--color-muted); text-transform: uppercase; letter-spacing: .12em;
}
.hero-stat-div { width: 1px; height: 2rem; background: var(--color-overlay); }

.scroll-cue {
  position: absolute; bottom: 2.5rem; right: 4rem;
  display: flex; flex-direction: column; align-items: center; gap: .4rem;
  font-family: var(--font-mono); font-size: .58rem;
  color: var(--color-muted); letter-spacing: .12em; text-transform: uppercase;
  animation: bob 3s ease-in-out infinite;
}
.scroll-line {
  width: 1px; height: 40px;
  background: linear-gradient(180deg, transparent, var(--color-muted), transparent);
}
@keyframes bob { 0%,100%{transform:translateY(0)} 50%{transform:translateY(8px)} }

/* ── CURRENTLY IN THE FRAME ── */
.now-wrap {
  padding: 0 4rem;
  max-width: 1200px;
  margin: 0 auto;
}
@media (max-width: 680px) { .now-wrap { padding: 0 1.5rem; } }

.now-card {
  position: relative;
  border-radius: 20px; overflow: hidden;
  background: var(--color-surface);
  border: 1px solid var(--color-overlay);
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 480px;
  margin-top: -80px;
  box-shadow: 0 40px 100px rgba(0,0,0,.7);
  transition: box-shadow .4s ease;
}
.now-card:hover { box-shadow: 0 60px 120px rgba(0,0,0,.8); }
@media (max-width: 780px) { .now-card { grid-template-columns: 1fr; margin-top: -40px; } }

.now-visual {
  position: relative; overflow: hidden; min-height: 300px;
  background: linear-gradient(135deg, #0e0b18 0%, #12111a 50%, #0a110e 100%);
}

.now-visual::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(to right, transparent 60%, var(--color-surface));
}

.film-strip {
  position: absolute; top: 0; left: 0; bottom: 0;
  width: 28px; z-index: 2;
  background: rgba(0,0,0,.8);
  display: flex; flex-direction: column; justify-content: space-around; align-items: center;
  padding: 1rem 0;
}
.film-hole {
  width: 10px; height: 14px; border-radius: 2px;
  background: var(--color-base); opacity: .7;
}

.now-visual-placeholder {
  position: absolute; inset: 0; z-index: 1;
  display: flex; align-items: center; justify-content: center;
  padding: 2rem 3rem 2rem 4rem;
}
.now-visual-year {
  font-family: var(--font-serif, 'Playfair Display', Georgia, serif);
  font-size: 7rem; font-weight: 700;
  color: rgba(255,255,255,.04); line-height: 1;
  position: absolute; bottom: 1rem; right: 1.5rem;
  letter-spacing: -.04em;
}

.now-body {
  padding: 3rem 3rem 3rem 2.5rem;
  display: flex; flex-direction: column; justify-content: center;
  gap: .75rem;
}
@media (max-width: 780px) { .now-body { padding: 2rem 1.5rem; } }

.now-label {
  font-family: var(--font-mono); font-size: .6rem;
  color: var(--color-gold); letter-spacing: .2em; text-transform: uppercase;
  display: flex; align-items: center; gap: .6rem;
}
.now-label-dot {
  width: 5px; height: 5px; border-radius: 50%; background: var(--color-gold);
  animation: pulse-gold 2s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes pulse-gold {
  0%,100%{ box-shadow: 0 0 0 0 rgba(201,168,76,.4); }
  50%{ box-shadow: 0 0 0 6px rgba(201,168,76,0); }
}

.now-type {
  font-family: var(--font-mono); font-size: .62rem;
  color: var(--color-muted); letter-spacing: .1em; text-transform: uppercase;
}

.now-title {
  font-family: var(--font-serif, 'Playfair Display', Georgia, serif);
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 700; color: var(--color-heading);
  line-height: 1.15; letter-spacing: -.02em;
}

.now-logline {
  font-size: .95rem; color: var(--color-subtle); line-height: 1.75;
  font-weight: 300; font-style: italic;
  border-left: 2px solid var(--color-gold); padding-left: 1rem;
  opacity: .7;
  margin: .25rem 0;
}

.now-details { display: flex; gap: 1.5rem; flex-wrap: wrap; margin-top: .5rem; }
.now-detail { display: flex; flex-direction: column; gap: .2rem; }
.now-detail-val {
  font-family: var(--font-mono); font-size: .78rem;
  font-weight: 700; color: var(--color-text);
}
.now-detail-key {
  font-family: var(--font-mono); font-size: .58rem;
  color: var(--color-muted); text-transform: uppercase; letter-spacing: .1em;
}

.now-status {
  display: inline-flex; align-items: center; gap: .5rem;
  font-family: var(--font-mono); font-size: .62rem;
  color: var(--color-ok); letter-spacing: .08em;
  background: color-mix(in srgb, var(--color-ok) 8%, transparent);
  border: 1px solid color-mix(in srgb, var(--color-ok) 20%, transparent);
  border-radius: 99px; padding: .3rem .8rem;
  width: fit-content; margin-top: .25rem;
}
.now-status::before {
  content: ''; width: 5px; height: 5px; border-radius: 50%;
  background: var(--color-ok);
  animation: pulse-green 2.5s ease-in-out infinite;
}
@keyframes pulse-green {
  0%,100%{ box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-ok) 40%, transparent); }
  50%{ box-shadow: 0 0 0 5px transparent; }
}

/* ── SECTION WRAPPER ── */
.section {
  max-width: 1200px; margin: 0 auto;
  padding: 6rem 4rem;
}
@media (max-width: 680px) { .section { padding: 4rem 1.5rem; } }

.divider {
  width: 100%; height: 1px;
  background: linear-gradient(90deg, transparent, var(--color-overlay), transparent);
  max-width: 1200px; margin: 0 auto;
}

.section-eyebrow {
  font-family: var(--font-mono); font-size: .6rem;
  color: var(--color-muted); letter-spacing: .2em; text-transform: uppercase;
  margin-bottom: .75rem; display: flex; align-items: center; gap: .75rem;
}
.section-eyebrow::after {
  content: ''; flex: 0 0 2rem; height: 1px; background: var(--color-overlay);
}

.section-title {
  font-family: var(--font-serif, 'Playfair Display', Georgia, serif);
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 400; font-style: italic;
  color: var(--color-heading); margin-bottom: .5rem;
  letter-spacing: -.02em; line-height: 1.2;
}

.section-sub {
  font-size: .9rem; color: var(--color-muted); line-height: 1.75;
  max-width: 480px; font-weight: 300; margin-bottom: 3rem;
}

/* ── SERIES GRID ── */
.series-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 1rem;
}
@media (max-width: 900px) { .series-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 580px) { .series-grid { grid-template-columns: 1fr; } }

.series-card {
  position: relative; border-radius: 14px; overflow: hidden;
  cursor: pointer;
  background: var(--color-surface);
  border: 1px solid var(--color-overlay);
  transition: transform .4s cubic-bezier(.16,1,.3,1),
              box-shadow .4s ease,
              border-color .4s ease;
}
.series-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 24px 60px rgba(0,0,0,.6);
  border-color: color-mix(in srgb, var(--color-gold) 30%, var(--color-overlay));
}

.sc-large  { grid-column: span 7; aspect-ratio: 4/3; }
.sc-medium { grid-column: span 5; aspect-ratio: 3/4; }
.sc-wide   { grid-column: span 12; aspect-ratio: 21/9; }
.sc-third  { grid-column: span 4; aspect-ratio: 1/1; }

@media (max-width: 900px) {
  .sc-large, .sc-medium, .sc-wide, .sc-third { grid-column: span 1; aspect-ratio: 4/3; }
}

.sc-img {
  position: absolute; inset: 0;
  background: var(--color-overlay);
  transition: transform .6s cubic-bezier(.16,1,.3,1);
}
.series-card:hover .sc-img { transform: scale(1.04); }

.sc-img::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(to top,
    rgba(7,7,11,.95) 0%,
    rgba(7,7,11,.4) 50%,
    rgba(7,7,11,.1) 100%);
}

.sc-img.tone-warm { background: linear-gradient(135deg, #1a1208 0%, #0f0e0a 100%); }
.sc-img.tone-cool { background: linear-gradient(135deg, #08101a 0%, #0a0f14 100%); }
.sc-img.tone-neut { background: linear-gradient(135deg, #111118 0%, #0c0c12 100%); }
.sc-img.tone-deep { background: linear-gradient(135deg, #120814 0%, #0c080f 100%); }

.sc-body {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 1.5rem; z-index: 2;
}

.sc-label {
  font-family: var(--font-mono); font-size: .58rem;
  color: var(--color-gold); letter-spacing: .16em;
  text-transform: uppercase; margin-bottom: .5rem;
  opacity: .7;
}

.sc-title {
  font-family: var(--font-serif, 'Playfair Display', Georgia, serif);
  font-size: clamp(1.1rem, 2.5vw, 1.5rem);
  font-weight: 700; color: var(--color-heading);
  line-height: 1.2; margin-bottom: .4rem;
  letter-spacing: -.01em;
}

.sc-desc {
  font-size: .8rem; color: var(--color-subtle);
  line-height: 1.6; font-weight: 300;
  margin-bottom: .75rem;
  display: -webkit-box; -webkit-line-clamp: 2;
  -webkit-box-orient: vertical; overflow: hidden;
}

.sc-footer { display: flex; align-items: center; justify-content: space-between; }

.sc-count {
  font-family: var(--font-mono); font-size: .62rem;
  color: var(--color-muted); letter-spacing: .08em;
}

.sc-arrow {
  width: 28px; height: 28px; border-radius: 50%;
  border: 1px solid rgba(255,255,255,.1);
  display: flex; align-items: center; justify-content: center;
  color: var(--color-subtle); font-size: .75rem;
  transition: border-color .2s, color .2s, background .2s;
}
.series-card:hover .sc-arrow {
  border-color: var(--color-gold); color: var(--color-gold);
  background: color-mix(in srgb, var(--color-gold) 8%, transparent);
}

.sc-num {
  position: absolute; top: 1rem; right: 1rem; z-index: 2;
  font-family: var(--font-mono); font-size: .62rem;
  color: rgba(255,255,255,.15); letter-spacing: .06em;
}

/* ── RECENT FRAMES ── */
.frames-grid { columns: 3; column-gap: .75rem; }
@media (max-width: 780px) { .frames-grid { columns: 2; } }
@media (max-width: 480px) { .frames-grid { columns: 1; } }

.frame-item {
  break-inside: avoid;
  margin-bottom: .75rem;
  position: relative; overflow: hidden;
  border-radius: 8px;
  background: var(--color-overlay);
  cursor: pointer;
  border: 1px solid var(--color-overlay);
  transition: transform .3s ease, box-shadow .3s ease;
}
.frame-item:hover { transform: scale(1.02); box-shadow: 0 16px 40px rgba(0,0,0,.5); }

.frame-ph { width: 100%; display: block; }

.frame-ph-inner {
  width: 100%; height: 100%;
  background: var(--color-overlay);
  display: flex; align-items: center; justify-content: center;
  color: var(--color-muted); font-family: var(--font-mono); font-size: .62rem;
  letter-spacing: .08em; text-transform: uppercase;
}

.frame-item:nth-child(1) .frame-ph-inner  { background: #0f0d14; }
.frame-item:nth-child(2) .frame-ph-inner  { background: #0a0f0d; }
.frame-item:nth-child(3) .frame-ph-inner  { background: #12100a; }
.frame-item:nth-child(4) .frame-ph-inner  { background: #0c0c14; }
.frame-item:nth-child(5) .frame-ph-inner  { background: #0a0e12; }
.frame-item:nth-child(6) .frame-ph-inner  { background: #100a10; }
.frame-item:nth-child(7) .frame-ph-inner  { background: #0f0d10; }
.frame-item:nth-child(8) .frame-ph-inner  { background: #0b110a; }
.frame-item:nth-child(9) .frame-ph-inner  { background: #111008; }

.frame-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(7,7,11,.8) 0%, transparent 50%);
  opacity: 0; transition: opacity .3s ease;
  display: flex; align-items: flex-end; padding: .75rem;
}
.frame-item:hover .frame-overlay { opacity: 1; }

.frame-series-tag {
  font-family: var(--font-mono); font-size: .58rem;
  color: var(--color-gold); letter-spacing: .1em; text-transform: uppercase;
}

/* ── CLOSING ── */
.closing {
  padding: 8rem 4rem;
  text-align: center; position: relative; overflow: hidden;
}
@media (max-width: 680px) { .closing { padding: 5rem 1.5rem; } }

.closing::before {
  content: ''; position: absolute; inset: 0; pointer-events: none;
  background: radial-gradient(ellipse 60% 50% at 50% 50%,
    color-mix(in srgb, var(--color-gold) 5%, transparent) 0%, transparent 65%);
}

.closing-inner { position: relative; z-index: 1; max-width: 580px; margin: 0 auto; }

.closing-title {
  font-family: var(--font-serif, 'Playfair Display', Georgia, serif);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 400; font-style: italic;
  color: var(--color-heading); line-height: 1.2;
  letter-spacing: -.02em; margin-bottom: 1.5rem;
}

.closing-sub {
  font-size: .95rem; color: var(--color-muted);
  line-height: 1.85; font-weight: 300; margin-bottom: 2.5rem;
}
.closing-sub strong { color: var(--color-text); font-weight: 400; }

.btn-p {
  display: inline-flex; align-items: center; gap: .5rem;
  background: transparent;
  color: var(--color-gold); font-family: var(--font-mono); font-size: .72rem;
  padding: .8rem 2rem; border-radius: 99px;
  border: 1px solid color-mix(in srgb, var(--color-gold) 35%, transparent);
  text-decoration: none; letter-spacing: .06em;
  transition: background .2s, box-shadow .2s, transform .2s;
}
.btn-p:hover {
  background: color-mix(in srgb, var(--color-gold) 7%, transparent);
  box-shadow: 0 0 32px color-mix(in srgb, var(--color-gold) 15%, transparent);
  transform: translateY(-2px);
}

/* ── Fade up ── */
.fu {
  opacity: 0; transform: translateY(32px);
  transition: opacity .8s cubic-bezier(.16,1,.3,1),
              transform .8s cubic-bezier(.16,1,.3,1);
}
.fu.vis { opacity: 1; transform: none; }
</style>

<script is:inline>
  // Fade up on scroll
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('vis'), 80);
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });

  document.querySelectorAll('.fu').forEach(el => {
    el.style.transitionDelay = '0ms';
    obs.observe(el);
  });

  // Stagger series cards
  const seriesObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const cards = e.target.querySelectorAll('.series-card');
        cards.forEach((c, i) => {
          c.style.opacity = '0';
          c.style.transform = 'translateY(24px)';
          c.style.transition = `opacity .7s ease ${i * 100}ms, transform .7s ease ${i * 100}ms`;
          requestAnimationFrame(() => setTimeout(() => {
            c.style.opacity = '1';
            c.style.transform = 'none';
          }, 50));
        });
        seriesObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.05 });

  const grid = document.querySelector('.series-grid');
  if (grid) seriesObs.observe(grid);

  // Stagger frame items
  const frameObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const frames = e.target.querySelectorAll('.frame-item');
        frames.forEach((f, i) => {
          f.style.opacity = '0';
          f.style.transition = `opacity .6s ease ${i * 60}ms`;
          requestAnimationFrame(() => setTimeout(() => {
            f.style.opacity = '1';
          }, 50));
        });
        frameObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.05 });

  const framesGrid = document.querySelector('.frames-grid');
  if (framesGrid) frameObs.observe(framesGrid);
</script>
