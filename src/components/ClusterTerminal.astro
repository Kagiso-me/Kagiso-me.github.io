---
const cmds = ['get nodes', 'get pods', 'top', 'uptime', 'whoami', 'help'];
---

<div class="term-wrap">
  <div class="term-bar">
    <span class="term-dot term-dot-red"></span>
    <span class="term-dot term-dot-yellow"></span>
    <span class="term-dot term-dot-green"></span>
    <span class="term-bar-title">kagiso@homelab — kubectl</span>
  </div>
  <div class="term-body" id="term-body" aria-live="polite"></div>
  <div class="term-input-row">
    <span class="term-prompt">kagiso@homelab:~$</span>
    <input
      id="term-input"
      class="term-input"
      type="text"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
      placeholder=""
      aria-label="terminal input"
    />
    <span class="term-cursor" id="term-cursor" aria-hidden="true">▌</span>
  </div>
  <div class="term-suggestions">
    <span class="term-hint">try:</span>
    {cmds.map(cmd => (
      <button class="term-suggestion" data-cmd={cmd}>{cmd}</button>
    ))}
  </div>
</div>

<style>
  .term-wrap {
    background: #0d0d0d;
    border: 1px solid var(--color-muted);
    border-radius: 12px;
    overflow: hidden;
    font-family: var(--font-mono);
  }

  .term-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    background: #1a1a1a;
    border-bottom: 1px solid #2a2a2a;
  }

  .term-bar-title {
    margin-left: 0.5rem;
    font-size: 0.72rem;
    color: #666;
  }

  .term-dot { width: 12px; height: 12px; border-radius: 50%; }
  .term-dot-red    { background: #ff5f57; }
  .term-dot-yellow { background: #ffbd2e; }
  .term-dot-green  { background: #28c840; }

  .term-body {
    padding: 1.25rem 1.5rem;
    min-height: 220px;
    max-height: 420px;
    overflow-y: auto;
    font-size: 0.82rem;
    line-height: 1.7;
    color: #c9d1d9;
    scrollbar-width: thin;
    scrollbar-color: #333 transparent;
  }

  .term-body:empty::before {
    content: "# Data loaded. Type a command or click a suggestion below.";
    color: #444;
  }

  :global(.term-line-cmd) { color: #58a6ff; margin-top: 0.75rem; }
  :global(.term-line-cmd)::before { content: "kagiso@homelab:~$ "; color: var(--color-peach); }
  :global(.term-line-header) {
    color: #666; font-size: 0.75rem; letter-spacing: 0.08em;
    text-transform: uppercase; margin-bottom: 0.25rem;
    border-bottom: 1px solid #222; padding-bottom: 0.25rem; margin-top: 0.5rem;
  }
  :global(.term-line-row)   { display: grid; gap: 0.5rem; padding: 0.15rem 0; }
  :global(.term-line-ok)    { color: #3fb950; }
  :global(.term-line-warn)  { color: #d29922; }
  :global(.term-line-crit)  { color: #f85149; }
  :global(.term-line-muted) { color: #666; }
  :global(.term-line-text)  { color: #c9d1d9; }
  :global(.term-line-peach) { color: var(--color-peach); }

  .term-input-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-top: 1px solid #1e1e1e;
    background: #111;
  }

  .term-prompt { color: var(--color-peach); font-size: 0.82rem; white-space: nowrap; flex-shrink: 0; }

  .term-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: #58a6ff;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    caret-color: var(--color-peach);
  }
  .term-input::placeholder { color: #333; }

  /* Blinking block cursor — visible when input is empty and unfocused */
  .term-cursor {
    color: var(--color-peach);
    font-size: 0.9rem;
    line-height: 1;
    animation: term-cur-blink 1s step-end infinite;
    pointer-events: none;
    flex-shrink: 0;
  }
  /* Hide cursor while user is typing (input has value) or input is focused */
  .term-input:focus ~ .term-cursor,
  .term-input.has-value ~ .term-cursor {
    display: none;
  }
  @keyframes term-cur-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* Typing animation states */
  .term-input.is-typing {
    caret-color: var(--color-peach);
    animation: cursor-blink 0.55s step-end infinite;
  }
  .term-input.is-submitting {
    opacity: 0.5;
    transition: opacity 0.1s;
  }
  @keyframes cursor-blink {
    0%, 100% { caret-color: var(--color-peach); }
    50%       { caret-color: transparent; }
  }

  .term-suggestions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.5rem;
    background: #0d0d0d;
    border-top: 1px solid #1a1a1a;
    flex-wrap: wrap;
  }

  .term-hint { font-size: 0.7rem; color: #444; font-family: var(--font-mono); }

  .term-suggestion {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #555;
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 4px;
    padding: 0.2rem 0.6rem;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  .term-suggestion:hover { color: var(--color-peach); border-color: var(--color-peach); }
</style>

<script>
  export let termData: any = null;

  function termPrint(lines: string[]) {
    const body = document.getElementById('term-body');
    if (!body) return;
    body.innerHTML += lines.join('\n') + '\n';
    body.scrollTop = body.scrollHeight;
  }

  function termClear() {
    const body = document.getElementById('term-body');
    if (body) body.innerHTML = '';
  }

  function statusColor(s: string) {
    if (s === 'ok')   return 'term-line-ok';
    if (s === 'warn') return 'term-line-warn';
    if (s === 'crit') return 'term-line-crit';
    return 'term-line-muted';
  }

  function dot(s: string) {
    const c = s === 'ok' ? '#3fb950' : s === 'warn' ? '#d29922' : s === 'crit' ? '#f85149' : '#555';
    return `<span style="color:${c}">●</span>`;
  }

  function pad(s: string, n: number) {
    return s.length >= n ? s : s + ' '.repeat(n - s.length);
  }

  function runCommand(raw: string) {
    const cmd = raw.trim().toLowerCase();
    if (!cmd) return;
    termPrint([`<span class="term-line-cmd">${raw.trim()}</span>`]);
    if (cmd === 'clear') { termClear(); return; }
    if (!termData) {
      termPrint([`<span class="term-line-muted">data not loaded yet — try again in a moment</span>`]);
      return;
    }
    switch (cmd) {
      case 'help':
        termPrint([
          `<span class="term-line-header">available commands</span>`,
          `<span class="term-line-peach">get nodes</span>   <span class="term-line-muted">— cluster node status and resource usage</span>`,
          `<span class="term-line-peach">get pods</span>    <span class="term-line-muted">— running workload count</span>`,
          `<span class="term-line-peach">top</span>         <span class="term-line-muted">— CPU and memory across all nodes</span>`,
          `<span class="term-line-peach">uptime</span>      <span class="term-line-muted">— cluster data freshness</span>`,
          `<span class="term-line-peach">whoami</span>      <span class="term-line-muted">— about this homelab</span>`,
          `<span class="term-line-peach">clear</span>       <span class="term-line-muted">— clear the terminal</span>`,
        ]);
        break;
      case 'whoami':
        termPrint([
          `<span class="term-line-text">Kagiso — software engineer, homelab operator.</span>`,
          `<span class="term-line-text">This cluster runs on 3× Lenovo ThinkCentre M93 nodes</span>`,
          `<span class="term-line-text">managed with k3s, Flux GitOps, and too much curiosity.</span>`,
          `<span class="term-line-text">Built in public. Everything you see here is real.</span>`,
        ]);
        break;
      case 'uptime': {
        const updated = termData.updated ?? '';
        if (updated) {
          const age = Date.now() - new Date(updated).getTime();
          const mins = Math.floor(age / 60000);
          const h = Math.floor(mins / 60), m = mins % 60;
          const ageStr = h > 0 ? `${h}h ${m}m ago` : `${m}m ago`;
          termPrint([
            `<span class="term-line-text">cluster data last refreshed: <span class="term-line-ok">${ageStr}</span></span>`,
            `<span class="term-line-muted">updates every 30 minutes via GitHub Actions on bran</span>`,
          ]);
        } else {
          termPrint([`<span class="term-line-muted">no timestamp available</span>`]);
        }
        break;
      }
      case 'get pods': {
        const wl = termData.cards?.find((c: any) => c.label === 'Workloads');
        if (wl) {
          const [running, total] = (wl.value ?? '0/0').split('/');
          const allRunning = running === total;
          termPrint([
            `<span class="term-line-header">${pad('WORKLOADS', 20)}  STATUS</span>`,
            `<span class="${allRunning ? 'term-line-ok' : 'term-line-warn'}">${pad('pods', 20)}  ${wl.value} running</span>`,
            `<span class="term-line-muted">${allRunning ? 'all pods healthy' : `${parseInt(total)-parseInt(running)} pod(s) not running`}</span>`,
          ]);
        } else {
          termPrint([`<span class="term-line-muted">no pod data available</span>`]);
        }
        break;
      }
      case 'get nodes': {
        const nodes = termData.nodes ?? [];
        if (!nodes.length) { termPrint([`<span class="term-line-muted">no node data available</span>`]); break; }
        termPrint([`<span class="term-line-header">${pad('NAME',12)} ${pad('ROLE',16)} ${pad('STATUS',10)} ${pad('CPU',8)} MEM</span>`]);
        nodes.forEach((n: any) => {
          const cls = statusColor(n.status);
          const statusTxt = n.status === 'ok' ? 'Ready' : n.status === 'crit' ? 'NotReady' : 'Degraded';
          termPrint([`<span class="${cls}">${dot(n.status)} ${pad(n.name,10)} ${pad(n.role,16)} ${pad(statusTxt,10)} ${pad(n.cpu,8)} ${n.memory}</span>`]);
        });
        break;
      }
      case 'top': {
        const nodes = termData.nodes ?? [];
        if (!nodes.length) { termPrint([`<span class="term-line-muted">no resource data available</span>`]); break; }
        termPrint([`<span class="term-line-header">${pad('NODE',14)} ${pad('CPU REQUESTS',16)} MEM REQUESTS</span>`]);
        nodes.forEach((n: any) => {
          termPrint([`<span class="${statusColor(n.status)}">${dot(n.status)} ${pad(n.name,12)} ${pad(n.cpu,16)} ${n.memory}</span>`]);
        });
        termPrint([`<span class="term-line-muted">values reflect scheduled pod resource requests</span>`]);
        break;
      }
      default:
        termPrint([
          `<span class="term-line-crit">command not found: ${raw.trim()}</span>`,
          `<span class="term-line-muted">type <span style="color:var(--color-peach)">help</span> for available commands</span>`,
        ]);
    }
  }

  // ── Boot sequence + typing animation ────────────────────────────────────
  const BOOT_LINES = [
    { text: 'Linux homelab 6.8.0-110-generic #110-Ubuntu SMP PREEMPT_DYNAMIC', cls: 'term-line-muted', delay: 0 },
    { text: 'k3s v1.31.4+k3s1 · Flux v2.4.0 · 3 nodes', cls: 'term-line-muted', delay: 80 },
    { text: 'Last login: ' + new Date().toUTCString() + ' from 192.168.8.1', cls: 'term-line-muted', delay: 160 },
  ];

  let autoRanOnce = false;
  let liveDataReady = false;

  function typeCommand(cmd: string, onDone: () => void) {
    const inp = document.getElementById('term-input') as HTMLInputElement;
    if (!inp) { onDone(); return; }
    inp.value = '';
    inp.disabled = true;
    inp.classList.add('is-typing');

    // Natural typing rhythm: slightly varied per character
    let i = 0;

    function tick() {
      if (i < cmd.length) {
        inp.value = cmd.slice(0, i + 1);
        i++;
        const delay = 48 + Math.random() * 55;
        setTimeout(tick, delay);
      } else {
        // Pause — looks like the person is reading before pressing Enter
        setTimeout(() => {
          inp.classList.remove('is-typing');
          inp.classList.add('is-submitting');
          setTimeout(() => {
            inp.classList.remove('is-submitting');
            inp.disabled = false;
            inp.value = '';
            onDone();
          }, 120);
        }, 360);
      }
    }
    // Small pause before starting — feels more human
    setTimeout(tick, 200);
  }

  // Auto-sequence of commands that loops silently after boot
  const AUTO_SEQUENCE = ['kubectl get nodes', 'kubectl get pods', 'kubectl top nodes'];
  const SEQUENCE_CMDS = ['get nodes', 'get pods', 'top'];
  let seqIdx = 0;
  let seqRunning = false;

  function runNextInSequence() {
    if (!liveDataReady) return;
    seqRunning = true;
    const cmd  = AUTO_SEQUENCE[seqIdx];
    const exec = SEQUENCE_CMDS[seqIdx];
    seqIdx = (seqIdx + 1) % AUTO_SEQUENCE.length;

    // Pause 4-7 seconds between commands — feels like a real operator
    const pause = 4000 + Math.random() * 3000;
    setTimeout(() => {
      if (document.hidden) { seqRunning = false; return; }
      typeCommand(cmd, () => {
        runCommand(exec);
        setTimeout(runNextInSequence, pause);
      });
    }, pause);
  }

  function runBoot() {
    const body = document.getElementById('term-body');
    if (!body) return;

    let done = 0;
    BOOT_LINES.forEach(({ text, cls, delay }) => {
      setTimeout(() => {
        body.innerHTML += `<span class="${cls}">${text}</span>\n`;
        body.scrollTop = body.scrollHeight;
        done++;
        if (done === BOOT_LINES.length) {
          setTimeout(() => {
            typeCommand('kubectl get nodes', () => {
              if (liveDataReady) {
                runCommand('get nodes');
                setTimeout(runNextInSequence, 5000);
              } else {
                body.innerHTML += `<span class="term-line-muted">connecting to cluster api…</span>\n`;
                body.scrollTop = body.scrollHeight;
              }
            });
          }, 400);
        }
      }, delay);
    });
  }

  // Start boot immediately — no data dependency
  // Guard against double-fire on Astro view transition re-mounts
  if (!(window as any).__termBooted) {
    (window as any).__termBooted = true;
    if (document.readyState === 'loading') {
      window.addEventListener('DOMContentLoaded', () => runBoot(), { once: true });
    } else {
      runBoot();
    }
  }

  // Expose setter so index.astro can push live data in.
  (window as any).__termSetData = (data: any) => {
    termData = data;
    liveDataReady = true;
    if (!autoRanOnce) {
      autoRanOnce = true;
      // Also kick off the auto-sequence loop if boot already finished
      if (!seqRunning) setTimeout(runNextInSequence, 5000);
      const body = document.getElementById('term-body');
      if (body) {
        // Replace the "connecting…" line if it exists, else just run the command
        const lines = body.innerHTML;
        if (lines.includes('connecting to cluster api')) {
          body.innerHTML = lines.replace(
            /<span class="term-line-muted">connecting to cluster api…<\/span>\n/,
            ''
          );
        }
      }
      runCommand('get nodes');
    }
  };

  const input = document.getElementById('term-input') as HTMLInputElement;
  const history: string[] = [];
  let histIdx = -1;

  // Keep has-value class in sync so the block cursor hides while typing
  input?.addEventListener('input', () => {
    input.classList.toggle('has-value', input.value.length > 0);
  });

  input?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') {
      const val = input.value;
      if (val.trim()) { history.unshift(val); histIdx = -1; }
      runCommand(val);
      input.value = '';
      input.classList.remove('has-value');
    }
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (histIdx < history.length - 1) { histIdx++; input.value = history[histIdx]; }
    }
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (histIdx > 0) { histIdx--; input.value = history[histIdx]; }
      else { histIdx = -1; input.value = ''; }
    }
    if (e.key === 'Tab') {
      e.preventDefault();
      const cmds = ['get nodes', 'get pods', 'top', 'uptime', 'whoami', 'help', 'clear'];
      const cur = input.value.toLowerCase();
      const match = cmds.find(c => c.startsWith(cur) && c !== cur);
      if (match) input.value = match;
    }
  });

  document.querySelectorAll('.term-suggestion').forEach(btn => {
    btn.addEventListener('click', () => {
      runCommand((btn as HTMLElement).dataset.cmd ?? '');
      input?.focus();
    });
  });
</script>
