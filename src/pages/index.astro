---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Command Center" description="Living Homelab — built in public by Kagiso.">

  <!-- ── Hero ── -->
  <section class="hero fade-up">
    <div class="hero-inner">
      <p class="mono hero-eyebrow">~/homelab</p>
      <h1>
        <span class="gradient-text">Living Homelab</span>
      </h1>
      <p class="hero-sub">
        A real homelab, built and operated in public —
        from bare metal to production discipline.
      </p>
      <div class="hero-actions">
        <a href="/status" class="btn-primary">View Status</a>
        <a href="/decisions" class="btn-ghost">Architecture Decisions</a>
      </div>
    </div>
  </section>

  <!-- ── Terminal ── -->
  <section class="section fade-up" style="animation-delay: 0.05s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Cluster Terminal</h2>
        <span class="mono" style="color:var(--color-subtle);font-size:0.8rem">read-only · live data</span>
      </div>

      <div class="term-wrap">
        <!-- Title bar -->
        <div class="term-bar">
          <span class="term-dot term-dot-red"></span>
          <span class="term-dot term-dot-yellow"></span>
          <span class="term-dot term-dot-green"></span>
          <span class="term-bar-title">kagiso@homelab — kubectl</span>
        </div>

        <!-- Output area -->
        <div class="term-body" id="term-body" aria-live="polite"></div>

        <!-- Input row -->
        <div class="term-input-row">
          <span class="term-prompt">kagiso@homelab:~$</span>
          <input
            id="term-input"
            class="term-input"
            type="text"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            placeholder="type a command or press Tab"
            aria-label="terminal input"
          />
        </div>

        <!-- Suggestions -->
        <div class="term-suggestions">
          <span class="term-hint">try:</span>
          {['get nodes', 'get pods', 'top', 'uptime', 'whoami', 'help'].map(cmd => (
            <button class="term-suggestion" data-cmd={cmd}>{cmd}</button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── What's Running Right Now ── -->
  <section class="section fade-up" style="animation-delay: 0.1s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">What's Running Right Now</h2>
        <span class="mono live-badge">
          <span class="status-dot ok"></span>
          Live
        </span>
      </div>

      <!-- Summary cards -->
      <div class="live-grid" id="live-grid">
        <div class="live-card skeleton"></div>
        <div class="live-card skeleton"></div>
        <div class="live-card skeleton"></div>
        <div class="live-card skeleton"></div>
      </div>

      <!-- Services grid -->
      <div class="svc-grid" id="svc-grid">
        <div class="svc-item skeleton" style="height:48px;border-radius:8px"></div>
        <div class="svc-item skeleton" style="height:48px;border-radius:8px"></div>
        <div class="svc-item skeleton" style="height:48px;border-radius:8px"></div>
        <div class="svc-item skeleton" style="height:48px;border-radius:8px"></div>
        <div class="svc-item skeleton" style="height:48px;border-radius:8px"></div>
        <div class="svc-item skeleton" style="height:48px;border-radius:8px"></div>
      </div>

      <!-- Media player cards -->
      <div class="media-grid" id="media-grid">
        <div class="media-card skeleton" style="height:200px"></div>
        <div class="media-card skeleton" style="height:200px"></div>
      </div>
    </div>
  </section>

  <!-- ── Cluster Status Strip ── -->
  <section class="section fade-up" style="animation-delay: 0.2s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Cluster Health</h2>
        <a href="/status" class="mono link-subtle">Full dashboard →</a>
      </div>
      <div class="status-strip" id="status-strip">
        <div class="status-strip-item skeleton" style="height: 56px; border-radius: 8px;"></div>
        <div class="status-strip-item skeleton" style="height: 56px; border-radius: 8px;"></div>
        <div class="status-strip-item skeleton" style="height: 56px; border-radius: 8px;"></div>
      </div>
    </div>
  </section>

  <!-- ── Recent Digest + Active Project ── -->
  <section class="section fade-up" style="animation-delay: 0.3s">
    <div class="section-inner two-col">

      <div>
        <div class="section-header">
          <h2 class="section-title">Recent Digest</h2>
          <a href="/digest" class="mono link-subtle">All entries →</a>
        </div>
        <div id="digest-list">
          <div class="skeleton" style="height: 80px; border-radius: 8px; margin-bottom: 0.75rem;"></div>
          <div class="skeleton" style="height: 80px; border-radius: 8px; margin-bottom: 0.75rem;"></div>
          <div class="skeleton" style="height: 80px; border-radius: 8px;"></div>
        </div>
      </div>

      <div>
        <div class="section-header">
          <h2 class="section-title">Active Work</h2>
          <a href="/projects" class="mono link-subtle">Roadmap →</a>
        </div>
        <div id="active-project">
          <div class="skeleton" style="height: 200px; border-radius: 12px;"></div>
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
  .hero {
    padding: 6rem 1.5rem 4rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    color: var(--color-peach);
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  h1 {
    font-size: clamp(3rem, 6vw, 5rem);
    margin: 0 0 1.5rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    color: var(--color-subtle);
    max-width: 520px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 0.625rem 1.5rem;
    background: var(--color-peach);
    color: var(--color-base);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: opacity 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
    color: var(--color-base);
  }

  .btn-ghost {
    padding: 0.625rem 1.5rem;
    border: 1px solid var(--color-muted);
    color: var(--color-text);
    border-radius: 8px;
    font-size: 0.9rem;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--color-mauve);
    color: var(--color-mauve);
  }

  .section {
    padding: 3rem 1.5rem;
    border-top: 1px solid var(--color-muted);
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 1.125rem;
    margin: 0;
  }

  .link-subtle {
    color: var(--color-subtle);
    transition: color 0.2s;
  }

  .link-subtle:hover { color: var(--color-peach); }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-ok);
  }

  .live-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .live-card {
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 12px;
    padding: 1.25rem;
    min-height: 100px;
  }

  .status-strip {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  /* ── Services grid ── */
  .svc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.625rem;
    margin-top: 1.5rem;
  }

  .svc-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 8px;
    padding: 0.625rem 1rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .svc-item:hover { background: var(--color-overlay); }
  .svc-item.ok   { border-left: 3px solid var(--color-ok); }
  .svc-item.warn { border-left: 3px solid var(--color-warn); }
  .svc-item.crit { border-left: 3px solid var(--color-crit); }

  .svc-name {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-heading);
  }

  .svc-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-subtle);
    margin-top: 0.1rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Media player cards ── */
  .media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .media-card {
    background: var(--color-surface);
    border: 1px solid var(--color-muted);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
    position: relative;
  }

  .media-card.active {
    border-color: var(--color-ok);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-ok) 20%, transparent);
  }

  .media-card.placeholder {
    border-style: dashed;
    opacity: 0.65;
  }

  /* Blurred art backdrop */
  .media-backdrop {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: blur(28px) saturate(1.4);
    opacity: 0.18;
    pointer-events: none;
    transition: opacity 0.4s;
  }

  .media-card.active .media-backdrop { opacity: 0.28; }

  .media-inner {
    position: relative;
    padding: 1.25rem;
    z-index: 1;
  }

  .media-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .media-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .media-badge.playing { color: var(--color-ok); }
  .media-badge.idle    { color: var(--color-subtle); }
  .media-badge.soon    { color: var(--color-peach); }

  .media-service-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .media-body {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .media-art {
    width: 80px;
    height: 80px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
    background: var(--color-overlay);
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
  }

  .media-art-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 8px;
    background: var(--color-overlay);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    flex-shrink: 0;
    color: var(--color-subtle);
  }

  .media-text { min-width: 0; flex: 1; }

  .media-title {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-heading);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.3;
  }

  .media-sub {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-subtle);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 0.3rem;
  }

  .media-next {
    margin-top: 0.875rem;
    padding-top: 0.875rem;
    border-top: 1px solid var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-subtle);
  }

  .media-next-label {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-peach);
    margin-bottom: 0.2rem;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; gap: 2rem; }
    .hero { padding: 4rem 1.5rem 3rem; }
  }

  .skeleton {
    background: linear-gradient(
      90deg,
      var(--color-surface) 25%,
      var(--color-overlay) 50%,
      var(--color-surface) 75%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Terminal ── */
  .term-wrap {
    background: #0d0d0d;
    border: 1px solid var(--color-muted);
    border-radius: 12px;
    overflow: hidden;
    font-family: var(--font-mono);
  }

  .term-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    background: #1a1a1a;
    border-bottom: 1px solid #2a2a2a;
  }

  .term-bar-title {
    margin-left: 0.5rem;
    font-size: 0.72rem;
    color: #666;
  }

  .term-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .term-dot-red    { background: #ff5f57; }
  .term-dot-yellow { background: #ffbd2e; }
  .term-dot-green  { background: #28c840; }

  .term-body {
    padding: 1.25rem 1.5rem;
    min-height: 220px;
    max-height: 420px;
    overflow-y: auto;
    font-size: 0.82rem;
    line-height: 1.7;
    color: #c9d1d9;
    scrollbar-width: thin;
    scrollbar-color: #333 transparent;
  }

  .term-body:empty::before {
    content: "# Data loaded. Type a command or click a suggestion below.";
    color: #444;
  }

  /* Output line types */
  .term-line-cmd {
    color: #58a6ff;
    margin-top: 0.75rem;
  }
  .term-line-cmd::before {
    content: "kagiso@homelab:~$ ";
    color: var(--color-peach);
  }
  .term-line-header {
    color: #666;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
    border-bottom: 1px solid #222;
    padding-bottom: 0.25rem;
    margin-top: 0.5rem;
  }
  .term-line-row {
    display: grid;
    gap: 0.5rem;
    padding: 0.15rem 0;
  }
  .term-line-ok     { color: #3fb950; }
  .term-line-warn   { color: #d29922; }
  .term-line-crit   { color: #f85149; }
  .term-line-muted  { color: #666; }
  .term-line-text   { color: #c9d1d9; }
  .term-line-peach  { color: var(--color-peach); }

  .term-input-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-top: 1px solid #1e1e1e;
    background: #111;
  }

  .term-prompt {
    color: var(--color-peach);
    font-size: 0.82rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .term-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: #58a6ff;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    caret-color: var(--color-peach);
  }

  .term-input::placeholder { color: #333; }

  .term-suggestions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.5rem;
    background: #0d0d0d;
    border-top: 1px solid #1a1a1a;
    flex-wrap: wrap;
  }

  .term-hint {
    font-size: 0.7rem;
    color: #444;
    font-family: var(--font-mono);
  }

  .term-suggestion {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #555;
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 4px;
    padding: 0.2rem 0.6rem;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  .term-suggestion:hover {
    color: var(--color-peach);
    border-color: var(--color-peach);
  }
</style>

<script>
  // ── Terminal ────────────────────────────────────────────────────────────────
  let termData: any = null;

  function termPrint(lines: string[]) {
    const body = document.getElementById('term-body');
    if (!body) return;
    body.innerHTML += lines.join('\n') + '\n';
    body.scrollTop = body.scrollHeight;
  }

  function termClear() {
    const body = document.getElementById('term-body');
    if (body) body.innerHTML = '';
  }

  function statusColor(s: string) {
    if (s === 'ok')   return 'term-line-ok';
    if (s === 'warn') return 'term-line-warn';
    if (s === 'crit') return 'term-line-crit';
    return 'term-line-muted';
  }

  function dot(s: string) {
    const c = s === 'ok' ? '#3fb950' : s === 'warn' ? '#d29922' : s === 'crit' ? '#f85149' : '#555';
    return `<span style="color:${c}">●</span>`;
  }

  function pad(s: string, n: number) {
    return s.length >= n ? s : s + ' '.repeat(n - s.length);
  }

  function runCommand(raw: string) {
    const cmd = raw.trim().toLowerCase();
    if (!cmd) return;

    termPrint([`<span class="term-line-cmd">${raw.trim()}</span>`]);

    if (cmd === 'clear') { termClear(); return; }

    if (!termData) {
      termPrint([`<span class="term-line-muted">data not loaded yet — try again in a moment</span>`]);
      return;
    }

    switch (cmd) {

      case 'help':
        termPrint([
          `<span class="term-line-header">available commands</span>`,
          `<span class="term-line-peach">get nodes</span>   <span class="term-line-muted">— cluster node status and resource usage</span>`,
          `<span class="term-line-peach">get pods</span>    <span class="term-line-muted">— running workload count</span>`,
          `<span class="term-line-peach">top</span>         <span class="term-line-muted">— CPU and memory across all nodes</span>`,
          `<span class="term-line-peach">uptime</span>      <span class="term-line-muted">— cluster data freshness</span>`,
          `<span class="term-line-peach">whoami</span>      <span class="term-line-muted">— about this homelab</span>`,
          `<span class="term-line-peach">clear</span>       <span class="term-line-muted">— clear the terminal</span>`,
        ]);
        break;

      case 'whoami':
        termPrint([
          `<span class="term-line-text">Kagiso — software engineer, homelab operator.</span>`,
          `<span class="term-line-text">This cluster runs on 3× Lenovo ThinkCentre M93 nodes</span>`,
          `<span class="term-line-text">managed with k3s, Flux GitOps, and too much curiosity.</span>`,
          `<span class="term-line-text">Built in public. Everything you see here is real.</span>`,
        ]);
        break;

      case 'uptime': {
        const updated = termData.updated ?? '';
        if (updated) {
          const age = Date.now() - new Date(updated).getTime();
          const mins = Math.floor(age / 60000);
          const h    = Math.floor(mins / 60);
          const m    = mins % 60;
          const ageStr = h > 0 ? `${h}h ${m}m ago` : `${m}m ago`;
          termPrint([
            `<span class="term-line-text">cluster data last refreshed: <span class="term-line-ok">${ageStr}</span></span>`,
            `<span class="term-line-muted">updates every 30 minutes via GitHub Actions on bran</span>`,
          ]);
        } else {
          termPrint([`<span class="term-line-muted">no timestamp available</span>`]);
        }
        break;
      }

      case 'get pods': {
        const wl = termData.cards?.find((c: any) => c.label === 'Workloads');
        if (wl) {
          const [running, total] = (wl.value ?? '0/0').split('/');
          const allRunning = running === total;
          termPrint([
            `<span class="term-line-header">${pad('WORKLOADS', 20)}  STATUS</span>`,
            `<span class="${allRunning ? 'term-line-ok' : 'term-line-warn'}">${pad('pods', 20)}  ${wl.value} running</span>`,
            `<span class="term-line-muted">${allRunning ? 'all pods healthy' : `${parseInt(total)-parseInt(running)} pod(s) not running`}</span>`,
          ]);
        } else {
          termPrint([`<span class="term-line-muted">no pod data available</span>`]);
        }
        break;
      }

      case 'get nodes': {
        const nodes = termData.nodes ?? [];
        if (!nodes.length) { termPrint([`<span class="term-line-muted">no node data available</span>`]); break; }
        termPrint([`<span class="term-line-header">${pad('NAME',12)} ${pad('ROLE',16)} ${pad('STATUS',10)} ${pad('CPU',8)} MEM</span>`]);
        nodes.forEach((n: any) => {
          const cls = statusColor(n.status);
          const statusTxt = n.status === 'ok' ? 'Ready' : n.status === 'crit' ? 'NotReady' : 'Degraded';
          termPrint([
            `<span class="${cls}">${dot(n.status)} ${pad(n.name,10)} ${pad(n.role,16)} ${pad(statusTxt,10)} ${pad(n.cpu,8)} ${n.memory}</span>`
          ]);
        });
        break;
      }

      case 'top': {
        const nodes = termData.nodes ?? [];
        if (!nodes.length) { termPrint([`<span class="term-line-muted">no resource data available</span>`]); break; }
        termPrint([`<span class="term-line-header">${pad('NODE',14)} ${pad('CPU REQUESTS',16)} MEM REQUESTS</span>`]);
        nodes.forEach((n: any) => {
          const cls = statusColor(n.status);
          termPrint([
            `<span class="${cls}">${dot(n.status)} ${pad(n.name,12)} ${pad(n.cpu,16)} ${n.memory}</span>`
          ]);
        });
        termPrint([`<span class="term-line-muted">values reflect scheduled pod resource requests</span>`]);
        break;
      }

      default:
        termPrint([
          `<span class="term-line-crit">command not found: ${raw.trim()}</span>`,
          `<span class="term-line-muted">type <span style="color:var(--color-peach)">help</span> for available commands</span>`,
        ]);
    }
  }

  function termInit() {
    const input = document.getElementById('term-input') as HTMLInputElement;
    const history: string[] = [];
    let histIdx = -1;

    // Run command on Enter
    input?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') {
        const val = input.value;
        if (val.trim()) { history.unshift(val); histIdx = -1; }
        runCommand(val);
        input.value = '';
      }
      // History navigation
      if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (histIdx < history.length - 1) { histIdx++; input.value = history[histIdx]; }
      }
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (histIdx > 0) { histIdx--; input.value = history[histIdx]; }
        else { histIdx = -1; input.value = ''; }
      }
      // Tab cycles through suggestions
      if (e.key === 'Tab') {
        e.preventDefault();
        const cmds = ['get nodes', 'get pods', 'top', 'uptime', 'whoami', 'help', 'clear'];
        const cur = input.value.toLowerCase();
        const match = cmds.find(c => c.startsWith(cur) && c !== cur);
        if (match) input.value = match;
      }
    });

    // Suggestion chip clicks
    document.querySelectorAll('.term-suggestion').forEach(btn => {
      btn.addEventListener('click', () => {
        const cmd = (btn as HTMLElement).dataset.cmd ?? '';
        runCommand(cmd);
        input?.focus();
      });
    });

  }

  // ── Fallback static list — shown immediately before live.json loads
  const STATIC_SERVICES = [
    { name: 'Immich',    tag: '—',    status: 'unknown' },
    { name: 'Nextcloud', tag: '—',    status: 'unknown' },
    { name: 'SABnzbd',   tag: 'idle', status: 'unknown' },
    { name: 'Sonarr',    tag: '—',    status: 'unknown' },
    { name: 'Radarr',    tag: '—',    status: 'unknown' },
    { name: 'Lidarr',    tag: '—',    status: 'unknown' },
  ];

  const STATIC_MEDIA = [
    { name: 'Plex',       label: 'idle',        status: 'unknown', playing: false },
    { name: 'AzuraCast',  label: 'coming soon', status: 'unknown', playing: false, placeholder: true },
  ];

  function buildSvcGrid(services: {name: string; tag: string; status: string}[]) {
    const grid = document.getElementById('svc-grid');
    if (!grid) return;
    grid.innerHTML = services.map(s => {
      const colonIdx = s.tag.indexOf(':');
      const name = colonIdx > -1 ? s.tag.slice(0, colonIdx).trim() : s.name;
      const meta = colonIdx > -1 ? s.tag.slice(colonIdx + 1).trim() : s.tag;
      return `
        <div class="svc-item ${s.status}">
          <span class="status-dot ${s.status}"></span>
          <div style="min-width:0">
            <div class="svc-name">${name}</div>
            ${meta ? `<div class="svc-meta">${meta}</div>` : ''}
          </div>
        </div>`;
    }).join('');
  }

  function buildMedia(items: any[]) {
    const grid = document.getElementById('media-grid');
    if (!grid) return;

    const icons: Record<string, string> = { Plex: '▶', AzuraCast: '📻' };

    grid.innerHTML = items.map(m => {
      const playing    = m.playing === true;
      const isPlaceholder = m.placeholder === true;
      const icon       = icons[m.name] ?? '▶';
      const backdropStyle = playing && m.coverUrl
        ? `style="background-image:url('${m.coverUrl}')"` : '';

      const artHtml = playing && m.coverUrl
        ? `<img class="media-art" src="${m.coverUrl}" alt="album art" loading="lazy"
             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
           <div class="media-art-placeholder" style="display:none">${icon}</div>`
        : `<div class="media-art-placeholder">${icon}</div>`;

      let textHtml = '';
      let nextHtml = '';

      if (isPlaceholder) {
        textHtml = `
          <div class="media-title" style="color:var(--color-subtle);font-weight:400">Coming soon</div>
          <div class="media-sub">Deploy AzuraCast to see your radio station here</div>`;
      } else if (m.name === 'AzuraCast') {
        if (playing) {
          textHtml = `
            <div class="media-title">${m.title || m.label}</div>
            <div class="media-sub">${[m.artist, m.show].filter(Boolean).join(' · ')}</div>`;
          if (m.next) {
            nextHtml = `
              <div class="media-next">
                <div class="media-next-label">Up next</div>
                <div>${m.next}</div>
              </div>`;
          }
        } else {
          textHtml = `<div class="media-title" style="color:var(--color-subtle);font-weight:400">Off air</div>`;
        }
      } else {
        if (playing) {
          textHtml = `
            <div class="media-title">${m.title || m.label}</div>
            <div class="media-sub">${[m.artist, m.album].filter(Boolean).join(' · ')}</div>`;
        } else {
          textHtml = `<div class="media-title" style="color:var(--color-subtle);font-weight:400">idle</div>`;
        }
      }

      const badgeClass = isPlaceholder ? 'soon' : playing ? 'playing' : 'idle';
      const badgeText  = isPlaceholder ? 'soon™' : playing ? 'playing' : 'idle';

      return `
      <div class="media-card${playing ? ' active' : ''}${isPlaceholder ? ' placeholder' : ''}">
        <div class="media-backdrop" ${backdropStyle}></div>
        <div class="media-inner">
          <div class="media-card-header">
            <span class="media-badge ${badgeClass}">
              <span class="status-dot ${m.status}"></span>
              ${badgeText}
            </span>
            <span class="media-service-label">${m.name}</span>
          </div>
          <div class="media-body">
            ${artHtml}
            <div class="media-text">${textHtml}</div>
          </div>
          ${nextHtml}
        </div>
      </div>`;
    }).join('');
  }

  async function loadLiveData() {
    // Render immediately with static fallback
    buildSvcGrid(STATIC_SERVICES);
    buildMedia(STATIC_MEDIA);

    try {
      const res = await fetch('/data/live.json');
      if (!res.ok) throw new Error('no data');
      const data = await res.json();
      termData = data; // make available to terminal

      const grid = document.getElementById('live-grid');
      if (grid && data.cards) {
        grid.innerHTML = data.cards.map((card: any) => `
          <div class="live-card fade-up">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem">
              <span class="mono" style="color:var(--color-subtle)">${card.label}</span>
              <span class="status-dot ${card.status}"></span>
            </div>
            <div style="font-size:1.5rem;font-weight:700;color:var(--color-heading);font-family:var(--font-mono)">${card.value}</div>
            <div class="mono" style="margin-top:0.25rem">${card.sub ?? ''}</div>
          </div>
        `).join('');
      }

      if (data.services?.length) buildSvcGrid(data.services);
      if (data.media?.length)    buildMedia(data.media);

      const strip = document.getElementById('status-strip');
      if (strip && data.nodes) {
        strip.innerHTML = data.nodes.map((node: any) => {
          const pressureWarning = node.pressure?.length
            ? `<span style="color:var(--color-warn);font-size:0.7rem;margin-left:0.5rem">${node.pressure.join(', ')}</span>`
            : '';
          return `
          <div style="background:var(--color-surface);border:1px solid var(--color-muted);border-radius:8px;padding:0.875rem 1rem;display:flex;align-items:center;gap:0.75rem">
            <span class="status-dot ${node.status}"></span>
            <div>
              <div style="font-size:0.875rem;color:var(--color-heading);font-weight:600">${node.name}${pressureWarning}</div>
              <div class="mono">${node.role}</div>
            </div>
            <div style="margin-left:auto;text-align:right">
              <div class="mono" style="color:var(--color-peach)">${node.pods} pods</div>
              <div class="mono">${node.cpu} CPU · ${node.memory} mem</div>
            </div>
          </div>`;
        }).join('');
      }
    } catch { /* skeletons stay, ticker already showing with static fallback */ }
  }

  async function loadDigest() {
    try {
      const res = await fetch('/data/digest.json');
      if (!res.ok) throw new Error('no data');
      const entries = await res.json();
      const list = document.getElementById('digest-list');
      if (list) {
        const TYPE_COLOR: Record<string, string> = {
          DEPLOY: 'var(--color-ok)', FIX: 'var(--color-peach)', INCIDENT: 'var(--color-crit)',
          HARDWARE: 'var(--color-gold)', NETWORK: 'var(--color-mauve)', SECURITY: 'var(--color-warn)',
        };
        list.innerHTML = entries.slice(0, 3).map((e: any) => {
          const color = TYPE_COLOR[e.type] ?? 'var(--color-subtle)';
          const tag = e.hasDetail ? 'a' : 'div';
          const href = e.hasDetail ? `href="/digest/entry?slug=${e.slug}"` : '';
          return `
          <${tag} ${href} style="display:block;text-decoration:none;margin-bottom:0.75rem">
            <div class="card" style="padding:1rem;transition:border-color 0.15s${e.hasDetail ? ';cursor:pointer' : ''}">
              <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.4rem">
                <span style="font-family:var(--font-mono);font-size:0.65rem;font-weight:600;padding:0.15rem 0.45rem;border-radius:4px;background:color-mix(in srgb,${color} 12%,transparent);color:${color};text-transform:uppercase;letter-spacing:0.05em">${e.type}</span>
                <span class="mono" style="color:var(--color-subtle);font-size:0.72rem">${e.date}</span>
                ${e.hasDetail ? `<span class="mono" style="color:var(--color-peach);font-size:0.7rem;margin-left:auto">read more →</span>` : ''}
              </div>
              <div style="color:var(--color-heading);font-weight:600;font-size:0.875rem;line-height:1.4">${e.title}</div>
            </div>
          </${tag}>`;
        }).join('');
      }
    } catch { /* no data yet */ }
  }

  async function loadProject() {
    try {
      const res = await fetch('/data/roadmap.json');
      if (!res.ok) throw new Error('no data');
      const data = await res.json();
      const active = data.active?.[0];
      if (!active) return;
      const el = document.getElementById('active-project');
      if (el) {
        const progressHtml = active.progress != null ? `
          <div style="margin:1rem 0">
            <div style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:0.68rem;color:var(--color-subtle);margin-bottom:0.35rem">
              <span>progress</span><span>${active.progress}%</span>
            </div>
            <div style="height:4px;background:var(--color-overlay);border-radius:2px;overflow:hidden">
              <div style="height:100%;width:${active.progress}%;background:var(--color-ok);border-radius:2px"></div>
            </div>
          </div>` : '';
        const stackHtml = active.stack?.length
          ? `<div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:1rem">${active.stack.map((s: string) => `<span style="font-family:var(--font-mono);font-size:0.68rem;padding:0.2rem 0.55rem;border-radius:4px;background:var(--color-overlay);color:var(--color-subtle);border:1px solid var(--color-muted)">${s}</span>`).join('')}</div>`
          : '';
        el.innerHTML = `
          <a href="/projects" style="display:block;text-decoration:none">
            <div class="card" style="transition:border-color 0.15s">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
                <span class="mono" style="color:var(--color-ok);font-size:0.75rem;display:flex;align-items:center;gap:0.35rem">● active</span>
                <span class="mono" style="color:var(--color-subtle);font-size:0.72rem">→ roadmap</span>
              </div>
              <h3 style="margin:0 0 0.2rem;font-size:1.1rem">${active.title}</h3>
              <div class="mono" style="color:var(--color-subtle);font-size:0.75rem;margin-bottom:0.75rem">${active.subtitle}</div>
              <p style="color:var(--color-subtle);font-size:0.875rem;margin:0;line-height:1.6">${active.description}</p>
              ${progressHtml}
              ${stackHtml}
            </div>
          </a>
        `;
      }
    } catch { /* no data yet */ }
  }

  termInit();
  loadLiveData();
  loadDigest();
  loadProject();
</script>
