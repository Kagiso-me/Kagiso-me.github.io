  function row(dot: string, name: string, stat: string, badge: string, badgeCls: string) {
    return `<div class="ops-row">
      <span class="ops-dot ${dot}"></span>
      <span class="ops-name">${name}</span>
      <span class="ops-stat">${stat}</span>
      <span class="ops-badge ${badgeCls}">${badge}</span>
    </div>`;
  }

  function statNum(n: string | number, unit = '') {
    return `<span class="ops-num">${n}</span>${unit ? `<span class="ops-unit">${unit}</span>` : ''}`;
  }

  function buildOpsPanel(svcs: any[], media: any[]) {
    const panel = document.getElementById('ops-panel');
    if (!panel) return;

    // Build lookup by name
    const byName = (name: string) => svcs.find((s: any) => s.name.toLowerCase() === name.toLowerCase()) ?? {};
    const plex = media?.find((m: any) => m.name === 'Plex') ?? {};

    // Parse the tag values the fetch script produces
    // "Immich: 12.3k photos · 45 videos" → extract numbers
    const immich = byName('Immich');
    const nc     = byName('Nextcloud');
    const sab    = byName('SABnzbd');
    const sonarr = byName('Sonarr');
    const radarr = byName('Radarr');
    const lidarr = byName('Lidarr');

    function extract(tag: string = '') {
      // strip "Name: " prefix
      return tag.includes(': ') ? tag.split(': ').slice(1).join(': ').trim() : tag.trim();
    }

    function badgeForStatus(s: string, activeLabel = 'online') {
      if (s === 'ok')      return { cls: 'ok',      label: activeLabel };
      if (s === 'warn')    return { cls: 'warn',    label: 'degraded' };
      if (s === 'crit')    return { cls: 'crit',    label: 'offline' };
      return { cls: 'unknown', label: 'checking' };
    }

    function badgeForSab(label: string, s: string) {
      if (label.includes('downloading')) return { cls: 'active', label: 'downloading' };
      return badgeForStatus(s, 'idle');
    }

    function plexBadge() {
      if (plex.playing) return { cls: 'active', label: `${(plex.label ?? '').match(/^(\d+)/)?.[1] ?? '1'} stream` };
      return { cls: 'ok', label: 'idle' };
    }

    const immichB = badgeForStatus(immich.status ?? 'unknown', 'online');
    const ncB     = badgeForStatus(nc.status ?? 'unknown', 'online');
    const sabB    = badgeForSab(extract(sab.tag), sab.status ?? 'unknown');
    const sonarrB = badgeForStatus(sonarr.status ?? 'unknown', 'online');
    const radarrB = badgeForStatus(radarr.status ?? 'unknown', 'online');
    const lidarrB = badgeForStatus(lidarr.status ?? 'unknown', 'online');
    const plexB   = plexBadge();

    const html = [
      group('Files &amp; Photos'),
      row(immich.status ?? 'unknown', 'Immich',
        immich.status === 'ok' ? extract(immich.tag) || statNum('—') : '—',
        immichB.label, immichB.cls),
      row(nc.status ?? 'unknown', 'Nextcloud',
        nc.status === 'ok' ? extract(nc.tag) || statNum('—') : '—',
        ncB.label, ncB.cls),

      group('Media'),
      row(plex.status ?? 'unknown', 'Plex',
        plex.playing ? (plex.title ? `<span style="color:var(--color-text)">${plex.title}</span>` : plex.label ?? 'streaming') : 'idle',
        plexB.label, plexB.cls),
      row(sonarr.status ?? 'unknown', 'Sonarr',
        sonarr.status === 'ok' ? extract(sonarr.tag).replace('Sonarr: ', '') : '—',
        sonarrB.label, sonarrB.cls),
      row(radarr.status ?? 'unknown', 'Radarr',
        radarr.status === 'ok' ? extract(radarr.tag).replace('Radarr: ', '') : '—',
        radarrB.label, radarrB.cls),
      row(lidarr.status ?? 'unknown', 'Lidarr',
        lidarr.status === 'ok' ? extract(lidarr.tag).replace('Lidarr: ', '') : '—',
        lidarrB.label, lidarrB.cls),

      group('Downloads'),
      row(sab.status ?? 'unknown', 'SABnzbd',
        sab.status === 'ok' ? extract(sab.tag).replace('SABnzbd: ', '') : '—',
        sabB.label, sabB.cls),
    ].join('');

    panel.innerHTML = html;
  }

  async function loadLiveData() {
    // Show skeleton while fetching — already in HTML
    try {
      const res = await fetch('/data/live.json');
      if (!res.ok) throw new Error('no data');
      const data = await res.json();

      // Push data to ClusterTerminal component
      if (typeof (window as any).__termSetData === 'function') {
        (window as any).__termSetData(data);
      }

      // ── Live cluster map: colour node dots + quorum from real status ──────────
      const ccNodes: any[] = Array.isArray(data.nodes) ? data.nodes : [];
      const byName: Record<string, any> = {};
      for (const n of ccNodes) byName[String(n.name).toLowerCase()] = n;
      document.querySelectorAll<HTMLElement>('.cc-host-dot[data-node]').forEach((dot) => {
        const node = byName[dot.dataset.node ?? ''];
        const s = node?.status;
        dot.className = 'cc-host-dot ' + (s === 'ok' ? 'ok' : s === 'warn' ? 'warn' : s ? 'crit' : '');
      });
      const k3s = ['tywin', 'jaime', 'tyrion'].map((n) => byName[n]).filter(Boolean);
      const readyCount = k3s.filter((n) => n.status === 'ok').length;
      const quorumEl = document.getElementById('cc-quorum');
      if (quorumEl && k3s.length) quorumEl.textContent = `etcd quorum ${readyCount}/${k3s.length} · runs all workloads`;

      // ── Topology teaser node colouring ──────────────────────────────────────
      const nodeMap: Record<string, string> = {
        'tt-dot-internet': 'ok',
        'tt-dot-mikrotik':  data.nodes?.find((n: any) => n.name?.toLowerCase().includes('tywin')) ? 'ok' : 'off',
        'tt-dot-tywin':  data.nodes?.find((n: any) => n.name?.toLowerCase() === 'tywin')?.ready ? 'ok' : 'crit',
        'tt-dot-jaime':  data.nodes?.find((n: any) => n.name?.toLowerCase() === 'jaime')?.ready ? 'ok' : 'crit',
        'tt-dot-tyrion': data.nodes?.find((n: any) => n.name?.toLowerCase() === 'tyrion')?.ready ? 'ok' : 'crit',
        'tt-dot-bronn':  'ok',
        'tt-dot-varys':  'ok',
        'tt-dot-ned':    data.storage ? 'ok' : 'off',
      };
      for (const [id, state] of Object.entries(nodeMap)) {
        const dot = document.getElementById(id);
        if (dot) { dot.className = `tt-node-dot ${state === 'ok' ? '' : state}`.trim(); }
      }

      // ── Topology mini packet animation ──────────────────────────────────────
      (function animateTeaser() {
        const svg = document.getElementById('tt-lines');
        if (!svg) return;
        // Draw a simple vertical beam from internet → router → cluster
        const wrap = document.getElementById('topo-teaser-inner');
        if (!wrap) return;
        const W = wrap.offsetWidth, H = wrap.offsetHeight;
        const cx = W / 2;
        const beam = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        beam.setAttribute('x1', String(cx)); beam.setAttribute('y1', '0');
        beam.setAttribute('x2', String(cx)); beam.setAttribute('y2', String(H * 0.55));
        beam.setAttribute('stroke', 'rgba(166,227,161,0.12)');
        beam.setAttribute('stroke-width', '1.5');
        svg.appendChild(beam);

        let packetY = 0;
        const pktSvg = document.getElementById('tt-packets');
        if (!pktSvg) return;
        const pkt = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        pkt.setAttribute('r', '3');
        pkt.setAttribute('fill', '#52e0a0');
        pkt.setAttribute('opacity', '0.8');
        pktSvg.appendChild(pkt);
        const maxY = H * 0.55;
        function tick() {
          packetY = (packetY + 1.2) % maxY;
          pkt.setAttribute('cx', String(cx));
          pkt.setAttribute('cy', String(packetY));
          requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      })();

      // Hero stat strip — count-up animation
      function countUp(el: HTMLElement, target: string, duration = 650) {
        const num = parseInt(target);
        if (isNaN(num)) { el.textContent = target; return; }
        const start = performance.now();
        const tick = (now: number) => {
          const pct = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - pct, 3);
          el.textContent = String(Math.round(ease * num));
          if (pct < 1) requestAnimationFrame(tick);
          else el.textContent = target;
        };
        requestAnimationFrame(tick);
      }

      if (data.nodes) {
        const ready = data.nodes.filter((n: any) => n.status === 'ok').length;
        const total = data.nodes.length;
        const pods = data.nodes.reduce((sum: number, n: any) => sum + (parseInt(n.pods) || 0), 0);
        const statNodes = document.getElementById('stat-nodes');
        const statPods  = document.getElementById('stat-pods');
        if (statNodes) countUp(statNodes, `${ready}/${total}`);
        if (statPods)  countUp(statPods,  String(pods));
      }
      if (data.flux) {
        const statFlux = document.getElementById('stat-flux');
        if (statFlux) countUp(statFlux, String(data.flux.ready ?? data.flux.total ?? '—'));
      }

      // Freshness badge — fetch cadence is 30m, so flag a stalled pipeline loudly
      if (data.updated) {
        const badge = document.getElementById('live-updated');
        if (badge) {
          const mins = Math.round((Date.now() - new Date(data.updated).getTime()) / 60000);
          const ago = mins < 60 ? `${mins}m` : mins < 1440 ? `${Math.round(mins / 60)}h` : `${Math.round(mins / 1440)}d`;
          badge.textContent = `updated ${ago} ago`;
          badge.style.color = mins > 180 ? 'var(--color-crit)' : mins > 60 ? 'var(--color-warn)' : '';
          badge.title = mins > 60 ? 'live-data pipeline may be stalled' : '';
        }
      }

      // Build the ops panel from live data
      buildOpsPanel(data.services ?? [], data.media ?? []);

      // Cluster status strip (used on /status, also on index hero)
      const strip = document.getElementById('status-strip');
      if (strip && data.nodes) {
        strip.innerHTML = data.nodes.map((node: any) => `
          <div style="background:var(--color-surface);border:1px solid var(--color-muted);border-radius:8px;padding:0.875rem 1rem;display:flex;align-items:center;gap:0.75rem">
            <span class="status-dot ${node.status}"></span>
            <div>
              <div style="font-size:0.875rem;color:var(--color-heading);font-weight:600">${node.name}</div>
              <div class="mono">${node.role}</div>
            </div>
            <div style="margin-left:auto;text-align:right">
              <div class="mono" style="color:var(--color-gold)">${node.pods} pods</div>
              <div class="mono">${node.cpu} CPU · ${node.memory} mem</div>
            </div>
          </div>`).join('');
      }
    } catch {
      // On failure, show a minimal fallback so panel isn't stuck on skeletons
      const panel = document.getElementById('ops-panel');
      if (panel) panel.innerHTML = '<div style="padding:2rem 1.5rem;font-family:var(--font-mono);font-size:0.8rem;color:var(--color-subtle)">Live data unavailable — cluster may be updating.</div>';
    }
  }

  async function loadDigest() {
    try {
      const res = await fetch('/data/digest.json');
      if (!res.ok) throw new Error('no data');
      const entries = await res.json();
      const list = document.getElementById('digest-list');
      if (list) {
        const TYPE_COLOR: Record<string, string> = {
          DEPLOY: 'var(--color-ok)', FIX: 'var(--color-gold)', INCIDENT: 'var(--color-crit)',
          HARDWARE: 'var(--color-gold)', NETWORK: 'var(--color-mauve)', SECURITY: 'var(--color-warn)',
        };
        list.innerHTML = entries.slice(0, 3).map((e: any) => {
          const color = TYPE_COLOR[e.type] ?? 'var(--color-subtle)';
          const tag = e.hasDetail ? 'a' : 'div';
          const href = e.hasDetail ? `href="/digest/entry?slug=${e.slug}"` : '';
          return `
          <${tag} ${href} style="display:block;text-decoration:none;margin-bottom:0.75rem">
            <div class="card" style="padding:1rem;transition:border-color 0.15s${e.hasDetail ? ';cursor:pointer' : ''}">
              <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.4rem">
                <span style="font-family:var(--font-mono);font-size:0.65rem;font-weight:600;padding:0.15rem 0.45rem;border-radius:4px;background:color-mix(in srgb,${color} 12%,transparent);color:${color};text-transform:uppercase;letter-spacing:0.05em">${e.type}</span>
                <span class="mono" style="color:var(--color-subtle);font-size:0.72rem">${e.date}</span>
                ${e.hasDetail ? `<span class="mono" style="color:var(--color-gold);font-size:0.7rem;margin-left:auto">read more →</span>` : ''}
              </div>
              <div style="color:var(--color-heading);font-weight:600;font-size:0.875rem;line-height:1.4">${e.title}</div>
            </div>
          </${tag}>`;
        }).join('');
      }
    } catch { /* no data yet */ }
  }

  async function loadProject() {
    try {
      const res = await fetch('/data/projects.json');
      if (!res.ok) throw new Error('no data');
      const items: any[] = await res.json();
      const active = items.find(p => p.status === 'active');
      if (!active) return;
      const el = document.getElementById('active-project');
      if (el) {
        const done  = (active.milestones ?? []).filter((m: any) => m.done).length;
        const total = (active.milestones ?? []).length;
        const progress = total > 0 ? Math.round((done / total) * 100) : null;
        const progressHtml = progress != null ? `
          <div style="margin:1rem 0">
            <div style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:0.68rem;color:var(--color-subtle);margin-bottom:0.35rem">
              <span>milestones</span><span>${done} / ${total}</span>
            </div>
            <div style="height:4px;background:var(--color-overlay);border-radius:2px;overflow:hidden">
              <div style="height:100%;width:${progress}%;background:var(--color-ok);border-radius:2px"></div>
            </div>
          </div>` : '';
        el.innerHTML = `
          <a href="/projects" style="display:block;text-decoration:none">
            <div class="card" style="transition:border-color 0.15s">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
                <span class="mono" style="color:var(--color-ok);font-size:0.75rem;display:flex;align-items:center;gap:0.35rem">● active</span>
                <span class="mono" style="color:var(--color-subtle);font-size:0.72rem">→ projects</span>
              </div>
              <h3 style="margin:0 0 0.2rem;font-size:1.1rem">${active.title}</h3>
              <div class="mono" style="color:var(--color-subtle);font-size:0.75rem;margin-bottom:0.75rem">${active.timeline ?? ''}</div>
              <p style="color:var(--color-subtle);font-size:0.875rem;margin:0;line-height:1.6">${active.description}</p>
              ${progressHtml}
            </div>
          </a>
        `;
      }
    } catch { /* no data yet */ }
  }

  // Fire on both first load and Astro view-transition navigations
  let _pageInited = false;
  let _ccClock: number | undefined;
  function startMapClock() {
    const el = document.getElementById('cc-map-clock');
    if (!el) return;
    const tick = () => { el.textContent = new Date().toTimeString().slice(0, 8); };
    tick();
    clearInterval(_ccClock);
    _ccClock = window.setInterval(tick, 1000);
  }

  function initPage() {
    if (_pageInited) return;
    _pageInited = true;
    loadLiveData();
    loadDigest();
    loadProject();
    startMapClock();
    // Reset for next navigation
    setTimeout(() => { _pageInited = false; }, 500);
  }
  document.addEventListener('astro:before-swap', () => { if (_ccClock) clearInterval(_ccClock); });

  document.addEventListener('astro:page-load', initPage);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPage);
  } else {
    initPage();
  }

  // ── Particle network (cursor-reactive, desktop only) ────────────────────
  (function initParticleNet() {
    // Skip on mobile — saves battery, particles are invisible on touch anyway
    if (window.innerWidth < 768) return;
    const canvas = document.getElementById('hero-grid') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;
    if (!ctx) return;

    const PARTICLE_COUNT = 70;
    const MAX_DIST       = 140;   // max px before a line fades out
    const CURSOR_ATTRACT = 180;   // px radius around cursor that attracts
    const CURSOR_FORCE   = 0.012; // strength of cursor pull
    const BASE_SPEED     = 0.28;
    const GOLD   = [230, 180, 80]  as const;
    const GREEN  = [166, 227, 161] as const;
    const SAPHIR = [116, 199, 236] as const;
    const COLS   = [GOLD, GREEN, SAPHIR];

    let W = 0, H = 0, raf = 0;
    let mouse = { x: -9999, y: -9999 };

    type Particle = {
      x: number; y: number;
      vx: number; vy: number;
      r: number;
      col: readonly [number,number,number];
      alpha: number;
    };

    let particles: Particle[] = [];

    function resize() {
      const rect = canvas.parentElement!.getBoundingClientRect();
      W = canvas.width  = rect.width;
      H = canvas.height = rect.height;
    }

    function spawn(): Particle {
      const col = COLS[Math.floor(Math.random() * COLS.length)];
      const angle = Math.random() * Math.PI * 2;
      return {
        x: Math.random() * W,
        y: Math.random() * H,
        vx: Math.cos(angle) * BASE_SPEED * (0.5 + Math.random()),
        vy: Math.sin(angle) * BASE_SPEED * (0.5 + Math.random()),
        r: 1.5 + Math.random() * 1.5,
        col,
        alpha: 0.4 + Math.random() * 0.5,
      };
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);

      // Update positions + cursor attraction
      for (const p of particles) {
        const dx = mouse.x - p.x;
        const dy = mouse.y - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < CURSOR_ATTRACT && dist > 1) {
          p.vx += (dx / dist) * CURSOR_FORCE;
          p.vy += (dy / dist) * CURSOR_FORCE;
        }
        // Speed limit
        const spd = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
        if (spd > 1.2) { p.vx *= 0.97; p.vy *= 0.97; }

        p.x += p.vx;
        p.y += p.vy;

        // Wrap around edges
        if (p.x < 0)  p.x = W;
        if (p.x > W)  p.x = 0;
        if (p.y < 0)  p.y = H;
        if (p.y > H)  p.y = 0;
      }

      // Draw connecting lines between nearby particles
      for (let i = 0; i < particles.length; i++) {
        const a = particles[i];
        for (let j = i + 1; j < particles.length; j++) {
          const b = particles[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const d  = Math.sqrt(dx * dx + dy * dy);
          if (d > MAX_DIST) continue;

          const t = 1 - d / MAX_DIST;
          const [r, g, bv] = a.col;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.strokeStyle = `rgba(${r},${g},${bv},${t * 0.22})`;
          ctx.lineWidth = t * 1.2;
          ctx.stroke();
        }

        // Lines from particle to cursor
        const cdx = a.x - mouse.x;
        const cdy = a.y - mouse.y;
        const cd  = Math.sqrt(cdx * cdx + cdy * cdy);
        if (cd < CURSOR_ATTRACT) {
          const t = 1 - cd / CURSOR_ATTRACT;
          const [r, g, bv] = a.col;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(mouse.x, mouse.y);
          ctx.strokeStyle = `rgba(${r},${g},${bv},${t * 0.45})`;
          ctx.lineWidth = t * 1.5;
          ctx.stroke();
        }
      }

      // Draw dots
      for (const p of particles) {
        const [r, g, bv] = p.col;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r},${g},${bv},${p.alpha})`;
        ctx.fill();
      }

      raf = requestAnimationFrame(draw);
    }

    const obs = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) { raf = requestAnimationFrame(draw); }
      else { cancelAnimationFrame(raf); }
    }, { threshold: 0 });

    resize();
    particles = Array.from({ length: PARTICLE_COUNT }, spawn);
    obs.observe(canvas);
    window.addEventListener('resize', () => { resize(); }, { passive: true });

    // Track cursor relative to canvas
    canvas.parentElement!.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    }, { passive: true });
    canvas.parentElement!.addEventListener('mouseleave', () => {
      mouse.x = -9999; mouse.y = -9999;
    }, { passive: true });

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      cancelAnimationFrame(raf);
      requestAnimationFrame(draw);
    }
  })();

  // ── H1 Typewriter ────────────────────────────────────────────────────────
  (function initTypewriter() {
    const line1El  = document.getElementById('h1-line1');
    const line2El  = document.getElementById('h1-line2');
    const cursorEl = document.querySelector('.h1-cursor') as HTMLElement;
    if (!line1El || !line2El || !cursorEl) return;

    const LINE1 = 'Living';
    const LINE2 = 'Homelab';

    function typeInto(el: HTMLElement, text: string, charDelay: number, onDone: () => void) {
      let i = 0;
      function tick() {
        if (i <= text.length) {
          el.textContent = text.slice(0, i);
          i++;
          setTimeout(tick, charDelay + Math.random() * 30);
        } else {
          onDone();
        }
      }
      tick();
    }

    // Type line 1, pause (as if reconsidering), then type line 2, then hide cursor
    typeInto(line1El, LINE1, 90, () => {
      setTimeout(() => {
        typeInto(line2El, LINE2, 80, () => {
          setTimeout(() => cursorEl.classList.add('done'), 900);
        });
      }, 420);
    });
  })();


  // ── GitHub contribution graph ────────────────────────────────────────────
  function renderContribGraph(dayCounts: Record<string, number>, graphEl: HTMLElement, totalEl: HTMLElement | null) {
    const maxCount = Math.max(1, ...Object.values(dayCounts));
    const toLevel = (n: number) => n === 0 ? 0 : Math.min(4, Math.ceil((n / maxCount) * 4));

    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const gridEnd = new Date(today);
    gridEnd.setDate(gridEnd.getDate() + (6 - today.getDay()));

    const cells: { date: string; level: number; count: number }[] = [];
    for (let w = 51; w >= 0; w--) {
      for (let d = 0; d < 7; d++) {
        const dt = new Date(gridEnd);
        dt.setDate(dt.getDate() - w * 7 - (6 - d));
        const iso = dt.toISOString().slice(0, 10);
        const count = dayCounts[iso] ?? 0;
        cells.push({ date: iso, level: toLevel(count), count });
      }
    }

    const grid = document.createElement('div');
    grid.className = 'contrib-grid';
    grid.innerHTML = cells.map(c => {
      const tip = c.count > 0
        ? `${c.date} · ${c.count} contribution${c.count > 1 ? 's' : ''}`
        : `${c.date} · no contributions`;
      return `<span class="contrib-cell" data-level="${c.level}" title="${tip}"></span>`;
    }).join('');

    graphEl.innerHTML = '';
    graphEl.appendChild(grid);

    if (totalEl) {
      const activeDays = cells.filter(c => c.level > 0).length;
      const totalContribs = Object.values(dayCounts).reduce((a, b) => a + b, 0);
      totalEl.textContent = `${totalContribs} contributions · ${activeDays} active days (last 90 days)`;
    }
  }

  async function loadContribGraph() {
    const graphEl = document.getElementById('contrib-graph');
    const totalEl = document.getElementById('contrib-total');
    if (!graphEl) return;

    try {
      // Prefer pre-fetched data from live.json (updated every 30 min, no rate-limit risk)
      const liveRes = await fetch('/data/live.json').then(r => r.ok ? r.json() : null).catch(() => null);
      if (liveRes?.contribs?.days && Object.keys(liveRes.contribs.days).length > 0) {
        renderContribGraph(liveRes.contribs.days, graphEl, totalEl);
        return;
      }

      // Fallback: fetch directly from GitHub API
      const user = 'Kagiso-me';
      const results = await Promise.all(
        [1, 2, 3].map(p =>
          fetch(`https://api.github.com/users/${user}/events/public?per_page=100&page=${p}`, {
            headers: { Accept: 'application/vnd.github+json' }
          }).then(r => r.ok ? r.json() : []).catch(() => [])
        )
      );
      const events: any[] = results.flat();

      const dayCounts: Record<string, number> = {};
      for (const ev of events) {
        const iso = ev.created_at?.slice(0, 10);
        if (!iso) continue;
        const commits = ev.type === 'PushEvent' ? (ev.payload?.commits?.length ?? 1) : 1;
        dayCounts[iso] = (dayCounts[iso] ?? 0) + commits;
      }

      renderContribGraph(dayCounts, graphEl, totalEl);
    } catch {
      if (graphEl) graphEl.innerHTML = '<div class="contrib-loading">graph unavailable</div>';
    }
  }

  loadContribGraph();

  // ── Hardware expand ──────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.hw-item').forEach(item => {
    const toggle = () => {
      const open = item.classList.toggle('open');
      item.setAttribute('aria-expanded', String(open));
    };
    item.addEventListener('click', toggle);
    item.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
    });
  });

  // ── Stack item 3D tilt ───────────────────────────────────────────────────────
  if (window.matchMedia('(pointer: fine)').matches) {
    document.querySelectorAll<HTMLElement>('.stack-item').forEach(card => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top  + rect.height / 2;
        const rx = ((e.clientY - cy) / (rect.height / 2)) * -6;
        const ry = ((e.clientX - cx) / (rect.width  / 2)) *  6;
        card.style.transform = `perspective(600px) rotateX(${rx}deg) rotateY(${ry}deg) translateZ(4px)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
      });
    });
  }

  // ── Activity cards — grouped by repo ────────────────────────────────────────
  (async function loadActivity() {
    const wrap = document.getElementById('act-wrap');
    if (!wrap) return;

    function relTime(iso: string) {
      const diff = Date.now() - new Date(iso).getTime();
      const m = Math.floor(diff / 60000);
      if (m < 1)  return 'just now';
      if (m < 60) return `${m}m ago`;
      const h = Math.floor(m / 60);
      if (h < 24) return `${h}h ago`;
      return `${Math.floor(h / 24)}d ago`;
    }

    const REPOS = [
      { id: 'homelab-infrastructure', label: 'homelab-infrastructure', url: 'https://github.com/Kagiso-me/homelab-infrastructure' },
      { id: 'kagiso-me.github.io',    label: 'kagiso-me.github.io',    url: 'https://github.com/Kagiso-me/kagiso-me.github.io' },
    ];

    const cutoff = Date.now() - 24 * 60 * 60 * 1000;

    try {
      const repoData = await Promise.all(REPOS.map(async repo => {
        try {
          const r = await fetch(`https://api.github.com/repos/Kagiso-me/${repo.id}/events?per_page=30`);
          if (!r.ok) return { ...repo, events: [] };
          const data: any[] = await r.json();
          const events = data.filter(ev => new Date(ev.created_at).getTime() > cutoff);
          return { ...repo, events };
        } catch {
          return { ...repo, events: [] };
        }
      }));

      const totalEvents = repoData.reduce((s, r) => s + r.events.length, 0);
      if (totalEvents === 0) {
        wrap.innerHTML = '<div class="act-empty mono">No activity in the last 24 hours.</div>';
        return;
      }

      wrap.innerHTML = '';

      repoData.forEach((repo, idx) => {
        const evs = repo.events;
        if (!evs.length) return;

        // Counts by type
        const pushCount   = evs.filter((e: any) => e.type === 'PushEvent').length;
        const prCount     = evs.filter((e: any) => e.type === 'PullRequestEvent').length;
        const deployCount = evs.filter((e: any) => e.type === 'CreateEvent' || e.type === 'ReleaseEvent').length;

        // Total commits across all push events
        const commitCount = evs
          .filter((e: any) => e.type === 'PushEvent')
          .reduce((s: number, e: any) => s + (e.payload?.commits?.length ?? 1), 0);

        // Most recent push commit message
        const lastPush = evs.find((e: any) => e.type === 'PushEvent');
        const lastMsg  = lastPush?.payload?.commits?.[0]?.message?.split('\n')[0]?.slice(0, 72) ?? '';
        const lastTime = evs[0]?.created_at ?? '';

        // 24-slot heatmap — one pip per event slot
        const SLOTS = 16;
        const oldest = new Date(evs[evs.length - 1]?.created_at ?? Date.now()).getTime();
        const range  = Date.now() - oldest || 1;
        const activePips = new Set(evs.map((e: any) =>
          Math.floor(((Date.now() - new Date(e.created_at).getTime()) / range) * (SLOTS - 1))
        ));
        const pips = Array.from({ length: SLOTS }, (_, i) =>
          `<div class="act-pip${activePips.has(i) ? ' active' : ''}"></div>`
        ).join('');

        // Type pills
        const pills = [
          pushCount   ? `<span class="act-pill push">${pushCount} push</span>` : '',
          prCount     ? `<span class="act-pill pr">${prCount} PR</span>` : '',
          deployCount ? `<span class="act-pill deploy">${deployCount} release</span>` : '',
        ].filter(Boolean).join('');

        const card = document.createElement('div');
        card.className = 'act-repo-card';
        card.innerHTML = `
          <div class="act-repo-header">
            <span class="act-repo-name">${repo.label}</span>
            <a class="act-repo-link" href="${repo.url}" target="_blank" rel="noopener">view →</a>
          </div>
          <div class="act-stat-row">
            <span class="act-stat-num">${commitCount}</span>
            <span class="act-stat-label">commit${commitCount !== 1 ? 's' : ''}<br>last 24h</span>
          </div>
          <div class="act-heatmap">${pips}</div>
          ${lastMsg ? `
          <div class="act-last-commit">
            <span class="act-commit-label">last commit</span>
            ${lastMsg}
          </div>` : ''}
          <div class="act-time-row">
            <span class="act-time">${lastTime ? relTime(lastTime) : ''}</span>
            <div class="act-type-pills">${pills}</div>
          </div>
        `;
        wrap.appendChild(card);
        setTimeout(() => card.classList.add('reveal'), idx * 120);
      });

    } catch {
      wrap.innerHTML = '<div class="act-empty mono">Activity unavailable.</div>';
    }
  })();

</script>
