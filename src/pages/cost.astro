---
import Layout from '../layouts/Layout.astro';

// в”Җв”Җ Cost data в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// When the cluster went live and cloud subscriptions were cancelled
const SELF_HOSTED_SINCE = '2025-12-02';

// Hardware вҖ” already owned, no monthly payments made
// Shown for comparison context only вҖ” NOT included in actual monthly outgoings
const HARDWARE = [
  { item: '3Г— Lenovo ThinkCentre M93p', cost: 4200  },
  { item: '2Г— Intel NUC (Bronn + Varys)', cost: 2400 },
  { item: 'HP MicroServer Gen8 (Ned)',   cost: 2800  },
  { item: '3Г— HDDs + 2Г— SSDs (Ned)',    cost: 3200  },
  { item: 'APC Back-UPS Pro 650VA',     cost: 1800  },
  { item: 'Raspberry Pi 3B+ (Bran)',    cost: 800   },
  { item: 'Networking вҖ” switch, cables', cost: 600   },
];
const HARDWARE_TOTAL   = HARDWARE.reduce((s, h) => s + h.cost, 0);
const HARDWARE_MONTHLY = Math.round(HARDWARE_TOTAL / 36); // for display only

// Ongoing monthly costs (ZAR) вҖ” what actually leaves the account
const ONGOING = [
  { item: 'Backblaze B2 (offsite backup)', cost: 85    },
  { item: 'Domain вҖ” kagiso.me',            cost: 15    },
  { item: 'Showmax',                        cost: 99    },
  { item: 'Apple Music',                    cost: 69.99 },
  { item: 'Cloudflare (free tier)',         cost: 0     },
  { item: 'GitHub Actions (free tier)',     cost: 0     },
];
const ONGOING_TOTAL = ONGOING.reduce((s, o) => s + o.cost, 0);

// Electricity вҖ” derived from UPS load readings + device power draw
// 5 mini PCs ~25W avg + NAS ~60W + RPi ~5W + networking ~15W вүҲ 205W continuous
// 205W Г— 24h Г— 30d = 147 kWh/month @ R3.50/kWh
const ELECTRICITY_KWH  = 147;
const ELECTRICITY_RATE = 3.50; // R/kWh вҖ” Johannesburg municipal tariff
const ELECTRICITY_COST = Math.round(ELECTRICITY_KWH * ELECTRICITY_RATE);

// Actual cash outgoings вҖ” hardware excluded (already owned, no payments)
const MY_MONTHLY_TOTAL = ONGOING_TOTAL + ELECTRICITY_COST;

// в”Җв”Җ Subscriptions actually cancelled в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// These are real invoices that no longer arrive. Exact prices as billed.
const CANCELLED = [
  {
    name:     'iCloud 200GB',
    replaces: 'Immich + Nextcloud',
    vendor:   'Apple',
    cost:     59.99,
    note:     'Photos вҶ’ Immich В· Files вҶ’ Nextcloud В· Calendar/Contacts вҶ’ Nextcloud',
    emoji:    'рҹҚҺ',
  },
  {
    name:     'Microsoft 365 Basic',
    replaces: 'Nextcloud',
    vendor:   'Microsoft',
    cost:     39.00,
    note:     'OneDrive 1TB + Office web вҶ’ Nextcloud handles files and docs',
    emoji:    'рҹӘҹ',
  },
  {
    name:     'Apple TV+',
    replaces: 'Plex',
    vendor:   'Apple',
    cost:     124.99,
    note:     'Streaming вҶ’ self-hosted Plex library. Own the content, own the server.',
    emoji:    'рҹ“ә',
  },
];

const CANCELLED_TOTAL = CANCELLED.reduce((s, c) => s + c.cost, 0);

// в”Җв”Җ What the full cloud stack would cost в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// If you had to pay for every layer of the homelab as a managed service.
// These are the services you run free that would cost real money on the cloud.
const CLOUD_SERVICES = [
  {
    name:     'iCloud 200GB',
    replaces: 'Immich + Nextcloud',
    cloudCost: 59.99,
    selfCost:  0,
    note:     'Actually cancelled В· exact price',
    actual:   true,
  },
  {
    name:     'Microsoft 365 Basic',
    replaces: 'Nextcloud',
    cloudCost: 39.00,
    selfCost:  0,
    note:     'Actually cancelled В· exact price',
    actual:   true,
  },
  {
    name:     'Apple TV+',
    replaces: 'Plex',
    cloudCost: 124.99,
    selfCost:  0,
    note:     'Actually cancelled В· exact price',
    actual:   true,
  },
];

const CLOUD_TOTAL        = CLOUD_SERVICES.reduce((s, c) => s + c.cloudCost, 0);
const SELF_CLOUD_EQUIV   = CLOUD_SERVICES.reduce((s, c) => s + c.selfCost, 0) + MY_MONTHLY_TOTAL;
const MONTHLY_SAVINGS    = CLOUD_TOTAL - SELF_CLOUD_EQUIV;
const ACTUAL_SAVINGS     = Math.round(CANCELLED_TOTAL); // what literally stopped being billed

const TICKER_RATE_PER_SEC = ACTUAL_SAVINGS / (30 * 24 * 3600); // R per second saved
---

<Layout
  title="Cost"
  description="What this homelab actually costs вҖ” and what you'd pay the cloud for the same."
>

<div class="page-wrap">

  <!-- в”Җв”Җ Header в”Җв”Җ -->
  <div class="page-header fade-up">
    <div>
      <p class="mono" style="color:var(--color-gold);margin-bottom:0.25rem">~/cost</p>
      <h1 style="margin:0">The Bill You're Not Paying</h1>
    </div>
    <p class="hero-sub">
      The money saved is real. But that's not why I did it.
      I did it because I was tired of paying companies to store my data
      on their terms, train their models on it, and change the rules whenever they felt like it.
      The savings are a bonus. The control is the point.
    </p>
  </div>

  <!-- в”Җв”Җ Live savings ticker в”Җв”Җ -->
  <section class="ticker-section fade-up" style="animation-delay:0.05s">
    <div class="ticker-wrap">
      <div class="ticker-label mono">saved in cancelled subscriptions since going self-hosted</div>
      <div class="ticker-amount">
        <span class="ticker-currency">R</span>
        <span class="ticker-number" id="ticker-num">0</span>
      </div>
      <div class="ticker-sub mono">
        and counting вҖ” R{ACTUAL_SAVINGS.toFixed(2).replace('.', ',')} every month that no longer leaves your account
      </div>
      <div class="ticker-since mono">
        since <span>{new Date(SELF_HOSTED_SINCE).toLocaleDateString('en-ZA', { year: 'numeric', month: 'long' })}</span>
      </div>
    </div>
  </section>

  <!-- в”Җв”Җ What I actually cancelled в”Җв”Җ -->
  <section class="section fade-up" style="animation-delay:0.08s">
    <div class="section-header">
      <h2 class="section-title">What I Actually Cancelled</h2>
      <span class="mono" style="color:var(--color-subtle);font-size:0.72rem">real invoices В· exact prices</span>
    </div>
    <div class="cancelled-grid">
      {CANCELLED.map(c => (
        <div class="cancelled-card">
          <div class="cancelled-top">
            <span class="cancelled-emoji">{c.emoji}</span>
            <div class="cancelled-meta">
              <span class="cancelled-vendor mono">{c.vendor}</span>
              <span class="cancelled-name">{c.name}</span>
            </div>
            <div class="cancelled-price-wrap">
              <span class="cancelled-was mono">was</span>
              <span class="cancelled-price">R{c.cost.toFixed(2).replace('.', ',')}</span>
              <span class="cancelled-per mono">/mo</span>
            </div>
          </div>
          <div class="cancelled-arrow">
            <span class="cancelled-arrow-line"></span>
            <span class="cancelled-arrow-label mono">now runs on</span>
            <span class="cancelled-arrow-line"></span>
          </div>
          <div class="cancelled-self mono">{c.replaces}</div>
          <p class="cancelled-note mono">{c.note}</p>
        </div>
      ))}
    </div>

    <div class="cancelled-total-row">
      <span class="mono" style="color:var(--color-subtle)">Total cancelled</span>
      <span class="cancelled-total-amount">R{CANCELLED_TOTAL.toFixed(2).replace('.', ',')}<span class="mono" style="font-size:1rem;color:var(--color-subtle)">/mo</span></span>
      <span class="mono" style="color:var(--color-subtle)">= R{(CANCELLED_TOTAL * 12).toFixed(0)}/year</span>
    </div>
  </section>

  <!-- в”Җв”Җ The real reason в”Җв”Җ -->
  <section class="privacy-section fade-up" style="animation-delay:0.1s">
    <div class="privacy-inner">
      <div class="privacy-icon" aria-hidden="true">вҡҝ</div>
      <div class="privacy-body">
        <h2 class="privacy-title">The Real Reason</h2>
        <p class="privacy-text">
          Saving R{CANCELLED_TOTAL.toFixed(0)} a month is nice. It's not why I spent weeks building this.
        </p>
        <p class="privacy-text">
          Every photo I took was living on Apple's servers. Every document I wrote
          sat on Microsoft's infrastructure. Every show I watched was feeding a
          recommendation algorithm. I was the product, not the customer.
        </p>
        <p class="privacy-text">
          Now my photos live on <em>my</em> drives, backed up to <em>my</em> offsite storage.
          My files are on <em>my</em> Nextcloud, encrypted at rest, not indexed for anything.
          My media library is mine вҖ” not licensed to me until a company decides otherwise.
        </p>
        <p class="privacy-text" style="color:var(--color-heading);font-weight:600">
          The cost comparison below is honest. But the reason I did this
          can't be put in a spreadsheet.
        </p>
      </div>
    </div>
  </section>

  <!-- в”Җв”Җ Receipt comparison в”Җв”Җ -->
  <section class="section fade-up" style="animation-delay:0.12s">
    <div class="section-header">
      <h2 class="section-title">Full Stack Comparison</h2>
      <span class="mono" style="color:var(--color-subtle);font-size:0.72rem">if you had to pay for every layer</span>
    </div>
    <div class="receipts-wrap">

      <!-- Cloud receipt вҖ” thermal printer style -->
      <div class="receipt receipt-cloud">
        <div class="receipt-header">
          <div class="receipt-logo">вҳҒ</div>
          <div class="receipt-title">CLOUD INVOICE</div>
          <div class="receipt-sub mono">what they'd charge</div>
          <div class="receipt-dashes">- - - - - - - - - - - - - - - - -</div>
        </div>
        <div class="receipt-body">
          {CLOUD_SERVICES.map(s => (
            <div class={`receipt-line${s.actual ? ' receipt-line-actual' : ''}`}>
              <span class="receipt-item">
                {s.actual && <span class="receipt-actual-dot" title="Actually cancelled">в—Ҹ</span>}
                {s.name}
              </span>
              <span class="receipt-price cloud-price">R{s.cloudCost % 1 === 0 ? s.cloudCost : s.cloudCost.toFixed(2)}</span>
            </div>
          ))}
        </div>
        <div class="receipt-dashes">= = = = = = = = = = = = = = = = =</div>
        <div class="receipt-total">
          <span>MONTHLY TOTAL</span>
          <span class="receipt-total-price cloud-total">R{CLOUD_TOTAL.toFixed(0)}</span>
        </div>
        <div class="receipt-dashes">- - - - - - - - - - - - - - - - -</div>
        <div class="receipt-footer mono">в—Ҹ = actually cancelled В· rest = avoided</div>
        <div class="receipt-footer mono" style="margin-top:0.25rem;color:var(--color-crit)">and they own your data</div>
      </div>

      <!-- VS divider -->
      <div class="vs-divider">
        <div class="vs-line"></div>
        <div class="vs-badge">VS</div>
        <div class="vs-line"></div>
      </div>

      <!-- Self-hosted bill вҖ” terminal style -->
      <div class="receipt receipt-self">
        <div class="receipt-header">
          <div class="receipt-logo" style="color:var(--color-gold)">в¬Ў</div>
          <div class="receipt-title" style="color:var(--color-gold)">HOMELAB BILL</div>
          <div class="receipt-sub mono">what you actually pay</div>
          <div class="receipt-dashes" style="color:var(--color-muted)">в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ</div>
        </div>
        <div class="receipt-body">
          <div class="receipt-section-label mono">Hardware (owned вҖ” no monthly payments)</div>
          {HARDWARE.map(h => (
            <div class="receipt-line">
              <span class="receipt-item">{h.item}</span>
              <span class="receipt-price" style="color:var(--color-green)">paid off</span>
            </div>
          ))}
          <div class="receipt-section-label mono" style="margin-top:0.75rem">Electricity</div>
          <div class="receipt-line">
            <span class="receipt-item">{ELECTRICITY_KWH} kWh @ R{ELECTRICITY_RATE}/kWh</span>
            <span class="receipt-price" style="color:var(--color-subtle)">R{ELECTRICITY_COST}</span>
          </div>
          <div class="receipt-section-label mono" style="margin-top:0.75rem">Services</div>
          {ONGOING.map(o => (
            <div class="receipt-line">
              <span class="receipt-item">{o.item}</span>
              <span class="receipt-price" style={`color:${o.cost === 0 ? 'var(--color-green)' : 'var(--color-subtle)'}`}>
                {o.cost === 0 ? 'free' : `R${o.cost}`}
              </span>
            </div>
          ))}
        </div>
        <div class="receipt-dashes" style="color:var(--color-muted)">в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ</div>
        <div class="receipt-total">
          <span>MONTHLY TOTAL</span>
          <span class="receipt-total-price self-total">R{MY_MONTHLY_TOTAL.toLocaleString()}</span>
        </div>
        <div class="receipt-dashes" style="color:var(--color-muted)">в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ в”Җ</div>
        <div class="receipt-footer mono" style="color:var(--color-green)">your data В· your hardware В· your rules</div>
      </div>

    </div>

    <!-- Savings callout -->
    <div class="savings-callout">
      <div class="savings-callout-inner">
        <span class="savings-callout-label mono">full-stack saving</span>
        <span class="savings-callout-amount">R{MONTHLY_SAVINGS.toLocaleString()}</span>
        <span class="savings-callout-label mono">/month vs cloud equivalent</span>
      </div>
      <p class="savings-callout-note mono">
        R{(MONTHLY_SAVINGS * 12).toLocaleString()} per year. Hardware is already paid off вҖ” every month is pure savings.
      </p>
    </div>
  </section>

  <!-- в”Җв”Җ Per-service breakdown в”Җв”Җ -->
  <section class="section fade-up" style="animation-delay:0.18s">
    <div class="section-header">
      <h2 class="section-title">Service by Service</h2>
    </div>
    <div class="breakdown-list">
      {CLOUD_SERVICES.map(s => {
        const savings = s.cloudCost - s.selfCost;
        const pct = Math.round((savings / CLOUD_TOTAL) * 100);
        return (
          <div class={`breakdown-row${s.actual ? ' breakdown-actual' : ''}`}>
            <div class="breakdown-names">
              {s.actual && <span class="breakdown-actual-badge mono">cancelled</span>}
              <span class="breakdown-cloud-name">{s.name}</span>
              <span class="breakdown-arrow mono">вҶ’</span>
              <span class="breakdown-self-name">{s.replaces}</span>
            </div>
            <div class="breakdown-bar-wrap">
              <div class="breakdown-bar">
                <div class="breakdown-bar-fill" style={`width:${pct}%`}></div>
              </div>
              <span class="breakdown-pct mono">вҲ’R{savings % 1 === 0 ? savings : savings.toFixed(2)}/mo</span>
            </div>
            <span class="breakdown-note mono">{s.note}</span>
          </div>
        );
      })}
    </div>
  </section>

  <!-- в”Җв”Җ Honest caveats в”Җв”Җ -->
  <section class="section fade-up" style="animation-delay:0.2s">
    <div class="caveat-wrap">
      <h2 class="section-title" style="margin-bottom:1.5rem">What These Numbers Don't Show</h2>
      <div class="caveat-grid">
        <div class="caveat-card">
          <div class="caveat-icon">вҸұ</div>
          <div class="caveat-title">Time</div>
          <p class="caveat-desc">
            Every hour spent on upgrades, debugging, and maintenance is real cost.
            Estimate: 3вҖ“5 hours/month. At any meaningful hourly rate, this changes the math entirely.
            I do it because I'm learning вҖ” not because it's cheaper per hour.
          </p>
        </div>
        <div class="caveat-card">
          <div class="caveat-icon">рҹ”Ӣ</div>
          <div class="caveat-title">Reliability</div>
          <p class="caveat-desc">
            iCloud has never lost a photo. My cluster has had incidents.
            If Immich goes down on holiday, it's a me problem. There is no SLA here.
          </p>
        </div>
        <div class="caveat-card">
          <div class="caveat-icon">рҹ“җ</div>
          <div class="caveat-title">Methodology</div>
          <p class="caveat-desc">
            Cancelled subscription prices are exact. Cloud equivalents converted at ~R18.50/USD.
            Electricity at R3.50/kWh (Johannesburg municipal). Power draw from UPS load readings.
            Hardware is already owned вҖ” no monthly payments, shown for context only.
          </p>
        </div>
      </div>
    </div>
  </section>

</div>

</Layout>

<style is:global>
  .page-wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .page-header { margin-bottom: 2.5rem; }
  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: 0.75rem; }

  .hero-sub {
    color: var(--color-subtle);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 640px;
    margin: 0;
  }

  /* в”Җв”Җ Live savings ticker в”Җв”Җ */
  .ticker-section {
    margin-bottom: 4rem;
  }

  .ticker-wrap {
    text-align: center;
    padding: 3rem 2rem;
    background: color-mix(in srgb, var(--color-gold) 4%, var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--color-gold) 25%, var(--color-muted));
    border-radius: 20px;
    position: relative;
    overflow: hidden;
  }

  .ticker-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 0%, color-mix(in srgb, var(--color-gold) 8%, transparent), transparent 70%);
    pointer-events: none;
  }

  .ticker-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-subtle);
    margin-bottom: 0.75rem;
  }

  .ticker-amount {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.15em;
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .ticker-currency {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--color-gold);
    letter-spacing: -0.02em;
  }

  .ticker-number {
    font-family: var(--font-display);
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 800;
    color: var(--color-heading);
    letter-spacing: -0.04em;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .ticker-sub {
    font-size: 0.85rem;
    color: var(--color-subtle);
    margin-bottom: 0.4rem;
  }

  .ticker-since {
    font-size: 0.72rem;
    color: color-mix(in srgb, var(--color-subtle) 60%, transparent);
  }

  /* в”Җв”Җ Receipts в”Җв”Җ */
  .receipts-wrap {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    align-items: start;
    margin-bottom: 2rem;
  }

  @media (max-width: 700px) {
    .receipts-wrap {
      grid-template-columns: 1fr;
    }
    .vs-divider {
      flex-direction: row !important;
      padding: 1.5rem 0;
    }
    .vs-line { flex: 1 !important; width: auto !important; height: 1px !important; }
  }

  .receipt {
    border-radius: 12px;
    padding: 1.75rem;
    font-family: var(--font-mono);
  }

  .receipt-cloud {
    background: color-mix(in srgb, var(--color-crit) 4%, var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--color-crit) 20%, var(--color-muted));
  }

  .receipt-self {
    background: color-mix(in srgb, var(--color-green) 4%, var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--color-green) 20%, var(--color-muted));
  }

  .receipt-header {
    text-align: center;
    margin-bottom: 1.25rem;
  }

  .receipt-logo {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
    color: var(--color-crit);
  }

  .receipt-title {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--color-heading);
    margin-bottom: 0.2rem;
  }

  .receipt-sub {
    font-size: 0.65rem;
    color: var(--color-subtle);
    margin-bottom: 0.75rem;
  }

  .receipt-dashes {
    font-size: 0.65rem;
    color: color-mix(in srgb, var(--color-crit) 50%, var(--color-muted));
    letter-spacing: 0.05em;
    text-align: center;
    margin: 0.75rem 0;
    overflow: hidden;
  }

  .receipt-section-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-subtle);
    margin: 0.5rem 0 0.4rem;
  }

  .receipt-line {
    display: flex;
