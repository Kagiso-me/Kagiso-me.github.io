---
import Layout from '../layouts/Layout.astro';

const adrs = [
  {
    id: '001', slug: 'ADR-001-k3s-over-kubeadm',
    title: 'k3s over kubeadm',
    category: 'infra', categoryLabel: 'Infrastructure',
    decision: 'Lightweight pre-bundled distribution over manual control-plane setup — less operational surface, faster iteration, without sacrificing production capability.',
  },
  {
    id: '002', slug: 'ADR-002-flux-over-argocd',
    title: 'FluxCD over ArgoCD',
    category: 'gitops', categoryLabel: 'GitOps',
    decision: 'Pull-based reconciliation with no UI dependency for core function. Simpler security model; Helm + Kustomize native without extra abstraction layers.',
  },
  {
    id: '003', slug: 'ADR-003-traefik-over-nginx-ingress',
    title: 'Traefik over nginx-ingress',
    category: 'network', categoryLabel: 'Networking',
    decision: 'Native Kubernetes integration with automatic HTTPS via cert-manager and dynamic routing — no reload required when routes change.',
  },
  {
    id: '004', slug: 'ADR-004-staging-to-pr-validation',
    title: 'Staging cluster decommissioned',
    category: 'arch', categoryLabel: 'Architecture',
    decision: 'A staging environment in a homelab gives false confidence. Replaced by PR-level dry-run validation and post-merge health checks. See: blog post.',
  },
  {
    id: '005', slug: 'ADR-005-self-hosted-runners',
    title: 'Self-hosted GitHub Actions runners',
    category: 'gitops', categoryLabel: 'GitOps',
    decision: 'Full control over runner environment, no usage limits, and direct access to internal network — required for cluster validation pipelines.',
  },
  {
    id: '006', slug: 'ADR-006-prometheus-local-storage',
    title: 'Prometheus TSDB on local storage',
    category: 'observability', categoryLabel: 'Observability',
    decision: 'NFS for time-series data causes I/O latency spikes on scrape intervals. Local SSD eliminates the problem entirely at the cost of portability.',
  },
  {
    id: '007', slug: 'ADR-007-discord-over-slack',
    title: 'Discord over Slack for alerts',
    category: 'platform', categoryLabel: 'Platform',
    decision: 'Webhook-native, free tier sufficient, faster mobile push delivery for a solo operator. Slack free tier 90-day history limit is a deal-breaker.',
  },
  {
    id: '008', slug: 'ADR-008-central-databases',
    title: 'Central PostgreSQL and Redis',
    category: 'platform', categoryLabel: 'Platform',
    decision: 'One database stack per cluster instead of per-service instances. Dramatically reduces operational surface — upgrades, backups, and monitoring in one place.',
  },
  {
    id: '009', slug: 'ADR-009-pr-validation-pipeline',
    title: 'PR-based validation pipeline',
    category: 'gitops', categoryLabel: 'GitOps',
    decision: 'Dry-run manifests on every PR; no change reaches the cluster without passing Kubernetes API validation. The cluster is the gatekeeper.',
  },
  {
    id: '010', slug: 'ADR-010-site-data-pipeline',
    title: 'Public site live data pipeline',
    category: 'arch', categoryLabel: 'Architecture',
    decision: 'GitHub Actions writes cluster state to static JSON on a schedule; the site reads it without exposing internal APIs or requiring a backend.',
  },
  {
    id: '011', slug: 'ADR-011-pihole-unbound-dns',
    title: 'Pi-hole + Unbound DNS stack',
    category: 'network', categoryLabel: 'Networking',
    decision: 'Local recursive DNS with no upstream resolver dependency. Gains: ad-blocking, internal hostname resolution, and latency reduction for repeated lookups.',
  },
  {
    id: '012', slug: 'ADR-012-upgrade-strategy',
    title: 'Automated upgrade strategy',
    category: 'gitops', categoryLabel: 'GitOps',
    decision: 'Flux image update policies handle patch-level bumps automatically. Minor version upgrades require manual PR approval — automation with a human gate.',
  },
  {
    id: '013', slug: 'ADR-013-sops-age-encryption',
    title: 'SOPS + age encryption',
    category: 'security', categoryLabel: 'Security',
    decision: 'Secrets encrypted at rest in Git using age keys (simpler than GPG). SOPS handles Kubernetes-native secret management without a secrets operator.',
  },
  {
    id: '014', slug: 'ADR-014-metallb-l2',
    title: 'MetalLB in L2 mode',
    category: 'network', categoryLabel: 'Networking',
    decision: 'Layer 2 ARP-based load balancer for bare-metal — no BGP infrastructure required on MikroTik. Sufficient for the current scale and topology.',
  },
  {
    id: '015', slug: 'ADR-015-velero-backup-strategy',
    title: 'Velero backup strategy',
    category: 'storage', categoryLabel: 'Storage',
    decision: 'Cluster-level backup with TrueNAS as the backend. Snapshots before major changes; weekly full schedule. Recovery tested, not assumed.',
  },
  {
    id: '016', slug: 'ADR-016-truenas-nfs-storage',
    title: 'TrueNAS SCALE as NFS storage backend',
    category: 'storage', categoryLabel: 'Storage',
    decision: 'ZFS-based storage with hardware ECC RAM and an LSI HBA for direct disk access. SCALE app management retired — NFS provisioning only.',
  },
  {
    id: '017', slug: 'ADR-017-crowdsec',
    title: 'CrowdSec for threat detection',
    category: 'security', categoryLabel: 'Security',
    decision: 'Collaborative threat intelligence with local decision-making. Blocks known bad actors across all ingress points using a shared community blocklist.',
  },
];

const REPO = 'https://github.com/Kagiso-me/homelab-infrastructure/blob/main/docs/adr';
---

<Layout title="Decisions" description="Architecture Decision Records — the decisions that have shaped this homelab.">

  <div class="page-wrap">

    <!-- ── Header ── -->
    <div class="page-header fade-up">
      <div>
        <p class="mono" style="color:var(--color-peach);margin-bottom:0.25rem">~/decisions</p>
        <h1 style="margin:0">Architecture Decisions</h1>
      </div>
      <p class="hero-sub">
        Every meaningful choice in this homelab has a reason behind it.
        These are the Architecture Decision Records — a running log of what was built,
        what was rejected, and why. Not aspirational. Not theoretical.
        Every entry reflects something that actually happened.
      </p>
    </div>

    <!-- ── Category filters ── -->
    <div class="filter-bar fade-up" style="animation-delay:0.04s" id="adr-filter-bar">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="infra">Infrastructure</button>
      <button class="filter-btn" data-filter="gitops">GitOps</button>
      <button class="filter-btn" data-filter="network">Networking</button>
      <button class="filter-btn" data-filter="security">Security</button>
      <button class="filter-btn" data-filter="storage">Storage</button>
      <button class="filter-btn" data-filter="observability">Observability</button>
      <button class="filter-btn" data-filter="platform">Platform</button>
      <button class="filter-btn" data-filter="arch">Architecture</button>
    </div>

    <!-- ── ADR timeline ── -->
    <section class="adr-timeline fade-up" style="animation-delay:0.05s" id="adr-timeline">
      {adrs.map((adr, i) => (
        <a
          class="adr-entry"
          data-category={adr.category}
          href={`${REPO}/${adr.slug}.md`}
          target="_blank"
          rel="noopener noreferrer"
          style={`animation-delay:${0.05 + i * 0.04}s`}
        >
          <div class="adr-spine">
            <div class={`adr-node cat-node-${adr.category}`}></div>
            <div class="adr-line"></div>
          </div>
          <div class="adr-card">
            <div class="adr-card-top">
              <span class="adr-id mono">ADR-{adr.id}</span>
              <span class={`adr-cat cat-${adr.category}`}>{adr.categoryLabel}</span>
              <span class="adr-arrow">↗</span>
            </div>
            <div class="adr-title">{adr.title}</div>
            <div class="adr-decision">{adr.decision}</div>
          </div>
        </a>
      ))}
    </section>

  </div>

</Layout>

<style>
  .page-wrap {
    max-width: 860px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .page-header { margin-bottom: 3.5rem; }

  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); }

  .hero-sub {
    color: var(--color-subtle);
    font-size: 0.95rem;
    line-height: 1.75;
    max-width: 620px;
    margin: 0.75rem 0 0;
  }

  /* ── Timeline ── */
  .adr-timeline {
    display: flex;
    flex-direction: column;
  }

  .adr-entry {
    display: flex;
    gap: 0;
    text-decoration: none;
    color: inherit;
    outline-offset: 4px;
  }

  /* Spine: node + vertical line */
  .adr-spine {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 2.5rem;
    padding-top: 0.35rem;
  }

  .adr-node {
    width: 13px; height: 13px;
    border-radius: 50%;
    border: 2px solid var(--color-base);
    flex-shrink: 0;
    transition: transform 0.2s, box-shadow 0.2s;
    z-index: 1;
  }

  .adr-entry:hover .adr-node {
    transform: scale(1.4);
  }

  .adr-line {
    flex: 1;
    width: 1px;
    background: linear-gradient(to bottom, color-mix(in srgb, var(--color-muted) 60%, transparent), color-mix(in srgb, var(--color-muted) 20%, transparent));
    margin-top: 4px;
  }

  .adr-entry:last-child .adr-line { display: none; }

  /* Node colours per category */
  .cat-node-infra        { background: var(--color-peach);    box-shadow: 0 0 8px var(--color-peach); }
  .cat-node-gitops       { background: var(--color-mauve);    box-shadow: 0 0 8px var(--color-mauve); }
  .cat-node-network      { background: var(--color-sapphire); box-shadow: 0 0 8px var(--color-sapphire); }
  .cat-node-observability{ background: var(--color-gold);     box-shadow: 0 0 8px var(--color-gold); }
  .cat-node-platform     { background: var(--color-subtle);   box-shadow: none; }
  .cat-node-security     { background: var(--color-crit);     box-shadow: 0 0 8px var(--color-crit); }
  .cat-node-storage      { background: var(--color-green);    box-shadow: 0 0 8px var(--color-green); }
  .cat-node-arch         { background: var(--color-gold);     box-shadow: 0 0 8px var(--color-gold); }

  /* Card */
  .adr-card {
    flex: 1;
    min-width: 0;
    margin-bottom: 1.25rem;
    padding: 1.1rem 1.25rem;
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    backdrop-filter: blur(8px);
    border: 1px solid color-mix(in srgb, var(--color-muted) 55%, transparent);
    border-top: 1px solid color-mix(in srgb, white 7%, transparent);
    border-radius: 12px;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }

  .adr-entry:hover .adr-card {
    border-color: color-mix(in srgb, var(--color-peach) 35%, var(--color-muted));
    box-shadow: 0 8px 32px rgba(0,0,0,0.3), 0 0 0 1px color-mix(in srgb, var(--color-peach) 12%, transparent);
    transform: translateX(4px);
  }

  .adr-card::after {
    content: '';
    pointer-events: none;
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s;
    background: radial-gradient(
      500px circle at calc(var(--mx, 50%) * 1%) calc(var(--my, 50%) * 1%),
      rgba(255,255,255,0.07) 0%,
      rgba(255,255,255,0.025) 40%,
      transparent 65%
    );
    z-index: 10;
  }
  .adr-entry:hover .adr-card::after { opacity: 1; }

  .adr-card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .adr-id {
    font-size: 0.7rem;
    color: var(--color-peach);
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .adr-cat {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .cat-infra        { background: color-mix(in srgb, var(--color-peach)     12%, transparent); color: var(--color-peach);     border: 1px solid color-mix(in srgb, var(--color-peach)     25%, transparent); }
  .cat-gitops       { background: color-mix(in srgb, var(--color-mauve)     12%, transparent); color: var(--color-mauve);     border: 1px solid color-mix(in srgb, var(--color-mauve)     25%, transparent); }
  .cat-network      { background: color-mix(in srgb, var(--color-sapphire)  12%, transparent); color: var(--color-sapphire);  border: 1px solid color-mix(in srgb, var(--color-sapphire)  25%, transparent); }
  .cat-observability{ background: color-mix(in srgb, var(--color-gold)      12%, transparent); color: var(--color-gold);      border: 1px solid color-mix(in srgb, var(--color-gold)      25%, transparent); }
  .cat-platform     { background: color-mix(in srgb, var(--color-subtle)    20%, transparent); color: var(--color-subtle);    border: 1px solid color-mix(in srgb, var(--color-muted)     30%, transparent); }
  .cat-security     { background: color-mix(in srgb, var(--color-crit)      12%, transparent); color: var(--color-crit);      border: 1px solid color-mix(in srgb, var(--color-crit)      25%, transparent); }
  .cat-storage      { background: color-mix(in srgb, var(--color-green)     12%, transparent); color: var(--color-green);     border: 1px solid color-mix(in srgb, var(--color-green)     25%, transparent); }
  .cat-arch         { background: color-mix(in srgb, var(--color-gold)      12%, transparent); color: var(--color-gold);      border: 1px solid color-mix(in srgb, var(--color-gold)      25%, transparent); }

  .adr-arrow {
    margin-left: auto;
    font-size: 0.82rem;
    color: var(--color-muted);
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }

  .adr-entry:hover .adr-arrow {
    color: var(--color-peach);
    transform: translate(3px, -3px);
  }

  .adr-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-heading);
    line-height: 1.35;
    margin-bottom: 0.35rem;
    letter-spacing: -0.01em;
  }

  .adr-decision {
    font-size: 0.82rem;
    color: var(--color-subtle);
    line-height: 1.6;
  }

  @media (max-width: 600px) {
    .adr-cat { display: none; }
    .adr-spine { width: 1.75rem; }
  }

  /* ── Filter bar ── */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .filter-btn {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.35rem 0.9rem;
    border-radius: 6px;
    border: 1px solid color-mix(in srgb, var(--color-muted) 60%, transparent);
    background: transparent;
    color: var(--color-subtle);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .filter-btn:hover {
    border-color: var(--color-peach);
    color: var(--color-peach);
    background: color-mix(in srgb, var(--color-peach) 6%, transparent);
  }

  .filter-btn.active {
    border-color: var(--color-peach);
    color: var(--color-peach);
    background: color-mix(in srgb, var(--color-peach) 10%, transparent);
  }

  .adr-entry[aria-hidden="true"] {
    display: none;
  }
</style>

<script>
  function initAdrFilter() {
    const bar = document.getElementById('adr-filter-bar');
    if (!bar) return;

    bar.addEventListener('click', (e) => {
      const btn = (e.target as Element).closest('.filter-btn') as HTMLElement | null;
      if (!btn) return;

      const filter = btn.dataset.filter ?? 'all';

      bar.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      document.querySelectorAll<HTMLElement>('.adr-entry').forEach(entry => {
        const match = filter === 'all' || entry.dataset.category === filter;
        entry.setAttribute('aria-hidden', match ? 'false' : 'true');
      });
    });
  }

  initAdrFilter();
  document.addEventListener('astro:page-load', initAdrFilter);
</script>
