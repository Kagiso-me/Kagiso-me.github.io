---
import Layout from '../layouts/Layout.astro';
import ClusterTerminal from '../components/ClusterTerminal.astro';
---

<Layout title="Command Center" description="Living Homelab — built in public by Kagiso.">

  <!-- ── Hero ── -->
  <section class="hero fade-up">
    <!-- Parallax background layers -->
    <div class="parallax-orb orb-1" data-speed="0.15" aria-hidden="true"></div>
    <div class="parallax-orb orb-2" data-speed="0.08" aria-hidden="true"></div>
    <div class="parallax-orb orb-3" data-speed="0.22" aria-hidden="true"></div>
    <div class="parallax-grid"      data-speed="0.05" aria-hidden="true"></div>

    <div class="hero-inner">
      <p class="mono hero-eyebrow">~/homelab</p>
      <h1>
        <span class="gradient-text">Living Homelab</span>
      </h1>
      <p class="hero-sub">
        A real homelab, built and operated in public —
        from bare metal to production discipline.
      </p>
      <p class="hero-typewriter mono" aria-live="polite">
        <span id="typewriter-text"></span><span class="typewriter-cursor">|</span>
      </p>
      <div class="hero-actions">
        <a href="/status" class="btn-primary">View Status</a>
        <a href="/decisions" class="btn-ghost">Architecture Decisions</a>
        <a href="/blog" class="btn-ghost">Blog</a>
      </div>
    </div>
  </section>

  <!-- ── Terminal ── -->
  <section class="section fade-up" style="animation-delay: 0.05s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Cluster Terminal</h2>
        <span class="mono" style="color:var(--color-subtle);font-size:0.8rem">read-only · live data</span>
      </div>

      <ClusterTerminal />
    </div>
  </section>

  <!-- ── What's Running Right Now ── -->
  <section class="section fade-up" style="animation-delay: 0.1s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">What's Running Right Now</h2>
        <span class="mono live-badge">
          <span class="status-dot ok"></span>
          Live
        </span>
      </div>

      <!-- Summary cards -->
      <div class="live-grid" id="live-grid">
        <div class="live-card skeleton"></div>
        <div class="live-card skeleton"></div>
        <div class="live-card skeleton"></div>
        <div class="live-card skeleton"></div>
      </div>

      <!-- Services grid -->
      <div class="svc-grid" id="svc-grid">
        <div class="svc-item skeleton" style="height:48px;border-radius:8px"></div>
        <div class="svc-item skeleton" style="height:48px;border-radius:8px"></div>
        <div class="svc-item skeleton" style="height:48px;border-radius:8px"></div>
        <div class="svc-item skeleton" style="height:48px;border-radius:8px"></div>
        <div class="svc-item skeleton" style="height:48px;border-radius:8px"></div>
        <div class="svc-item skeleton" style="height:48px;border-radius:8px"></div>
      </div>

      <!-- Media player cards -->
      <div class="media-grid" id="media-grid">
        <div class="media-card skeleton" style="height:200px"></div>
        <div class="media-card skeleton" style="height:200px"></div>
      </div>
    </div>
  </section>

  <!-- ── Cluster Status Strip ── -->
  <section class="section fade-up" style="animation-delay: 0.2s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Cluster Health</h2>
        <a href="/status" class="mono link-subtle">Full dashboard →</a>
      </div>
      <div class="status-strip" id="status-strip">
        <div class="status-strip-item skeleton" style="height: 56px; border-radius: 8px;"></div>
        <div class="status-strip-item skeleton" style="height: 56px; border-radius: 8px;"></div>
        <div class="status-strip-item skeleton" style="height: 56px; border-radius: 8px;"></div>
      </div>
    </div>
  </section>

  <!-- ── Stack ── -->
  <section class="section fade-up" style="animation-delay: 0.25s">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-title">Stack</h2>
        <a href="/decisions" class="mono link-subtle">ADRs →</a>
      </div>
      <div class="stack-grid">
        {[
          { name: 'k3s',         role: 'Kubernetes distro',     accent: 'peach'    },
          { name: 'Flux',        role: 'GitOps operator',        accent: 'mauve'    },
          { name: 'Traefik',     role: 'Ingress / proxy',        accent: 'sapphire' },
          { name: 'Authentik',   role: 'Identity provider',      accent: 'gold'     },
          { name: 'Prometheus',  role: 'Metrics & alerting',     accent: 'peach'    },
          { name: 'Grafana',     role: 'Observability',          accent: 'gold'     },
          { name: 'Loki',        role: 'Log aggregation',        accent: 'mauve'    },
          { name: 'Velero',      role: 'Cluster backups',        accent: 'sapphire' },
          { name: 'CrowdSec',    role: 'Threat intelligence',    accent: 'crit'     },
          { name: 'SOPS',        role: 'Secret encryption',      accent: 'mauve'    },
          { name: 'MikroTik',    role: 'Router / firewall',      accent: 'peach'    },
          { name: 'TrueNAS',     role: 'NAS / storage',          accent: 'gold'     },
        ].map(t => (
          <div class="stack-item" data-accent={t.accent}>
            <span class="stack-name">{t.name}</span>
            <span class="stack-role">{t.role}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Recent Digest + Active Project ── -->
  <section class="section fade-up" style="animation-delay: 0.3s">
    <div class="section-inner two-col">

      <div>
        <div class="section-header">
          <h2 class="section-title">Recent Digest</h2>
          <a href="/digest" class="mono link-subtle">All entries →</a>
        </div>
        <div id="digest-list">
          <div class="skeleton" style="height: 80px; border-radius: 8px; margin-bottom: 0.75rem;"></div>
          <div class="skeleton" style="height: 80px; border-radius: 8px; margin-bottom: 0.75rem;"></div>
          <div class="skeleton" style="height: 80px; border-radius: 8px;"></div>
        </div>
      </div>

      <div>
        <div class="section-header">
          <h2 class="section-title">Active Work</h2>
          <a href="/projects" class="mono link-subtle">Roadmap →</a>
        </div>
        <div id="active-project">
          <div class="skeleton" style="height: 200px; border-radius: 12px;"></div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── About ── -->
  <section class="section about-section fade-up" style="animation-delay: 0.35s">
    <div class="section-inner">
      <div class="about-grid">

        <div class="about-text">
          <p class="mono" style="color:var(--color-peach);margin-bottom:0.75rem">~/whoami</p>
          <h2 style="font-size:clamp(1.5rem,3vw,2rem);margin:0 0 1.25rem">Hey, I'm Kagiso.</h2>
          <p style="color:var(--color-subtle);line-height:1.8;margin-bottom:1rem">
            Software engineer by day, homelab operator by night. I built this cluster to run my own
            infrastructure — storage, media, backups, identity — with the same discipline I bring
            to production systems at work.
          </p>
          <p style="color:var(--color-subtle);line-height:1.8;margin-bottom:1.75rem">
            Everything here is real: the data is live, the ops log is the actual changelog,
            and the architecture decisions document real trade-offs I've made. No demos, no staging.
          </p>
          <div class="about-links">
            <a href="https://github.com/Kagiso-me" target="_blank" rel="noopener" class="about-link">
              <span class="about-link-icon">⌥</span> GitHub
            </a>
            <a href="/decisions" class="about-link">
              <span class="about-link-icon">⎇</span> ADRs
            </a>
            <a href="/digest" class="about-link">
              <span class="about-link-icon">◎</span> Ops Log
            </a>
          </div>

          <!-- GitHub contribution graph -->
          <div class="contrib-wrap">
            <div class="contrib-header">
              <span class="mono contrib-label">GitHub activity</span>
              <span class="mono" id="contrib-total" style="color:var(--color-subtle);font-size:0.7rem"></span>
            </div>
            <div id="contrib-graph" class="contrib-graph">
              <div class="contrib-loading">loading graph…</div>
            </div>
            <div class="contrib-legend">
              <span class="mono" style="color:var(--color-subtle);font-size:0.65rem">less</span>
              <span class="contrib-cell" data-level="0"></span>
              <span class="contrib-cell" data-level="1"></span>
              <span class="contrib-cell" data-level="2"></span>
              <span class="contrib-cell" data-level="3"></span>
              <span class="contrib-cell" data-level="4"></span>
              <span class="mono" style="color:var(--color-subtle);font-size:0.65rem">more</span>
            </div>
          </div>
        </div>

        <div class="about-hardware">
          <div class="hw-label mono">Hardware</div>
          <div class="hw-list">
            {[
              { icon: '▣', name: '3× Lenovo ThinkCentre M93p', sub: 'k3s control-plane nodes' },
              { icon: '▣', name: 'Intel NUC',                   sub: 'Docker host' },
              { icon: '▣', name: 'HP MicroServer Gen8',         sub: 'TrueNAS · primary & archive storage' },
              { icon: '◈', name: 'MikroTik hEX S',              sub: 'router & firewall' },
              { icon: '◈', name: 'RPi 4 (bran)',                sub: 'automation runner & CI' },
              { icon: '◉', name: 'APC UPS',                     sub: '390W · 1h 55m runtime' },
            ].map(h => (
              <div class="hw-item">
                <span class="hw-icon mono">{h.icon}</span>
                <div>
                  <div class="hw-name">{h.name}</div>
                  <div class="hw-sub mono">{h.sub}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  .hero {
    padding: 6rem 1.5rem 4rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    color: var(--color-peach);
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  h1 {
    font-size: clamp(3rem, 6vw, 5rem);
    margin: 0 0 1.5rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    color: var(--color-subtle);
    max-width: 520px;
    margin: 0 auto 1rem;
    line-height: 1.7;
  }

  .hero-typewriter {
    font-size: 0.9rem;
    color: var(--color-peach);
    margin: 0 auto 2rem;
    height: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .typewriter-cursor {
    animation: blink 1s step-end infinite;
    color: var(--color-peach);
    margin-left: 1px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 0.625rem 1.5rem;
    background: var(--color-peach);
    color: var(--color-base);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: opacity 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
    color: var(--color-base);
  }

  .btn-ghost {
    padding: 0.625rem 1.5rem;
    border: 1px solid var(--color-muted);
    color: var(--color-text);
    border-radius: 8px;
    font-size: 0.9rem;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--color-mauve);
    color: var(--color-mauve);
  }

  .section {
    padding: 3rem 1.5rem;
    border-top: 1px solid var(--color-muted);
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 1.125rem;
    margin: 0;
    padding-left: 0.75rem;
    border-left: 2px solid transparent;
    border-image: linear-gradient(to bottom, var(--color-peach), transparent) 1;
  }

  .link-subtle {
    color: var(--color-subtle);
    transition: color 0.2s;
  }

  .link-subtle:hover { color: var(--color-peach); }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-ok);
  }

  .live-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .live-card {
    background: rgba(30, 37, 52, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 12px;
    padding: 1.25rem;
    min-height: 100px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .live-card:hover {
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
  }

  .status-strip {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  /* ── Services strip ── */
  .svc-grid {
    display: flex;
    align-items: center;
    justify-content: space-evenly;
    background: rgba(16, 20, 28, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 12px;
    padding: 1rem 1.5rem;
    margin-top: 1.25rem;
    gap: 1rem;
    overflow-x: auto;
  }

  .svc-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    flex-shrink: 0;
  }

  .svc-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .svc-name {
    font-family: var(--font-mono);
    font-size: 0.825rem;
    font-weight: 600;
    color: var(--color-heading);
  }

  .svc-meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-subtle);
    white-space: nowrap;
  }

  /* ── Media player cards ── */
  .media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .media-card {
    background: rgba(30, 37, 52, 0.55);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
    position: relative;
  }

  .media-card.active {
    border-color: var(--color-ok);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-ok) 20%, transparent);
  }

  .media-card.placeholder {
    border-color: color-mix(in srgb, var(--color-mauve) 30%, transparent);
    border-style: dashed;
    opacity: 0.85;
  }

  /* Blurred art backdrop */
  .media-backdrop {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: blur(28px) saturate(1.4);
    opacity: 0.18;
    pointer-events: none;
    transition: opacity 0.4s;
  }

  .media-card.active .media-backdrop { opacity: 0.28; }

  .media-inner {
    position: relative;
    padding: 1.25rem;
    z-index: 1;
  }

  .media-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .media-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .media-badge.playing { color: var(--color-ok); }
  .media-badge.idle    { color: var(--color-subtle); }
  .media-badge.soon    { color: var(--color-peach); }

  .media-service-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .media-body {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .media-art {
    width: 80px;
    height: 80px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
    background: var(--color-overlay);
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
  }

  .media-art-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 8px;
    background: var(--color-overlay);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    flex-shrink: 0;
    color: var(--color-subtle);
  }

  .media-text { min-width: 0; flex: 1; }

  .media-title {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-heading);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.3;
  }

  .media-sub {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-subtle);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 0.3rem;
  }

  .media-next {
    margin-top: 0.875rem;
    padding-top: 0.875rem;
    border-top: 1px solid var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-subtle);
  }

  .media-next-label {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-peach);
    margin-bottom: 0.2rem;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; gap: 2rem; }
    .hero { padding: 4rem 1.5rem 3rem; }
    .stack-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.5rem; }
    .media-grid { grid-template-columns: 1fr; }
    .contrib-grid { gap: 1.5px; }
    .contrib-cell { width: 8px; height: 8px; }
  }

  @media (max-width: 480px) {
    .stack-grid { grid-template-columns: repeat(2, 1fr); }
    .hero-typewriter { font-size: 0.8rem; }
  }

  /* ── Stack grid ── */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.75rem;
  }

  .stack-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    background: rgba(30, 37, 52, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 10px;
    padding: 0.875rem 1rem;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    position: relative;
    overflow: hidden;
    cursor: default;
  }

  /* Accent glow on top edge */
  .stack-item::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    border-radius: 10px 10px 0 0;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .stack-item[data-accent="peach"]::before    { background: var(--color-peach); }
  .stack-item[data-accent="mauve"]::before    { background: var(--color-mauve); }
  .stack-item[data-accent="gold"]::before     { background: var(--color-gold); }
  .stack-item[data-accent="sapphire"]::before { background: var(--color-sapphire); }
  .stack-item[data-accent="crit"]::before     { background: var(--color-crit); }

  .stack-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.35);
  }

  .stack-item[data-accent="peach"]:hover    { border-color: var(--color-peach); }
  .stack-item[data-accent="mauve"]:hover    { border-color: var(--color-mauve); }
  .stack-item[data-accent="gold"]:hover     { border-color: var(--color-gold); }
  .stack-item[data-accent="sapphire"]:hover { border-color: var(--color-sapphire); }
  .stack-item[data-accent="crit"]:hover     { border-color: var(--color-crit); }

  .stack-item:hover::before { opacity: 1; }

  .stack-name {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-heading);
  }

  .stack-role {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-subtle);
    line-height: 1.4;
  }

  .skeleton {
    background: linear-gradient(
      90deg,
      var(--color-surface) 25%,
      var(--color-overlay) 50%,
      var(--color-surface) 75%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Parallax hero ── */
  .hero {
    position: relative;
    overflow: hidden;
  }

  .parallax-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
    filter: blur(80px);
    opacity: 0.18;
  }

  .orb-1 {
    width: 520px; height: 520px;
    background: radial-gradient(circle, var(--color-peach), transparent 70%);
    top: -140px; left: -100px;
  }

  .orb-2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, var(--color-mauve), transparent 70%);
    top: -60px; right: -80px;
    opacity: 0.14;
  }

  .orb-3 {
    width: 280px; height: 280px;
    background: radial-gradient(circle, var(--color-sapphire), transparent 70%);
    bottom: -60px; left: 40%;
    opacity: 0.1;
  }

  .parallax-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
    will-change: transform;
    mask-image: radial-gradient(ellipse 80% 100% at 50% 0%, black, transparent);
    -webkit-mask-image: radial-gradient(ellipse 80% 100% at 50% 0%, black, transparent);
  }

  /* ── About section ── */
  .about-section {
    border-top: 1px solid var(--color-muted);
    background: linear-gradient(to bottom, transparent, color-mix(in srgb, var(--color-mantle) 60%, transparent));
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  .about-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .about-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-subtle);
    border: 1px solid var(--color-muted);
    border-radius: 6px;
    padding: 0.35rem 0.8rem;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .about-link:hover {
    color: var(--color-peach);
    border-color: var(--color-peach);
    background: color-mix(in srgb, var(--color-peach) 8%, transparent);
  }

  .about-link-icon {
    font-size: 0.75rem;
    opacity: 0.7;
  }

  .hw-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-subtle);
    margin-bottom: 1rem;
  }

  .hw-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .hw-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    background: rgba(30, 37, 52, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .hw-item:hover {
    border-color: var(--color-mauve);
    transform: translateX(3px);
  }

  .hw-icon {
    color: var(--color-mauve);
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .hw-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-heading);
    line-height: 1.3;
  }

  .hw-sub {
    font-size: 0.72rem;
    color: var(--color-subtle);
    margin-top: 0.15rem;
  }

  /* ── GitHub contribution graph ── */
  .contrib-wrap {
    margin-top: 2rem;
    border-top: 1px solid var(--color-muted);
    padding-top: 1.25rem;
  }

  .contrib-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .contrib-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-subtle);
  }

  .contrib-graph {
    overflow-x: auto;
    padding-bottom: 0.25rem;
  }

  .contrib-grid {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(7, 10px);
    gap: 2px;
    width: max-content;
  }

  .contrib-cell {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    background: var(--color-overlay);
    transition: transform 0.15s;
    cursor: default;
    flex-shrink: 0;
  }

  .contrib-cell:hover { transform: scale(1.4); }

  .contrib-cell[data-level="0"] { background: var(--color-overlay); }
  .contrib-cell[data-level="1"] { background: color-mix(in srgb, var(--color-peach) 25%, var(--color-overlay)); }
  .contrib-cell[data-level="2"] { background: color-mix(in srgb, var(--color-peach) 50%, var(--color-overlay)); }
  .contrib-cell[data-level="3"] { background: color-mix(in srgb, var(--color-peach) 75%, var(--color-overlay)); }
  .contrib-cell[data-level="4"] { background: var(--color-peach); }

  .contrib-loading {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-subtle);
    padding: 1rem 0;
  }

  .contrib-legend {
    display: flex;
    align-items: center;
    gap: 3px;
    margin-top: 0.5rem;
    justify-content: flex-end;
  }

  .contrib-legend .contrib-cell {
    width: 10px;
    height: 10px;
    cursor: default;
  }
  .contrib-legend .contrib-cell:hover { transform: none; }
</style>

<script>
  // ── Fallback static list — shown immediately before live.json loads
  const STATIC_SERVICES = [
    { name: 'Immich',    tag: '—',    status: 'unknown' },
    { name: 'Nextcloud', tag: '—',    status: 'unknown' },
    { name: 'SABnzbd',   tag: 'idle', status: 'unknown' },
    { name: 'Sonarr',    tag: '—',    status: 'unknown' },
    { name: 'Radarr',    tag: '—',    status: 'unknown' },
    { name: 'Lidarr',    tag: '—',    status: 'unknown' },
  ];

  const STATIC_MEDIA = [
    { name: 'Plex',       label: 'idle',        status: 'unknown', playing: false },
    { name: 'AzuraCast',  label: 'coming soon', status: 'unknown', playing: false, placeholder: true },
  ];

  function buildSvcGrid(services: {name: string; tag: string; status: string}[]) {
    const grid = document.getElementById('svc-grid');
    if (!grid) return;
    grid.innerHTML = services.map(s => {
      const colonIdx = s.tag.indexOf(':');
      const name = colonIdx > -1 ? s.tag.slice(0, colonIdx).trim() : s.name;
      const meta = colonIdx > -1 ? s.tag.slice(colonIdx + 1).trim() : s.tag;
      return `
        <div class="svc-item ${s.status}">
          <div class="svc-header">
            <span class="status-dot ${s.status}"></span>
            <span class="svc-name">${name}</span>
          </div>
          ${meta ? `<div class="svc-meta">${meta}</div>` : ''}
        </div>`;
    }).join('');
  }

  function buildMedia(items: any[]) {
    const grid = document.getElementById('media-grid');
    if (!grid) return;

    const icons: Record<string, string> = { Plex: '▶', AzuraCast: '📻' };

    grid.innerHTML = items.map(m => {
      const playing    = m.playing === true;
      const isPlaceholder = m.placeholder === true;
      const icon       = icons[m.name] ?? '▶';
      const backdropStyle = playing && m.coverUrl
        ? `style="background-image:url('${m.coverUrl}')"` : '';

      const artHtml = playing && m.coverUrl
        ? `<img class="media-art" src="${m.coverUrl}" alt="album art" loading="lazy"
             onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
           <div class="media-art-placeholder" style="display:none">${icon}</div>`
        : `<div class="media-art-placeholder">${icon}</div>`;

      let textHtml = '';
      let nextHtml = '';

      if (isPlaceholder) {
        textHtml = `
          <div class="media-title" style="color:var(--color-mauve);font-weight:600;letter-spacing:0.01em">Self-hosted radio</div>
          <div class="media-sub" style="color:var(--color-subtle);margin-top:0.35rem">AzuraCast · coming soon</div>
          <div style="margin-top:0.6rem;display:flex;align-items:center;gap:0.4rem">
            <span style="font-family:var(--font-mono);font-size:0.68rem;padding:0.15rem 0.5rem;border-radius:4px;background:color-mix(in srgb,var(--color-mauve) 12%,transparent);color:var(--color-mauve);border:1px solid color-mix(in srgb,var(--color-mauve) 25%,transparent)">in progress</span>
          </div>`;
      } else if (m.name === 'AzuraCast') {
        if (playing) {
          textHtml = `
            <div class="media-title">${m.title || m.label}</div>
            <div class="media-sub">${[m.artist, m.show].filter(Boolean).join(' · ')}</div>`;
          if (m.next) {
            nextHtml = `
              <div class="media-next">
                <div class="media-next-label">Up next</div>
                <div>${m.next}</div>
              </div>`;
          }
        } else {
          textHtml = `<div class="media-title" style="color:var(--color-subtle);font-weight:400">Off air</div>`;
        }
      } else {
        if (playing) {
          textHtml = `
            <div class="media-title">${m.title || m.label}</div>
            <div class="media-sub">${[m.artist, m.album].filter(Boolean).join(' · ')}</div>`;
        } else {
          textHtml = `<div class="media-title" style="color:var(--color-subtle);font-weight:400">idle</div>`;
        }
      }

      const badgeClass = isPlaceholder ? 'soon' : playing ? 'playing' : 'idle';
      const badgeText  = isPlaceholder ? 'soon™' : playing ? 'playing' : 'idle';

      return `
      <div class="media-card${playing ? ' active' : ''}${isPlaceholder ? ' placeholder' : ''}">
        <div class="media-backdrop" ${backdropStyle}></div>
        <div class="media-inner">
          <div class="media-card-header">
            <span class="media-badge ${badgeClass}">
              <span class="status-dot ${m.status}"></span>
              ${badgeText}
            </span>
            <span class="media-service-label">${m.name}</span>
          </div>
          <div class="media-body">
            ${artHtml}
            <div class="media-text">${textHtml}</div>
          </div>
          ${nextHtml}
        </div>
      </div>`;
    }).join('');
  }

  async function loadLiveData() {
    // Render immediately with static fallback
    buildSvcGrid(STATIC_SERVICES);
    buildMedia(STATIC_MEDIA);

    try {
      const res = await fetch('/data/live.json');
      if (!res.ok) throw new Error('no data');
      const data = await res.json();
      // Push data to ClusterTerminal component
      if (typeof (window as any).__termSetData === 'function') {
        (window as any).__termSetData(data);
      }

      const grid = document.getElementById('live-grid');
      if (grid && data.cards) {
        grid.innerHTML = data.cards.map((card: any) => `
          <div class="live-card fade-up">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem">
              <span class="mono" style="color:var(--color-subtle)">${card.label}</span>
              <span class="status-dot ${card.status}"></span>
            </div>
            <div style="font-size:1.5rem;font-weight:700;color:var(--color-heading);font-family:var(--font-mono)">${card.value}</div>
            <div class="mono" style="margin-top:0.25rem">${card.sub ?? ''}</div>
          </div>
        `).join('');
      }

      if (data.services?.length) buildSvcGrid(data.services);
      if (data.media?.length)    buildMedia(data.media);

      const strip = document.getElementById('status-strip');
      if (strip && data.nodes) {
        strip.innerHTML = data.nodes.map((node: any) => {
          const pressureWarning = node.pressure?.length
            ? `<span style="color:var(--color-warn);font-size:0.7rem;margin-left:0.5rem">${node.pressure.join(', ')}</span>`
            : '';
          return `
          <div style="background:var(--color-surface);border:1px solid var(--color-muted);border-radius:8px;padding:0.875rem 1rem;display:flex;align-items:center;gap:0.75rem">
            <span class="status-dot ${node.status}"></span>
            <div>
              <div style="font-size:0.875rem;color:var(--color-heading);font-weight:600">${node.name}${pressureWarning}</div>
              <div class="mono">${node.role}</div>
            </div>
            <div style="margin-left:auto;text-align:right">
              <div class="mono" style="color:var(--color-peach)">${node.pods} pods</div>
              <div class="mono">${node.cpu} CPU · ${node.memory} mem</div>
            </div>
          </div>`;
        }).join('');
      }
    } catch { /* skeletons stay, ticker already showing with static fallback */ }
  }

  async function loadDigest() {
    try {
      const res = await fetch('/data/digest.json');
      if (!res.ok) throw new Error('no data');
      const entries = await res.json();
      const list = document.getElementById('digest-list');
      if (list) {
        const TYPE_COLOR: Record<string, string> = {
          DEPLOY: 'var(--color-ok)', FIX: 'var(--color-peach)', INCIDENT: 'var(--color-crit)',
          HARDWARE: 'var(--color-gold)', NETWORK: 'var(--color-mauve)', SECURITY: 'var(--color-warn)',
        };
        list.innerHTML = entries.slice(0, 3).map((e: any) => {
          const color = TYPE_COLOR[e.type] ?? 'var(--color-subtle)';
          const tag = e.hasDetail ? 'a' : 'div';
          const href = e.hasDetail ? `href="/digest/entry?slug=${e.slug}"` : '';
          return `
          <${tag} ${href} style="display:block;text-decoration:none;margin-bottom:0.75rem">
            <div class="card" style="padding:1rem;transition:border-color 0.15s${e.hasDetail ? ';cursor:pointer' : ''}">
              <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.4rem">
                <span style="font-family:var(--font-mono);font-size:0.65rem;font-weight:600;padding:0.15rem 0.45rem;border-radius:4px;background:color-mix(in srgb,${color} 12%,transparent);color:${color};text-transform:uppercase;letter-spacing:0.05em">${e.type}</span>
                <span class="mono" style="color:var(--color-subtle);font-size:0.72rem">${e.date}</span>
                ${e.hasDetail ? `<span class="mono" style="color:var(--color-peach);font-size:0.7rem;margin-left:auto">read more →</span>` : ''}
              </div>
              <div style="color:var(--color-heading);font-weight:600;font-size:0.875rem;line-height:1.4">${e.title}</div>
            </div>
          </${tag}>`;
        }).join('');
      }
    } catch { /* no data yet */ }
  }

  async function loadProject() {
    try {
      const res = await fetch('/data/roadmap.json');
      if (!res.ok) throw new Error('no data');
      const data = await res.json();
      const active = data.active?.[0];
      if (!active) return;
      const el = document.getElementById('active-project');
      if (el) {
        const progressHtml = active.progress != null ? `
          <div style="margin:1rem 0">
            <div style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:0.68rem;color:var(--color-subtle);margin-bottom:0.35rem">
              <span>progress</span><span>${active.progress}%</span>
            </div>
            <div style="height:4px;background:var(--color-overlay);border-radius:2px;overflow:hidden">
              <div style="height:100%;width:${active.progress}%;background:var(--color-ok);border-radius:2px"></div>
            </div>
          </div>` : '';
        const stackHtml = active.stack?.length
          ? `<div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:1rem">${active.stack.map((s: string) => `<span style="font-family:var(--font-mono);font-size:0.68rem;padding:0.2rem 0.55rem;border-radius:4px;background:var(--color-overlay);color:var(--color-subtle);border:1px solid var(--color-muted)">${s}</span>`).join('')}</div>`
          : '';
        el.innerHTML = `
          <a href="/projects" style="display:block;text-decoration:none">
            <div class="card" style="transition:border-color 0.15s">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
                <span class="mono" style="color:var(--color-ok);font-size:0.75rem;display:flex;align-items:center;gap:0.35rem">● active</span>
                <span class="mono" style="color:var(--color-subtle);font-size:0.72rem">→ roadmap</span>
              </div>
              <h3 style="margin:0 0 0.2rem;font-size:1.1rem">${active.title}</h3>
              <div class="mono" style="color:var(--color-subtle);font-size:0.75rem;margin-bottom:0.75rem">${active.subtitle}</div>
              <p style="color:var(--color-subtle);font-size:0.875rem;margin:0;line-height:1.6">${active.description}</p>
              ${progressHtml}
              ${stackHtml}
            </div>
          </a>
        `;
      }
    } catch { /* no data yet */ }
  }

  loadLiveData();
  loadDigest();
  loadProject();

  // ── Typewriter ───────────────────────────────────────────────────────────
  (function initTypewriter() {
    const el = document.getElementById('typewriter-text')!;
    if (!el) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = 'software engineer · homelab operator';
      return;
    }

    const phrases = [
      'software engineer',
      'homelab operator',
      'k3s cluster admin',
      'built in public',
      'from bare metal up',
    ];

    let phraseIdx = 0;
    let charIdx   = 0;
    let deleting  = false;
    const TYPE_SPEED   = 65;
    const DELETE_SPEED = 35;
    const PAUSE_END    = 1800;
    const PAUSE_START  = 300;

    function tick() {
      const phrase = phrases[phraseIdx];
      if (!deleting) {
        charIdx++;
        el.textContent = phrase.slice(0, charIdx);
        if (charIdx === phrase.length) {
          deleting = true;
          setTimeout(tick, PAUSE_END);
          return;
        }
        setTimeout(tick, TYPE_SPEED);
      } else {
        charIdx--;
        el.textContent = phrase.slice(0, charIdx);
        if (charIdx === 0) {
          deleting = false;
          phraseIdx = (phraseIdx + 1) % phrases.length;
          setTimeout(tick, PAUSE_START);
          return;
        }
        setTimeout(tick, DELETE_SPEED);
      }
    }

    setTimeout(tick, 800); // small initial delay after page load
  })();

  // ── GitHub contribution graph ────────────────────────────────────────────
  function renderContribGraph(dayCounts: Record<string, number>, graphEl: HTMLElement, totalEl: HTMLElement | null) {
    const maxCount = Math.max(1, ...Object.values(dayCounts));
    const toLevel = (n: number) => n === 0 ? 0 : Math.min(4, Math.ceil((n / maxCount) * 4));

    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const gridEnd = new Date(today);
    gridEnd.setDate(gridEnd.getDate() + (6 - today.getDay()));

    const cells: { date: string; level: number; count: number }[] = [];
    for (let w = 51; w >= 0; w--) {
      for (let d = 0; d < 7; d++) {
        const dt = new Date(gridEnd);
        dt.setDate(dt.getDate() - w * 7 - (6 - d));
        const iso = dt.toISOString().slice(0, 10);
        const count = dayCounts[iso] ?? 0;
        cells.push({ date: iso, level: toLevel(count), count });
      }
    }

    const grid = document.createElement('div');
    grid.className = 'contrib-grid';
    grid.innerHTML = cells.map(c => {
      const tip = c.count > 0
        ? `${c.date} · ${c.count} contribution${c.count > 1 ? 's' : ''}`
        : `${c.date} · no contributions`;
      return `<span class="contrib-cell" data-level="${c.level}" title="${tip}"></span>`;
    }).join('');

    graphEl.innerHTML = '';
    graphEl.appendChild(grid);

    if (totalEl) {
      const activeDays = cells.filter(c => c.level > 0).length;
      const totalContribs = Object.values(dayCounts).reduce((a, b) => a + b, 0);
      totalEl.textContent = `${totalContribs} contributions · ${activeDays} active days (last 90 days)`;
    }
  }

  async function loadContribGraph() {
    const graphEl = document.getElementById('contrib-graph');
    const totalEl = document.getElementById('contrib-total');
    if (!graphEl) return;

    try {
      // Prefer pre-fetched data from live.json (updated every 30 min, no rate-limit risk)
      const liveRes = await fetch('/data/live.json').then(r => r.ok ? r.json() : null).catch(() => null);
      if (liveRes?.contribs?.days && Object.keys(liveRes.contribs.days).length > 0) {
        renderContribGraph(liveRes.contribs.days, graphEl, totalEl);
        return;
      }

      // Fallback: fetch directly from GitHub API
      const user = 'Kagiso-me';
      const results = await Promise.all(
        [1, 2, 3].map(p =>
          fetch(`https://api.github.com/users/${user}/events/public?per_page=100&page=${p}`, {
            headers: { Accept: 'application/vnd.github+json' }
          }).then(r => r.ok ? r.json() : []).catch(() => [])
        )
      );
      const events: any[] = results.flat();

      const dayCounts: Record<string, number> = {};
      for (const ev of events) {
        const iso = ev.created_at?.slice(0, 10);
        if (!iso) continue;
        const commits = ev.type === 'PushEvent' ? (ev.payload?.commits?.length ?? 1) : 1;
        dayCounts[iso] = (dayCounts[iso] ?? 0) + commits;
      }

      renderContribGraph(dayCounts, graphEl, totalEl);
    } catch {
      if (graphEl) graphEl.innerHTML = '<div class="contrib-loading">graph unavailable</div>';
    }
  }

  loadContribGraph();

  // ── Parallax ─────────────────────────────────────────────────────────────
  (function initParallax() {
    const layers = document.querySelectorAll<HTMLElement>('[data-speed]');
    if (!layers.length) return;

    // Respect reduced-motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        layers.forEach(el => {
          const speed = parseFloat(el.dataset.speed ?? '0');
          el.style.transform = `translateY(${y * speed}px)`;
        });
        ticking = false;
      });
    }, { passive: true });
  })();
</script>
