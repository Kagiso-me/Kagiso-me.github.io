---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Digest Entry" description="Ops log entry — homelab infrastructure change detail.">

  <div class="page-wrap" id="page-wrap">

    <!-- Skeleton while loading -->
    <div id="skeleton">
      <div style="margin-bottom:2rem">
        <div class="skeleton" style="height:14px;width:120px;border-radius:4px;margin-bottom:0.75rem"></div>
        <div class="skeleton" style="height:36px;width:70%;border-radius:6px;margin-bottom:0.75rem"></div>
        <div class="skeleton" style="height:14px;width:200px;border-radius:4px"></div>
      </div>
      <div class="skeleton" style="height:400px;border-radius:12px"></div>
    </div>

    <!-- Loaded content -->
    <div id="entry-content" style="display:none">

      <a href="/digest" class="back-link">← Digest</a>

      <div class="entry-header">
        <div class="entry-header-meta" id="entry-meta"></div>
        <h1 id="entry-title"></h1>
        <div class="entry-header-sub" id="entry-sub"></div>
      </div>

      <div class="entry-body card" id="entry-body"></div>

    </div>

    <div id="entry-notfound" style="display:none;text-align:center;padding:4rem 0">
      <p class="mono" style="color:var(--color-subtle)">Entry not found.</p>
      <a href="/digest" class="back-link" style="display:inline-block;margin-top:1rem">← Back to Digest</a>
    </div>

  </div>

</Layout>

<style>
  .page-wrap {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-subtle);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 2rem;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--color-peach); }

  .entry-header {
    margin-bottom: 2.5rem;
  }

  .entry-header-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  h1 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }

  .entry-header-sub {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-subtle);
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .type-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .type-DEPLOY   { background: color-mix(in srgb, var(--color-ok)    12%, transparent); color: var(--color-ok); }
  .type-FIX      { background: color-mix(in srgb, var(--color-peach)  12%, transparent); color: var(--color-peach); }
  .type-INCIDENT { background: color-mix(in srgb, var(--color-crit)   12%, transparent); color: var(--color-crit); }
  .type-HARDWARE { background: color-mix(in srgb, var(--color-gold)   12%, transparent); color: var(--color-gold); }
  .type-NETWORK  { background: color-mix(in srgb, var(--color-mauve)  12%, transparent); color: var(--color-mauve); }
  .type-SECURITY { background: color-mix(in srgb, var(--color-warn)   12%, transparent); color: var(--color-warn); }
  .type-SCALE    { background: color-mix(in srgb, var(--color-ok)     12%, transparent); color: var(--color-ok); }
  .type-default  { background: color-mix(in srgb, var(--color-subtle) 12%, transparent); color: var(--color-subtle); }

  .entry-body {
    padding: 2rem 2rem;
    line-height: 1.8;
  }

  /* ── Markdown rendering ── */
  .entry-body :global(h2) {
    font-size: 1.1rem;
    color: var(--color-heading);
    margin: 2rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-muted);
  }

  .entry-body :global(h3) {
    font-size: 0.95rem;
    color: var(--color-peach);
    margin: 1.5rem 0 0.5rem;
    font-family: var(--font-mono);
  }

  .entry-body :global(p) {
    color: var(--color-text);
    margin: 0 0 1rem;
  }

  .entry-body :global(ul), .entry-body :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1rem;
  }

  .entry-body :global(li) {
    color: var(--color-text);
    margin-bottom: 0.35rem;
  }

  .entry-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.82em;
    background: var(--color-overlay);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--color-peach);
  }

  .entry-body :global(pre) {
    background: var(--color-overlay);
    border: 1px solid var(--color-muted);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1rem 0;
  }

  .entry-body :global(pre code) {
    background: none;
    padding: 0;
    color: var(--color-text);
    font-size: 0.82rem;
  }

  .entry-body :global(strong) { color: var(--color-heading); }

  .entry-body :global(a) {
    color: var(--color-peach);
    text-decoration: none;
  }

  .entry-body :global(a:hover) { text-decoration: underline; }

  .entry-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-muted);
    margin: 2rem 0;
  }

  .entry-body :global(blockquote) {
    border-left: 3px solid var(--color-peach);
    margin: 1rem 0;
    padding: 0.5rem 1rem;
    color: var(--color-subtle);
  }

  .skeleton {
    background: linear-gradient(90deg, var(--color-surface) 25%, var(--color-overlay) 50%, var(--color-surface) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  @media (max-width: 640px) {
    .entry-body { padding: 1.25rem; }
  }
</style>

<script>
  // Get slug from URL path: /digest/some-slug
  const slug = window.location.pathname.replace(/^\/digest\//, '').replace(/\/$/, '');

  const TYPE_COLORS: Record<string, string> = {
    DEPLOY: 'type-DEPLOY', FIX: 'type-FIX', INCIDENT: 'type-INCIDENT',
    HARDWARE: 'type-HARDWARE', NETWORK: 'type-NETWORK', SECURITY: 'type-SECURITY',
    SCALE: 'type-SCALE',
  };

  function formatDate(d: string) {
    if (d.length === 7) {
      const [y, m] = d.split('-');
      return new Date(+y, +m - 1).toLocaleDateString('en-ZA', { month: 'long', year: 'numeric' });
    }
    return new Date(d + 'T12:00:00').toLocaleDateString('en-ZA', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  // Simple markdown → HTML renderer (no dependency needed for our subset)
  function renderMarkdown(md: string): string {
    // Strip the front-matter style header block (lines starting with ** up to first ---)
    const lines = md.split('\n');
    let bodyStart = 0;
    // Skip h1 title line and metadata lines before first ---
    let seenSep = 0;
    for (let i = 0; i < lines.length; i++) {
      if (lines[i].trim() === '---') {
        seenSep++;
        if (seenSep === 1) { bodyStart = i + 1; break; }
      }
    }
    const body = lines.slice(bodyStart).join('\n');

    return body
      // Fenced code blocks
      .replace(/```(\w*)\n([\s\S]*?)```/g, (_, lang, code) =>
        `<pre><code class="language-${lang}">${escHtml(code.trimEnd())}</code></pre>`)
      // h3
      .replace(/^### (.+)$/gm, '<h3>$1</h3>')
      // h2
      .replace(/^## (.+)$/gm, '<h2>$1</h2>')
      // h1 (skip — we render the title ourselves)
      .replace(/^# .+$/gm, '')
      // HR
      .replace(/^---$/gm, '<hr>')
      // Bold
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      // Inline code
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      // Links
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
      // Unordered list items
      .replace(/^[-*] (.+)$/gm, '<li>$1</li>')
      // Wrap consecutive <li> in <ul>
      .replace(/(<li>.*<\/li>\n?)+/g, m => `<ul>${m}</ul>`)
      // Checkboxes
      .replace(/<li>\[x\] /gi, '<li>✓ ')
      .replace(/<li>\[ \] /g, '<li>○ ')
      // Paragraphs — blank line separated, not already a block element
      .replace(/\n\n(?!<[hup]|<li|<pre|<block)/g, '\n</p><p>')
      .replace(/^(?!<[hup]|<li|<pre|<block|<hr)(.+)/gm, (m) =>
        m.startsWith('<') ? m : m)
      // Wrap in initial <p>
      .replace(/^([^<\n].*)$/m, '<p>$1')
      // Cleanup
      .replace(/<p><\/p>/g, '')
      .replace(/<p>\s*<\/p>/g, '');
  }

  function escHtml(s: string) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  async function load() {
    try {
      const res = await fetch('/data/digest.json');
      if (!res.ok) throw new Error();
      const entries: any[] = await res.json();
      const entry = entries.find(e => e.slug === slug);

      document.getElementById('skeleton')!.style.display = 'none';

      if (!entry) {
        document.getElementById('entry-notfound')!.style.display = 'block';
        return;
      }

      // Update page title
      document.title = `${entry.title} · kagiso.me`;

      const typeClass = TYPE_COLORS[entry.type] ?? 'type-default';

      document.getElementById('entry-meta')!.innerHTML =
        `<span class="type-badge ${typeClass}">${entry.type}</span>
         <span class="mono" style="color:var(--color-subtle);font-size:0.78rem">${formatDate(entry.date)}</span>
         ${entry.commit ? `<span class="mono" style="color:var(--color-subtle);font-size:0.78rem">${entry.commit}</span>` : ''}`;

      document.getElementById('entry-title')!.textContent = entry.title;

      document.getElementById('entry-content')!.style.display = 'block';

      if (entry.body) {
        document.getElementById('entry-body')!.innerHTML = renderMarkdown(entry.body);
      } else {
        document.getElementById('entry-body')!.innerHTML =
          `<p style="color:var(--color-subtle)">No detailed write-up for this entry — see commit <code>${entry.commit || '—'}</code> in the <a href="https://github.com/Kagiso-me/homelab-infrastructure" target="_blank" rel="noopener">homelab-infrastructure</a> repository.</p>`;
      }

    } catch {
      document.getElementById('skeleton')!.style.display = 'none';
      document.getElementById('entry-notfound')!.style.display = 'block';
    }
  }

  load();
</script>
