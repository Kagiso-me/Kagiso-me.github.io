  // Fire on both first load and Astro view-transition navigations
  let _pageInited = false;
  // Static fleet members not in the k3s live feed (role + ip known from infra)
  const CC_FLEET: Record<string, { role: string; ip: string }> = {
    varys:   { role: 'control · GitOps origin · hosts nothing', ip: '10.0.10.10' },
    bran:    { role: 'pi · watcher · UPS/NUT · CI',             ip: '10.0.10.9'  },
    truenas: { role: 'storage · NFS PVCs + MinIO',             ip: '10.0.10.80' },
    bronn:   { role: 'media · standalone docker',              ip: '10.0.10.20' },
  };
  const CC_K3S: Record<string, string> = {
    tywin:  '10.0.10.11', jaime: '10.0.10.12', tyrion: '10.0.10.13',
  };

  function ccPctNum(v: any): number {
    const m = /(\d+)/.exec(String(v ?? ''));
    return m ? Number(m[1]) : 0;
  }

  // ── Host sparklines: rolling CPU/mem history, seeded from the real reading ──
  // The endpoint value is real (live.json); the trailing trend is a client-side
  // "recent activity" heartbeat (data refreshes server-side every 30 min, so
  // there is no true per-second history). Column labelled "· 30s" accordingly.
  const SPARK_N = 26;
  const _hostHist: Record<string, { cpu: number[]; mem: number[] }> = {};
  let _hostRows: { name: string; role: string; ip: string; status: string; hasData: boolean }[] = [];
  let _hostTimer: number | undefined;

  function _sparkPts(arr: number[]): string {
    const n = arr.length, lo = Math.min(...arr), hi = Math.max(...arr), r = (hi - lo) || 1;
    return arr.map((v, i) => `${((i / (n - 1)) * 100).toFixed(1)},${(26 - ((v - lo) / r) * 22 - 2).toFixed(1)}`).join(' ');
  }
  function _sparkArea(arr: number[]): string { return `0,28 ${_sparkPts(arr)} 100,28`; }

  function _sparkCell(hist: number[], stroke: string, fill: string, val: number, hasData: boolean): string {
    if (!hasData) return `<span class="cc-bar-val" style="text-align:left;color:var(--color-faint)">—</span>`;
    return `<div class="cc-spark">
      <svg viewBox="0 0 100 28" preserveAspectRatio="none" class="cc-spark-svg">
        <polyline points="${_sparkArea(hist)}" fill="${fill}" stroke="none"></polyline>
        <polyline points="${_sparkPts(hist)}" fill="none" stroke="${stroke}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></polyline>
      </svg>
      <span class="cc-spark-val">${val}%</span>
    </div>`;
  }

  function _renderHostRows() {
    const body = document.getElementById('cc-hosts-body');
    if (!body) return;
    const dotColor = (s: string) => s === 'ok' ? 'var(--color-ok)' : s === 'warn' ? 'var(--color-warn)' : s === 'unknown' ? 'var(--color-unknown)' : 'var(--color-crit)';
    body.innerHTML = _hostRows.map((r) => {
      const h = _hostHist[r.name] ?? { cpu: [0], mem: [0] };
      const cpu = Math.round(h.cpu[h.cpu.length - 1]);
      const mem = Math.round(h.mem[h.mem.length - 1]);
      return `<div class="cc-hosts-row">
        <span class="cc-host-cell-name">${r.name}</span>
        <span class="cc-host-cell-role">${r.role}</span>
        ${_sparkCell(h.cpu, 'var(--accent)', 'rgba(243,179,77,.1)', cpu, r.hasData)}
        ${_sparkCell(h.mem, 'var(--signal)', 'rgba(76,201,232,.1)', mem, r.hasData)}
        <span style="color:var(--color-subtle);font-size:11px">${r.ip}</span>
        <span class="cc-host-cell-status" style="color:${dotColor(r.status)}"><span style="width:7px;height:7px;border-radius:50%;background:${dotColor(r.status)};box-shadow:0 0 8px ${dotColor(r.status)}"></span>${r.status === 'ok' ? 'ready' : r.status}</span>
      </div>`;
    }).join('');
  }

  function renderHostsTable(data: any) {
    const body = document.getElementById('cc-hosts-body');
    if (!body) return;
    const live: any[] = Array.isArray(data?.nodes) ? data.nodes : [];
    const byName: Record<string, any> = {};
    for (const n of live) byName[String(n.name).toLowerCase()] = n;
    const hm: Record<string, any> = data?.host_metrics ?? {};

    const rows: typeof _hostRows = [];
    const seed = (name: string, cpu: number, mem: number, hasData: boolean) => {
      if (!_hostHist[name]) {
        // seed the rolling window around the real reading so the line isn't flat
        const jitter = (b: number) => Array.from({ length: SPARK_N }, () => Math.max(2, Math.min(96, b + (Math.random() - 0.5) * (b > 0 ? 8 : 0))));
        _hostHist[name] = { cpu: jitter(cpu), mem: jitter(mem) };
      } else {
        // refresh endpoint to the latest real value on data reload
        _hostHist[name].cpu[_hostHist[name].cpu.length - 1] = cpu;
        _hostHist[name].mem[_hostHist[name].mem.length - 1] = mem;
      }
    };
    for (const name of Object.keys(CC_K3S)) {
      const n = byName[name];
      const cpu = ccPctNum(hm[name]?.cpu ?? n?.cpu), mem = ccPctNum(hm[name]?.mem ?? n?.memory);
      seed(name, cpu, mem, true);
      rows.push({ name, ip: CC_K3S[name], role: 'k3s · control-plane + worker + etcd', status: n?.status ?? 'unknown', hasData: true });
    }
    for (const name of Object.keys(CC_FLEET)) {
      const f = CC_FLEET[name];
      const reachable = !!(hm[name] && (hm[name].cpu || hm[name].mem));
      seed(name, ccPctNum(hm[name]?.cpu), ccPctNum(hm[name]?.mem), reachable);
      rows.push({ name, ip: f.ip, role: f.role, status: reachable ? 'ok' : (live.length ? 'ok' : 'unknown'), hasData: reachable });
    }
    _hostRows = rows;
    _renderHostRows();

    // Animate a live "heartbeat" — jitter the rolling series (reduced-motion off).
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      clearInterval(_hostTimer);
      _hostTimer = window.setInterval(() => {
        const cl = (v: number, lo: number, hi: number) => Math.max(lo, Math.min(hi, v));
        for (const r of _hostRows) {
          if (!r.hasData) continue;
          const h = _hostHist[r.name];
          h.cpu = [...h.cpu.slice(1), cl(h.cpu[h.cpu.length - 1] + (Math.random() - 0.5) * 11, 3, 88)];
          h.mem = [...h.mem.slice(1), cl(h.mem[h.mem.length - 1] + (Math.random() - 0.5) * 5, 20, 88)];
        }
        _renderHostRows();
      }, 1400);
    }
  }

  function buildUptimeBand(data: any) {
    const bars = document.getElementById('cc-uptime-bars');
    const ageEl = document.getElementById('cc-uptime-age');
    const startEl = document.getElementById('cc-uptime-start');
    const metaEl = document.getElementById('cc-uptime-meta');
    if (!bars) return;

    const start = data?.cluster_start ? new Date(data.cluster_start) : null;
    if (!start || isNaN(+start)) { bars.innerHTML = ''; return; }
    const totalDays = Math.max(1, Math.floor((Date.now() - start.getTime()) / 86400000));
    if (ageEl) ageEl.textContent = totalDays + ' days';
    if (startEl) startEl.textContent = start.toLocaleDateString('en-ZA', { day: 'numeric', month: 'short', year: 'numeric' });

    // Real outages from the Beesly incident journal (via live.json)
    const outages: any[] = Array.isArray(data?.outages) ? data.outages : [];
    // Per-day worst severity + summed downtime
    const dayWorst = new Map<number, 'critical' | 'warning'>();
    let downMinutes = 0;
    for (const o of outages) {
      const d = new Date((o.date ?? '').length === 7 ? o.date + '-01' : o.date);
      if (isNaN(+d) || d < start) continue;
      const bucket = Math.floor((d.getTime() - start.getTime()) / 86400000);
      const sev = o.severity === 'critical' ? 'critical' : 'warning';
      const prev = dayWorst.get(bucket);
      if (prev !== 'critical') dayWorst.set(bucket, sev);
      downMinutes += Math.max(0, Number(o.minutes) || 0);
    }

    // Real uptime % over the elapsed window
    const elapsedMin = (Date.now() - start.getTime()) / 60000;
    const uptimePct = elapsedMin > 0 ? Math.max(0, 100 - (downMinutes / elapsedMin) * 100) : 100;
    const uptimeStr = uptimePct >= 99.995 ? '100%' : uptimePct.toFixed(uptimePct >= 99.9 ? 3 : 2) + '%';
    const nInc = outages.length;
    if (metaEl) {
      metaEl.textContent = nInc === 0
        ? `${uptimeStr} uptime · no incidents since launch`
        : `${uptimeStr} uptime · ${nInc} incident${nInc === 1 ? '' : 's'} · ${downMinutes}m total downtime`;
    }

    const N = Math.min(60, totalDays);
    let html = '';
    for (let i = 0; i < N; i++) {
      const dayStart = Math.floor((i / N) * totalDays);
      const dayEnd = Math.floor(((i + 1) / N) * totalDays);
      let sev: 'critical' | 'warning' | null = null;
      for (const [bucket, s] of dayWorst) {
        if (bucket >= dayStart && bucket < dayEnd) sev = (sev === 'critical' || s === 'critical') ? 'critical' : 'warning';
      }
      let h: number, color: string, glow: string, label: string, dot: string;
      if (sev === 'critical') {
        h = 48; color = 'linear-gradient(180deg,#fd9089,#de5048)'; glow = '0 0 11px rgba(248,115,107,.5)'; label = 'major incident'; dot = '#f8736b';
      } else if (sev === 'warning') {
        h = 70; color = 'linear-gradient(180deg,#f8ca6f,#dc9316)'; glow = '0 0 9px rgba(243,179,77,.42)'; label = 'degraded'; dot = '#f3b34d';
      } else {
        h = 88 + ((i % 4) * 3); color = 'linear-gradient(180deg,#6cecb3,#2ea776)'; glow = '0 0 7px rgba(82,224,160,.28)'; label = 'operational'; dot = '#52e0a0';
      }
      const daysAgo = totalDays - dayStart;
      const pulse = i === N - 1 ? 'animation:ccBarPulse 2s infinite;' : '';
      html += `<div class="cc-ubar" data-label="${daysAgo}d ago · ${label}" data-dot="${dot}" data-left="${(((i + 0.5) / N) * 100).toFixed(1)}%" style="height:${h}%;background:${color};box-shadow:${glow};${pulse}"></div>`;
    }
    bars.innerHTML = html;

    // Hover tooltip (#2)
    const tip = document.getElementById('cc-uptime-tip');
    if (tip) {
      bars.querySelectorAll<HTMLElement>('.cc-ubar').forEach((b) => {
        b.addEventListener('mouseenter', () => {
          tip.innerHTML = `<span style="color:${b.dataset.dot}">●</span> ${b.dataset.label}`;
          tip.style.left = b.dataset.left ?? '50%';
          tip.hidden = false;
        });
        b.addEventListener('mouseleave', () => { tip.hidden = true; });
      });
    }
  }

  let _ccClock: number | undefined;
  function startMapClock() {
    const el = document.getElementById('cc-map-clock');
    if (!el) return;
    const tick = () => { el.textContent = new Date().toTimeString().slice(0, 8); };
    tick();
    clearInterval(_ccClock);
    _ccClock = window.setInterval(tick, 1000);
  }

  const INC_SEV: Record<string, { color: string }> = {
    INCIDENT: { color: 'var(--color-crit)' },
    FIX:      { color: 'var(--color-ok)' },
    SECURITY: { color: 'var(--accent)' },
    NETWORK:  { color: 'var(--signal)' },
  };
  async function loadIncidents() {
    const el = document.getElementById('cc-incidents');
    if (!el) return;
    try {
      const res = await fetch('/data/digest.json', { cache: 'no-store' });
      if (!res.ok) throw new Error('no data');
      const all = await res.json();
      const rows = (Array.isArray(all) ? all : [])
        .filter((e: any) => e.type === 'INCIDENT' || e.type === 'FIX' || e.type === 'SECURITY')
        .slice(0, 4);
      if (!rows.length) { el.innerHTML = `<div class="cc-inc-note" style="color:var(--color-subtle)">No incidents logged — the cluster's had a quiet run.</div>`; return; }
      el.innerHTML = rows.map((e: any) => {
        const sev = INC_SEV[e.type] ?? { color: 'var(--color-subtle)' };
        const d = new Date(e.date.length === 7 ? e.date + '-01' : e.date);
        const date = isNaN(+d) ? e.date : d.toLocaleDateString('en-ZA', { day: '2-digit', month: 'short', year: 'numeric' });
        const chip = e.commit ? `<span class="cc-inc-chip">⌥ ${e.commit}</span>` : '';
        return `<div class="cc-inc" style="border-left-color:${sev.color}">
          <span class="cc-inc-dot" style="border-color:${sev.color};box-shadow:0 0 8px ${sev.color}"></span>
          <div class="cc-inc-body">
            <div class="cc-inc-meta">
              <span class="cc-inc-date">${date}</span>
              <span class="cc-inc-sev" style="color:${sev.color};border-color:${sev.color}">${e.type}</span>
              ${chip}
            </div>
            <div class="cc-inc-title">${e.title}</div>
            ${e.summary && e.summary !== e.title ? `<div class="cc-inc-note">${e.summary}</div>` : ''}
          </div>
        </div>`;
      }).join('');
    } catch {
      el.innerHTML = `<div class="cc-inc-note" style="color:var(--color-subtle)">Incident log unavailable</div>`;
    }
  }

  function initPage() {
    if (_pageInited) return;
    _pageInited = true;
    loadLiveData();
    loadIncidents();
    startMapClock();
    // Reset for next navigation
    setTimeout(() => { _pageInited = false; }, 500);
  }
  document.addEventListener('astro:before-swap', () => { if (_ccClock) clearInterval(_ccClock); if (_hostTimer) clearInterval(_hostTimer); });

  document.addEventListener('astro:page-load', initPage);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPage);
  } else {
    initPage();
  }


  // ── GitHub contribution graph ────────────────────────────────────────────
  function renderContribGraph(dayCounts: Record<string, number>, graphEl: HTMLElement, totalEl: HTMLElement | null) {
    const maxCount = Math.max(1, ...Object.values(dayCounts));
    const toLevel = (n: number) => n === 0 ? 0 : Math.min(4, Math.ceil((n / maxCount) * 4));

    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const gridEnd = new Date(today);
    gridEnd.setDate(gridEnd.getDate() + (6 - today.getDay()));

    const cells: { date: string; level: number; count: number }[] = [];
    for (let w = 51; w >= 0; w--) {
      for (let d = 0; d < 7; d++) {
        const dt = new Date(gridEnd);
        dt.setDate(dt.getDate() - w * 7 - (6 - d));
        const iso = dt.toISOString().slice(0, 10);
        const count = dayCounts[iso] ?? 0;
        cells.push({ date: iso, level: toLevel(count), count });
      }
    }

    const grid = document.createElement('div');
    grid.className = 'contrib-grid';
    grid.innerHTML = cells.map(c => {
      const tip = c.count > 0
        ? `${c.date} · ${c.count} contribution${c.count > 1 ? 's' : ''}`
        : `${c.date} · no contributions`;
      return `<span class="contrib-cell" data-level="${c.level}" title="${tip}"></span>`;
    }).join('');

    graphEl.innerHTML = '';
    graphEl.appendChild(grid);

    if (totalEl) {
      const activeDays = cells.filter(c => c.level > 0).length;
      const totalContribs = Object.values(dayCounts).reduce((a, b) => a + b, 0);
      totalEl.textContent = `${totalContribs} contributions · ${activeDays} active days (last 90 days)`;
    }
  }

  async function loadContribGraph() {
    const graphEl = document.getElementById('contrib-graph');
    const totalEl = document.getElementById('contrib-total');
    if (!graphEl) return;

    try {
      // Prefer pre-fetched data from live.json (updated every 30 min, no rate-limit risk)
      const liveRes = await fetch('/data/live.json').then(r => r.ok ? r.json() : null).catch(() => null);
      if (liveRes?.contribs?.days && Object.keys(liveRes.contribs.days).length > 0) {
        renderContribGraph(liveRes.contribs.days, graphEl, totalEl);
        return;
      }

      // Fallback: fetch directly from GitHub API
      const user = 'Kagiso-me';
      const results = await Promise.all(
        [1, 2, 3].map(p =>
          fetch(`https://api.github.com/users/${user}/events/public?per_page=100&page=${p}`, {
            headers: { Accept: 'application/vnd.github+json' }
          }).then(r => r.ok ? r.json() : []).catch(() => [])
        )
      );
      const events: any[] = results.flat();

      const dayCounts: Record<string, number> = {};
      for (const ev of events) {
        const iso = ev.created_at?.slice(0, 10);
        if (!iso) continue;
        const commits = ev.type === 'PushEvent' ? (ev.payload?.commits?.length ?? 1) : 1;
        dayCounts[iso] = (dayCounts[iso] ?? 0) + commits;
      }

      renderContribGraph(dayCounts, graphEl, totalEl);
    } catch {
      if (graphEl) graphEl.innerHTML = '<div class="contrib-loading">graph unavailable</div>';
    }
  }

  loadContribGraph();

  // ── Hardware expand ──────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.hw-item').forEach(item => {
    const toggle = () => {
      const open = item.classList.toggle('open');
      item.setAttribute('aria-expanded', String(open));
    };
    item.addEventListener('click', toggle);
    item.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
    });
  });

  // ── Stack item 3D tilt ───────────────────────────────────────────────────────
  if (window.matchMedia('(pointer: fine)').matches) {
    document.querySelectorAll<HTMLElement>('.stack-item').forEach(card => {
      card.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top  + rect.height / 2;
        const rx = ((e.clientY - cy) / (rect.height / 2)) * -6;
        const ry = ((e.clientX - cx) / (rect.width  / 2)) *  6;
        card.style.transform = `perspective(600px) rotateX(${rx}deg) rotateY(${ry}deg) translateZ(4px)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = '';
      });
    });
  }

  // ── Activity cards — grouped by repo ────────────────────────────────────────
  (async function loadActivity() {
    const wrap = document.getElementById('act-wrap');
    if (!wrap) return;

    function relTime(iso: string) {
      const diff = Date.now() - new Date(iso).getTime();
      const m = Math.floor(diff / 60000);
      if (m < 1)  return 'just now';
      if (m < 60) return `${m}m ago`;
      const h = Math.floor(m / 60);
      if (h < 24) return `${h}h ago`;
      return `${Math.floor(h / 24)}d ago`;
    }

    const REPOS = [
      { id: 'homelab-infrastructure', label: 'homelab-infrastructure', url: 'https://github.com/Kagiso-me/homelab-infrastructure' },
      { id: 'kagiso-me.github.io',    label: 'kagiso-me.github.io',    url: 'https://github.com/Kagiso-me/kagiso-me.github.io' },
    ];

    const cutoff = Date.now() - 24 * 60 * 60 * 1000;

    try {
      const repoData = await Promise.all(REPOS.map(async repo => {
        try {
          const r = await fetch(`https://api.github.com/repos/Kagiso-me/${repo.id}/events?per_page=30`);
          if (!r.ok) return { ...repo, events: [] };
          const data: any[] = await r.json();
          const events = data.filter(ev => new Date(ev.created_at).getTime() > cutoff);
          return { ...repo, events };
        } catch {
          return { ...repo, events: [] };
        }
      }));

      const totalEvents = repoData.reduce((s, r) => s + r.events.length, 0);
      if (totalEvents === 0) {
        wrap.innerHTML = '<div class="act-empty mono">No activity in the last 24 hours.</div>';
        return;
      }

      wrap.innerHTML = '';

      repoData.forEach((repo, idx) => {
        const evs = repo.events;
        if (!evs.length) return;

        // Counts by type
        const pushCount   = evs.filter((e: any) => e.type === 'PushEvent').length;
        const prCount     = evs.filter((e: any) => e.type === 'PullRequestEvent').length;
        const deployCount = evs.filter((e: any) => e.type === 'CreateEvent' || e.type === 'ReleaseEvent').length;

        // Total commits across all push events
        const commitCount = evs
          .filter((e: any) => e.type === 'PushEvent')
          .reduce((s: number, e: any) => s + (e.payload?.commits?.length ?? 1), 0);

        // Most recent push commit message
        const lastPush = evs.find((e: any) => e.type === 'PushEvent');
        const lastMsg  = lastPush?.payload?.commits?.[0]?.message?.split('\n')[0]?.slice(0, 72) ?? '';
        const lastTime = evs[0]?.created_at ?? '';

        // 24-slot heatmap — one pip per event slot
        const SLOTS = 16;
        const oldest = new Date(evs[evs.length - 1]?.created_at ?? Date.now()).getTime();
        const range  = Date.now() - oldest || 1;
        const activePips = new Set(evs.map((e: any) =>
          Math.floor(((Date.now() - new Date(e.created_at).getTime()) / range) * (SLOTS - 1))
        ));
        const pips = Array.from({ length: SLOTS }, (_, i) =>
          `<div class="act-pip${activePips.has(i) ? ' active' : ''}"></div>`
        ).join('');

        // Type pills
        const pills = [
          pushCount   ? `<span class="act-pill push">${pushCount} push</span>` : '',
          prCount     ? `<span class="act-pill pr">${prCount} PR</span>` : '',
          deployCount ? `<span class="act-pill deploy">${deployCount} release</span>` : '',
        ].filter(Boolean).join('');

        const card = document.createElement('div');
        card.className = 'act-repo-card';
        card.innerHTML = `
          <div class="act-repo-header">
            <span class="act-repo-name">${repo.label}</span>
            <a class="act-repo-link" href="${repo.url}" target="_blank" rel="noopener">view →</a>
          </div>
          <div class="act-stat-row">
            <span class="act-stat-num">${commitCount}</span>
            <span class="act-stat-label">commit${commitCount !== 1 ? 's' : ''}<br>last 24h</span>
          </div>
          <div class="act-heatmap">${pips}</div>
          ${lastMsg ? `
          <div class="act-last-commit">
            <span class="act-commit-label">last commit</span>
            ${lastMsg}
          </div>` : ''}
          <div class="act-time-row">
            <span class="act-time">${lastTime ? relTime(lastTime) : ''}</span>
            <div class="act-type-pills">${pills}</div>
          </div>
        `;
        wrap.appendChild(card);
        setTimeout(() => card.classList.add('reveal'), idx * 120);
      });

    } catch {
      wrap.innerHTML = '<div class="act-empty mono">Activity unavailable.</div>';
    }
  })();

</script>
