    `<span class="log-ts">[now]          </span>   <span class="lvl-event">EVNT</span>   <span class="out-gold">cluster live · ops log honest · learning never stops</span>`,
  ], 55);
  await blank();

  await typeCmd('ps aux | grep passion');
  await sleep(120);
  await printLines([
    `<span class="out-dim">USER       PID  STAT  COMMAND</span>`,
    `<span class="out-gold">kagiso</span>    1001  <span class="out-green">S+</span>    k3s — lightweight Kubernetes on owned hardware`,
    `<span class="out-gold">kagiso</span>    1002  <span class="out-green">S+</span>    flux-cd — git is the source of truth`,
    `<span class="out-gold">kagiso</span>    1003  <span class="out-green">S+</span>    immich — 100% off Apple's servers`,
    `<span class="out-gold">kagiso</span>    1004  <span class="out-green">S+</span>    ollama — local AI, stays on my hardware`,
    `<span class="out-gold">kagiso</span>    1005  <span class="out-green">S+</span>    canon + blackmagic — the archive keeps growing`,
    `<span class="out-gold">kagiso</span>    1006  <span class="out-green">S+</span>    self-teaching — no signs of stopping`,
  ], 45);
  await blank();

  await typeCmd('echo "why does this exist?"');
  await sleep(120);
  await printLines([
    `<span class="out-dim">I built this cluster because I was tired of understanding</span>`,
    `<span class="out-dim">technology only at the level of a customer.</span>`,
    ``,
    `<span class="out">I wanted to understand it at the level of</span> <span class="out-gold">a builder.</span>`,
    ``,
    `<span class="out-green">You just need to be willing to start badly. And keep going.</span>`,
  ], 38);
  await blank();

  await sleep(500);
  await typeCmd('exit', 80);
  await sleep(300);
  append(el('div', 'out-dim', 'logout'));
  await sleep(900);

  if (!aborted) showManifesto();
}

function showManifesto() {
  const tp = document.getElementById('terminal-phase');
  const mp = document.getElementById('manifesto-phase');
  const skip = document.getElementById('skip-btn');
  skip.style.display = 'none';
  tp.style.transition = 'opacity .8s ease';
  tp.style.opacity = '0';
  setTimeout(() => {
    tp.style.display = 'none';
    mp.classList.add('show');
    requestAnimationFrame(() => mp.classList.add('fade-in'));
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.style.opacity = '1';
          e.target.style.transform = 'none';
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    mp.querySelectorAll('.ab-dual-card, .ab-belief, .ab-personal-card').forEach((el, i) => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = `opacity .6s ease ${i * 60}ms, transform .6s ease ${i * 60}ms`;
      obs.observe(el);
    });
  }, 820);
}

document.getElementById('skip-btn').addEventListener('click', () => {
  aborted = true;
  showManifesto();
});

// ── Real About data: longest uptime (cluster age) + GitHub contrib graph ──
async function loadAboutData() {
  let data = null;
  try { data = await fetch('/data/live.json', { cache: 'no-store' }).then(r => r.ok ? r.json() : null); } catch {}

  const upEl = document.getElementById('ab-uptime');
  if (upEl && data?.cluster_start) {
    const days = Math.max(0, Math.floor((Date.now() - new Date(data.cluster_start).getTime()) / 86400000));
    upEl.textContent = days + 'd';
  } else if (upEl) { upEl.textContent = '—'; }

  const graphEl = document.getElementById('ab-contrib-graph');
  const totalEl = document.getElementById('ab-contrib-total');
  if (graphEl && data?.contribs?.days && Object.keys(data.contribs.days).length) {
    const dayCounts = data.contribs.days;
    const maxCount = Math.max(1, ...Object.values(dayCounts));
    const toLevel = n => n === 0 ? 0 : Math.min(4, Math.ceil((n / maxCount) * 4));
    const today = new Date(); today.setHours(0,0,0,0);
    const gridEnd = new Date(today); gridEnd.setDate(gridEnd.getDate() + (6 - today.getDay()));
    const cells = [];
    for (let w = 12; w >= 0; w--) for (let d = 0; d < 7; d++) {
      const dt = new Date(gridEnd); dt.setDate(dt.getDate() - w * 7 - (6 - d));
      const iso = dt.toISOString().slice(0,10);
      const count = dayCounts[iso] ?? 0;
      cells.push({ iso, level: toLevel(count), count });
    }
    const grid = document.createElement('div');
    grid.className = 'ab-contrib-grid';
    grid.innerHTML = cells.map(c => `<span data-level="${c.level}" title="${c.iso} · ${c.count} contribution${c.count===1?'':'s'}"></span>`).join('');
    graphEl.innerHTML = ''; graphEl.appendChild(grid);
    if (totalEl) {
      const total = cells.reduce((a,c) => a + c.count, 0);
      const active = cells.filter(c => c.level > 0).length;
      totalEl.textContent = `${total} contributions · ${active}d active`;
    }
  } else if (graphEl) {
    graphEl.innerHTML = '<div class="ab-contrib-loading mono">activity unavailable</div>';
  }
}
loadAboutData();

run();
</script>
